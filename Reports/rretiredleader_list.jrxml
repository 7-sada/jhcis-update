	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND persontype.pcucodeperson =  '01856' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
cpersontype.persontypename,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) pname,
person.lname,
person.hnomoi,
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8),' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,
DATE_FORMAT(persontype.dateretire,'%Y-%m-%d') AS dateretire
FROM
persontype
Inner Join person ON persontype.pcucodeperson = person.pcucodeperson AND persontype.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join house ON person.hcode = house.hcode AND person.pcucodeperson = house.pcucode
Inner Join village ON house.pcucode = village.pcucode AND house.villcode = village.villcode
Inner Join cpersontype ON persontype.typecode = cpersontype.persontypecode
WHERE  persontype.dateretire <= current_date
$P!{pcucode}
ORDER BY
cpersontype.persontypecode ASC,
village.villno ASC,
person.hnomoi ASC]]></queryString>

