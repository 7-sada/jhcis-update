	<columnHeader>
		<band height="307">
			<textField>
				<reportElement x="0" y="103" width="555" height="34" uuid="c8de86d8-d555-45cd-8124-b4e75c9a6200"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["สรุปอัตราการใช้พลังงานขั้นพื้นฐาน (BMR): "+$P{BMR}+ " แคลลอรี/วัน"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="137" width="555" height="34" uuid="bf8a3a5a-2285-4549-926e-62d6377477e9"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["สรุปอัตราการใช้พลังงานต่อวันโดยรวม (TDEE) : "+$P{TDEE} + " แคลอรี่ต่อวัน"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="171" width="555" height="34" uuid="c2efe91b-d4af-4bb2-91bc-cd17610591e0"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["การควบคุมพลังงานจากแคลอรี่ (20%) : "+$P{controlledCalories} + " แคลอรี่ต่อวัน"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="205" width="555" height="34" uuid="68edcafe-e7bb-41c4-b234-bb2ac55d24fb"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["ปริมาณคาร์โบไฮเดรต/วันที่ต้องการควบคุม ควรบริโภคไม่เกิน: : "+$P{carbohydrateGrams} + " กรัมต่อวัน หรือ"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="239" width="555" height="34" uuid="b5407aaa-d582-4782-8b27-cd10fc0a688e"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["ปริมาณคาร์บ/วันที่ต้องการควบคุม(คาร์โบไฮเดรต/15)ควรบริโภคไม่เกิน : " +$P{controlledCarbs} + " คาร์บ/วัน "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="273" width="555" height="34" uuid="e1ae323b-949b-4c7e-8b46-7c082d3a4c21"/>
				<textElement textAlignment="Center">
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["(หมายเหตุ: คาร์โบไฮเดรต 15 กรัม = 1 คาร์บ = ข้าว 1 ทัพพี)"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="34" width="555" height="30" uuid="1e316961-f72d-4f41-bd0e-0e9b25b1e2f2"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["เพศ : "+ $P{sex} +"      อายุ : "+$P{age}+ " ปี          น้ำหนัก : "+ $P{weight}+
" กิโลกรัม      ส่วนสูง  : "+$P{height} + " ซม."]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="0" y="64" width="555" height="35" uuid="74335dfd-973f-44ae-a291-eaebc5523d35"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="22"/>
				</textElement>
				<textFieldExpression><![CDATA["กิจกรรมที่ทำเป็นประจำ : "+$P{activityFactor}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="98" width="555" height="1" uuid="ee9fdbbc-c234-4aa5-90af-449d0aad0831"/>
			</line>
			<textField>
				<reportElement x="0" y="4" width="555" height="30" uuid="6d5ea5ae-c1a4-4385-ba5e-03b89ed63134"/>
