	</parameter>
	<queryString>
		<![CDATA[SELECT
   `person`.`pid`,concat(pcucodeperson,pid) as ppid,
   concat(ifnull(ctt.titlename,concat('(..',`person`.`prename`,')')),ifnull(`person`.`fname`,''),'  ',ifnull(`person`.`lname`,'')) as pati,
   ifnull(idcard,'...ไม่ระบุฯ') as idc,
   birth,`person`.`birth`,date_format(`person`.`birth`,'%Y-%m-%d') as birt,pid,
   concat(pcucodeperson,'-',pid,'/',substring(curdate(),1,4)+543) as hnyear,hnomoi,mumoi,subdistname,subdistname,distname,provname,
   timeworkday,s,mon,tue,wed,thu,fri,sat,concat('โทร. สถานบริการ: ',ifnull(tel,'...ไม่ระบุ')) as tel
FROM
`person`
Left Outer Join `cprovince` ON  `cprovince`.`provcode` = `person`.`provcodemoi`
Left Outer Join `cdistrict` ON `cdistrict`.`provcode` = `person`.`provcodemoi` AND
                                          `cdistrict`.`distcode` = `person`.`distcodemoi`
Left Outer Join `csubdistrict` ON `csubdistrict`.`provcode` = `person`.`provcodemoi` AND
                                               `csubdistrict`.`distcode` = `person`.`distcodemoi` AND
                                               `csubdistrict`.`subdistcode` = `person`.`subdistcodemoi`
left outer join office on 1=1
left join ctitle ctt on person.prename=ctt.titlecode
where
	person.pcucodeperson = '$P!{HCC}'
        and person.pid =  '$P!{hn}'
        and office.offid =  '$P!{oid}']]>
	</queryString>
