	<queryString>
		<![CDATA[select ifnull(p2.labname,'...') lna,labresultdigit lg
from visitlabchcyhembmsse p1 join clabchcyhembmsse p2 on p1.labcode=p2.labcode
where  p1.pcucode = $P{pcucode} AND p1.`visitno` = $P{visitno}]]>
	</queryString>
