<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rb1k012total_subreport2" pageWidth="557" pageHeight="555" columnWidth="557" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="14bdb041-e8e2-4daf-bce3-360fb56ee046">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<parameter name="visitdate" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select drugname,unit
from visitdrug
      inner join cdrug on visitdrug.drugcode = cdrug.drugcode
      inner join visit on visit.visitno=visitdrug.visitno and visit.pcucode = visitdrug.pcucode
where  visitdrug.visitno = $P{visitno}
       and visit.pcucode = $P{pcucode}
       and visit.visitdate=$P{visitdate}
       and cdrug.drugtype ='01']]>
	</queryString>
	<field name="drugname" class="java.lang.String"/>
	<field name="unit" class="java.lang.Integer"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="21" splitType="Stretch">
			<textField isStretchWithOverflow="true" isBlankWhenNull="false">
				<reportElement uuid="9d10be48-4ebb-4862-ac9f-78395520adeb" key="textField" stretchType="RelativeToBandHeight" x="0" y="0" width="70" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#0000CC"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="5" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["->"+$F{drugname}+", "+$F{unit}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<columnFooter>
		<band splitType="Stretch"/>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
	<summary>
		<band splitType="Stretch"/>
	</summary>
</jasperReport>
