	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT
     person.`pid` AS person_pid,
     person.`sex` AS person_sex,
     cdisease.`diseasenamethai` AS cdisease_diseasenamethai
FROM
     `person` person INNER JOIN `visit` visit ON person.`pcucodeperson` = visit.`pcucodeperson`
     AND person.`pid` = visit.`pid`
     INNER JOIN `visitdiag` visitdiag ON visit.`pcucode` = visitdiag.`pcucode`
     AND visit.`visitno` = visitdiag.`visitno`
     INNER JOIN `cdisease` cdisease ON visitdiag.`diagcode` = cdisease.`diseasecode`
WHERE
     visit.visitdate between '2009-01-01' and '2009-01-31']]></queryString>

	<field name="person_pid" class="java.lang.Integer"/>
	<field name="person_sex" class="java.lang.String"/>
	<field name="cdisease_diseasenamethai" class="java.lang.String"/>

