<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="asuAcuteUri" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="73d96595-31b2-493f-a13a-a0c3807476c4">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="offAddress" class="java.lang.String"/>
	<parameter name="ye_r" class="java.lang.String"/>
	<parameter name="ye_rt" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT ELT(m12.m,'มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม') mn
,t.* ,u.UiTot,u.UiUsed,u.UiNotused FROM
(SELECT 1 m UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7
UNION SELECT 8 UNION SELECT 9 UNION SELECT 10 UNION SELECT 11 UNION SELECT 12) AS m12
LEFT JOIN(
SELECT x.y,x.m,x.tot AcTot,IFNULL(y.c1,0) AcUsed,tot-IFNULL(y.c1,0) AcNotused FROM
(SELECT YEAR(v.visitdate) y,MONTH(v.visitdate) m,COUNT(*) tot
 FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
 JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
 WHERE LCASE(LEFT(d2.icd10acui,1)) IN('a','k')
   AND YEAR(v.visitdate)=$P{ye_r}
 GROUP BY YEAR(v.visitdate),MONTH(v.visitdate)) x
LEFT JOIN
(SELECT a.y,a.m,COUNT(*) c1
 FROM(SELECT YEAR(v.visitdate) y,MONTH(v.visitdate) m,v.pcucode,v.visitno
      FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
      JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
      WHERE LCASE(LEFT(d2.icd10acui,1)) IN('a','k')
        AND YEAR(v.visitdate)=$P{ye_r}
      GROUP BY YEAR(v.visitdate),MONTH(v.visitdate),v.visitno) AS a
 JOIN
 (SELECT v.pcucode,v.visitno FROM visitdrug d1
  JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
  JOIN cdrug d2 ON d1.drugcode=d2.drugcode
  WHERE d2.antibio='1'
    AND YEAR(v.visitdate)=$P{ye_r}
  GROUP BY v.visitno) AS b
 ON a.pcucode=b.pcucode AND a.visitno=b.visitno
 GROUP BY a.y,a.m) AS y
ON x.y=y.y AND x.m=y.m
ORDER BY x.y,x.m) AS t
ON m12.m=t.m
LEFT JOIN
(SELECT x.y,x.m,x.tot UiTot,IFNULL(y.c1,0) UiUsed,tot-IFNULL(y.c1,0) UiNotused FROM
(SELECT YEAR(v.visitdate) y,MONTH(v.visitdate) m,COUNT(*) tot
 FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
 JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
 WHERE LCASE(LEFT(d2.icd10acui,1)) IN('b','h','j')
   AND YEAR(v.visitdate)=$P{ye_r}
 GROUP BY YEAR(v.visitdate),MONTH(v.visitdate)) x
LEFT JOIN
(SELECT a.y,a.m,COUNT(*) c1
 FROM(SELECT YEAR(v.visitdate) y,MONTH(v.visitdate) m,v.pcucode,v.visitno
      FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
      JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
      WHERE LCASE(LEFT(d2.icd10acui,1)) IN('b','h','j')
        AND YEAR(v.visitdate)=$P{ye_r}
      GROUP BY YEAR(v.visitdate),MONTH(v.visitdate),v.visitno) AS a
 JOIN
 (SELECT v.pcucode,v.visitno FROM visitdrug d1
  JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
  JOIN cdrug d2 ON d1.drugcode=d2.drugcode
  WHERE d2.antibio='1'
    AND YEAR(v.visitdate)=$P{ye_r}
  GROUP BY v.visitno) AS b
 ON a.pcucode=b.pcucode AND a.visitno=b.visitno
 GROUP BY a.y,a.m) AS y
ON x.y=y.y AND x.m=y.m
ORDER BY x.y,x.m) AS u
ON m12.m=u.m]]>
	</queryString>
	<field name="mn" class="java.lang.String"/>
	<field name="y" class="java.lang.Integer"/>
	<field name="m" class="java.lang.Integer"/>
	<field name="AcTot" class="java.lang.Long"/>
	<field name="AcUsed" class="java.lang.Long"/>
	<field name="AcNotused" class="java.lang.Long"/>
	<field name="UiTot" class="java.lang.Long"/>
	<field name="UiUsed" class="java.lang.Long"/>
	<field name="UiNotused" class="java.lang.Long"/>
	<variable name="sumTotA" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{AcTot}]]></variableExpression>
	</variable>
	<variable name="sumTotU" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{UiTot}]]></variableExpression>
	</variable>
	<variable name="su1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{AcUsed}]]></variableExpression>
	</variable>
	<variable name="suno1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{AcNotused}]]></variableExpression>
	</variable>
	<variable name="su2" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{UiUsed}]]></variableExpression>
	</variable>
	<variable name="suno2" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{UiNotused}]]></variableExpression>
	</variable>
