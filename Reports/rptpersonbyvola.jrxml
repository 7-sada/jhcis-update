<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptpersonbyvola"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["AND person.pcucodeperson ='07918'"]]></defaultValueExpression>
	</parameter>
	<parameter name="villcode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["70041206"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select if((concat(house.pcucodeperson,house.pidvola) is null or house.pidvola =''),"ไม่ระบุ อสม.",CONVERT(concat( ifnull(tpvola.titlename,ifnull(pvola.prename,'ไม่ระบุ') ),pvola.fname,' ',pvola.lname) using utf8 ) ) as volaname
,house.hno,right(house.villcode,2) as villcode
,CONVERT(concat( ifnull(ctitle.titlename,ifnull(person.prename,'ไม่ระบุ') ),person.fname,' ',person.lname) using utf8 ) as personname
,if(diseasenamethai is null,'-' ,concat(diseasenamethai,'(',chroniccode,')' ) ) as diseasename
,if(person.idcard is null,"-",person.idcard) idcard,round(datediff(curdate(),person.birth)/365) as age
,house.pcucode,hosname
from person
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode
	left join ctitle on person.prename = ctitle.titlecode
	left join person pvola on house.pcucodepersonvola = pvola.pcucodeperson and house.pidvola = pvola.pid
	left join ctitle tpvola on pvola.prename = tpvola.titlecode
	left join personchronic on person.pid = personchronic.pid and person.pcucodeperson = personchronic.pcucodeperson
	left join cdisease  on personchronic.chroniccode = cdisease.diseasecode
	left join chospital on house.pcucode = chospital.hoscode
where village.villcode = $P!{villcode} $P!{pcucode}
order by concat(pvola.pcucodeperson,pvola.pid),house.villcode,house.hno]]></queryString>

	<field name="volaname" class="java.lang.String"/>
	<field name="hno" class="java.lang.String"/>
	<field name="villcode" class="java.lang.String"/>
	<field name="personname" class="java.lang.String"/>
	<field name="diseasename" class="java.lang.String"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="age" class="java.math.BigDecimal"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>


