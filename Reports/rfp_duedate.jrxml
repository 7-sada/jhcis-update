	<parameter name="DateDue" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[$P{DateDue}]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" AND visitfp.datedue BETWEEN '2009-11-01' AND '2009-11-30' " ]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND `visitfp`.`pcucode`='06766' AND village.pcucode='06766' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     ifnull(ctitle.titlename,person.prename) AS prename,
     person.`fname`,
     person.`lname`,
     person.`hnomoi`,
     cdrug.`drugname`,
     village.villno,
     CONCAT(village.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,
     visitfp.datefp,village.villcode
FROM
     person INNER JOIN house ON person.hcode = house.hcode AND house.pcucode = person.pcucodeperson
     Left Outer Join ctitle ON person.prename = ctitle.titlecode
     INNER JOIN village village ON house.`villcode` = village.`villcode`
     INNER JOIN visitfp visitfp ON person.`pid` = visitfp.`pid` AND `visitfp`.`pcucodeperson` = `person`.`pcucodeperson`
     INNER JOIN cdrug cdrug ON visitfp.`fpcode` = cdrug.`drugcode`

WHERE
     1=1 $P!{DateDue} $P!{pcucode}
ORDER BY
     village.villcode,person.`hnomoi` ASC]]></queryString>

