	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT DISTINCT
`visitfp`.`datefp`,
CASE
when `visitfp`.`typefp`=0 then 'เก่า'
when `visitfp`.`typefp`=1 then 'ใหม่'
end as typefp,
concat(`person`.`prename`,`person`.`fname`,' ',`person`.`lname`) as visitname,
`person`.`birth`,
concat((year(current_date)-year(`person`.`birth`)-(right(current_date,5)<right(`person`.`birth`,14))),' / ',(if (right(current_date,5)<right(`person`.`birth`,14),(12+month(current_date))-month(`person`.`birth`),month(current_date)-month(`person`.`birth`)))) as age,
concat(`person`.`hnomoi`,' ม.',`person`.`mumoi`,' ',`csubdistrict`.`subdistname`,' ',`cdistrict`.`distname`,' ',`cprovince`.`provname`) as addr,
CASE
when `cdrug`.`drugtypesub`=1 then 'ยาเม็ด'
when `cdrug`.`drugtypesub`=2 then 'ยาฉีด'
when `cdrug`.`drugtypesub`=3 then 'ยาฝัง'
when `cdrug`.`drugtypesub`=4 then 'ห่วงอนามัย'
when `cdrug`.`drugtypesub`=5 then 'ถุงยางอนามัย'
else 'อื่น ๆ' end AS `type`,
`visitfp`.`unit`,
`person`.`rightcode`,
`person`.`rightno`,
`person`.`idcard`,
`visit`.`weight`,
`visit`.`pressure`,
`chospital`.`hosname`
FROM
`cprovince`
Inner Join `cdistrict` ON `cprovince`.`provcode` = `cdistrict`.`provcode`
Inner Join `csubdistrict` ON `cdistrict`.`provcode` = `csubdistrict`.`provcode` AND `cdistrict`.`distcode` = `csubdistrict`.`distcode`
Inner Join `person` ON `csubdistrict`.`provcode` = `person`.`provcodemoi` AND `csubdistrict`.`distcode` = `person`.`distcodemoi` AND `csubdistrict`.`subdistcode` = `person`.`subdistcodemoi`
Inner Join `visitfp` ON `person`.`pid` = `visitfp`.`pid`
Inner Join `cdrug` ON `visitfp`.`fpcode` = `cdrug`.`drugcode`
Inner Join `visit` ON `visit`.`pid` = `visitfp`.`pid` AND `visit`.`visitdate` = `visitfp`.`datefp`
Inner Join `chospital` ON `person`.`hosmain` = `chospital`.`hoscode`
$P!{DateFp}
ORDER BY `visitfp`.`datefp`]]></queryString>

