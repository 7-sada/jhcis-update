		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="eFpDate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="bFpDate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DateFp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" WHERE datefp BETWEEN ('2007-01-01') AND ('2007-01-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
