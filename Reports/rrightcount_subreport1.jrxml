<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="RRightCount_subreport1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="villcode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'77060401'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["current_date"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="TypeLive" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ลักษณะการอยู่อาศัย ตามทะเบียนราษฎร์,อยู่จริง]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
Count(`person`.`pid`)
FROM
`person`
Left Outer Join `house` ON `person`.`hcode` = `house`.`hcode` AND `house`.`pcucode` = `person`.`pcucodeperson`
Left Outer Join `village` ON `house`.`villcode` = `village`.`villcode` AND `village`.`pcucode` = `house`.`pcucode`
Left Outer Join `cright` ON `person`.`rightcode` = `cright`.`rightcode`
Left Outer Join crightgroup ON cright.rightgroup = crightgroup.rightgroupcode
Left Outer Join persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
WHERE right(`house`.`villcode`,2)  <>  '00'  AND persondeath.pid IS NULL 
AND (`cright`.`rightgroup` =  'x' OR `person`.`rightcode` = 'xx' OR `person`.`rightcode` IS NULL)
AND (`person`.`dateexpire` <= $P!{ReportDate} OR `person`.`dateexpire` is null)
AND `village`.`villcode` = $P!{villcode}
$P!{TypeLive}
GROUP BY
`village`.`villcode`
ORDER BY `village`.`villcode`,`cright`.`rightgroup]]></queryString>

	<field name="Count(`person`.`pid`)" class="java.lang.Long"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="23"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="#,##0" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="438"
						y="2"
						width="83"
						height="17"
						forecolor="#CC0000"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" size="10" isUnderline="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.Long"><![CDATA[$F{Count(`person`.`pid`)}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						x="0"
						y="2"
						width="438"
						height="17"
						forecolor="#CC0000"
						backcolor="#FFFFFF"
						key="staticText"
						positionType="Float"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" size="10"/>
					</textElement>
				<text><![CDATA[ผู้(ที่ยังมีชีวิต-นับถึงวันปัจจุบัน (วันนี้)) และไม่มีหลักประกันด้านสุขภาพ(ในหมู่.):]]></text>
				</staticText>
			</band>
		</detail>
		<columnFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnFooter>
