<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDentInTime" language="groovy" pageWidth="1212" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="1172" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-11-08"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-11-08"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select if(timeservice='1' ,'4. ให้บริการผู้ป่วยในเวลา','5. ให้บริการผู้ป่วยนอกเวลา') as timeservice
,count(distinct visitdrugdental.pcucode,visitdrugdental.visitno) as cperson
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-01'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt1
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-02'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt2
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-03'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt3
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-04'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt4
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-05'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt5
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-06'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt6
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-07'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt7
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-08'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt8
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-09'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt9
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-10'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt10
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-11'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt11
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-12'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt12

,count(concat(visitdrugdental.pcucode,visitdrugdental.visitno) ) as ctime
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-01'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt1
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-02'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt2
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-03'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt3
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-04'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt4
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-05'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt5
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-06'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt6
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-07'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt7
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-08'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt8
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-09'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt9
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-10'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt10
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-11'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt11
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{sdate}),'-12'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt12


,curdate() as cdate, hosname
from visitdrugdental
     left join visit on visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
     left join visitdrug on visit.pcucode = visitdrug.pcucode and visit.visitno = visitdrug.visitno
     left join cright on visit.rightcode = cright.rightcode
     left join crightgroup  on cright.rightgroup = crightgroup.rightgroupcode
     left join chospital on visit.pcucode = chospital.hoscode
where  1=1
and visitdate between $P{sdate} and  $P{edate}
$P!{pcucode}
group by timeservice]]>
	</queryString>
