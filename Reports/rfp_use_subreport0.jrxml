<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rfp_use_subreport0"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="eFpDate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="bFpDate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DateFp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2008-11-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["01057"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     cdrug.`drugname`,
     Sum(`visitfp`.`unit`),
     cdrug.`unitsell`,
     CASE WHEN `cdrug`.`drugtypesub`=1 THEN 'ยาเม็ด' WHEN `cdrug`.`drugtypesub`=2 THEN 'ยาฉีด' WHEN `cdrug`.`drugtypesub`=3 THEN 'ยาฝัง' WHEN `cdrug`.`drugtypesub`=4 THEN 'ห่วง' ELSE 'อื่น ๆ' END as type
FROM
     `cdrug` cdrug INNER JOIN `visitfp` visitfp ON cdrug.`drugcode` = visitfp.`fpcode` 
WHERE `cdrug`.`drugtypesub` <> '0' AND cdrug.drugcode <> 'fp0000' AND $P!{DateFp} AND `visitfp`.`pcucode`=$P!{pcucode} 
GROUP BY
     `cdrug`.`drugname`
ORDER BY
 `cdrug`.`drugtypesub`]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="Sum(`visitfp`.`unit`)" class="java.lang.Double"/>
	<field name="unitsell" class="java.lang.String"/>
	<field name="type" class="java.lang.String"/>


		<group  name="FpDrugType" >
			<groupExpression><![CDATA[$F{type}]]></groupExpression>
			<groupHeader>
			<band height="43"  isSplitAllowed="true" >
				<line direction="TopDown">
					<reportElement
						x="0"
						y="9"
						width="535"
						height="0"
						forecolor="#808080"
						key="line"
						positionType="FixRelativeToBottom"/>
					<graphicElement stretchType="NoStretch" pen="Thin"/>
				</line>
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="8"
						y="22"
						width="133"
						height="19"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" leftPadding="2" rightBorder="None" rightBorderColor="#000000" rightPadding="2" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement>
						<font fontName="Times-Roman" size="14" isUnderline="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{type}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
