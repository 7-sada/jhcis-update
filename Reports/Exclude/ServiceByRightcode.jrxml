	<subDataset name="data1" uuid="00cc6c3b-5174-41b2-b198-098b75ef611b">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select if(cp.rightgroupname is null,"ไม่ระบุ",cp.rightgroupname) as rightgroupname
,p2.*
from
(select cr.rightcode,if(cr.rightname is null,"ไม่ระบุ",cr.rightname) as rightname,cr.rightgroup,
sum(p1.visit_type) as newperson,sum(p1.totalperson) as totolperson,sum(p1.visit_count) as times,sum(p1.sumgrain) as gain,
sum(p1.sumservice) as service,sum(p1.sumcost) as cost
from
(SELECT
  v.pid as pid,v.pcucodeperson,count(distinct(pid)) as totalPerson,sum(money1) as sumService,sum(money3) as sumCost,sum(money2) as sumGrain
  ,COUNT(*) AS visit_count,
  MIN(visitdate) AS first_visit,
  GROUP_CONCAT(v.visitdate) AS visitdate,
  CASE
    WHEN COUNT(*) >= 2 THEN '0'
    ELSE '1'
  END AS visit_type,
  v.rightcode
FROM visit v
WHERE v.visitdate BETWEEN $P{sdate} AND $P{edate}
and v.flagservice in ('02','03')
GROUP BY v.pid) as p1
left join cright cr on (cr.rightcode = p1.rightcode)
group by cr.rightcode) as p2
left join crightgroup cp on (p2.rightgroup = cp.rightgroupcode)
order by cp.rightgroupcode]]>
		</queryString>
		<field name="rightgroupname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="rightcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="rightname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="rightgroup" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="newperson" class="java.lang.Double"/>
		<field name="totolperson" class="java.math.BigDecimal"/>
		<field name="times" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="gain" class="java.lang.Double"/>
		<field name="service" class="java.lang.Double"/>
		<field name="cost" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<variable name="sumnewperson" class="java.lang.Double" resetType="Group" resetGroup="rightgroupname" calculation="Sum">
			<variableExpression><![CDATA[$F{newperson}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="sumTotalPerson" class="java.lang.Double" resetType="Group" resetGroup="rightgroupname" calculation="Sum">
			<variableExpression><![CDATA[$F{totolperson}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="sumTimes" class="java.lang.Double" resetType="Group" resetGroup="rightgroupname" calculation="Sum">
			<variableExpression><![CDATA[$F{times}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="sumGrain" class="java.lang.Double" resetType="Group" resetGroup="rightgroupname" calculation="Sum">
			<variableExpression><![CDATA[$F{gain}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="sumSeervice" class="java.lang.Double" resetType="Group" resetGroup="rightgroupname" calculation="Sum">
			<variableExpression><![CDATA[$F{service}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="sumCost" class="java.lang.Double" resetType="Group" resetGroup="rightgroupname" calculation="Sum">
			<variableExpression><![CDATA[$F{cost}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="Totalnewperson" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{newperson}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="TotalTotalPerson" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{newperson}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="TotalTimes" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{times}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="TotalGrain" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{gain}]]></variableExpression>
