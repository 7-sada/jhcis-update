		</variable>
		<variable name="TotalSeervice" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{service}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<variable name="TotalCost" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{cost}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
		<group name="rightgroupname">
			<groupExpression><![CDATA[$F{rightgroupname}]]></groupExpression>
		</group>
	</subDataset>
