	<subDataset name="data3" uuid="81284df9-7c22-480e-87d5-726050ee630b">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select p2.pid,p.idcard,ct.titlename,p.fname,p.lname,p2.seqonday,p2.pcucodeperson,
p2.datecheck,p2.labresultdigit,p3.dm,p3.ht,p2.labcode
from
(select p1.seqonday,p1.pid,p1.pcucodeperson,date_add(p1.datecheck,interval 543 year) as datecheck
,vl.labresultdigit,p1.labcode
from
(select aa.seqonday,aa.pid,aa.pcucodeperson,bb.datecheck,aa.labcode
from
(select max(seqonday) as seqonday,pid,pcucodeperson,datecheck,labcode
from visitlabchcyhembmsse
where datecheck between $P{sdate} and $P{edate}
and ucase(labcode) = 'CH09'
group by datecheck,pid
order by datecheck desc) as aa
join
(select max(datecheck) as datecheck,pid,pcucodeperson
from visitlabchcyhembmsse
where datecheck between $P{sdate} and $P{edate}
and ucase(labcode) = 'CH09'
group by pid
order by datecheck desc) as bb on (aa.datecheck = bb.datecheck and aa.pid = bb.pid
and aa.pcucodeperson = bb.pcucodeperson)
group by aa.pid) as p1
join visitlabchcyhembmsse vl on (p1.pid = vl.pid and p1.seqonday = vl.seqonday
and p1.datecheck = vl.datecheck)) as p2
join
(select aa.pid,aa.pcucodeperson,group_concat(distinct(bb.dm)) as dm,group_concat(distinct(ht)) as ht
from
(
select pid,chroniccode as HT,pcucodeperson
from personchronic
where (lcase(left(chroniccode,3)) between 'i10' and 'i15')
) as aa
join
(select pid,chroniccode as DM,pcucodeperson
from personchronic
where (lcase(left(chroniccode,3)) between 'e10' and 'e14')
) as bb on (aa.pid = bb.pid and aa.pcucodeperson = bb.pcucodeperson)
group by aa.pid) as p3 on (p2.pid = p3.pid and p2.pcucodeperson = p3.pcucodeperson)
join person p on (p3.pid = p.pid and p3.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join persondeath pd on (p.pid = pd.pid and p.pcucodeperson = pd.pcucodeperson)
where pd.pid is null
group by p2.pid]]>
		</queryString>
