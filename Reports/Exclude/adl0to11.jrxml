				<textFieldExpression><![CDATA["ชื่อสถานบริการ  "+$F{hosname}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="75" y="91" width="652" height="20" uuid="5a265d6e-c452-4c4c-ae82-adec91298f33"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="16"/>
				</textElement>
				<textFieldExpression><![CDATA["วันที่พิมพ์รายงาน " + new java.text.SimpleDateFormat("dd MMMMM yyyy เวลา HH:mm น.", new Locale("TH","th")).format(new java.util.Date())]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="75" y="2" width="632" height="61" uuid="783d5b43-b932-43d2-a205-a43b4e834944"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="26" isBold="true"/>
				</textElement>
				<text><![CDATA[ทะเบียนผู้สูงอายุ 60 ปีขึ้นไป คำแนะ ADL 0-11 (ติดบ้าน,ติดเตียง) แยกรายหมู่บ้าน
SPECIALPP 1B1281 ติดบ้าน ADL 5-11 คะแนน,1B1282 ติดเตียง ADL 0-4 คะแนน]]></text>
			</staticText>
		</band>
	</title>
