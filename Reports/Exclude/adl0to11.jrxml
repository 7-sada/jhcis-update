	<subDataset name="adl" uuid="f14b0a5e-20cd-447e-8556-e309dcd95f1e">
		<queryString>
			<![CDATA[SELECT
person.pcucodeperson,person.pid,
CONCAT_WS('-',SUBSTRING(idcard,1,1),SUBSTRING(idcard,2,4),SUBSTRING(idcard,6,5),SUBSTRING(idcard,11,2),SUBSTRING(idcard,13,1))AS 'idcard',
village.villno,village.villname AS 'หมู่บ้าน',
concat(titlename,' ',fname,' ',lname) as 'NAME',
getAgeYearNum(birth,current_date) as AGE,
MAX(f43specialpp.dateserv) as 'maxspecialpp',
MAX(f43specialpp.ppspecial) as 'maxspecialppdate',
CASE WHEN f43specialpp.ppspecial = '1B1281' THEN 'x' ELSE '' END AS 'ติดบ้าน',
CASE WHEN f43specialpp.ppspecial = '1B1282' THEN 'x' ELSE '' END AS 'ติดเตียง',
CONVERT(CONCAT(f43specialpp.ppspecial,' - ',cspecialpp.ppname) using utf8) as concatspecialpp
from person
LEFT JOIN ctitle on person.prename = ctitle.titlecode
INNER JOIN house on person.pcucodeperson = house.pcucodeperson and person.hcode = house.hcode
INNER JOIN village on house.villcode = village.villcode and villno <>'00'
LEFT JOIN f43specialpp on f43specialpp.pcucodeperson=person.pcucodeperson AND f43specialpp.pid=person.pid
LEFT JOIN cspecialpp on f43specialpp.ppspecial=cspecialpp.ppcode
WHERE getAgeYearNum (person.birth,CURDATE()) >= 60 and nation = 99
AND f43specialpp.dateserv <= CURDATE()
AND f43specialpp.ppspecial IN ('1B1281','1B1282')
#OR f43specialpp.ppspecial NOT IN ('1B1280','1B1281','1B1282')
AND person.pid not in (select persondeath.pid from persondeath)#ตัดคนตาย
AND f43specialpp.dateserv BETWEEN CONCAT(YEAR(CURDATE())-1,'10','01') AND CONCAT(YEAR(CURDATE()),'09','30')
GROUP BY villno,hno,person.pid
ORDER BY f43specialpp.ppspecial DESC;]]>
		</queryString>
		<field name="pcucodeperson" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="idcard" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="villno" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="หมู่บ้าน" class="java.lang.String"/>
		<field name="NAME" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="AGE" class="java.lang.Long">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="maxspecialpp" class="java.sql.Date"/>
		<field name="ติดเตียง" class="java.lang.String"/>
		<field name="ติดบ้าน" class="java.lang.String"/>
		<field name="concatspecialpp" class="java.lang.String"/>
	</subDataset>
	<queryString>
		<![CDATA[SELECT
IFNULL(CONCAT(chospital.hosname,
     "  ต.",csubdistrict.subdistname,
     "  อ.",cdistrict.distname,
     "  จ.",cprovince.provname),'xNoProvince') as office_name
,chospital.hosname,
CONCAT((SELECT CASE WHEN MONTH(CURRENT_DATE())=1 THEN 'มกราคม'
WHEN MONTH(CURRENT_DATE())=2 THEN 'กุมภาพันธ์'
WHEN MONTH(CURRENT_DATE())=3 THEN 'มีนาคม'
WHEN MONTH(CURRENT_DATE())=4 THEN 'เมษายน'
WHEN MONTH(CURRENT_DATE())=5 THEN 'พฤษภาคม'
WHEN MONTH(CURRENT_DATE())=6 THEN 'มิถุนายน'
WHEN MONTH(CURRENT_DATE())=7 THEN 'กรกฎาคม'
WHEN MONTH(CURRENT_DATE())=8 THEN 'สิงหาคม'
WHEN MONTH(CURRENT_DATE())=9 THEN 'กันยายน'
WHEN MONTH(CURRENT_DATE())=10 THEN 'ตุลาคม'
WHEN MONTH(CURRENT_DATE())=11 THEN 'พฤศจิกายน'
WHEN MONTH(CURRENT_DATE())=12 THEN 'ธันวาคม' ELSE NULL END AS 'เดือน'),' ',
SUBSTR(CURRENT_DATE(),1,4)+543) AS 'dateprint',
CONCAT(DAY(CURRENT_DATE()),' ',(SELECT CASE WHEN MONTH(CURRENT_DATE())=1 THEN 'มกราคม'
WHEN MONTH(CURRENT_DATE())=2 THEN 'กุมภาพันธ์'
WHEN MONTH(CURRENT_DATE())=3 THEN 'มีนาคม'
WHEN MONTH(CURRENT_DATE())=4 THEN 'เมษายน'
WHEN MONTH(CURRENT_DATE())=5 THEN 'พฤษภาคม'
WHEN MONTH(CURRENT_DATE())=6 THEN 'มิถุนายน'
WHEN MONTH(CURRENT_DATE())=7 THEN 'กรกฎาคม'
WHEN MONTH(CURRENT_DATE())=8 THEN 'สิงหาคม'
WHEN MONTH(CURRENT_DATE())=9 THEN 'กันยายน'
WHEN MONTH(CURRENT_DATE())=10 THEN 'ตุลาคม'
WHEN MONTH(CURRENT_DATE())=11 THEN 'พฤศจิกายน'
WHEN MONTH(CURRENT_DATE())=12 THEN 'ธันวาคม' ELSE NULL END AS 'เดือน'),' ',
SUBSTR(CURRENT_DATE(),1,4)+543) AS 'footdateprint'
FROM chospital
  JOIN office ON chospital.hoscode = office.offid
LEFT JOIN csubdistrict ON chospital.provcode = csubdistrict.provcode AND csubdistrict.subdistcode = chospital.subdistcode
AND csubdistrict.distcode = chospital.distcode
LEFT JOIN cdistrict ON csubdistrict.provcode = cdistrict.provcode AND cdistrict.distcode = csubdistrict.distcode
LEFT JOIN cprovince ON cdistrict.provcode = cprovince.provcode
WHERE offid<>'0000x'  LIMIT 1]]>
	</queryString>
	<field name="office_name" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="dateprint" class="java.lang.String"/>
	<field name="footdateprint" class="java.lang.String"/>
