<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpt_sumvisitgroupbyrightgroup" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6d7a5fd3-81e3-4909-9789-8bfdcd4d4783">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="sdate" class="java.lang.String"/>
	<parameter name="edate" class="java.lang.String"/>
	<parameter name="showDate1" class="java.lang.String"/>
	<parameter name="showDate2" class="java.lang.String"/>
	<parameter name="office" class="java.lang.String"/>
	<queryString>
		<![CDATA[(select count(v.visitno) as num,ifnull(c2.rightgroupname,'ไม่ระบุ') as rightgroup,
year(v.visitdate)+543 as y
,
(case
 when month(v.visitdate) = 1 then '(04)ม.ค.'
 when month(v.visitdate) = 2 then '(05)ก.พ.'
 when month(v.visitdate) = 3 then '(06)มี.ค.'
 when month(v.visitdate) = 4 then '(07)เม.ย.'
 when month(v.visitdate) = 5 then '(08)พ.ค.'
 when month(v.visitdate) = 6 then '(09)มิ.ย.'
 when month(v.visitdate) = 7 then '(10)ก.ค.'
 when month(v.visitdate) = 8 then '(11)ส.ค.'
 when month(v.visitdate) = 9 then '(12)ก.ย.'
 when month(v.visitdate) = 10 then '(01)ต.ค.'
 when month(v.visitdate) = 11 then '(02)พ.ย.'
 when month(v.visitdate) = 12 then '(03)ธ.ค.'
end) as m
from visit v
left join cright c ON (v.rightcode = c.rightcode)
left join crightgroup c2 on (c.rightgroup = c2.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and v.flagservice = '03'
group by month(v.visitdate),c2.rightgroupcode
order by y,m )]]>
	</queryString>
	<field name="num" class="java.lang.Long"/>
	<field name="rightgroup" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="y" class="java.lang.Long">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="m" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
