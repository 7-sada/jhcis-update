	<pageHeader>
		<band height="146" splitType="Stretch">
			<staticText>
				<reportElement key="staticText-8" x="189" y="0" width="469" height="32" uuid="c9d648d7-9497-4e7f-839e-0c77073bfc82"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Tahoma" size="12" isBold="true" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[ทะเบียนผู้รับบริการอนามัยเด็กและสร้างเสริมภูมิคุ้มกันโรค]]></text>
			</staticText>
			<textField isBlankWhenNull="false">
				<reportElement key="textField" x="0" y="32" width="417" height="25" uuid="ca3ff752-35a6-4e40-94fe-aa63032a5393"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="8" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["หน่วยงาน : "+$F{hosname} +"  อ. "+ $F{distname}+ "   จ. " + $F{provname}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement key="staticText-12" x="417" y="32" width="123" height="25" uuid="bb215b2d-24cd-46e2-8b19-c59494794a4f"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Tahoma" size="8" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[วันที่ตัดยอดทะเบียนระหว่างวันที่ :]]></text>
			</staticText>
			<staticText>
				<reportElement key="staticText-17" x="0" y="57" width="466" height="25" forecolor="#CC0000" uuid="5ad03a77-8c6d-4bbe-a5c7-9521a0f24bf5"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="8" isBold="true" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[หมายเหตุ : รหัส วัคซีน ต้องใช้รหัสตามมาตรฐานของโปรแกรม (กำหนดค่าเริ่มต้น หัวข้อ รหัสยา)]]></text>
			</staticText>
			<staticText>
				<reportElement x="11" y="96" width="791" height="15" forecolor="#000099" uuid="5681e8b9-715b-49e8-b862-e8319eab3540"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<text><![CDATA[ แต่ทั้งนี้อาจไม่พบกรณีที่ว่านี้มากนัก  เนื่องจากโดยทั่วไป หากผู้รับบริการ 1 คน ได้รับวัคซีนมากกว่า 1 ตัวในช่วงใดๆ ก็มักจะได้รับฯ ในวันเดียวกัน เสมอ]]></text>
			</staticText>
			<staticText>
				<reportElement x="11" y="82" width="791" height="15" forecolor="#CC0000" uuid="e879ebc5-5a6f-4262-9dd9-98613ed4e67a"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<text><![CDATA[ ในกรณีดังกล่าว วันที่รับบริการวัคซีน ของ ดช. ดำ จะแสดงเป็นวันที่ 2 กพ 58 เท่านั้น (1 Row) แต่จะแสดงการรับวัคซีนทั้ง 2 รายการ ทั้งนี้เพราะ 1 ผู้รับบริการ จะแสดงเพียง 1 Row ในรายงานนี้]]></text>
			</staticText>
			<staticText>
				<reportElement x="11" y="111" width="775" height="29" forecolor="#CC0000" uuid="797e0fb7-dd5f-46a7-8e77-f2dbbc99e899"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<text><![CDATA[ 2. รายงานนี้ จะแสดงรายชื่อผู้ได้รับบริการวัคซีน เฉพาะที่ได้รับวัคซีนฯ เมื่ออายุไม่เกิน 45 ปีบริบูรณ์ เท่านั้น (ผู้ที่ได้รับฯ ขณะที่ ณ วันที่รับฯ อายุเกิน 45 ปีบริบูรณ์ไปแล้ว จะไม่ปรากฏในรายงานนี้ (แต่ยังคงอยู่ในฐานข้อมูล))]]></text>
			</staticText>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="540" y="32" width="216" height="25" uuid="d489bec3-5c23-49a4-8b2d-fb833584cb17"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{showDate1}+" ถึงวันที่ "+$P{showDate2}]]></textFieldExpression>
			</textField>
		</band>
