<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpt_listVaccine" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" isSummaryWithPageHeaderAndFooter="true" uuid="a75d764e-bf9d-4082-b2b4-a8ab8419ae77">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="showDate1" class="java.lang.String"/>
	<parameter name="showDate2" class="java.lang.String"/>
	<parameter name="sdate" class="java.lang.String"/>
	<parameter name="edate" class="java.lang.String"/>
	<queryString>
		<![CDATA[select ve.dateepi,IF(ve.dateepi IS NULL,'ไม่ระบุ',concat(convert(DAY(ve.dateepi) using utf8),' ',
   CASE WHEN MONTH(ve.dateepi)=1 THEN '01'
   WHEN MONTH(ve.dateepi)=2 THEN '02' WHEN MONTH(ve.dateepi)=3 THEN '03'
   WHEN MONTH(ve.dateepi)=4 THEN '04' WHEN MONTH(ve.dateepi)=5 THEN '05'
   WHEN MONTH(ve.dateepi)=6 THEN '06' WHEN MONTH(ve.dateepi)=7 THEN '07'
   WHEN MONTH(ve.dateepi)=8 THEN '08' WHEN MONTH(ve.dateepi)=9 THEN '09'
   WHEN MONTH(ve.dateepi)=10 THEN '10' WHEN MONTH(ve.dateepi)=11 THEN '11'
   WHEN MONTH(ve.dateepi)=12 THEN '12' END,' ',right(year(dateepi)+543,2))) as epidate,
   ve.pid,concat(ct.titlename,p.fname," ",p.lname) as fullname,
   replace(replace(replace(getageymd(p.birth,ve.dateepi),"ปี","/"),"เดือน","/"),"วัน","") as age1,
   date_add(ve.dateepi,interval 543 year) as dateepi1,
ve.vaccinecode,"Y" as aa,ch.hosname,cd.distname,cp.provname
from visitepi ve
join visit v on (ve.dateepi = v.visitdate and ve.visitno = v.visitno and ve.pcucode = v.pcucode)
join person p on (ve.pid = p.pid and ve.pcucodeperson = ve.pcucodeperson)
left join  ctitle ct on (p.prename = ct.titlecode)
left join chospital ch on (v.pcucode = ch.hoscode)
left join cdistrict cd on (ch.distcode = cd.distcode and cd.provcode = ch.provcode)
left join cprovince cp on (ch.provcode = cp.provcode)
where v.visitdate between $P{sdate} and $P{edate}
and (getageyearnum(p.birth,ve.dateepi) <= 45)
order by ve.dateepi]]>
	</queryString>
