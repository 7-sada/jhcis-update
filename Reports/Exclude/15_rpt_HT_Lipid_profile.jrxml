<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="15_rpt_HT_Lipid_profile" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="5ea7b23d-5314-42cf-80dd-40ec05604634">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<subDataset name="data1" uuid="54932992-7dd4-4baf-9f88-f88965aec4c4">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select p1.pcucodeperson,p1.pid,(case when p1.labcode = 'CH07' then 'ค่า  Cholesterol CH07'
when p1.labcode = 'CH25' then 'ค่า  Triglyceride CH25'
when p1.labcode = 'CH14' then 'ค่า  HDL CH14'
when p1.labcode = 'CH17' then 'ค่า  LDL CH17'
else 'n/a'
end) as labcode
,p2.labresultdigit,p1.datecheck,p1.seq,ct.titlename,p.idcard,
p.fname,p.lname,group_concat(pc.chroniccode) as chroniccode,concat(ct.titlename," ",p.fname," ",p.lname) as fullname
from
(select a1.pcucodeperson,a1.pid,a1.labcode,max(a1.datecheck) as datecheck,a1.seq
from
(select pcucodeperson,pid,datecheck,labcode,max(seqonday) as seq
from visitlabchcyhembmsse
where labcode in ('CH07','CH25','CH14','CH17')
and datecheck between $P{sdate} and $P{edate}
group by labcode,datecheck
order by datecheck desc) as a1
group by a1.labcode,a1.pid) as p1
join
(select pcucodeperson,pid,datecheck,labcode,seqonday,labresultdigit
from visitlabchcyhembmsse
where labcode in ('CH07','CH25','CH14','CH17')
and datecheck between $P{sdate} and $P{edate}
) as p2
on (p1.pcucodeperson=p2.pcucodeperson and p1.pid=p2.pid and p1.labcode = p2.labcode
and p1.datecheck=p2.datecheck and p1.seq=p2.seqonday)
join person p on (p1.pid = p.pid and p1.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join personchronic pc on (p1.pid = pc.pid and p1.pcucodeperson = pc.pcucodeperson)
where  UCASE(left(pc.chroniccode,3)) BETWEEN 'I10' AND 'I15'
group by p1.pid,p1.labcode,p1.datecheck,p1.seq]]>
		</queryString>
		<field name="pcucodeperson" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
