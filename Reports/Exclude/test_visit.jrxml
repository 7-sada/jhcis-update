	<subDataset name="test" uuid="73375349-1822-49b2-aeeb-32d5466c4a87">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[select v.visitdate,v.pid,concat(ifnull(titlename,ifnull(p.prename,'...')) ,' ', fname,' ', lname) as pname
from visit v
inner join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
inner join ctitle t on (p.prename = t.titlecode)
where v.visitdate between '2018-01-01' and '2018-01-05'
order by v.pid]]>
		</queryString>
		<field name="visitdate" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pname" class="java.lang.String"/>
	</subDataset>
	<parameter name="edate" class="java.lang.String"/>
	<parameter name="sdate" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select 1 as dummy]]>
	</queryString>
	<field name="dummy" class="java.lang.Long"/>
