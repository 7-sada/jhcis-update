	<subDataset name="data" uuid="15cbfad4-e027-4549-bb75-709c16721a69">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select p1.pid as HN,
CONCAT_WS('-',substring(p.idcard,1,1),substring(p.idcard,2,4),substring(p.idcard,6,5),substring(p.idcard,11,2),substring(p.idcard,13,1))AS 'idcard',
concat(ct.titlename,p.fname,' ',p.lname)as 'name',
CONVERT(concat(DAY(p.birth),' ',(case when (month (p.birth) = 1) then 'ม.ค.'
      when (month (p.birth) = 2) then 'ก.พ.'
      when (month (p.birth) = 3) then 'มี.ค.'
      when (month (p.birth) = 4) then 'เม.ย.'
      when (month (p.birth) = 5) then 'พ.ค.'
      when (month (p.birth) = 6) then 'มิ.ย.'
      when (month (p.birth) = 7) then 'ก.ค.'
      when (month (p.birth) = 8) then 'ส.ค.'
      when (month (p.birth) = 9) then 'ก.ย.'
      when (month (p.birth) = 10) then 'ต.ค.'
      when (month (p.birth) = 11) then 'พ.ย.'
      when (month (p.birth) = 12) then 'ธ.ค.'
end),' ',year (p.birth) + 543)USING utf8) 'birth',
getAgeymd(p.birth,v.visitdate) AS 'age',
p.mumoi,
p.rightcode,
cr.rightname,
p1.chroniccode,
CONVERT(concat(DAY(v.visitdate),' ',(case when (month (v.visitdate) = 1) then 'ม.ค.'
      when (month (v.visitdate) = 2) then 'ก.พ.'
      when (month (v.visitdate) = 3) then 'มี.ค.'
      when (month (v.visitdate) = 4) then 'เม.ย.'
      when (month (v.visitdate) = 5) then 'พ.ค.'
      when (month (v.visitdate) = 6) then 'มิ.ย.'
      when (month (v.visitdate) = 7) then 'ก.ค.'
      when (month (v.visitdate) = 8) then 'ส.ค.'
      when (month (v.visitdate) = 9) then 'ก.ย.'
      when (month (v.visitdate) = 10) then 'ต.ค.'
      when (month (v.visitdate) = 11) then 'พ.ย.'
      when (month (v.visitdate) = 12) then 'ธ.ค.'
end),' ',year (v.visitdate) + 543)USING utf8) 'servicedate',
GROUP_CONCAT(vd.drugcode) as drugcode
from
(select pc.pid,GROUP_CONCAT(pc.chroniccode) as chroniccode,pc.pcucodeperson
from personchronic pc
where (lcase(left(pc.chroniccode,3)) between 'e10' and 'e14') or (pc.chroniccode = 'I10')
group by pc.pid ) as p1
left join person p on (p1.pid = p.pid and p1.pcucodeperson = p.pcucodeperson)
left join persondeath pd on (p1.pid = pd.pid and p1.pcucodeperson = pd.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode )
left join cright cr on (p.rightcode = cr.rightcode)
left join visit v on (v.pid = p1.pid and v.pcucodeperson = p1.pcucodeperson)
left join visitdrug vd on (v.visitno = vd.visitno and vd.pcucode = v.pcucode)
left join cdrug cd on (cd.drugcode = vd.drugcode)
where p.typelive in ('0','1','3')
and pd.pid is null
and v.visitdate between $P{sdate} and $P{edate}
and v.flagservice in ('02','03')
and cd.drugtype in ('01','10')
group by v.visitno
order by v.visitdate,p.mumoi]]>
		</queryString>
		<field name="HN" class="java.lang.Integer"/>
		<field name="idcard" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="name" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="birth" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="age" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="mumoi" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="rightcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="rightname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="chroniccode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="servicedate" class="java.lang.String"/>
		<field name="drugcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
