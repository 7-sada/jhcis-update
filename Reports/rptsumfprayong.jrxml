<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptsumfprayong"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and visitfp.datefp  between '2010-04-01' and '2010-04-30' "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["AND visitfp.datefp between '2010-10-01' and '2010-10-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date"/>
	<queryString><![CDATA[select count(distinct concat(visitfp.pcucode,visitfp.visitno)) as  cdiag
,sum(case when visitdiag.diagcode   like 'K%' then 1 else 0 end)  as caccid
,count(distinct concat(visitfp.pcucodeperson,visitfp.pid)) as cperson

,sum(case when cdrug.drugtype ='04' then 1 else 0 end) as cdrugtime0104
,sum(case when cdrug.drugtype ='04' then (visitdrug.realprice * visitdrug.unit )  else 0 end) as cdrugtype0104

,sum(case when cdrug.drugtype = '06'  then 1 else 0 end) as ctimedruttype06
,sum(case when cdrug.drugtype = '06' then (visitdrug.realprice* visitdrug.unit ) else 0 end) as cdrugtype06
,chospital.hosname
,hmain.hosname as hosmain
from visitfp left join visitdiag on visitfp.pcucode = visitdiag.pcucode and visitfp.visitno = visitdiag.visitno
	left join visit on visitfp.visitno = visit.visitno and visitfp.pcucode = visit.pcucode
	left join person on visitfp.pcucodeperson = person.pcucodeperson and visitfp.pid = person.pid
 	left join visitdrug on visitfp.pcucode = visitdrug.pcucode and visitfp.visitno = visitdrug.visitno
	left join cdrug on visitdrug.drugcode = cdrug.drugcode
	left join chospital on visitfp.pcucode = chospital.hoscode
	left join chospital hmain on person.hosmain = hmain.hoscode
where  1=1
$P!{DateFp}
$P!{pcucode}
group by visitfp.pcucode]]></queryString>

	<field name="cdiag" class="java.lang.Long"/>
	<field name="caccid" class="java.math.BigDecimal"/>
	<field name="cperson" class="java.lang.Long"/>
	<field name="cdrugtime0104" class="java.math.BigDecimal"/>
	<field name="cdrugtype0104" class="java.math.BigDecimal"/>
	<field name="ctimedruttype06" class="java.math.BigDecimal"/>
	<field name="cdrugtype06" class="java.math.BigDecimal"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="hosmain" class="java.lang.String"/>

