<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="jvisit_person" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="d9ed5ee6-6f35-403e-9bfc-d4854779266c">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="208"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Program Files (x86)\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["08989"]]></defaultValueExpression>
	</parameter>
	<parameter name="visitno" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["91997"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[##
SELECT
concat(ifnull(c1.titlename,ifnull(prename,'...')),fname,'   ',lname) AS fullname,
person.idcard,
getageymd(person.birth,visit.visitdate) AS age,
visithomehealthindividual.visitno,
chomehealthtype.homehealthmeaning,
visithomehealthindividual.patientsign,
visithomehealthindividual.homehealthresult,
visithomehealthindividual.homehealthdetail,
visithomehealthindividual.homehealthplan,
IF(visithomehealthindividual.dateappoint IS NULL,'ไม่ระบุ',
concat(convert(DAY(visithomehealthindividual.dateappoint) using utf8),' ',
   CASE WHEN MONTH(visithomehealthindividual.dateappoint)=1 THEN 'มกราคม'
   WHEN MONTH(visithomehealthindividual.dateappoint)=2 THEN 'กุมภาพันธ์'
   WHEN MONTH(visithomehealthindividual.dateappoint)=3 THEN 'มีนาคม'
   WHEN MONTH(visithomehealthindividual.dateappoint)=4 THEN 'เมษายน'
   WHEN MONTH(visithomehealthindividual.dateappoint)=5 THEN 'พฤษภาคม'
   WHEN MONTH(visithomehealthindividual.dateappoint)=6 THEN 'มิถุนายน'
   WHEN MONTH(visithomehealthindividual.dateappoint)=7 THEN 'กรกฎาคม'
   WHEN MONTH(visithomehealthindividual.dateappoint)=8 THEN 'สิงหาคม'
   WHEN MONTH(visithomehealthindividual.dateappoint)=9 THEN 'กันยายน'
   WHEN MONTH(visithomehealthindividual.dateappoint)=10 THEN 'ตุลาคม'
   WHEN MONTH(visithomehealthindividual.dateappoint)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(visithomehealthindividual.dateappoint)=12 THEN 'ธันวาคม' END,' ',
   YEAR(visithomehealthindividual.dateappoint)+543)) as dateappointth,
date_format(visithomehealthindividual.dateappoint,'%Y-%m-%d') AS dateappoint1,
IF(visit.visitdate IS NULL,'ไม่ระบุ',concat(convert(DAY(visit.visitdate) using utf8),' ',
   CASE WHEN MONTH(visit.visitdate)=1 THEN 'มกราคม'
   WHEN MONTH(visit.visitdate)=2 THEN 'กุมภาพันธ์'
   WHEN MONTH(visit.visitdate)=3 THEN 'มีนาคม'
   WHEN MONTH(visit.visitdate)=4 THEN 'เมษายน'
   WHEN MONTH(visit.visitdate)=5 THEN 'พฤษภาคม'
   WHEN MONTH(visit.visitdate)=6 THEN 'มิถุนายน'
   WHEN MONTH(visit.visitdate)=7 THEN 'กรกฎาคม'
   WHEN MONTH(visit.visitdate)=8 THEN 'สิงหาคม'
   WHEN MONTH(visit.visitdate)=9 THEN 'กันยายน'
   WHEN MONTH(visit.visitdate)=10 THEN 'ตุลาคม'
   WHEN MONTH(visit.visitdate)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(visit.visitdate)=12 THEN 'ธันวาคม' END,' ',YEAR(visitdate)+543) )
   as visitdateth,

date_format(visit.visitdate,'%d-%m-%Y') AS visitdate1,
concat('เลขที่: ',ifnull(hnomoi,'...'),' ถนน: ',ifnull(roadmoi,'...'), '  หมู่ที่.',ifnull(mumoi,'...'),'  ต.',ifnull(csd.subdistname,'...'), ' อ.',ifnull(cd.distname,'...'), ' จ.',ifnull(cw.provname,'...') ) as addr
FROM
person
LEFT JOIN ctitle AS c1 ON person.prename = c1.titlecode
LEFT OUTER JOIN csubdistrict AS csubdistricth ON person.subdistcodemoi = csubdistricth.subdistcode AND person.distcodemoi = csubdistricth.distcode AND person.provcodemoi = csubdistricth.provcode
LEFT OUTER JOIN cdistrict AS cdistricth ON person.distcodemoi = cdistricth.distcode AND person.provcodemoi = cdistricth.provcode
LEFT OUTER JOIN cprovince AS cprovinceh ON person.provcodemoi = cprovinceh.provcode
LEFT OUTER JOIN cstatus ON person.marystatus = cstatus.statuscode
LEFT OUTER JOIN cnation ON person.origin = cnation.nationcode
LEFT OUTER JOIN creligion ON person.religion = creligion.religioncode
LEFT OUTER JOIN coccupa ON person.occupa = coccupa.occupacode
LEFT OUTER JOIN csubdistrict AS csd ON csd.subdistcode = person.subdistcodemoi AND csd.distcode = person.distcodemoi AND csd.provcode = person.provcodemoi
LEFT OUTER JOIN cdistrict AS cd ON cd.distcode = person.distcodemoi AND cd.provcode = person.provcodemoi
LEFT OUTER JOIN cprovince AS cw ON cw.provcode = person.provcodemoi
LEFT OUTER JOIN personaddresscontact ON person.pcucodeperson = personaddresscontact.pcucodeperson AND person.pid = personaddresscontact.pid
LEFT OUTER JOIN csubdistrict AS csd2 ON csd2.subdistcode = personaddresscontact.subdistcode AND csd2.distcode = personaddresscontact.distcode AND csd2.provcode = personaddresscontact.provcode
LEFT OUTER JOIN cdistrict AS cd2 ON cd2.distcode = personaddresscontact.distcode AND cd2.provcode = personaddresscontact.provcode
LEFT OUTER JOIN cprovince AS cw2 ON cw2.provcode = personaddresscontact.provcode
LEFT JOIN cright ON person.rightcode = cright.rightcode
LEFT JOIN chospital ON person.hosmain = chospital.hoscode
INNER JOIN visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
INNER JOIN visithomehealthindividual ON visithomehealthindividual.pcucode = visit.pcucode AND visithomehealthindividual.visitno = visit.visitno
INNER JOIN chomehealthtype ON chomehealthtype.homehealthcode = visithomehealthindividual.homehealthtype
##
WHERE
visit.visitno =  $P!{visitno}
AND visit.pcucode = $P!{pcucode}]]>
	</queryString>
