<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDentPart3" language="groovy" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-11-08"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and visit.pcucode = '01035' "]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-11-08"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
case 	when visitdrugdental.dentcode in('2301','2372700','2382770')  then '1.ถอนฟัน (ครั้ง / ซี่)'
	when visitdrugdental.dentcode in('23771A1','23771A2','23771A3','23771A4','23771B1','23771B2','23771B3','23771B4','23771B5','23771C1','23771C2','23771C3','2387179'              ,'2387188','2387189','23871A1','23871A2','23871A3','23871A4','23871B1','23871B2','23871B3','23871B4','23871B5','23871C1','23871C2','23871C3','23871C4') then '2.อุดฟัน (ครั้ง / ซี่)'
	when visitdrugdental.dentcode in('2277310','2287320','2377010','2287310') then'3.ขูดหินปูนทั้งปาก (ครั้ง) '

	when visitdrugdental.dentcode in('x') then '4.ศัลกรรมช่องปาก (ครั้ง)  '

	when visitdrugdental.dentcode in('23871L1','23871L2','23871L3','23871M1','23871M2','23871M3','23871M4','23871Q4','23871Q2','23871Q3','23871R1','23871R2','23871R3','23871R4','23871R5','23871S1','23871S2','23871S3','23871S4','23871S8','23871T1','23871T2','23871T3') then '5.ทันตกรรมหัตถการ (ครั้ง / ซี่)'


	when visitdrugdental.dentcode in('2387212','2387213','2387214','2387220','2387221','2387222','2387223','2387224','2387225','2387226','2387227','2387228','2387230',
                                                         '2387231','2387232','2387240','2387241','2387242','2387243','2387244','2387245','2387250','2387251','2387252','2387279') then '6.รักษาคลองรากฟัน (ครั้ง / ซี่) '
	when visitdrugdental.dentcode in('xx') then '7.ปริทันต์ (ครั้ง)'
	when visitdrugdental.dentcode in('2377121','2377210','2377211','22377220') then '8.ทันตกรรมสำหรับเด็ก (ครั้ง) '
	when visitdrugdental.dentcode in('2287410','2287411','2287412','2287413','2287420','2287421','2287422','2287423') then '9.ทันตกรรมประดิษฐ์ (ครั้ง / ชิ้น) '
else 'อื่น ๆ ' end as typedent
,count(distinct visitdrugdental.pcucode,visitdrugdental.visitno) as ctime
,count(tootharea) as cpr
from visitdrugdental join visit on visitdrugdental.pcucode = visit.pcucode and visitdrugdental.visitno = visit.visitno
where visitdate between $P{sdate} and $P{edate} $P!{pcucode}
group by typedent]]>
	</queryString>
	<field name="typedent" class="java.lang.String"/>
	<field name="ctime" class="java.lang.Long"/>
	<field name="cpr" class="java.lang.Long"/>
	<background>
		<band splitType="Stretch"/>
	</background>
