<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rexpenseopd" pageWidth="813" pageHeight="595" orientation="Landscape" columnWidth="753" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="5c29d23e-f2b3-400e-a5ed-cee304d898a4">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-10"]]></defaultValueExpression>
	</parameter>
	<parameter name="rightgroup" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-10-24"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["AND v.pcucode ='01024' "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="zdiag" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and Lcase(left(visitdiag.diagcode,1)) !='z'"]]></defaultValueExpression>
	</parameter>
	<parameter name="note1" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["ไม่นับบริการ (Diage Z)"]]></defaultValueExpression>
	</parameter>
	<parameter name="hosmain" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="officertypep" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  DATE_FORMAT(v.visitdate,"%Y-%m-%d")as visitdate
,birth,v.visitno,v.pcucode,v.pid
,v.rightno
,CONVERT(concat( ifnull(titlename,ifnull(p.prename,'ไม่ระบุ') ),p.fname,' ',p.lname) using utf8 ) as personname,p.idcard
,if(birth is not null , CONVERT(CONCAT(  DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " / ",
    CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(v.visitdate,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END) USING utf8),"ไม่มีวันเกิด") AS age_ym
,c.occupaname
,crightgroup.rightgroupname
,cright.rightgroup
,u.officerposition

,CONVERT(concat(chospital.`hosname`,' ต.',csubdistricth.`subdistname`,' อ.',cdistricth.`distname`) using utf8 ) AS hostname
,cprovinceh.`provname`
,u.officertype as offtypecode

,case when  u.officertype ='1' then "AND u.officertype = '1' "
      when (u.officertype ='2' OR u.officertype ='6' ) then "AND u.officertype in('2','6')"
      when (u.officertype ='3' OR u.officertype ='4' OR u.officertype ='5' ) then "AND u.officertype in('3','4','5')"
      when  u.officertype ='7' then "AND u.officertype = '7' "
      else "AND u.officertype is null "
      end as officertype
,case when  u.officertype ='1' then "= '1' "
      when (u.officertype ='2' OR u.officertype ='6' ) then " in('2','6')"
      when (u.officertype ='3' OR u.officertype ='4' OR u.officertype ='5' ) then " in('3','4','5')"
      when  u.officertype ='7' then " = '7' "
      else " is null "
      end as officertypep

,case when  u.officertype ='1' then " แพทย์ "
      when (u.officertype ='2' OR u.officertype ='6' ) then " ทันตแพทย์ / ทันตาภิบาล"
      when (u.officertype ='3' OR u.officertype ='4' OR u.officertype ='5' ) then " พยาบาลวิชาชีพ /นักวิชาการสาธารณสุข / เจ้าหน้าที่สาธารณสุข "
      when u.officertype ='7' then " นักการแพทย์แผนไทย "
   else " อื่น ๆ " end as officername
,case when  u.officertype ='1' then "A"
      when (u.officertype ='2' OR u.officertype ='6' ) then "B"
      when (u.officertype ='3' OR u.officertype ='4' OR u.officertype ='5' ) then "C"
      when u.officertype ='7' then "D"
   else "E" end as officersorte
,v.hosmain,htm.hosname
,hpcu.hosname as pcuname

from  visit v
     left join person p on v.pcucodeperson = p.pcucodeperson and v.pid= p.pid
     left join ctitle on p.prename = ctitle.titlecode
     left join visitdrug  on v.pcucode = visitdrug.pcucode and v.visitno = visitdrug.visitno
     left join visitdiag on v.visitno = visitdiag.visitno and v.pcucode = visitdiag.pcucode
     left JOIN cdrug cdr on visitdrug.drugcode = cdr.drugcode
     left JOIN coccupa c  on p.occupa = c.occupacode
     left JOIN cright on cright.rightcode = v.rightcode
     left JOIN `user` u on v.username = u.username and v.pcucode = u.pcucode
     left JOIN chospital chospital ON v.`pcucode` = chospital.`hoscode`
     left JOIN csubdistrict csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left JOIN cdistrict cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
     left JOIN cprovince cprovinceh ON chospital.provcode = cprovinceh.provcode
     left JOIN crightgroup on cright.rightgroup=crightgroup.rightgroupcode
     left JOIN chospital htm on v.hosmain = htm.hoscode
     left join chospital hpcu on v.pcucode = hpcu.hoscode
where cright.rightgroup=$P{rightgroup}
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
     and v.visitdate between $P{sdate} and $P{edate}
     $P!{pcucode}
     $P!{zdiag}
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
group by v.pcucode,v.visitdate,v.visitno
order by v.pcucode,v.hosmain,officersorte ,v.visitdate,v.visitno]]>
	</queryString>
