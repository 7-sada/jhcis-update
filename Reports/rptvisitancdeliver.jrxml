<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptvisitancdeliver"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="39"
		 bottomMargin="42"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-28"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select visitancdeliver.datedeliver
,sum(case when (select count(v1.pregno) as dc from visitancdeliver v1,visit where visit.visitno= v1.visitno and visit.pcucode = v1.pcucode and v1.deliverplace='3'  group by v1.pcucode ,v1.pregno having dc =4) then 1 else 0 end) as mc421
,sum(case when (select count(v1.pid) from visitancdeliver v1  where person.pid = v1.pid and person.pcucodeperson = v1.pcucodeperson and ( DATEDIFF(datedeliver,birth) <=7300 )  group by v1.pcucode)then 1 else 0 end ) as deli22
,sum(case when (visitancdeliver.deliverplace='3' and visitancdeliver.operater='3') then 1 else 0 end) as deli26
,sum(case when (visitancdeliver.deliverplace='3' and visitancdeliver.operater='4') then 1 else 0 end) as deli27
,sum(case when (visitancdeliver.delivertype='1') then 1 else 0 end) as deli291
,sum(case when (select count(v1.pidchild) as dc from visitancdeliverchild v1 where visitancdeliver.pid= v1.pid and visitancdeliver.pcucodeperson = v1.pcucodeperson  group by v1.pid,v1.pcucodeperson ,v1.pregno having dc >1) then 1 else 0 end)  as deli2101
,sum(case when (select count(v2.pidchild) as dc from visitancdeliverchild v2 where visitancdeliverchild.pidchild = v2.pidchild and visitancdeliverchild.pcucodechild= v2.pcucodechild  group by v2.pid,v2.pcucodeperson ,v2.pregno having dc >1) then 1 else 0 end)  as deli2102
,sum(case when (visitancdeliver.deliverresult='ช' OR visitancdeliver.deliverresult='ท') then 1 else 0 end) as deli211
,sum(case when (visitancdeliver.deliverresult='ท') then 1 else 0 end) as deli212
,sum(case when (visitancdeliver.deliverresult='ช' ) then 1 else 0 end) as deli213
,sum(case when (visitancdeliver.deliverresult='ช' and visitancdeliverchild.weight !='' ) then 1 else 0 end) as deli216
,sum(case when ( visitancdeliverchild.weight between '1' and '2501' ) then 1 else 0 end) as deli217
,sum(case when (select count( pd.pid)  FROM persondeath pd WHERE person.pid = pd.pid and person.pcucodeperson = pd.pcucodeperson and pd.pcucodeperson='11349' and ( DATEDIFF(deaddate,birth) <=6)  and (pd.deaddate IS NULL OR pd.deaddate<='2009-08-30')  )then 1 else 0 end ) as cd218 
,sum(case when (select count( pd.pid)  FROM persondeath pd WHERE person.pid = pd.pid and person.pcucodeperson = pd.pcucodeperson and pd.pcucodeperson='11349' and ( DATEDIFF(deaddate,birth) <=365)  and (pd.deaddate IS NULL OR pd.deaddate<='2009-08-30')  )then 1 else 0 end ) as cd219 
,sum(case when (select count( pd.pid)  FROM persondeath pd WHERE visitancdeliver.pid = pd.pid and visitancdeliver.pcucodeperson = pd.pcucodeperson and pd.pcucodeperson='11349' and (pd.deaddate IS NULL OR pd.deaddate<='2009-08-30')  )then 1 else 0 end ) as md220 
,hosname
from person left join visit ON person.pid = visit.pid and person.pcucodeperson = visit.pcucodeperson
                  left join visitancdeliver   ON  visit.visitno = visitancdeliver.visitno and visit.pcucode = visitancdeliver.pcucode  
                  left join visitancdeliverchild ON visit.pid = visitancdeliverchild.pid and visit.pcucodeperson = visitancdeliverchild.pcucodeperson
	          left join chospital ON visit.pcucode = chospital.hoscode
where visitancdeliver.datedeliver between $P{sdate} and  $P{edate}
       $P!{pcucode} 
group by visitancdeliver.pcucode]]></queryString>

	<field name="datedeliver" class="java.sql.Date"/>
	<field name="mc421" class="java.math.BigDecimal"/>
	<field name="deli22" class="java.math.BigDecimal"/>
	<field name="deli26" class="java.math.BigDecimal"/>
	<field name="deli27" class="java.math.BigDecimal"/>
	<field name="deli291" class="java.math.BigDecimal"/>
