<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rdrugstore"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dstock" isForPrompting="false" class="java.lang.Double"/>
	<queryString><![CDATA[(SELECT 
v.cdrug,
v.drug,
DATE_FORMAT(v.ddate,'%Y-%m-%d') AS ddate,
sum(v.dr0) dr0,
sum(v.dr1) dr1,
sum(v.dr2) dr2,
sum(v.dr3) dr3,
0 AS dserv,
0 AS dl1,
0 AS dl2,
0 AS dl3
FROM
vdrugreceive v
WHERE CONCAT(v.cdrug,v.ddate) not in (SELECT CONCAT(vdrugstore.cdrug,vdrugstore.ddate) FROM vdrugstore)
GROUP BY v.ddate,v.drug)
UNION
(SELECT
v.cdrug,
v.drug,
DATE_FORMAT(v.ddate,'%Y-%m-%d') AS ddate,
0 AS dr0,
0 AS dr1,
0 AS dr2,
0 AS dr3,
v.dserv,
v.dl1,
v.dl2,
v.dl3
FROM
 vdrugstore v
WHERE CONCAT(v.cdrug,v.ddate) not in (SELECT CONCAT(vdrugreceive.cdrug,vdrugreceive.ddate) FROM vdrugreceive))
UNION
(SELECT
v.cdrug,
v.drug,
DATE_FORMAT(v.ddate,'%Y-%m-%d') AS ddate,
sum(v.dr0) dr0,
sum(v.dr1) dr1,
sum(v.dr2) dr2,
sum(v.dr3) dr3,
v.dserv,
v.dl1,
v.dl2,
v.dl3
FROM
vdrugreceive_union_drugstore v
GROUP BY v.ddate,v.drug
)
ORDER BY drug,ddate]]></queryString>

	<field name="cdrug" class="java.lang.String"/>
	<field name="drug" class="java.lang.String"/>
	<field name="ddate" class="java.util.Date"/>
	<field name="dr0" class="java.lang.Double"/>
	<field name="dr1" class="java.lang.Double"/>
