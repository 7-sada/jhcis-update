	<field name="dl2" class="java.lang.Double"/>
	<field name="dl3" class="java.lang.Double"/>

	<variable name="dr_total" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Double( ($F{dr0}.doubleValue()) + ($F{dr1}.doubleValue()) +($F{dr2}.doubleValue())+($F{dr3}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="dl_total" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Double( ($F{dserv}.doubleValue())+ $F{dl1}.doubleValue()+$F{dl2}.doubleValue()+$F{dl3}.doubleValue())]]></variableExpression>
	</variable>
