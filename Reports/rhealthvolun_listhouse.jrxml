	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND ptv.pcucodeperson =  '04914' "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["รายชื่อ อสม."]]></defaultValueExpression>
	</parameter>
	<parameter name="where_ptype" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND hv.pidvola IS NOT NULL  "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
village.villno,
village.villname,
hv.pidvola pidvolun,
CONCAT(pv.prename,pv.fname) AS pnamev,
pv.lname AS lnamev,
getAgeYearNum(person.birth,current_date) age,
DATE_FORMAT(persontype.dateelect,'%Y-%m-%d') AS dateelect,
hv.hcode,
hv.hno AS hnovola,
pv.rightno,
h.hno,
CONCAT(person.prename,person.fname) AS pname,
person.lname
FROM
house AS h
Left Join persontype AS ptv ON ptv.pid = h.pidvola AND ptv.pcucodeperson = h.pcucodepersonvola
Left Join person AS pv ON ptv.pcucodeperson = pv.pcucodeperson AND ptv.pid = pv.pid
Left Join house AS hv ON pv.hcode = hv.hcode AND pv.pcucodeperson = hv.pcucode
Left Join village ON village.pcucode = hv.pcucode AND village.villcode = hv.villcode
Left Join person ON person.pcucodeperson = h.pcucodepersonvola AND person.pid = h.pidvola 
Left Join persontype ON persontype.pcucodeperson = person.pcucodeperson AND persontype.pid = person.pid
WHERE
ptv.typecode =  '09' AND (persontype.typecode =  '10' OR persontype.typecode is null) 
$P!{where_ptype}
$P!{pcucode}
GROUP BY
h.hcode
ORDER BY
village.villno ASC,person.pid asc,
h.hno ASC]]></queryString>

