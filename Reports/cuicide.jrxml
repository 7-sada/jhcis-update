<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="report2" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="871d42a0-d6b3-4520-8f43-80916ad70856">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="SelectDate" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[วันเริ่มต้น]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and person.pcucodeperson ='08868 '"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
ch.hoscode,
ch.hosname,
date_format(vs.visitdate,'%Y-%m-%d') visitdate,
CONCAT(ct.titlename,person.fname,'  ',person.lname) AS pname,
person.idcard,
getAgeYearNum(person.birth,CURDATE()) AS age
,IF(vd.coderesult IS NULL OR vd.coderesult<>'2','ปกติ','ผิดปกติ') AS result
,(select count(CONCAT(pcucodeperson,vs.pid)) from visit vs1 where vs1.pcucode = vd.pcucode and vs1.visitno = vd.visitno and vd.codescreen ='c01') counttime,
(vd.q91+vd.q92+vd.q93+vd.q94+vd.q95+vd.q96+vd.q97+vd.q98+vd.q99) as q9,
IF(vd.riskgroup IS NULL,'',vd.riskgroup)AS riskgroup,
CONCAT(if(vd.healthf='1','1,',''),if(vd.consultf='1','2,',''),if(vd.cbt='1','3,',''),if(vd.satir='1','4,',''),if(vd.healthbydrug='1','5,',''),if(vd.healthother='1','6','')) AS care,
IF(vs.refer='00' OR vs.refer IS NULL,'0','1') AS ref,
CONCAT(if(vd.screen='1','1,',''),if(vd.diag='1','2,',''),if(vd.treatmind='1','3,',''),if(vd.treatfollow='1','4,',''),if(vd.watchcareful='1','5,','')) AS activity
,concat(date_format('$P!{SelectDate}','%Y-%m'),"-01") as startdate
,date_format(last_day('$P!{SelectDate}'),'%Y-%m-%d') as enddate
,curdate() as currentdate
FROM
visitscreenspecialdisease vd
INNER JOIN visit vs ON vd.visitno = vs.visitno AND vd.pcucode = vs.pcucode
INNER JOIN person  ON vs.pcucode = person.pcucodeperson AND vs.pid = person.pid
LEFT  JOIN ctitle ct ON ct.titlecode = person.prename
LEFT JOIN chospital ch ON ch.hoscode = vd.pcucode
where vs.visitdate between concat(date_format('$P!{SelectDate}','%Y-%m'),"-01") and  last_day('$P!{SelectDate}')
and vd.codescreen = 'c01'
$P!{pcucode}
ORDER BY vs.visitdate]]>
	</queryString>
