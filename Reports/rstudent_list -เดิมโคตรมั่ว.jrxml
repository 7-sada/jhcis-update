<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rstudent_list" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="9fe3cd5d-41c8-44e0-b0a1-3003d24dcdc1">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND villageschool.pcucode='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="persondeath" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath) "]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[(SELECT cschoolclass.classcode,
if(villageschool.schoolname is null,'ไม่ระบุฯ',villageschool.schoolname) as schoolname,
if(cschoolclass.classname is null,'ไม่ระบุฯ',cschoolclass.classname) as classname,
person.sex,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as fname,
person.lname,
person.hnomoi,
person.mumoi,
DATE_FORMAT(person.birth,'%Y-%m-%d') as birth,
if(studenthealthnutrition.dateservice is not null,
concat((year(dateservice)-year(`person`.`birth`)-(right(dateservice,5)<right(`person`.`birth`,5))),' - ',
(if (day(dateservice) <day(`person`.`birth`),(if (right(dateservice,5)<right(`person`.`birth`,5),(12+ month(dateservice))-month(`person`.`birth`),month(dateservice)-month(`person`.`birth`)))-1 ,(if (right(dateservice,5)<right(`person`.`birth`,5),(12+ month(dateservice))-month(`person`.`birth`),month(dateservice)-month(`person`.`birth`))))) ,' - ',
(if (day(dateservice) < day(`person`.`birth`),(30+ day(dateservice))-day(`person`.`birth`),day(dateservice)-day(`person`.`birth`)))),
null) as age,
if(studenthealthnutrition.dateservice is not null,getagemonth(person.birth,studenthealthnutrition.dateservice),null) as agemonth,
if((SELECT MAX(studenthealthnutrition.dateservice) FROM studenthealthnutrition WHERE (personstudent.pcucodeperson = studenthealthnutrition.pcucodeperson AND personstudent.pid = studenthealthnutrition.pid ) ),studenthealthnutrition.weight,null) as weight,
DATE_FORMAT(studenthealthnutrition.dateservice,'%Y-%m-%d') as dateservice
FROM
personstudent
Left Outer Join studenthealthnutrition ON personstudent.pcucodeperson = studenthealthnutrition.pcucodeperson AND personstudent.pid = studenthealthnutrition.pid
Left Outer Join villageschool ON personstudent.pcucode = villageschool.pcucode AND personstudent.villcode = villageschool.villcode AND personstudent.schoolno = villageschool.schoolno
Left Outer Join cschoolclass ON personstudent.classeducate = cschoolclass.classcode
Left Outer Join person ON personstudent.pcucodeperson = person.pcucodeperson AND personstudent.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
WHERE
 dateservice = (SELECT MAX(dateservice) FROM studenthealthnutrition WHERE personstudent.pcucodeperson = studenthealthnutrition.pcucodeperson AND personstudent.pid = studenthealthnutrition.pid AND studenthealthnutrition.weight is not null)
$P!{pcucode}
$P!{persondeath}
)
UNION
(SELECT cschoolclass.classcode,
if(villageschool.schoolname is null,'ไม่ระบุฯ',villageschool.schoolname) as schoolname,
if(cschoolclass.classname is null,'ไม่ระบุฯ',cschoolclass.classname) as classname,
person.sex,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as fname,
person.lname,
person.hnomoi,
person.mumoi,
DATE_FORMAT(person.birth,'%Y-%m-%d') as birth,
concat((year(current_date)-year(`person`.`birth`)-(right(current_date,5)<right(`person`.`birth`,5))),'-',
(if (day(current_date) <day(`person`.`birth`),(if (right(current_date,5)<right(`person`.`birth`,5),(12+ month(current_date))-month(`person`.`birth`),month(current_date)-month(`person`.`birth`)))-1 ,(if (right(current_date,5)<right(`person`.`birth`,5),(12+ month(current_date))-month(`person`.`birth`),month(current_date)-month(`person`.`birth`))))) ,'-',
(if (day(current_date) < day(`person`.`birth`),((day(last_day(current_date())))+ day(current_date))-day(`person`.`birth`),day(current_date)-day(`person`.`birth`)))) as age,
null as agemonth,
null as weight,
null as dateservice
FROM
personstudent
Left Outer Join villageschool ON personstudent.pcucode = villageschool.pcucode AND personstudent.villcode = villageschool.villcode AND personstudent.schoolno = villageschool.schoolno
Left Outer Join cschoolclass ON personstudent.classeducate = cschoolclass.classcode
Left Outer Join person ON personstudent.pcucodeperson = person.pcucodeperson AND personstudent.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
WHERE
 CONCAT(personstudent.pcucodeperson,personstudent.pid) not in (SELECT CONCAT(studenthealthnutrition.pcucodeperson,studenthealthnutrition.pid) FROM studenthealthnutrition WHERE  studenthealthnutrition.weight IS NOT NULL $P!{pcucode})
$P!{pcucode}
$P!{persondeath}
)
ORDER BY schoolname,classcode,sex,mumoi,hnomoi]]>
	</queryString>
