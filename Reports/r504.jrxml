	<queryString>
		<![CDATA[SELECT
`cdisease504`.`group504code`,
`cdisease504`.`group504icd10interval`,
`cdisease504`.`group504name`,
`v504_1`.`sumvisit`
FROM
`cdisease504`
Left Join `v504_1` ON `cdisease504`.`group504code` = `v504_1`.`code504`]]>
	</queryString>
