<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="condom_aids"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-02-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-10-28"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-04-27"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),p.fname,'  ',p.lname)USING utf8) as pname,p.birth
,CONVERT(case  when p.hnomoi is null then concat(' หมู่ที่ ',  p.`mumoi` ,' ต.',  tb.`subdistname` )
              when p.mumoi is null then concat(p.`hnomoi`  ,' ต.',  tb.`subdistname` )
              else concat(p.`hnomoi` ,' หมู่ที่ ',  p.`mumoi` ,' ต.',  tb.`subdistname` ) end   USING utf8)  AS address
,DATE_FORMAT(v.visitdate,"%Y-%m-%d") as visitdate
,CONVERT(CONCAT(  DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")< DATE_FORMAT(birth,"00-%m-%d")), " ปี ",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))  
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " เดือน ",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))  
 	 WHEN 0 THEN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") )  
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))  
 	 WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END ,  " วัน " ) USING utf8) AS age_ymd
,v.username,du.unit,du.drugcode,cd.drugname,cd.unitusage,h.hosname,htb.subdistname,hdt.distname,hcw.provname 
from person p left join visit v on v.pid = p.pid and v.pcucodeperson = p.pcucodeperson
	left join ctitle t on p.prename = t.titlecode 
        left join visitdrug du on v.visitno = du.visitno and v.pcucode = du.pcucode           
        left join cdrug cd on cd.drugcode = du.drugcode 
        left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
        left join village on house.villcode = village.villcode and village.pcucode = v.pcucode
         left join csubdistrict tb on tb.provcode = left(village.villcode,2) and tb.distcode = substring(village.villcode,3,2) and tb.subdistcode = substring(village.villcode,5,2)
        left join chospital h on h.hoscode= v.pcucode
        left join csubdistrict htb on htb.subdistcode = h.subdistcode and htb.distcode = h.distcode and htb.provcode = h.provcode
        left join cdistrict hdt on hdt.distcode = h.distcode and hdt.provcode = h.provcode
        left join cprovince hcw on hcw.provcode = h.provcode 
where cd.drugcode='CONDOM' 
      $P!{pcucode} 
      and v.visitdate between $P{sdate} and $P{edate}
      and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
order by v.visitdate]]></queryString>

	<field name="pname" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="address" class="java.lang.String"/>
	<field name="visitdate" class="java.lang.String"/>
	<field name="age_ymd" class="java.lang.String"/>
	<field name="username" class="java.lang.String"/>
	<field name="unit" class="java.lang.Integer"/>
	<field name="drugcode" class="java.lang.String"/>
