		 pageWidth="283"
		 pageHeight="802"
		 columnWidth="283"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="person" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA["'0116052452009-11-06'"]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="p" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[(($P{person}==null || $P{person}.equals("")) ?"''":" AND CONCAT(visitdiag.pcucode,visit.visitno,visit.visitdate) = "+$P{person})]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
cdisease.diseasenamethai,visitdiag.diagcode,cdrug.drugname
FROM
visitdiag
Left Join cdisease ON visitdiag.diagcode = cdisease.diseasecode
Left Join visitdrug ON visitdiag.pcucode = visitdrug.pcucode AND visitdiag.visitno = visitdrug.visitno
Left Join cdrug ON visitdrug.drugcode = cdrug.drugcode
Left Outer Join `visit` ON `visit`.`visitno` = `visitdiag`.`visitno` AND `visitdiag`.`pcucode` = `visit`.`pcucode`
WHERE
(visitdiag.dxtype =  '01' OR visitdiag.dxtype IS NULL) 
AND LEFT(visitdiag.diagcode,3) BETWEEN  'K00' AND 'K14' 
AND cdrug.drugtype =  '08'
$P!{p}
ORDER BY diagcode]]></queryString>

	<field name="diseasenamethai" class="java.lang.String"/>
	<field name="diagcode" class="java.lang.String"/>
	<field name="drugname" class="java.lang.String"/>

