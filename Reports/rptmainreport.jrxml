	<parameter name="SelectDate" isForPrompting="true" class="java.sql.Timestamp">
		<parameterDescription><![CDATA[กำหนดวันที่ดูรายงาน]]></parameterDescription>
		<defaultValueExpression ><![CDATA[new Date() ]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select
case when getAgeYearNum(birth,concat(year('$P!{SelectDate}')-(month('$P!{SelectDate}') <10 ),'-07-01') ) between 15 and 29 then '15-29'
     when getAgeYearNum(birth,concat(year('$P!{SelectDate}')-(month('$P!{SelectDate}') <10 ),'-07-01') ) between 30 and 60 then '30-60'
     when getAgeYearNum(birth,concat(year('$P!{SelectDate}')-(month('$P!{SelectDate}') <10 ),'-07-01') ) > 60 then '60 +'
   else '<15 ' end as agegroup
,count(distinct person.pid,person.pcucodeperson) as cperson
,hosname
from person inner join house ON person.hcode = house.hcode
            and person.pcucodeperson = house.pcucode
  inner join chospital on person.pcucodeperson = chospital.hoscode
where getAgeYearNum(birth,concat(year('$P!{SelectDate}') - (month('$P!{SelectDate}') <10 ),'-07-01') ) >= 15
   and  right(villcode,2) != '00'
  and concat(person.pid,person.pcucodeperson) not in
     (select concat(persondeath.pid, persondeath.pcucodeperson)
      from  persondeath)
  and person.typelive in ('0','1','3')
   $P!{pcucode}
group by agegroup]]></queryString>

	<field name="agegroup" class="java.lang.String"/>
	<field name="cperson" class="java.lang.Long"/>
	<field name="hosname" class="java.lang.String"/>

