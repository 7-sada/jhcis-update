<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="RWomenList"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and  (year(current_date)-year(`person`.`birth`)-(RIGHT(`person`.`birth`,14)>RIGHT(CURRENT_DATE(),5)) ) between 15 and 44"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
concat(`person`.`prename`,`person`.`fname`,' ',`person`.`lname`) as wname,
(year(`person`.`birth`)+543) AS `yearbirth`,
`person`.`hnomoi`,
`cstatus`.`statusname` as marystatus,
if(`women`.`fptype`=1,(`women`.`datesurvey`),null) AS `tab`,
if(`women`.`fptype`=2,(`women`.`datesurvey`),null) AS `inj`,
if(`women`.`fptype`=3,(`women`.`datesurvey`),null) AS `inte`,
if(`women`.`fptype`=4,(`women`.`datesurvey`),null) AS `loop`,
if(`women`.`fptype`=6,(`women`.`datesurvey`),null) AS `fpwomen`,
if(`women`.`fptype`=7,(`women`.`datesurvey`),null) AS `fpmen`,
if(`women`.`fptype`=5,'X','') AS `condom`,
if(`women`.`reasonnofp`=9,'X','') AS `preg`,
if(`women`.`reasonnofp`=1,'X','') AS `wantchild`,
if(`women`.`reasonnofp`=3,'X','') AS `other`,
`women`.`childalive`,
max(`visitancdeliver`.`pregno`),
if(`visitancdeliver`.`deliverresult`='ท',(year(`visitancdeliver`.`datedeliver`)+543),'') AS `abort`,
women.motherpomotion,
if(`visitlabcancer`.`typecancer`=2,(`visit`.`visitdate`),'') AS `papsmear`,`village`.`villname`,person.mumoi
FROM
`person`
Left Outer Join `women` ON `women`.`pid` = `person`.`pid`
Left Outer Join `visitancdeliver` ON `visitancdeliver`.`pid` = `person`.`pid`
Left Outer Join `visit` ON `visit`.`pid` = `person`.`pid`
Left Outer Join `visitlabcancer` ON `visitlabcancer`.`visitno` = `visit`.`visitno`
Left Outer Join `house` ON `person`.`hcode` = `house`.`hcode`
Left Outer Join `village` ON `village`.`villcode` = `house`.`villcode`
Left Outer Join `cstatus` ON `person`.`marystatus` = `cstatus`.`statuscode`
WHERE
`person`.`sex` =  '2'
$P!{ReportDate}

GROUP BY
`person`.`pid`]]></queryString>

