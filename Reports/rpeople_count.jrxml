	<parameter name="offAddress1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="offAddress2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="where_person" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND (person.dischargedate is null OR person.dischargedate > '20090101') AND (person.datein is null OR person.datein <= '20090101')  AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.deaddate <= '20090101') "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="type_live" class="java.lang.String" isForPrompting="false"/>
	<parameter name="note2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="note1" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT 1,substring(house.villcode,1,6) AS subdistcode,getSubdist(substring(house.villcode,1,6)) AS subdistname,village.villname,village.villno,
	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) < 1 THEN 1 ELSE null END) AS m1,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) < 1 THEN 1 ELSE null END) AS w1,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 1 AND 4 THEN 1 ELSE null END) AS m14,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 1 AND 4 THEN 1 ELSE null END) AS w14,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 5 AND 9 THEN 1 ELSE null END) AS m59,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 5 AND 9 THEN 1 ELSE null END) AS w59,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 10 AND 14 THEN 1 ELSE null END) AS m1014,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 10 AND 14 THEN 1 ELSE null END) AS w1014,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 15 AND 19 THEN 1 ELSE null END) AS m1519,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 15 AND 19 THEN 1 ELSE null END) AS w1519,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 20 AND 24 THEN 1 ELSE null END) AS m2024,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 20 AND 24 THEN 1 ELSE null END) AS w2024,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 25 AND 29 THEN 1 ELSE null END) AS m2529,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 25 AND 29 THEN 1 ELSE null END) AS w2529,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 30 AND 34 THEN 1 ELSE null END) AS m3034,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 30 AND 34 THEN 1 ELSE null END) AS w3034,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 35 AND 39 THEN 1 ELSE null END) AS m3539,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 35 AND 39 THEN 1 ELSE null END) AS w3539,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 40 AND 44 THEN 1 ELSE null END) AS m4044,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 40 AND 44 THEN 1 ELSE null END) AS w4044,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 45 AND 49 THEN 1 ELSE null END) AS m4549,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 45 AND 49 THEN 1 ELSE null END) AS w4549,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 50 AND 54 THEN 1 ELSE null END) AS m5054,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 50 AND 54 THEN 1 ELSE null END) AS w5054,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 55 AND 59 THEN 1 ELSE null END) AS m5559,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 55 AND 59 THEN 1 ELSE null END) AS w5559,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 60 AND 64 THEN 1 ELSE null END) AS m6064,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 60 AND 64 THEN 1 ELSE null END) AS w6064,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 65 AND 69 THEN 1 ELSE null END) AS m6569,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 65 AND 69 THEN 1 ELSE null END) AS w6569,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 70 AND 74 THEN 1 ELSE null END) AS m7074,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 70 AND 74 THEN 1 ELSE null END) AS w7074,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 75 AND 79 THEN 1 ELSE null END) AS m7579,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 75 AND 79 THEN 1 ELSE null END) AS w7579,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 80 AND 84 THEN 1 ELSE null END) AS m8084,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) BETWEEN 80 AND 84 THEN 1 ELSE null END) AS w8084,

	SUM(CASE WHEN person.sex='1' AND GetAgeYearNum(person.birth,CURRENT_DATE) >= 85 THEN 1 ELSE null END) AS m85,
	SUM(CASE WHEN person.sex='2' AND GetAgeYearNum(person.birth,CURRENT_DATE) >= 85 THEN 1 ELSE null END) AS w85,

	SUM(CASE WHEN person.sex='1' AND (person.birth = '' OR person.birth is null) THEN 1 ELSE null END) AS mnon,
	SUM(CASE WHEN person.sex='2' AND (person.birth = '' OR person.birth is null) THEN 1 ELSE null END) AS wnon,

	SUM(CASE WHEN person.sex='1' THEN 1 ELSE null END) AS m,
	SUM(CASE WHEN person.sex='2' THEN 1 ELSE null END) AS w,
	SUM(1) AS p
FROM
person
Left Outer Join house ON person.hcode = house.hcode AND house.pcucode = person.pcucodeperson
Left Outer Join village ON house.villcode = village.villcode AND village.pcucode = house.pcucode
Left Outer Join cright ON person.rightcode = cright.rightcode
Left Outer Join persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
WHERE SUBSTRING(house.villcode,7,2)<>'00'
 $P!{pcucode}
 $P!{where_person}
GROUP BY house.villcode]]>
	</queryString>
