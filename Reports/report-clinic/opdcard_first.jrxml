<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="opdcard_first" pageWidth="595" pageHeight="421" orientation="Landscape" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="f52c2e67-d451-4a18-98a9-bd0bfe26cdbe">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Program Files\\jhcis-client\\Reports"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["07084"]]></defaultValueExpression>
	</parameter>
	<parameter name="hn" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["22"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select 	person.pcucodeperson,concat('HN: ',convert(person.pid using utf8)) as pid,
concat('ชื่อผู้ป่วย: ',ifnull(c1.titlename,ifnull(prename,'...')),fname,'   ',lname) as pfl
	,idcard,concat('เลขที่บัตรประชาชน: ',convert(idcard using utf8)) as idcard_lb
	,birth as birth,date_format(`person`.`birth`,'%Y-%m-%d') as bformated
	,curdate() as dprint,date_format(curdate(),'%Y-%m-%d') as dprintformat
	,concat('สถานะสมรส: ',convert(statusname using utf8)) as status
	,concat('เพศ: ',elt(CAST(sex AS UNSIGNED INTEGER),'ชาย','หญิง')) as sex
	,concat('ชื่อบิดา: ',ifnull(father,'...ไม่ระบุ')) as fat
        ,concat('ชื่อมารดา: ',ifnull(mother,'...ไม่ระบุ')) as mot
	,concat('เชื้อชาติ: ',ifnull(nationname,'...')) as origin
	,concat('ศาสนา: ',ifnull(religionname,'...')) as religionname
	,concat('อาชีพ: ',ifnull(occupaname,'...')) as occupaname
,concat('สิทธิ: ',ifnull(rightname,'...'),'เลขบัตรฯ:',ifnull(rightno,'...')) as rig
,ifnull(hosname,'') as hosmain
	,ifnull(messengername,'...ไม่ระบุ') as msgname
	,ifnull(messengeraddr,'...ไม่ระบุ') as msgaddr
	,ifnull(messengertel,'...ไม่ระบุ') as msgtel
	,ifnull(patientrelate,'...ไม่ระบุ') as msgrel
,concat('เลขที่: ',ifnull(hnomoi,'...'),' ถนน: ',ifnull(roadmoi,'...')) as addrsec1
,concat('หมู่ที่.',ifnull(mumoi,'...')) as moimu
,concat('ต.',ifnull(csd.subdistname,'...')) as moitb
,concat('อ.',ifnull(cd.distname,'...')) as moiap
,concat('จ.',ifnull(cw.provname,'...')) as moicw

,concat('เลขที่: ',ifnull(hno,'...'),' ถนน: ',ifnull(personaddresscontact.road,'...')) as addrsec2
,concat('หมู่ที่.',ifnull(personaddresscontact.mu,'...')) as mu
,concat('ต.',ifnull(csd2.subdistname,'...')) as tb
,concat('อ.',ifnull(cd2.distname,'...')) as ap
,concat('จ.',ifnull(cw2.provname,'...')) as cw
	,concat('หมู่โลหิต: ',ifnull(bloodgroup,'ไม่ระบุ')) as bloodg
	,concat(' Blood RH: ',case when (bloodrh='P')then 'Positive(+)'
	      when (bloodrh='N')then 'Negative -'
	      else 'ไม่ระบุ'  end) as rh
,concat('การแพ้ยา-อาหาร: ',ifnull(allergic,'...')) as alg
,concat('โรคประจำตัว: ',ifnull(persondisease,'...')) as pds
,concat('โทร:',ifnull(telephoneperson,'...')) as telephoneperson
from person
left join ctitle c1 on prename = c1.titlecode
     	left outer JOIN `csubdistrict` csubdistricth ON person.subdistcodemoi = csubdistricth.subdistcode and person.distcodemoi = csubdistricth.distcode and person.provcodemoi = csubdistricth.provcode
     	left outer JOIN `cdistrict` cdistricth ON person.distcodemoi = cdistricth.distcode and person.provcodemoi = cdistricth.provcode
     	left outer JOIN `cprovince` cprovinceh ON person.provcodemoi = cprovinceh.provcode
	left outer join cstatus on person.marystatus = cstatus.statuscode

	left outer join cnation on person.origin = cnation.nationcode
	left outer join creligion on person.religion = creligion.religioncode
	left outer join coccupa on person.occupa = coccupa.occupacode

	left outer JOIN `csubdistrict` csd ON csd.subdistcode = person.subdistcodemoi and csd.distcode = person.distcodemoi and csd.provcode = person.provcodemoi
     	left outer JOIN `cdistrict` cd ON cd.distcode = person.distcodemoi and cd.provcode = person.provcodemoi
     	left outer JOIN `cprovince` cw ON cw.provcode = person.provcodemoi

	left outer join personaddresscontact on person.pcucodeperson = personaddresscontact.pcucodeperson and person.pid = personaddresscontact.pid

	left outer JOIN `csubdistrict` csd2 ON csd2.subdistcode = personaddresscontact.subdistcode and csd2.distcode = personaddresscontact.distcode and csd2.provcode = personaddresscontact.provcode
	left outer JOIN `cdistrict` cd2 ON cd2.distcode = personaddresscontact.distcode and cd2.provcode = personaddresscontact.provcode
	left outer JOIN `cprovince` cw2 ON cw2.provcode = personaddresscontact.provcode
        left join cright on person.rightcode = cright.rightcode
        left join chospital on person.hosmain = chospital.hoscode
where
	person.pcucodeperson = '$P!{HCC}'
        and person.pid =  '$P!{hn}']]>
	</queryString>
