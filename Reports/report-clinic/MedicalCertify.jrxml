		<defaultValueExpression><![CDATA["124532"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["00996"]]></defaultValueExpression>
	</parameter>
	<parameter name="H1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="H2" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select
concat(ifnull(`tt1`.titlename,ifnull(person.prename,'..')), ifnull(person.fname,''), '  ', ifnull(person.lname,'')) as fullname,visit.pid pid ,
concat(' อายุ ',getageymd(person.birth,visit.visitdate)) aymd,
concat(ifnull(`tt2`.titlename,ifnull(`user`.prename,'..')), ifnull(`user`.fname,''), '  ', ifnull(`user`.lname,'') ) as docname,
ifnull(`user`.noofoccupation,'...ไม่ระบุฯ') as noofoccupation, visitdoctorcer.doctorexplain as doctorexplain
,visit.visitdate as vdate
,date_format(visit.visitdate,'%Y-%m-%d') as vdate_f
,visitdoctorcer.datestartstop as dateStopStart
,date_format(visitdoctorcer.datestartstop,'%Y-%m-%d') as dateStopStart_f
,visitdoctorcer.daystopwork
,date_add(visitdoctorcer.datestartstop, INTERVAL (visitdoctorcer.daystopwork - 1) day) as dateStopEnd
,date_format(date_add(visitdoctorcer.datestartstop, INTERVAL (visitdoctorcer.daystopwork - 1) day),'%Y-%m-%d') as dateStopEnd_f,
visit.visitno as visitno
from visitdoctorcer
inner join visit on visit.pcucode=visitdoctorcer.pcucode and visit.visitno=visitdoctorcer.visitno
inner join person on person.pcucodeperson=visit.pcucodeperson and person.pid=visit.pid
left join `user` on `user`.username=visit.username
left join `ctitle` tt1 on `person`.`prename` = `tt1`.`titlecode`
left join `ctitle` tt2 on `user`.`prename` = `tt2`.`titlecode`
where visit.pcucode='$P!{HCC}' and visit.visitno=$P!{VN}]]>
	</queryString>
