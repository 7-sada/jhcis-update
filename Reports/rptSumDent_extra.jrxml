<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptSumDent_extra"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="782"
		 pageHeight="555"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="visitdate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="round" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="byear" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT visitdrugdental.pcucode,DATE_FORMAT(visitdate,'%Y-%m') as visitdate
,count(distinct visitdrugdental.visitno,visitdrugdental.pcucode) as cpersondent
,count(concat(visitdrugdental.visitno,visitdrugdental.pcucode) ) as cnumtooth

FROM  visitdrugdental 
	left join visit on   visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
WHERE case when $P{round} != 1 then 
	visit.visitdate between CONCAT($P{byear} ,"-04","-01")  and CONCAT($P{byear},"-09","-30")
 	else visit.visitdate between CONCAT(($P{byear})-1 ,"-10","-01")  and CONCAT($P{byear} ,"-03","-31")   end 
and dentcode in('2372700','2382770')  
and DATE_FORMAT(visitdate,'%Y-%m')  = $P{visitdate}
$P!{pcucode}
GROUP BY visit.pcucode,DATE_FORMAT(visitdate,'%Y-%m')]]></queryString>

	<field name="cpersondent" class="java.lang.Long"/>
	<field name="cnumtooth" class="java.lang.Long"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="25"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="###0" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="25"
						height="25"
						forecolor="#000000"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Dotted" rightBorderColor="#FF0033" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="10" isBold="false" isItalic="false" isUnderline="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H" isStrikeThrough="false" />
					</textElement>
				<textFieldExpression   class="java.lang.Long"><![CDATA[ $F{cpersondent}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="###0" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="25"
						y="0"
						width="25"
						height="25"
						forecolor="#000000"
						key="textField-1"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="10" isBold="false" isItalic="false" isUnderline="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H" isStrikeThrough="false" />
					</textElement>
				<textFieldExpression   class="java.lang.Long"><![CDATA[$F{cnumtooth}]]></textFieldExpression>
				</textField>
			</band>
		</detail>
		<columnFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnFooter>
		<pageFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageFooter>
		<summary>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</summary>
</jasperReport>
