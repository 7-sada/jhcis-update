<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="report_0110_subreport3" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="842" leftMargin="0" rightMargin="0" topMargin="20" bottomMargin="20" uuid="2a7e0b61-606b-4e8a-bcb2-af7e9e48b3b3">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="edate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="startDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2020-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2020-01-15"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["visit.pcucode='01913'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select p.sex,a.*
from(
SELECT  "1" AS idx,
v0110_5_heal_chk_in_mon_st1.pid AS pc,
birth,Ivd,chk_UC,
DATE_FORMAT(Ivd,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(Ivd,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) as age_years,
CAST(IF(DATE_FORMAT(Ivd,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(Ivd,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  < 6 , '1',
IF(DATE_FORMAT(Ivd,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(Ivd,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  between 6 and 14 , '2',
IF(DATE_FORMAT(Ivd,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(Ivd,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  > 14 , '3', '0')))  AS BINARY) as ay
, 0.0 as weight

FROM person INNER JOIN v0110_5_heal_chk_in_mon_st1 ON person.pid = v0110_5_heal_chk_in_mon_st1.pid

UNION

SELECT
"2","",visitepi.visitno,visit.incup AS arg,Left(vaccinecode,3) AS vc3,
###IF( Left(visit.rightcode,1)='7'  OR Left(visit.rightcode,1)='8'  OR ###visit.rightcode = '00' OR visit.rightcode='02' OR visit.rightcode='03',
       CASE
	when Left(visit.rightcode,1) IN('7','8','9') then 'u'
	### when Left(visit.rightcode,1)='8'  then 'u'
	### when visit.rightcode='00'  then 'a'
           when cr.rightgroup='1'  then 'a'
	### when visit.rightcode='02' OR  visit.rightcode='03'  then 'b'
           when cr.rightgroup='2'  then 'b' ELSE 'n'
       END
       ###,'n')
       AS chk_UC
,0,0.0
FROM
(person
Inner Join visit ON person.pid = visit.pid AND visit.pcucode = person.pcucodeperson)
Inner Join visitepi ON visit.visitno = visitepi.visitno AND visit.pcucode = visitepi.pcucodeperson
LEFT JOIN cright cr on visit.rightcode=cr.rightcode
WHERE
DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) < 6
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))

UNION

SELECT  "5", "","","",
IF( LEFT(visit.rightcode,1) IN('7','8') ,
CASE incup WHEN '1' THEN '3' WHEN '2' THEN '4' ELSE '3' END,
	IF(visit.rightcode IN('00','02','03') , ELT(FIELD(visit.rightcode,'00','02','03'),'1','2','2') , '5')) AS rgroup,
	"", Count(1), 0.0

FROM (person INNER JOIN visit ON person.pid = visit.pid  AND person.pcucodeperson = visit.pcucode)
INNER JOIN visitepi ON visit.visitno = visitepi.visitno  AND visit.pcucode = visitepi.pcucodeperson
WHERE
(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) BETWEEN  5  AND 15)
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND (visitepi.vaccinecode like 'MMR%' OR  visitepi.vaccinecode='MEAS')
GROUP BY
	IF( LEFT(visit.rightcode,1) IN('7','8') ,
	CASE incup WHEN '1' THEN '3' WHEN '2' THEN '4' ELSE '3' END,
		IF(visit.rightcode IN('00','02','03') , ELT(FIELD(visit.rightcode,'00','02','03'),'1','2','2') , '5'))

UNION

SELECT
"6",
v0110_5_bmi_in_mon_y0_5.agemonth,visit.visitno,
v0110_5_bmi_in_mon_y0_5.rgroup,
"", "",
v0110_5_bmi_in_mon_y0_5.sex,
visit.weight
FROM
v0110_5_bmi_in_mon_y0_5
Inner Join visit ON v0110_5_bmi_in_mon_y0_5.maxVisitdate = visit.visitdate AND v0110_5_bmi_in_mon_y0_5.pid = visit.pid
Inner Join v0110_last_visit_in_mon_st2 ON visit.visitno = v0110_last_visit_in_mon_st2.maxVn
Left Join v0110_5_bmi_18_bf_lo ON v0110_5_bmi_18_bf_lo.pid = v0110_5_bmi_in_mon_y0_5.pid
WHERE
`visit`.`weight` > 0
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_18_bf_lo.pid is NULL

UNION

SELECT  "7", `v0110_5_bmi_in_mon_y6_14`.`agemonth`,
`v0110_5_bmi_in_mon_y6_14`.`pid`,
`v0110_5_bmi_in_mon_y6_14`.`rgroup`,"",
"", `v0110_5_bmi_in_mon_y6_14`.`sex` , `visit`.`weight`
FROM
`v0110_5_bmi_in_mon_y6_14`
Inner Join `visit` ON `v0110_5_bmi_in_mon_y6_14`.`maxVisitdate` = `visit`.`visitdate` AND `v0110_5_bmi_in_mon_y6_14`.`pid` = `visit`.`pid`
Inner Join `v0110_last_visit_in_mon_st2` ON `visit`.`visitno` = `v0110_last_visit_in_mon_st2`.`maxVn`
Left Join v0110_5_bmi_18_bf_ov ON v0110_5_bmi_18_bf_ov.pid = v0110_5_bmi_in_mon_y6_14.pid
WHERE
`visit`.`weight` > 0
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_18_bf_ov.pid  IS NULL
UNION

SELECT
"8",
v0110_5_bmi_in_mon_y1518.agemonth,visit.visitno,
v0110_5_bmi_in_mon_y1518.rgroup,
"", "",
v0110_5_bmi_in_mon_y1518.sex,
visit.weight
FROM
v0110_5_bmi_in_mon_y1518
Inner Join visit ON v0110_5_bmi_in_mon_y1518.maxVisitdate = visit.visitdate AND v0110_5_bmi_in_mon_y1518.pid = visit.pid
Inner Join v0110_last_visit_in_mon_st2 ON visit.visitno = v0110_last_visit_in_mon_st2.maxVn
Left Join v0110_5_bmi_18_bf_lo ON v0110_5_bmi_18_bf_lo.pid = v0110_5_bmi_in_mon_y1518.pid
WHERE
visit.weight > 0
AND visit.weight/((visit.height/100)*(visit.height/100))<18.5
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_18_bf_lo.pid is NULL

UNION

SELECT
"9",
v0110_5_bmi_in_mon_y19.agemonth,visit.visitno,
v0110_5_bmi_in_mon_y19.rgroup,
"", "",
v0110_5_bmi_in_mon_y19.sex,
visit.weight
FROM
v0110_5_bmi_in_mon_y19
Inner Join visit ON v0110_5_bmi_in_mon_y19.maxVisitdate = visit.visitdate AND v0110_5_bmi_in_mon_y19.pid = visit.pid
Inner Join v0110_last_visit_in_mon_st2 ON visit.visitno = v0110_last_visit_in_mon_st2.maxVn AND visit.pid = v0110_last_visit_in_mon_st2.pid
Left Join v0110_5_bmi_19_bf_lo ON v0110_5_bmi_19_bf_lo.pid = v0110_5_bmi_in_mon_y19.pid
WHERE
visit.weight > 0
AND visit.weight/((visit.height/100)*(visit.height/100))<18.5
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_19_bf_lo.pid is NULL

UNION

SELECT  "10", `v0110_5_bmi_in_mon_y19`.`agemonth`,
`v0110_5_bmi_in_mon_y19`.`pid`,
`v0110_5_bmi_in_mon_y19`.`rgroup`,"",
"", `v0110_5_bmi_in_mon_y19`.`sex` , `visit`.`weight`
FROM
`v0110_5_bmi_in_mon_y19`
Inner Join `visit` ON `v0110_5_bmi_in_mon_y19`.`maxVisitdate` = `visit`.`visitdate` AND `v0110_5_bmi_in_mon_y19`.`pid` = `visit`.`pid`
Inner Join `v0110_last_visit_in_mon_st2` ON `visit`.`visitno` = `v0110_last_visit_in_mon_st2`.`maxVn` AND visit.pid = v0110_last_visit_in_mon_st2.pid
Left Join v0110_5_bmi_19_bf_ov ON v0110_5_bmi_19_bf_ov.pid = v0110_5_bmi_in_mon_y19.pid
WHERE
`visit`.`weight` > 0
AND `visit`.`height` > 0
AND `visit`.`weight`/((`visit`.`height`/100)*(`visit`.`height`/100))>=25
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_19_bf_ov.pid is NULL
UNION

SELECT
"11",
v0110_5_bmi_in_mon_y0_5.agemonth,visit.visitno,
v0110_5_bmi_in_mon_y0_5.rgroup,
"", "",
v0110_5_bmi_in_mon_y0_5.sex,
visit.weight
FROM
v0110_5_bmi_in_mon_y0_5
Inner Join visit ON v0110_5_bmi_in_mon_y0_5.maxVisitdate = visit.visitdate AND v0110_5_bmi_in_mon_y0_5.pid = visit.pid
Inner Join v0110_last_visit_in_mon_st2 ON visit.visitno = v0110_last_visit_in_mon_st2.maxVn
Left Join v0110_5_bmi_18_bf_ov ON v0110_5_bmi_18_bf_ov.pid = v0110_5_bmi_in_mon_y0_5.pid
WHERE
visit.weight > 0
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_18_bf_ov.pid is NULL

UNION

SELECT  "12", v0110_5_bmi_in_mon_y1518.agemonth,
v0110_5_bmi_in_mon_y1518.pid,
v0110_5_bmi_in_mon_y1518.rgroup,"",
"", v0110_5_bmi_in_mon_y1518.sex , visit.weight
FROM
v0110_5_bmi_in_mon_y1518
Inner Join visit ON v0110_5_bmi_in_mon_y1518.maxVisitdate = visit.visitdate AND v0110_5_bmi_in_mon_y1518.pid = visit.pid
Inner Join v0110_last_visit_in_mon_st2 ON visit.visitno = v0110_last_visit_in_mon_st2.maxVn
Left Join v0110_5_bmi_18_bf_ov ON v0110_5_bmi_18_bf_ov.pid = v0110_5_bmi_in_mon_y1518.pid
WHERE
visit.weight > 0
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_18_bf_ov.pid is NULL

UNION
SELECT  "13", `v0110_5_bmi_in_mon_y6_14`.`agemonth`,
`v0110_5_bmi_in_mon_y6_14`.`pid`,
`v0110_5_bmi_in_mon_y6_14`.`rgroup`,"",
"", `v0110_5_bmi_in_mon_y6_14`.`sex` , `visit`.`weight`
FROM
v0110_5_bmi_in_mon_y6_14
Inner Join visit ON v0110_5_bmi_in_mon_y6_14.maxVisitdate = visit.visitdate AND v0110_5_bmi_in_mon_y6_14.pid = visit.pid
Inner Join v0110_last_visit_in_mon_st2 ON visit.visitno = v0110_last_visit_in_mon_st2.maxVn
Left Join v0110_5_bmi_18_bf_lo ON v0110_5_bmi_18_bf_lo.pid = v0110_5_bmi_in_mon_y6_14.pid
WHERE
`visit`.`weight` > 0
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND v0110_5_bmi_18_bf_lo.pid  IS NULL

UNION
SELECT  "14_1",
visit.visitno,
person.birth,
visit.incup as ivd,
IF( LEFT(visit.rightcode,1) IN('7','8') ,
CASE incup
WHEN '1' THEN 'u1'
WHEN '2' THEN 'u0' ELSE 'u1' END,
IF(visit.rightcode IN('00','02','03') , ELT(FIELD(visit.rightcode,'00','02','03'),'a','b','b') , 'n')) AS chk_UC,
DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) as age_years,
CAST(IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  < 6 , '1',
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  between 6 and 14 , '2',
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  > 14 , '3', '0'))) AS BINARY) as ay ,
0.0 as weight
FROM
cdrug
Inner Join visitdrug ON cdrug.drugcode = visitdrug.drugcode
Inner Join visit ON visitdrug.pcucode = visit.pcucode AND visitdrug.visitno = visit.visitno
Inner Join person ON visit.pcucodeperson = person.pcucodeperson AND visit.pid = person.pid
WHERE 1=1
AND DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) < 15
AND cdrug.drugtype =  '02' AND cdrug.drugtypesub =  '1'
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}

UNION
SELECT  "14_2",
visit.visitno,
person.birth,
visit.incup as ivd,
IF( LEFT(visit.rightcode,1) IN('7','8') ,
CASE incup
WHEN '1' THEN 'u1'
WHEN '2' THEN 'u0' ELSE 'u1' END,
IF(visit.rightcode IN('00','02','03') , ELT(FIELD(visit.rightcode,'00','02','03'),'a','b','b') , 'n')) AS chk_UC,
DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) as age_years,
CAST(IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  < 6 , '1',
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  between 6 and 14 , '2',
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  > 14 , '3', '0'))) AS BINARY) as ay ,
0.0 as weight
FROM
visitdentalcheck
Inner Join visit ON visitdentalcheck.pcucode = visit.pcucode AND visitdentalcheck.visitno = visit.visitno
Inner Join person ON visit.pcucodeperson = person.pcucodeperson AND visit.pid = person.pid
WHERE 1=1
AND DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) < 15
AND ((visit.flagservice<='03') OR (visit.flagservice IS NULL))
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
) As a
LEFT join person p on p.pid=a.pc
where idx not in('14_2') #p.sex is not null
]]>
	</queryString>
	<field name="sex" class="java.lang.String"/>
	<field name="idx" class="java.lang.String"/>
	<field name="pc" class="java.lang.Integer"/>
	<field name="birth" class="java.lang.String"/>
	<field name="Ivd" class="java.lang.String"/>
	<field name="chk_UC" class="java.lang.String"/>
	<field name="age_years" class="java.lang.String"/>
	<field name="ay" class="java.lang.Integer"/>
	<field name="weight" class="java.math.BigDecimal"/>
	<variable name="va3" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "a" )  && $F{ay}.equals( "3" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="va1" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "a" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="va2" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "a" )  && $F{ay}.equals( "2" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vb1" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "b" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu11" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u1" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu01" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u0" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vn1" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "n" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="v1total" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[new java.lang.Integer(
($V{va1}.intValue()) +
($V{vb1}.intValue()) +
($V{vu11}.intValue()) +
($V{vu01}.intValue())+
($V{vn1}.intValue()) )]]></variableExpression>
	</variable>
	<variable name="vb2" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "b" )  && $F{ay}.equals( "2" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu12" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u1" )  && $F{ay}.equals( "2" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu02" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u0" )  && $F{ay}.equals( "2" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vn2_temp" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "n" )  && $F{ay}.equals( "2" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="v2total" class="java.lang.Integer">
		<variableExpression><![CDATA[new java.lang.Integer(
($V{va2}.intValue()) +
($V{vb2}.intValue()) +
($V{vu12}.intValue()) +
($V{vu02}.intValue())+
($V{vn2_temp}.intValue()) )]]></variableExpression>
	</variable>
	<variable name="vb3" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "b" )  && $F{ay}.equals( "3" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu13" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u1" )  && $F{ay}.equals( "3" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu03" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u0" )  && $F{ay}.equals( "3" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vn3" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "n" )  && $F{ay}.equals( "3" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="v3total" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[new java.lang.Integer(
($V{va3}.intValue()) +
($V{vb3}.intValue()) +
($V{vu13}.intValue()) +
($V{vu03}.intValue())+
($V{vn3}.intValue()) )]]></variableExpression>
	</variable>
	<variable name="dtp_a" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "2" ) && $F{chk_UC}.equals( "DTP" ) && $F{age_years}.equals( "a" ) ?
new Integer(1) : new Integer(0) )]]></variableExpression>
