<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rhealthvolun_list"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND persontype.pcucodeperson =  '01032' "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["รายชื่อ อสม."]]></defaultValueExpression>
	</parameter>
	<parameter name="where_ptype" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND house.pidvola IS  NOT NULL  "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as pname,
person.lname,
getAgeYearNum(person.birth,current_date) age,
person.rightno,
person.hnomoi,
DATE_FORMAT(persontype.dateelect,'%Y-%m-%d') AS dateelect,
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8),' ต.',getSubdist(LEFT(village.villcode,6))) AS village
FROM
persontype
Left Join person ON persontype.pcucodeperson = person.pcucodeperson AND persontype.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Left Join house ho ON person.pcucodeperson = ho.pcucode AND person.hcode = ho.hcode
Left Join village ON ho.pcucode = village.pcucode AND ho.villcode = village.villcode
Left  Join house ON house.pidvola = persontype.pid AND house.pcucodepersonvola = persontype.pcucodeperson
WHERE
persontype.typecode =  '09' 
$P!{where_ptype}
$P!{pcucode}
GROUP BY
persontype.pid
ORDER BY
village.villcode ASC,
person.hnomoi ASC]]></queryString>

