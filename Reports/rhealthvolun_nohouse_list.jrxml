	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND house.pcucode =  '04914' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
house.hno,CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8),' ต.',getSubdist(LEFT(village.villcode,6))) AS villname
FROM
house
Inner Join village ON house.pcucode = village.pcucode AND house.villcode = village.villcode
WHERE
house.pidvola IS NULL AND right(house.villcode,2) <> '00' AND house.hno IS NOT NULL 
$P!{pcucode}
GROUP BY house.hcode
ORDER BY
village.villcode ASC,
house.hno ASC]]></queryString>

	<field name="hno" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>


