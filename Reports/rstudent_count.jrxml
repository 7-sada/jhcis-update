	<parameter name="where" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["WHERE personstudent.pcucode='01856' AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath) "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT 1,
if(villageschool.schoolname is null,'ไม่ระบุฯ',villageschool.schoolname) schoolname,
Sum(if((personstudent.classeducate = 1 AND person.sex='1'),1,null )) AS  'a1m',
Sum(if((personstudent.classeducate = 1 AND person.sex='2'),1,null )) AS  'a1f',
Sum(if((personstudent.classeducate = 2 AND person.sex='1'),1,null )) AS  'a2m',
Sum(if((personstudent.classeducate = 2 AND person.sex='2'),1,null )) AS  'a2f',
Sum(if((personstudent.classeducate = 3 AND person.sex='1'),1,null )) AS  'a3m',
Sum(if((personstudent.classeducate = 3 AND person.sex='2'),1,null )) AS  'a3f',
Sum(if((personstudent.classeducate = 4 AND person.sex='1'),1,null )) AS  'p1m',
Sum(if((personstudent.classeducate = 4 AND person.sex='2'),1,null )) AS  'p1f',
Sum(if((personstudent.classeducate = 5 AND person.sex='1'),1,null )) AS  'p2m',
Sum(if((personstudent.classeducate = 5 AND person.sex='2'),1,null )) AS  'p2f',
Sum(if((personstudent.classeducate = 6 AND person.sex='1'),1,null )) AS  'p3m',
Sum(if((personstudent.classeducate = 6 AND person.sex='2'),1,null )) AS  'p3f',
Sum(if((personstudent.classeducate = 7 AND person.sex='1'),1,null )) AS  'p4m',
Sum(if((personstudent.classeducate = 7 AND person.sex='2'),1,null )) AS  'p4f',
Sum(if((personstudent.classeducate = 8 AND person.sex='1'),1,null )) AS  'p5m',
Sum(if((personstudent.classeducate = 8 AND person.sex='2'),1,null )) AS  'p5f',
Sum(if((personstudent.classeducate = 9 AND person.sex='1'),1,null )) AS  'p6m',
Sum(if((personstudent.classeducate = 9 AND person.sex='2'),1,null )) AS  'p6f',
Sum(if((personstudent.classeducate = 10 AND person.sex='1'),1,null )) AS  'm1m',
Sum(if((personstudent.classeducate = 10 AND person.sex='2'),1,null )) AS  'm1f',
Sum(if((personstudent.classeducate = 11 AND person.sex='1'),1,null )) AS  'm2m',
Sum(if((personstudent.classeducate = 11 AND person.sex='2'),1,null )) AS  'm2f',
Sum(if((personstudent.classeducate = 12 AND person.sex='1'),1,null )) AS  'm3m',
Sum(if((personstudent.classeducate = 12 AND person.sex='2'),1,null )) AS  'm3f'
FROM
personstudent
Inner Join person ON person.pcucodeperson = personstudent.pcucodeperson AND person.pid = personstudent.pid
Inner Join villageschool ON personstudent.pcucode = villageschool.pcucode AND personstudent.villcode = villageschool.villcode AND personstudent.schoolno = villageschool.schoolno
Inner Join cschoolclass ON personstudent.classeducate = cschoolclass.classcode
$P!{where}
GROUP BY villageschool.schoolname
ORDER BY
villageschool.villcode ASC,
cschoolclass.classcode ASC]]>
	</queryString>
