<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ncd_sugarblood"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-26"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-12-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["40"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 1, ifnull(titlename,ifnull(prename,'ไม่ระบุ') )  prename,p.fname,p.lname,p.hnomoi
,CONVERT(if(village.villno=0,"นอกเขต"  ,village.villno)using utf8) villno
,p.birth as br,DATE_FORMAT(p.birth,"%Y-%m-%d") as birth

,Max(DATE_FORMAT(v.visitdate,"%Y-%m-%d")) as visitdate
,CONVERT(CONCAT(DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " - ",
	CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " - ",
	CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN( DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))
	  WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_visit
,case when (vb.foodsuspend='0') then 'งด'
      when (vb.foodsuspend='1') then 'ไม่งด'
         else '-'  end as t1
,vb.sugarnumdigit
,if(vb.sugarnumdigit  ='0' ,"รอผล LAB",case when (vb.foodsuspend='0' and vb.sugarnumdigit <= office.foodnofsbn) then "ปกติ" 
      when (vb.foodsuspend='0' and (vb.sugarnumdigit between office.foodnofsbn and  office.foodnofsbr )) then "เสี่ยง"
      when (vb.foodsuspend='0' and vb.sugarnumdigit >= office.foodnofsbr) then "สูง"
      when (vb.foodsuspend='1' and vb.sugarnumdigit <= office.foodsbn) then "ปกติ" 
      when (vb.foodsuspend='1' and (vb.sugarnumdigit between office.foodsbn and  office.foodsbr )) then "เสี่ยง"
      when (vb.foodsuspend='1' and vb.sugarnumdigit >= office.foodsbr) then "สูง"
     else "" end )  as rb
,cr.rightname,p.rightno,p.idcard
,h.hosname,tb.subdistname,hdt.distname,hcw.provname 

FROM   visitlabsugarblood vb
     left join  visit v on vb.visitno = v.visitno and vb.pcucode = v.pcucode
     left join person p on p.pid = v.pid and p.pcucodeperson = v.pcucodeperson
     left join ctitle on p.prename = ctitle.titlecode
     left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
     left join village on house.villcode = village.villcode and village.pcucode = house.pcucode
     left join cright cr on v.rightcode = cr.rightcode
     left join visitdiag on v.visitno = visitdiag.visitno and v.pcucode = visitdiag.pcucode
    
     left join chospital h on h.hoscode = v.pcucode
     left join csubdistrict tb on h.subdistcode = tb.subdistcode and h.distcode = tb.distcode and h.provcode = tb.provcode
     left join cdistrict hdt on hdt.distcode = h.distcode and hdt.provcode = h.provcode
     left join cprovince hcw on hcw.provcode = h.provcode
     left join office on office.offid = v.pcucode
WHERE v.visitdate between $P{sdate} and $P{edate} 
	and (birth IS NOT NULL OR birth NOT LIKE '0000%')
      and visitdiag.diagcode not in ('E10' , 'E11' , 'E12' ,'E13' , 'E14' , 'E148' ,'200')
      and DATEDIFF(concat(YEAR($P{pdate}),'-','07','-','01'),p.birth)/365 >= $P{age}
      and visitdate in (select Max(visitdate) from visit vv where vv.pid = v.pid and vv.pcucodeperson = v.pcucodeperson and vv.visitdate between $P{sdate} and $P{edate}  group by vv.pid,vv.pcucodeperson)
      $P!{pcucode} 
      and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
group by v.pid,v.pcucodeperson
order by v.pcucode,village.villno,v.visitdate]]></queryString>

