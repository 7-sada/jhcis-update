					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[หมายเหตุ : 1. อายุนับจากปีเกิดถึง 1 กรกฏาคม ของปีนั้น ๆ (กลางปี) 35 ปีขึ้นไป 2. ไม่นับผู้ป่วยที่ป่วยเป็นโรคเบาหวาน (ที่วินิจฉัยด้วยรหัสโรค E10, E11, E12, E13, E14, E148 200) ]]></text>
				</staticText>
