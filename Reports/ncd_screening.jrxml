	</parameter>
	<parameter name="p_sqlOffice" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND ncd_person_ncd_screen.pcucode ='05833' "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["D:\\JHCIS\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     sum(CASE WHEN b.sex='1'  THEN 1 ELSE 0 END) AS screen_m,
FORMAT(IF(sum(1)=0,0,sum(CASE WHEN b.sex='1'  THEN 1 ELSE 0 END)*100/sum(1)),1) pc_m,
     sum(CASE WHEN b.sex='2' THEN 1 ELSE 0 END) AS screen_w,
FORMAT(IF(sum(1)=0,0,sum(CASE WHEN b.sex='2'  THEN 1 ELSE 0 END)*100/sum(1)),1) pc_w,
     sum(1) AS screen_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='1'  THEN 1 ELSE 0 END) AS dm1_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='1' THEN 1 ELSE 0 END) AS dm1_w ,
     sum(CASE WHEN c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='1' THEN 1 ELSE 0 END) AS dm1_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='2'  THEN 1 ELSE 0 END) AS dm2_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='2' THEN 1 ELSE 0 END) AS dm2_w ,
     sum(CASE WHEN c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='2' THEN 1 ELSE 0 END) AS dm2_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='3'  THEN 1 ELSE 0 END) AS dm3_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='3' THEN 1 ELSE 0 END) AS dm3_w ,
     sum(CASE WHEN c.chronic_flag='0' and ncd_person_ncd_screen.result_new_dm='3' THEN 1 ELSE 0 END) AS dm3_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.dm_flag='1'  THEN 1 ELSE 0 END) AS dm_old_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.dm_flag='1'  THEN 1 ELSE 0 END) AS dm_old_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.dm_flag='1'  THEN 1 ELSE 0 END) AS dm_old_total,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='1'  THEN 1 ELSE 0 END) AS dm_comp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS dm_comp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS dm_comp_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='0'  THEN 1 ELSE 0 END) AS dm_nocomp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS dm_nocomp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS dm_nocomp_total ,

     sum(CASE WHEN b.sex='1'  THEN 1 ELSE 0 END) AS screenHT_m,
     sum(CASE WHEN b.sex='2' THEN 1 ELSE 0 END) AS screenHT_w,
     sum(1) AS screenHT_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='1'  THEN 1 ELSE 0 END) AS ht1_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='1' THEN 1 ELSE 0 END) AS ht1_w ,
     sum(CASE WHEN c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='1' THEN 1 ELSE 0 END) AS ht1_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='2'  THEN 1 ELSE 0 END) AS ht2_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='2' THEN 1 ELSE 0 END) AS ht2_w ,
     sum(CASE WHEN c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='2' THEN 1 ELSE 0 END) AS ht2_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='3'  THEN 1 ELSE 0 END) AS ht3_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='3' THEN 1 ELSE 0 END) AS ht3_w ,
     sum(CASE WHEN c.chronic_flag='0' and ncd_person_ncd_screen.result_new_hbp='3' THEN 1 ELSE 0 END) AS ht3_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.hbp_flag='1'  THEN 1 ELSE 0 END) AS ht_old_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.hbp_flag='1'  THEN 1 ELSE 0 END) AS ht_old_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.hbp_flag='1'  THEN 1 ELSE 0 END) AS ht_old_total,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.hbp_flag='1' and d.has_symptom='1'  THEN 1 ELSE 0 END) AS ht_comp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.hbp_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS ht_comp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.hbp_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS ht_comp_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.hbp_flag='1' and d.has_symptom='0'  THEN 1 ELSE 0 END) AS ht_nocomp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.hbp_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS ht_nocomp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.hbp_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS ht_nocomp_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.hbp_flag='1' and d.dm_flag='1' and d.has_symptom='1'  THEN 1 ELSE 0 END) AS dmht_comp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.hbp_flag='1' and d.dm_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS dmht_comp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.hbp_flag='1' and d.dm_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS dmht_comp_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.hbp_flag='1' and d.dm_flag='1'  and d.has_symptom='0'  THEN 1 ELSE 0 END) AS dmht_nocomp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.hbp_flag='1' and d.dm_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS dmht_nocomp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.hbp_flag='1' and d.dm_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS dmht_nocomp_total ,

     sum(CASE WHEN b.sex='1' and ncd_person_ncd_screen.waist >0  THEN 1 ELSE 0 END) AS waist_m,
     sum(CASE WHEN b.sex='2' and ncd_person_ncd_screen.waist >0 THEN 1 ELSE 0 END) AS waist_w ,
     sum(CASE WHEN  ncd_person_ncd_screen.waist >0 THEN 1 ELSE 0 END) AS waist_total ,

     sum(CASE WHEN b.sex='1' and ncd_person_ncd_screen.waist >89  THEN 1 ELSE 0 END) AS overwaist_m,
     sum(CASE WHEN b.sex='2' and ncd_person_ncd_screen.waist >79 THEN 1 ELSE 0 END) AS overwaist_w ,
     sum(CASE WHEN  (b.sex='1' and ncd_person_ncd_screen.waist >89 ) or (b.sex='2' and ncd_person_ncd_screen.waist >79) THEN 1 ELSE 0 END) AS overwaist_total ,

     sum(CASE WHEN b.sex='1' and ncd_person_ncd_screen.bmi >24  THEN 1 ELSE 0 END) AS bmi_m,
     sum(CASE WHEN b.sex='2' and ncd_person_ncd_screen.bmi >24 THEN 1 ELSE 0 END) AS bmi_w ,
     sum(CASE WHEN  ncd_person_ncd_screen.bmi >24 THEN 1 ELSE 0 END) AS bmi_total

FROM
     `ncd_person_ncd_screen` ncd_person_ncd_screen
     INNER JOIN `ncd_person` b ON ncd_person_ncd_screen.`pcucode` = b.`pcucode` AND ncd_person_ncd_screen.`pid` = b.`pid`
     INNER JOIN `ncd_person_ncd` c ON ncd_person_ncd_screen.`pcucode` = c.`pcucode` AND ncd_person_ncd_screen.`pid` = c.`pid`
     LEFT OUTER JOIN `ncd_person_ncd_hist` d ON ncd_person_ncd_screen.`pcucode` = d.`pcucode` AND ncd_person_ncd_screen.`pid` = d.`pid`
WHERE 1=1 $P!{p_sqlOffice} $P!{p_sqlDate}]]>
	</queryString>
