<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptPersonGrowSurvey"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="round" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(1)]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-05-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="budgetyear" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT ifnull(titlename,ifnull(prename,'ไม่ระบุ') ) prename,fname,lname
,person.pid,person.idcard
,CONVERT(case when ((birth is not null OR birth not like '0000-00-00' or birth !='' ) AND  (datesurvey is not null OR datesurvey not like '0000-00-00' or datesurvey !=''))    
          then  (getagemonth(birth,datesurvey) )     
         else  " ไม่มีวันเกิด / วันสำรวจ "   end using utf8) as agemonth
,DATE_FORMAT(datesurvey,'%Y-%m-%d') as datesurvey
,chospital.hoscode pcucode, chospital.hosname
,growname,persongrow.growcode,growstd
,if(agemonthcan !='',agemonthcan,"NoData" ) as agemonthcan
,if(agemonthcan !='' , if(growstd >= agemonthcan,"พัฒนาการดี","พัฒนาการ... ผิดปกติ" ),"-" ) as grow  
,DATE_FORMAT(curdate(),'%Y-%m-%d') currentDate
,curdate() cdate
,$P{budgetyear}+543 as cyear
,($P{budgetyear}+543)-1 as byear
FROM persongrow left join person ON persongrow.pid = person.pid and persongrow.pcucodeperson = person.pcucodeperson
	left join ctitle ON person.prename = ctitle.titlecode
	left join cgrow ON persongrow.growcode = cgrow.growcode
	left join chospital ON persongrow.pcucodeperson = chospital.hoscode
WHERE getagemonth(birth,curdate())  <=72
     and
     case when $P{round}= 1 then
        persongrow.datesurvey between CONCAT(($P{budgetyear})-1 ,"-10","-01")  and CONCAT( $P{budgetyear} ,"-03","-31") 
     else
        persongrow.datesurvey between CONCAT( $P{budgetyear} ,"-04","-01")  and CONCAT( $P{budgetyear},"-09","-30") 
     end
      $P!{pcucode}
ORDER BY datesurvey]]></queryString>

	<field name="prename" class="java.lang.String"/>
	<field name="fname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="agemonth" class="java.lang.String"/>
	<field name="datesurvey" class="java.util.Date"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="growname" class="java.lang.String"/>
