	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[select p.pid,fname,lname, villcode
,p.birth
,DATE_FORMAT(zero2null(p.`birth`),'%Y-%m-%d') AS birthvalue
from person p join house h on p.pcucodeperson=h.pcucode and p.hcode=h.hcode where p.birth < '1925-01-01' and right(villcode,2)<>'00']]>
	</queryString>
	<field name="pid" class="java.lang.Integer">
