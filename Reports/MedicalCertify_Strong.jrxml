	<parameter name="VN" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[$P{VN}]]></parameterDescription>
		<defaultValueExpression><![CDATA["14261"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false"/>
	<parameter name="oid" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Program Files\\jhcis-client\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="_cup" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
CONCAT('สถานที่ตรวจ ',cp.hosname,' ')as hos,cp.hosname,
concat('ข้าพเจ้า ',ifnull(tt1.`titlenamelong`,'...'),ifnull(`user`.`fname`,`user`.`fullName`),'   ',ifnull(`user`.`lname`,'...')) as fullName,
concat('ได้ตรวจร่างกาย ',ifnull(tt2.titlename,ifnull(`person`.`prename`,'..')),ifnull(`person`.`fname`,''),'   ',ifnull(`person`.`lname`,''),' HN: ',convert(visit.pid using utf8),' อายุ ' ,getageymd(person.birth,visit.visitdate)) as fpt,
concat(tt1.`titlename`,`user`.`fname`,'  ',`user`.`lname`) as doctorName,
concat('ใบอนุญาตประกอบวิชาชีพเวชกรรมเลขที่ ',ifnull(`user`.`noofoccupation`,'ไม่ระบุเลขที่ใบประกอบวิชาชีพ')) as noofoccupation,
concat('สถานที่ประกอบวิชาชีพเวชกรรม ',ifnull(`user`.`workoffice`,'...')) as workoffice,
concat('ข้าพเจ้า  ',ifnull(tt2.titlenamelong,ifnull(`person`.`prename`,'..')),ifnull(`person`.`fname`,''),'   ',ifnull(`person`.`lname`,''),' HN: ',convert(visit.pid using utf8),' อายุ ' ,getageymd(person.birth,visit.visitdate)) as pfl,
concat('สถานที่อยู่ (ที่สามารถติดต่อได้)  ',ifnull(pc.`hno`,'-'),' ม.',ifnull(convert(pc.`mu` using utf8),'-'),' ต.',ifnull(csd.`subdistname`,'-'),
                            ' อ.',ifnull(cd.`distname`,'-'),              ' จ.',ifnull(cw.`provname`,'-')) AS addr,
`person`.`idcard` as idcard,
concat('วันที่  ',day(visit.visitdate),'  เดือน  ',convert(case MONTH(visit.visitdate) WHEN 1 THEN 'มกราคม'
WHEN 2 THEN 'กุมภาพันธ์' WHEN 3 THEN 'มีนาคม' WHEN 4 THEN 'เมษายน'
WHEN 5 THEN 'พฤษภาคม' WHEN 6 THEN 'มิถุนายน' WHEN 7 THEN 'กรกฎาคม' WHEN 8 THEN 'สิงหาคม' WHEN 9 THEN 'กันยายน'  WHEN 10 THEN 'ตุลาคม'
WHEN 11 THEN 'พฤศจิกายน' WHEN 12 THEN 'ธันวาคม' ELSE 'xx' END USING utf8),'  พ.ศ. ',IF(visit.visitdate IS null OR TRIM(visit.visitdate)='','',YEAR(visit.visitdate)+543)) vd,
visit.weight,visit.height,visit.pressure,visit.pulse,
`visit`.`rightno`
FROM
`visit`
Left Outer Join `user` ON `user`.`username` = `visit`.`username`
Left Outer Join `person` ON `person`.`pid` = `visit`.`pid`
LEFT Outer JOIN chospital cp ON cp.hoscode=visit.pcucode
left outer join personaddresscontact pc on person.pcucodeperson = pc.pcucodeperson and person.pid = pc.pid
left outer JOIN `csubdistrict` csd ON csd.subdistcode = pc.subdistcode and csd.distcode = pc.distcode and csd.provcode = pc.provcode
left outer JOIN `cdistrict` cd ON cd.distcode = pc.distcode and cd.provcode = pc.provcode
left outer JOIN `cprovince` cw ON cw.provcode = pc.provcode
left outer join `ctitle` tt1 on `user`.`prename` = `tt1`.`titlecode`
left outer join `ctitle` tt2 on `person`.`prename` = `tt2`.`titlecode`
WHERE visit.visitno = $P!{VN}]]>
	</queryString>
