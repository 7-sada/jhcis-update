			<staticText>
				<reportElement x="38" y="393" width="487" height="20" uuid="17a16c16-4333-45aa-bc42-10cf10f3fb23"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[ขอรับรองว่าบุคคลดังกล่าว  ไม่เป็นผู้มีร่างกายทุพพลภาพจนไม่สามารถปฏิบัติหน้าที่ได้  ไม่ปรากฏอาการของโรคจิต]]></text>
			</staticText>
			<staticText>
				<reportElement x="1" y="413" width="536" height="20" uuid="e8a59d12-bbc6-4c76-83cc-6c446d7669a1"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[หรือจิตฟั่นเฟือน หรือปัญญาอ่อน  ไม่ปรากฏอาการของการติดยาเสพติดให้โทษ  และอาการของโรคพิษสุราเรื้อรัง และไม่ปรากฏ]]></text>
			</staticText>
			<staticText>
				<reportElement x="1" y="433" width="524" height="20" uuid="41e431c0-92e1-42bf-8671-635a86949fb3"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[อาการและอาการแสดงของโรคต่อไปนี้]]></text>
			</staticText>
			<staticText>
				<reportElement x="38" y="453" width="487" height="20" uuid="519c17fb-d920-4771-85e0-28800fd101fd"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[(1) โรคเรื้อนในระยะติดต่อหรือในระยะที่ปรากฏอาการเป็นที่รังเกียจแก่สังคม]]></text>
			</staticText>
			<staticText>
				<reportElement x="38" y="473" width="487" height="20" uuid="6f3d96ab-29a2-4375-81aa-ac408e071980"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[(2) วัณโรคในระยะอันตราย]]></text>
			</staticText>
			<staticText>
				<reportElement x="38" y="493" width="487" height="20" uuid="0b65ff9f-8fa9-4c49-986c-05c4d451fbcc"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[(3) โรคเท้าช้างในระยะที่ปรากฏอาการเป็นที่รังเกียจแก่สังคม]]></text>
			</staticText>
			<staticText>
				<reportElement x="38" y="513" width="499" height="20" uuid="31969d55-ac32-4a0c-8001-6db819d9467a"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[(4) (ถ้าจำเป็นต้องตรวจหาโรคที่เกี่ยวข้องกับการปฏิบัติงานของผู้รับการตรวจให้ระบุในข้อนี้)........................................]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="533" width="535" height="20" uuid="cac2b30b-c054-42a1-8952-48b3186a3b3d"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[.................................................................................................................................................................................]]></text>
			</staticText>
			<staticText>
				<reportElement x="38" y="553" width="497" height="20" uuid="1a54df54-ef58-4236-8902-4b73e7482d25"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[สรุปความเห็นและข้อแนะนำของแพทย์................................................................................................................]]></text>
			</staticText>
			<staticText>
				<reportElement x="2" y="573" width="535" height="20" uuid="9f5b3c5d-4064-43a2-b9c9-4cb7439bbd35"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[.................................................................................................................................................................................]]></text>
			</staticText>
			<staticText>
				<reportElement x="2" y="593" width="535" height="20" uuid="06a3e55e-ad64-4aec-b43c-5c5819470f31"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14"/>
				</textElement>
				<text><![CDATA[.................................................................................................................................................................................]]></text>
			</staticText>
			<staticText>
				<reportElement x="228" y="633" width="297" height="20" uuid="9dd5caf5-c022-4f67-8900-41e2ebdb0a5a"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="16" isBold="true"/>
				</textElement>
				<text><![CDATA[ลงชื่อ.......................................................แพทย์ผู้ตรวจร่างกาย]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="663" width="525" height="20" uuid="f4550c85-5d26-4765-b0bd-7f4d3c85310b"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14" isBold="true" isItalic="true"/>
				</textElement>
				<text><![CDATA[หมายเหตุ   (1) ต้องเป็นแพทย์ซึ่งได้ขึ้นทะเบียนรับใบอนุญาตประกอบวิชาชีพเวชกรรม]]></text>
			</staticText>
			<staticText>
				<reportElement x="45" y="683" width="480" height="20" uuid="b3164206-ced4-4649-afe8-5b631890b844"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14" isBold="true" isItalic="true"/>
				</textElement>
				<text><![CDATA[(2) ให้แสดงว่าเป็นผู้มีร่างกายสมบูรณ์เพียงใด  ใบรับรองแพทย์ฉบับนี้ให้ใช้ได้ 1 เดือน นับแต่วันที่ตรวจร่างกาย]]></text>
			</staticText>
			<staticText>
				<reportElement x="45" y="703" width="457" height="20" uuid="eb4560f9-dcb3-4079-a748-93565c63ebf6"/>
				<textElement>
					<font fontName="TH SarabunPSK" size="14" isBold="true" isItalic="true"/>
				</textElement>
				<text><![CDATA[แบบฟอร์มนี้ได้รับการรับรองจากมติคณะกรรมการแพทยสภาในการประชุมครั้งที่ 8/2551 วันที่ 14 สิงหาคม 2551]]></text>
			</staticText>
