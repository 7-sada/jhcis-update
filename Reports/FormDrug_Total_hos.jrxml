	<subDataset name="data1" uuid="3edbe313-80ae-4423-a964-18af3b62cdb7">
		<parameter name="visitno" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[select vd.drugcode,d.drugname,vd.unit,vd.realprice,
(vd.realprice*unit) as price1,noclaimprice,
(1-ifnull(noclaimprice,0))*vd.unit*vd.realprice  as paid
,(ifnull(noclaimprice,0))*vd.unit*vd.realprice  as noclaim
from visitdrug vd
join cdrug d on (vd.drugcode = d.drugcode)
where vd.visitno = $P{visitno}
and d.drugcode not like 'DF%'
order by d.drugtype]]>
		</queryString>
		<field name="drugcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="drugname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="unit" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="realprice" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="price1" class="java.math.BigDecimal"/>
		<field name="noclaimprice" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="paid" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="noclaim" class="java.math.BigDecimal"/>
		<variable name="sumtotal" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{price1}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
	</subDataset>
	<parameter name="visitno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select v.pid,p.fname,p.lname,ct.titlename,ifnull(p.idcard,"ไม่ระบุเลขบัตรประชาชน") as idcard,v.visitno,vr.receiptno,
IF(v.visitdate IS NULL,'',concat(convert(DAY(v.visitdate) using utf8),' ',
   CASE WHEN MONTH(v.visitdate)=1 THEN 'ม.ค.'
   WHEN MONTH(v.visitdate)=2 THEN 'ก.พ.' WHEN MONTH(v.visitdate)=3 THEN 'มี.ค'
   WHEN MONTH(v.visitdate)=4 THEN 'เม.ย.' WHEN MONTH(v.visitdate)=5 THEN 'พ.ค.'
   WHEN MONTH(v.visitdate)=6 THEN 'มิ.ย.' WHEN MONTH(v.visitdate)=7 THEN 'ก.ค.'
   WHEN MONTH(v.visitdate)=8 THEN 'ส.ค.' WHEN MONTH(v.visitdate)=9 THEN 'ก.ย.'
   WHEN MONTH(v.visitdate)=10 THEN 'ต.ค.' WHEN MONTH(v.visitdate)=11 THEN 'พ.ย.'
   WHEN MONTH(v.visitdate)=12 THEN 'ธ.ค.' END,' ',YEAR(visitdate)+543) )
   as visitdate,
ch.hosname,o.tel,ifnull(bb.diagcode,"ไม่ระบุการวินิจฉัย") as diagcode,ifnull(cdi.diseasenamethai,"") diseasenamethai,ch.hosname,o.tel
from visit v
left join
(
select vi.pcucode,vi.visitno,vi.diagcode
from visitdiag vi
where vi.dxtype = '01' and vi.visitno = $P{visitno}
group by vi.visitno ) as bb on (v.visitno = bb.visitno and v.pcucode = bb.pcucode)
left join cdisease cdi on (bb.diagcode = cdi.diseasecode)
join chospital ch on (v.pcucode = ch.hoscode)
left join office o on (ch.hoscode = o.offid)
left join visitreceiptno vr on (v.visitno = vr.visitno)
join person p on (p.pid = v.pid and p.pcucodeperson = v.pcucodeperson)
left join ctitle ct on (ct.titlecode = p.prename)
where vr.visitno = $P{visitno} and vr.flag is null and vr.datetime_cancel is null]]>
	</queryString>
