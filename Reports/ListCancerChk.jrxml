`vcancer12`.`cervic`,
`vcancer12`.`rightname`,
`vcancer12`.`hosname`,
`vcancer12`.`visitno`,
`vcancer12`.`rightno`,
`vcancer12`.`idcard`
FROM
`vcancer12`]]></queryString>

