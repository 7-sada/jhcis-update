	<queryString><![CDATA[SELECT
`vcancer1`.`pid`,
`vcancer1`.`name`,
`vcancer1`.`hnomoi`,
`vcancer1`.`villno`,
`vcancer1`.`birth`,
`vcancer1`.`age`,
`vcancer1`.`visitdate`,
`vcancer1`.`breast`,
`vcancer1`.`cervic`,
`vcancer1`.`rightname`,
`vcancer1`.`hosname`,
`vcancer1`.`visitno`,
`vcancer1`.`rightno`,
`vcancer1`.`idcard`
FROM
`vcancer1`
WHERE `vcancer1`.`villno` <>  '0' AND `vcancer1`.`visitno` not in (SELECT `vcancer2`.`visitno` FROM `vcancer2`)
union
SELECT
`vcancer2`.`pid`,
`vcancer2`.`name`,
`vcancer2`.`hnomoi`,
`vcancer2`.`villno`,
`vcancer2`.`birth`,
`vcancer2`.`age`,
`vcancer2`.`visitdate`,
`vcancer2`.`breast`,
`vcancer2`.`cervic`,
`vcancer2`.`rightname`,
`vcancer2`.`hosname`,
`vcancer2`.`visitno`,
`vcancer2`.`rightno`,
`vcancer2`.`idcard`
FROM
`vcancer2`
WHERE `vcancer2`.`villno` <>  '0' AND `vcancer2`.`visitno` not in (SELECT `vcancer1`.`visitno` FROM `vcancer1`)
union 
SELECT
`vcancer12`.`pid`,
`vcancer12`.`name`,
`vcancer12`.`hnomoi`,
`vcancer12`.`villno`,
`vcancer12`.`birth`,
`vcancer12`.`age`,
`vcancer12`.`visitdate`,
