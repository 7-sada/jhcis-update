		<defaultValueExpression ><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT house.pcucode,cdrug.drugcode, cdrug.drugname
,visitepiappoint.dateappoint,DATE_FORMAT(dateappoint,'%Y-%m-%d') as df
,concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ) ,' ',person.fname) AS pf,person.lname
,person.hnomoi,village.villno, village.villname
,village.villcode,chospital.hosname,cprovince.provname,cdistrict.distname
,tb.subdistname
FROM   visitepiappoint
        left JOIN  person ON  visitepiappoint.pid = person.pid and visitepiappoint.pcucodeperson = person.pcucodeperson
        left JOIN ctitle ON person.prename = ctitle.titlecode    
	left JOIN  visitepi ON visitepiappoint.pid = visitepi.pid and visitepiappoint.pcucodeperson = visitepi.pcucode
        left JOIN cdrug ON visitepiappoint.vaccinecode = cdrug.drugcode 
        left JOIN house ON person.hcode = house.hcode and person.pcucodeperson = house.pcucode
        left JOIN village ON house.villcode = village.villcode and visitepi.pcucode = village.pcucode
        left JOIN chospital ON (village.pcucode = chospital.hoscode)
        left JOIN cprovince ON (cprovince.provcode =chospital.provcode)
        left JOIN cdistrict ON (cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode)
	 left join csubdistrict tb on tb.provcode = left(village.villcode,2) and tb.distcode = substring(village.villcode,3,2) and tb.subdistcode = substring(village.villcode,5,2)
WHERE   DATE_FORMAT(dateappoint,'%Y-%m') = DATE_FORMAT($P{pdate},'%Y-%m') 
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
	and visitepiappoint.pcucode = $P{pcucode}
        and not exists (select visitepi.pid,visitepi.pcucodeperson from visitepi where visitepi.pid =visitepiappoint.pid 
                            and visitepi.pcucodeperson = visitepiappoint.pcucodeperson 
                            and DATE_FORMAT(visitepi.dateepi,'%Y-%m') > DATE_FORMAT(visitepiappoint.dateappoint,'%Y-%m')
                            group by visitepiappoint.pid,visitepiappoint.pcucodeperson )
	and village.villno >= $P{villno}
 group by visitepiappoint.pid,visitepiappoint.pcucodeperson 
 ORDER BY visitepiappoint.dateappoint,visitepiappoint.vaccinecode]]></queryString>

