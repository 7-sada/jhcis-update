<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ncd_sugarurine"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-05-04"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-02-28"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["30"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 1,v.visitno, ifnull(titlename,ifnull(prename,'ไม่ระบุ') )  prename,p.fname,p.lname,p.hnomoi
,CONVERT(if(village.villno =0 ,"นอกเขต",village.villno ) using utf8 ) as villno
,p.birth as br,DATE_FORMAT(birth, "%Y-%m-%d") as birth
,Max(DATE_FORMAT(v.visitdate,"%Y-%m-%d")) as visitdate
,if(birth is not null,
 CONVERT(CONCAT(DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " - ",
	CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " - ",
	CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") )
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8),"ไม่มีวันเกิด") AS age_visit
,case when (vs.sugarlevel='0')then 'ปกติ'
      when (vs.sugarlevel='1')then 'ระดับ 1'
      when (vs.sugarlevel='2')then 'ระดับ 2'
      when (vs.sugarlevel='3')then 'ระดับ 3'
      when (vs.sugarlevel='4')then 'ระดับ 4'
         else 'ไม่บันทึก'  end as t1
,case when (vs.alblevel='0')then 'ปกติ'
      when (vs.alblevel='1')then 'ระดับ 1'
      when (vs.alblevel='2')then 'ระดับ 2'
      when (vs.alblevel='3')then 'ระดับ 3'
      when (vs.alblevel='4')then 'ระดับ 4'
         else 'ไม่บันทึก'  end as t2
,cr.rightname,p.rightno,p.idcard,h.hosname,tb.subdistname,hdt.distname,hcw.provname 

FROM visitlabsugarurine vs 
     left join visit v  on v.visitno = vs.visitno and v.pcucode = vs.pcucode 
     left join person p on p.pid = v.pid and p.pcucodeperson = v.pcucodeperson
     left join ctitle on p.prename = ctitle.titlecode
     left join visitdiag vd on v.visitno = vd.visitno and v.pcucode = vd.pcucode
     left join cright cr on v.rightcode = cr.rightcode
     left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
     left join village on house.villcode = village.villcode and house.pcucode =village.pcucode
     left join chospital h on h.hoscode= v.pcucode
     left join csubdistrict tb on h.subdistcode = tb.subdistcode and h.distcode = tb.distcode and h.provcode = tb.provcode 
     left join cdistrict hdt on hdt.distcode = h.distcode and hdt.provcode = h.provcode
     left join cprovince hcw on hcw.provcode = h.provcode 
WHERE v.visitdate between $P{sdate} and $P{edate}
	and (birth IS NOT NULL OR birth NOT LIKE '0000%')
      and DATEDIFF(concat(YEAR($P{edate}),'-','07','-','01'),p.birth)/365 >= $P{age}
      and visitdate in (select Max(visitdate) from visit vv where vv.pid = v.pid and vv.pcucodeperson = v.pcucodeperson and vv.visitdate between $P{sdate} and $P{edate} group by vv.pid,vv.pcucodeperson)
      and vd.diagcode  not in('E10','E11','E12','E13','E14','E148','200' ) 
      $P!{pcucode} 
      and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
group by v.pid,v.pcucodeperson
order by v.pcucode,village.villcode,v.visitdate]]></queryString>

