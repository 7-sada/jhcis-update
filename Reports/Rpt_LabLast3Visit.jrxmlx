union all
(select p1.pid,p1.labcode,'' as labname,p1.date1,
(case when p1.value1 = '1' then 'Opthalmoscope ปกติ'
when p1.value1 = '2' then 'Fundus camera ปกติ'
when p1.value1 = '3' then 'Opthalmoscope ผิดปกติ'
when p1.value1 = '4' then 'Fundus camera ผิดปกติ'
when p1.value1 = '9' then 'ไม่ตรวจ'
else null end) as value1,
p1.date2,
(case when p1.value2 = '1' then 'Opthalmoscope ปกติ'
when p1.value2 = '2' then 'Fundus camera ปกติ'
when p1.value2 = '3' then 'Opthalmoscope ผิดปกติ'
when p1.value2 = '4' then 'Fundus camera ผิดปกติ'
when p1.value2 = '9' then 'ไม่ตรวจ'
else null end) as value2,
p1.date3,
(case when p1.value3 = '1' then 'Opthalmoscope ปกติ'
when p1.value3 = '2' then 'Fundus camera ปกติ'
when p1.value3 = '3' then 'Opthalmoscope ผิดปกติ'
when p1.value3 = '4' then 'Fundus camera ผิดปกติ'
when p1.value3 = '9' then 'ไม่ตรวจ'
else null end) as value3
from
((select nd.pcucodeperson,nd.pid,'การตรวจตา' as labcode,
(select datefollow from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1) as date1,
(select eyeopthalmoscope from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1) as value1,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 1) as date2,
(select eyeopthalmoscope from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 1) as value2,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 2) as date3,
(select eyeopthalmoscope from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 2) as value3
from ncdservice nd
where nd.pid = $P{pid}
group by nd.pid)) as p1)

union all
(select B.pid,B.labcode,'' as labname,B.date1,
(case when B.value1 = '0' then 'ตรวจ-ผลปกติ'
when B.value1 = '1' then 'Low-Risk'
when B.value1 = '2' then 'Moderate-Risk'
when B.value1 = '3' then 'High-Risk'
when B.value1 = '4' then 'Foot-Ulcer'
when B.value1 = '5' then 'Amputation'
else null end) as value1, B.date2,
(case when B.value2 = '0' then 'ตรวจ-ผลปกติ'
when B.value2 = '1' then 'Low-Risk'
when B.value2 = '2' then 'Moderate-Risk'
when B.value2 = '3' then 'High-Risk'
when B.value2 = '4' then 'Foot-Ulcer'
when B.value2 = '5' then 'Amputation'
else null end) as value2, B.date3,
(case when B.value3 = '0' then 'ตรวจ-ผลปกติ'
when B.value3 = '1' then 'Low-Risk'
when B.value3 = '2' then 'Moderate-Risk'
when B.value3 = '3' then 'High-Risk'
when B.value3 = '4' then 'Foot-Ulcer'
when B.value3 = '5' then 'Amputation'
else null end) as value3
from(
(select nd.pcucodeperson,nd.pid,'การตรวจเท้า' as labcode,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1) as date1,
(select examfoot from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1) as value1,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 1) as date2,
(select examfoot from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 1) as value2,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 2) as date3,
(select examfoot from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 2) as value3
from ncdservice nd
where nd.pid = $P{pid}
group by nd.pid))B)

union all
select bb.pid,
(case when bb.typetesting = '1' then 'DTX'
when bb.typetesting = '2' then 'FBS'
else null end) as labcode,"" as labname,
bb.date1,bb.value1,bb.date2,bb.value2,bb.date3,bb.value3
from
(
select a.pid,a.typetesting,b.visitdate as date1,b.sugarnumdigit as value1
,c.visitdate as date2,c.sugarnumdigit as value2
,d.visitdate as date3,d.sugarnumdigit as value3
from
(select vi.pid,vis.typetesting,vis.sugarnumdigit,vi.visitdate,vis.visitno,vis.pcucode
from visitlabsugarblood vis
join visit vi on (vis.visitno = vi.visitno and vis.pcucode = vi.pcucode)
where vi.pid = $P{pid}
and vis.typetesting = '1') as a
left join
(
select aa.pid,bb.visitno,aa.sugarnumdigit,aa.typetesting,bb.visitdate
from
(select vt.pid,vg.visitno,vg.sugarnumdigit,vg.typetesting,vt.visitdate
from visitlabsugarblood vg
join visit vt on (vg.visitno = vt.visitno and vg.pcucode = vt.pcucode)
where vg.typetesting = '1' and vt.pid = $P{pid}) as aa
join
(
select v.pid,max(vs.visitno) as visitno,v.visitdate
from visitlabsugarblood vs
join visit v on (vs.visitno = v.visitno and vs.pcucode = v.pcucode)
where vs.typetesting = '1'
and v.pid = $P{pid}
group by v.visitdate
order by v.visitdate desc) as bb on (aa.visitno = bb.visitno and aa.pid = bb.pid)
order by bb.visitdate desc
limit 1) as b on (a.pid = b.pid)

left join
(
select aa.pid,bb.visitno,aa.sugarnumdigit,aa.typetesting,bb.visitdate
from
(select vt.pid,vg.visitno,vg.sugarnumdigit,vg.typetesting,vt.visitdate
from visitlabsugarblood vg
join visit vt on (vg.visitno = vt.visitno and vg.pcucode = vt.pcucode)
where vg.typetesting = '1' and vt.pid = $P{pid}) as aa
join
(
select v.pid,max(vs.visitno) as visitno,v.visitdate
from visitlabsugarblood vs
join visit v on (vs.visitno = v.visitno and vs.pcucode = v.pcucode)
where vs.typetesting = '1'
and v.pid = $P{pid}
group by v.visitdate
order by v.visitdate desc) as bb on (aa.visitno = bb.visitno and aa.pid = bb.pid)
order by bb.visitdate desc
limit 1 offset 1) as c on (a.pid = c.pid)
left join
(
select aa.pid,bb.visitno,aa.sugarnumdigit,aa.typetesting,bb.visitdate
from
(select vt.pid,vg.visitno,vg.sugarnumdigit,vg.typetesting,vt.visitdate
from visitlabsugarblood vg
join visit vt on (vg.visitno = vt.visitno and vg.pcucode = vt.pcucode)
where vg.typetesting = 1 and vt.pid = $P{pid}) as aa
join
(
select v.pid,max(vs.visitno) as visitno,v.visitdate
from visitlabsugarblood vs
join visit v on (vs.visitno = v.visitno and vs.pcucode = v.pcucode)
where vs.typetesting = '1'
and v.pid = $P{pid}
group by v.visitdate
order by v.visitdate desc) as bb on (aa.visitno = bb.visitno and aa.pid = bb.pid)
order by bb.visitdate desc
limit 1 offset 2) as d on (a.pid = d.pid)
group by a.pid) as bb
union all
select bb.pid,
(case when bb.typetesting = '1' then 'DTX'
when bb.typetesting = '2' then 'FBS'
else null end) as labcode,"" as labname,
bb.date1,bb.value1,bb.date2,bb.value2,bb.date3,bb.value3
from
(
select a.pid,a.typetesting,b.visitdate as date1,b.sugarnumdigit as value1
,c.visitdate as date2,c.sugarnumdigit as value2
,d.visitdate as date3,d.sugarnumdigit as value3
from
(select vi.pid,vis.typetesting,vis.sugarnumdigit,vi.visitdate,vis.visitno,vis.pcucode
from visitlabsugarblood vis
join visit vi on (vis.visitno = vi.visitno and vis.pcucode = vi.pcucode)
where vi.pid = $P{pid}
and vis.typetesting = '2'
order by vi.visitdate desc,vis.visitno desc) as a
left join
(
select aa.pid,bb.visitno,aa.sugarnumdigit,aa.typetesting,bb.visitdate
from
(select vt.pid,vg.visitno,vg.sugarnumdigit,vg.typetesting,vt.visitdate
from visitlabsugarblood vg
join visit vt on (vg.visitno = vt.visitno and vg.pcucode = vt.pcucode)
where vg.typetesting = '2' and vt.pid = $P{pid}) as aa
join
(
select v.pid,max(vs.visitno) as visitno,v.visitdate
from visitlabsugarblood vs
join visit v on (vs.visitno = v.visitno and vs.pcucode = v.pcucode)
where vs.typetesting = '2'
and v.pid = $P{pid}
group by v.visitdate
order by v.visitdate desc) as bb on (aa.visitno = bb.visitno and aa.pid = bb.pid)
order by bb.visitdate desc
limit 1) as b on (a.pid = b.pid)
left join
(
select aa.pid,bb.visitno,aa.sugarnumdigit,aa.typetesting,bb.visitdate
from
(select vt.pid,vg.visitno,vg.sugarnumdigit,vg.typetesting,vt.visitdate
from visitlabsugarblood vg
join visit vt on (vg.visitno = vt.visitno and vg.pcucode = vt.pcucode)
where vg.typetesting = '2' and vt.pid = $P{pid}) as aa
join
(
select v.pid,max(vs.visitno) as visitno,v.visitdate
from visitlabsugarblood vs
join visit v on (vs.visitno = v.visitno and vs.pcucode = v.pcucode)
where vs.typetesting = '2'
and v.pid = $P{pid}
group by v.visitdate
order by v.visitdate desc) as bb on (aa.visitno = bb.visitno and aa.pid = bb.pid)
order by bb.visitdate desc
limit 1 offset 1) as c on (a.pid = c.pid)
left join
(
select aa.pid,bb.visitno,aa.sugarnumdigit,aa.typetesting,bb.visitdate
from
(select vt.pid,vg.visitno,vg.sugarnumdigit,vg.typetesting,vt.visitdate
from visitlabsugarblood vg
join visit vt on (vg.visitno = vt.visitno and vg.pcucode = vt.pcucode)
where vg.typetesting = '2' and vt.pid = $P{pid}) as aa
join
(
select v.pid,max(vs.visitno) as visitno,v.visitdate
from visitlabsugarblood vs
join visit v on (vs.visitno = v.visitno and vs.pcucode = v.pcucode)
where vs.typetesting = '2'
and v.pid = $P{pid}
group by v.visitdate
order by v.visitdate desc) as bb on (aa.visitno = bb.visitno and aa.pid = bb.pid)
order by bb.visitdate desc
limit 1 offset 2) as d on (a.pid = d.pid)
group by a.pid) as bb
)as p2
order by p2.labcode]]>
