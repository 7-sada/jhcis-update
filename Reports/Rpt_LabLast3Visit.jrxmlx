	<subDataset name="New Dataset 1" uuid="c7636604-fcd7-4b2a-99f9-f477522fa9ac">
		<parameter name="pid" class="java.lang.String">
			<defaultValueExpression><![CDATA["96"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select p2.pid,p2.labcode,p2.labname,date_add(p2.datecheck1,interval 543 year) as date1,p2.labresultdigit1
,date_add(p2.datecheck2,interval 543 year) as date2,p2.labresultdigit2
,date_add(p2.datecheck3,interval 543 year) as date3,p2.labresultdigit3
from
(select a.pid,a.labcode,cl.labname,
b.datecheck as datecheck1,b.labresultdigit as labresultdigit1,
c.datecheck as datecheck2,c.labresultdigit as labresultdigit2 ,
d.datecheck as datecheck3,d.labresultdigit as labresultdigit3
from (
select pid,labcode,labresultdigit,datecheck,seqonday from visitlabchcyhembmsse
where pid = $P{pid}
and lcase(labcode) = 'ch07'
group by labcode
) as a
left join
(
select v.labcode, v.datecheck,v.seqonday,v.labresultdigit,v.pid
from visitlabchcyhembmsse as v
join (
select labcode,pid,datecheck,max(seqonday) as  seqonday  from visitlabchcyhembmsse
group by datecheck,labcode order by datecheck desc) as aa on aa.labcode = v.labcode and  v.pid = aa.pid and v.datecheck = aa.datecheck and v.seqonday = aa.seqonday
where v.pid = $P{pid}
and lcase(v.labcode) = 'ch07'
order by datecheck desc
limit 1
) as b on a.labcode=b.labcode and  a.pid = b.pid
left join
(
select v.labcode, v.datecheck,v.seqonday,v.labresultdigit,v.pid
from visitlabchcyhembmsse as v
join (
select labcode,pid,datecheck,max(seqonday) as  seqonday  from visitlabchcyhembmsse
group by datecheck,labcode order by datecheck desc) as aa on aa.labcode = v.labcode and  v.pid = aa.pid and v.datecheck = aa.datecheck and v.seqonday = aa.seqonday
where v.pid = $P{pid}
and lcase(v.labcode) = 'ch07'
order by datecheck desc
limit 1 offset 1
) as c on a.labcode=c.labcode and  a.pid = c.pid
left join
(
select v.labcode, v.datecheck,v.seqonday,v.labresultdigit,v.pid
from visitlabchcyhembmsse as v
join (
select labcode,pid,datecheck,max(seqonday) as  seqonday  from visitlabchcyhembmsse
group by datecheck,labcode order by datecheck desc) as aa on aa.labcode = v.labcode and  v.pid = aa.pid and v.datecheck = aa.datecheck and v.seqonday = aa.seqonday
where v.pid = $P{pid}
and lcase(v.labcode) = 'ch07'
order by datecheck desc
limit 1 offset 2
) as d on a.labcode=d.labcode and  a.pid = d.pid
join clabchcyhembmsse cl on (a.labcode = cl.labcode)

