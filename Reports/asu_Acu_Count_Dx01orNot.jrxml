<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="asu_Uri_Count_Dx01orNot" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="73d96595-31b2-493f-a13a-a0c3807476c4">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="offAddress" class="java.lang.String"/>
	<parameter name="ye_r" class="java.lang.String"/>
	<parameter name="ye_rt" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT ELT(m12.m,'มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม') mn
,m12.m, a.c1, a.dgFreq, b.c1 c1b, b.dgFreq dgFreqb
FROM
(SELECT 1 m UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7
UNION SELECT 8 UNION SELECT 9 UNION SELECT 10 UNION SELECT 11 UNION SELECT 12) AS m12
##
LEFT JOIN
(SELECT a.y,a.m,COUNT(*) c1 ,COUNT(dC) dgFreq
 FROM
  (SELECT YEAR(v.visitdate) y,MONTH(v.visitdate) m,v.pcucode,v.visitno
      FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
      JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
      WHERE LCASE(LEFT(d2.icd10acui,1)) IN('a','k')
        AND dxtype='01'
        AND YEAR(v.visitdate)=$P{ye_r}
      GROUP BY YEAR(v.visitdate),MONTH(v.visitdate),v.visitno) AS a
 LEFT JOIN
  (SELECT v.pcucode,v.visitno,COUNT(*) dC FROM visitdrug d1
   JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
   JOIN cdrug d2 ON d1.drugcode=d2.drugcode
   WHERE d2.antibio='1'
    AND YEAR(v.visitdate)=$P{ye_r}
   GROUP BY v.visitno) AS b
  ON a.pcucode=b.pcucode AND a.visitno=b.visitno
  GROUP BY a.y,a.m
) AS a ON m12.m=a.m
##
LEFT JOIN
(SELECT a.y,a.m,COUNT(*) c1 ,COUNT(dC) dgFreq
 FROM
  (SELECT YEAR(v.visitdate) y,MONTH(v.visitdate) m,v.pcucode,v.visitno
      FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
      JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
      WHERE LCASE(LEFT(d2.icd10acui,1)) IN('a','k')
        AND dxtype<>'01'
        AND YEAR(v.visitdate)=$P{ye_r}
      GROUP BY YEAR(v.visitdate),MONTH(v.visitdate),v.visitno) AS a
 LEFT JOIN
  (SELECT v.pcucode,v.visitno,COUNT(*) dC FROM visitdrug d1
   JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
   JOIN cdrug d2 ON d1.drugcode=d2.drugcode
   WHERE d2.antibio='1'
    AND YEAR(v.visitdate)=$P{ye_r}
   GROUP BY v.visitno) AS b
  ON a.pcucode=b.pcucode AND a.visitno=b.visitno
  GROUP BY a.y,a.m
) AS b ON m12.m=b.m]]>
	</queryString>
	<field name="mn" class="java.lang.String"/>
	<field name="m" class="java.lang.Long"/>
	<field name="c1" class="java.lang.Long"/>
	<field name="dgFreq" class="java.lang.Long"/>
	<field name="c1b" class="java.lang.Long"/>
	<field name="dgFreqb" class="java.lang.Long"/>
	<variable name="sumTotA" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{c1}]]></variableExpression>
	</variable>
	<variable name="sumTotU" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{c1b}]]></variableExpression>
	</variable>
	<variable name="fq1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{dgFreq}]]></variableExpression>
	</variable>
	<variable name="fq2" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{dgFreqb}]]></variableExpression>
	</variable>
