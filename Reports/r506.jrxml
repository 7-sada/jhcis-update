	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="p_office1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="p_office2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="p_date_col" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" sickdatestart "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_date_start" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2004-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_date_end" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2004-01-31"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT visitdiag506address.visitno, cdisease.code506, visitdiag506address.diagcode, cdisease.diseasename, visitdiag506address.sickdatestart, visitdiag506address.sickdatefind, visit.visitdate,
 visitdiag506address.hno, visitdiag506address.mu, visitdiag506address.road, csubdistrict.subdistname AS tn, cdistrict.distname AS an,
 @villcode:=(select villcode from house h where h.pcucode=person.pcucodeperson AND h.hcode=person.hcode ) AS villcode, IF(Right(@villcode,2)='00','(นอกเขตฯ)-ผู้รับบริการ เป็นคนนอกเขตรับผิดชอบของสถานบริการนี้','(ในเขตฯ)-ผู้รับบริการ เป็นคนในเขตรับผิดชอบของสถานบริการนี้') AS areatype,
 cprovince.provname, visitdiag506address.area, person.birth, IF(status IS NULL,'ไม่ทราบ',ELT(status,'หาย','ตาย','ยังรักษาอยู่','ไม่ทราบ') )  AS sickstat, visitdiag506address.deaddate,
 CONCAT(IFNULL(ctitle.titlename,IFNULL(person.prename,'...')),person.fname,' ',person.lname) AS full, If(person.sex='1','ชาย','หญิง') AS sex1, coccupa.occupaname AS occ, ELT(marystatus,'โสด','สมรส','หม่าย','หย่า')  AS maried, cnation.nationname AS nat, creligion.religionname AS relig,father,mother,
@ay:= (YEAR(NOW())-YEAR(birth)) - (month(NOW())<month(birth)) AS ay ,IF(@ay IS NULL Or @ay>=15,Null,father) AS f, IF(@ay IS NULL Or @ay>=15,Null,mother) AS m, person.pid,
 TIMESTAMPDIFF(MONTH,DATE_SUB(DATE_FORMAT(birth,CONCAT(YEAR(NOW()),'-%m-%d')),INTERVAL MONTH(birth)>MONTH(NOW()) YEAR) ,NOW()) AS am,
 CASE SIGN(DAY(NOW()) - DAY(birth)) WHEN 0 THEN 0 WHEN -1 THEN (DAY(LAST_DAY(birth)) + DAY(NOW())  - DAY(birth)) WHEN 1 THEN (DAY(NOW()) - DAY(birth) - (DAY(NOW()) < DAY(birth))) END  AS ad,personstudent.schoolno
,concat(if(t2.titlecode IS NULL,'..',t2.titlename)
        ,IFNULL(`user`.`fname`,'..'),'  ',IFNULL(`user`.`lname`,'.. ..')) as uname
,e.e0, e.e1
,c.hno AS hnoc ,c.mu AS muc ,c.road AS roadc ,s.subdistname AS tnc
,d.distname AS anc ,p.provname AS cwc
,person.idcard
FROM (((cdisease INNER JOIN (((coccupa RIGHT JOIN (cnation RIGHT JOIN (creligion RIGHT JOIN person ON creligion.religioncode = person.religion) ON cnation.nationcode = person.nation)
 ON coccupa.occupacode = person.occupa) LEFT JOIN personstudent ON person.pcucodeperson=personstudent.pcucodeperson AND person.pid = personstudent.pid) INNER JOIN ((cprovince RIGHT JOIN (cdistrict RIGHT JOIN (csubdistrict RIGHT JOIN (visitdiag506address INNER JOIN visit
 ON visitdiag506address.visitno = visit.visitno) ON (csubdistrict.provcode=visitdiag506address.provcode AND csubdistrict.distcode=visitdiag506address.distcode AND csubdistrict.subdistcode=visitdiag506address.subdistcode) )
 ON  (cdistrict.provcode=visitdiag506address.provcode AND cdistrict.distcode=visitdiag506address.distcode) ) ON cprovince.provcode = visitdiag506address.provcode) INNER JOIN visitdiag
 ON (visitdiag506address.diagcode = visitdiag.diagcode) AND (visitdiag506address.visitno = visitdiag.visitNo)) ON person.pcucodeperson=visit.pcucode AND person.pid=visit.pid) ON cdisease.diseasecode = visitdiag.diagcode) LEFT JOIN (personaddresscontact c LEFT JOIN cprovince p
 ON c.provcode= p.provcode) ON c.pid=person.pid)  LEFT JOIN cdistrict d ON c.provcode= d.provcode AND c.distcode= d.distcode LEFT JOIN csubdistrict s
 ON c.provcode= s.provcode AND c.distcode= s.distcode AND c.subdistcode= s.subdistcode) INNER JOIN 506_cal_e0_e1 e ON visitdiag506address.visitno = e.visitno
left outer JOIN `user` ON visit.username = `user`.`username` and `visit`.`pcucode` = `user`.`pcucode`
left join ctitle on ctitle.titlecode=person.prename
left join ctitle t2 on `user`.prename=t2.titlecode
WHERE $P!{p_date_col} Between '$P!{p_date_start}' And '$P!{p_date_end}' AND cdisease.code506  IS NOT NULL AND visitdiag.conti = '0' AND (visit.flagservice<='03' OR visit.flagservice IS NULL) ORDER BY visit.visitdate, visit.visitno ;]]>
	</queryString>
