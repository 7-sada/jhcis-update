	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4525"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(visitepi.`dateepi`,"%Y-%m-%d")AS dateepi,
     cdrug.`drugname` AS cdrug_drugname
FROM
     `cdrug` cdrug INNER JOIN `visitepi` visitepi ON cdrug.`drugcode` = visitepi.`vaccinecode`
WHERE
     visitepi.pcucodeperson = '$P!{p_pcucode}'
 AND visitepi.pid = '$P!{p_pid}'
AND vaccinecode in('DTANC1','DTANC2','DTANC3','DTANC4','DTANC5','TT1','TT2','TT3','TT4','TT5','DT1','DT2')]]></queryString>

	<field name="dateepi" class="java.util.Date"/>
	<field name="cdrug_drugname" class="java.lang.String"/>

