	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["220"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     personunable3need.`pcucodeperson` AS personunable3need_pcucodeperson,
     personunable3need.`pid` AS personunable3need_pid,
     personunable3need.`needcode` AS personunable3need_needcode,
     cpersonneed.`needname` AS cpersonneed_needname
FROM
     `personunable3need` personunable3need INNER JOIN `cpersonneed` cpersonneed ON personunable3need.`needcode` = cpersonneed.`needcode`
WHERE
     personunable3need.pcucodeperson = '$P!{p_pcucode}'
     and personunable3need.pid = '$P!{p_pid}']]></queryString>

