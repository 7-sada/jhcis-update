	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4539"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     visitlabblood.`pcucodeperson` AS visitlabblood_pcucodeperson,
     visitlabblood.`pid` AS visitlabblood_pid,
     DATE_FORMAT(visitlabblood.`datecheck`,"%Y-%m-%d") AS datecheck,
     visitlabblood.`pcucode` AS visitlabblood_pcucode,
     visitlabblood.`visitno` AS visitlabblood_visitno,
     CASE visitlabblood.`vdrl` WHEN '' THEN '-' WHEN '0' THEN 'Non-Reactive' WHEN '1' THEN '1:16' WHEN '2' THEN '1:8' WHEN '3' THEN '1:4' WHEN '9' THEN 'ไม่ตรวจ' WHEN 'x' THEN 'รอผลฯ' ELSE '-' END  AS visitlabblood_vdrl,
     CASE visitlabblood.`hiv` WHEN '' THEN '-' WHEN '0' THEN '-(Negative)' WHEN '1' THEN '+(Positive)' WHEN '9' THEN 'ไม่ตรวจ' WHEN 'x' THEN 'รอผลฯ' ELSE '-' END  AS visitlabblood_hiv,
     CASE visitlabblood.`hbag` WHEN '' THEN '-' WHEN '0' THEN '-(Negative)' WHEN '1' THEN '+(Positive)' WHEN '9' THEN 'ไม่ตรวจ' WHEN 'x' THEN 'รอผลฯ' ELSE '-' END AS visitlabblood_hbag,
     visitlabblood.`hct` AS visitlabblood_hct,
     CASE visitlabblood.`talas1` WHEN '' THEN '-' WHEN '0' THEN '-(Negative)' WHEN '1' THEN '+(Positive)' WHEN '9' THEN 'ไม่ตรวจ' WHEN 'x' THEN 'รอผลฯ' ELSE '-' END AS visitlabblood_talas1,
     CASE visitlabblood.`talas2` WHEN '' THEN '-' WHEN '0' THEN '-(Negative)' WHEN '1' THEN '+(Positive)' WHEN '9' THEN 'ไม่ตรวจ' WHEN 'x' THEN 'รอผลฯ' ELSE '-' END AS visitlabblood_talas2,
     visitlabblood.`clinic` AS visitlabblood_clinic,
     visitlabblood.`hosservice` AS visitlabblood_hosservice,
     visitlabblood.`hoslab` AS visitlabblood_hoslab,
     visitlabblood.`datesend` AS visitlabblood_datesend,
     visitlabblood.`dateresult` AS visitlabblood_dateresult,
     visitlabblood.`dateback` AS visitlabblood_dateback
FROM
     `visitlabblood` visitlabblood
WHERE
     visitlabblood.pcucodeperson = '$P!{p_pcucode}'
     and visitlabblood.pid = '$P!{p_pid}'
ORDER BY visitlabblood.`datecheck`]]></queryString>

	<field name="visitlabblood_pcucodeperson" class="java.lang.String"/>
