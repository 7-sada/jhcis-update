<jasperReport
		 name="FamilyFolder_bmisub"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="595"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["886"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(visit.visitdate,"%Y-%m-%d")AS visitdate,
     person.`sex` AS person_sex,
     visit.`weight` AS visit_weight,
     visit.`height` AS visit_height,
     visit.`waist` AS visit_waist,
     visit.`bmilevel` AS visit_bmilevel,
     CASE  WHEN visit.weight !='' and (visit.height !='' and visit.height >0)  
           THEN round((visit.weight/((visit.height/100)*(visit.height/100))),2) END  AS bmi ,
     CASE  WHEN visit.weight !='' and (visit.height !='' and visit.height >0)  
                  AND  round((visit.weight/((visit.height/100)*(visit.height/100))),2) <18.50 THEN 'ผอม'
	   WHEN visit.weight !='' and (visit.height !='' and visit.height >0)  
                  AND  round((visit.weight/((visit.height/100)*(visit.height/100))),2) BETWEEN 18.50 AND 24.9  THEN 'ปกติ'
	   WHEN visit.weight !='' and (visit.height !='' and visit.height >0)  
                  AND  round((visit.weight/((visit.height/100)*(visit.height/100))),2) BETWEEN 25.00 AND 29.90 THEN 'อ้วนระดับ 1'
	   WHEN visit.weight !='' and (visit.height !='' and visit.height >0)  
                  AND  round((visit.weight/((visit.height/100)*(visit.height/100))),2) BETWEEN 30.0 AND 39.90 THEN 'อ้วนระดับ 2'
	   WHEN visit.weight !='' and (visit.height !='' and visit.height >0)  
                  AND  round((visit.weight/((visit.height/100)*(visit.height/100))),2) >40.00 THEN 'อ้วนระดับ 3'
          
      END  AS result 

FROM
     `person` person INNER JOIN `visit` visit ON person.`pcucodeperson` = visit.`pcucodeperson`
     AND person.`pid` = visit.`pid`
WHERE
     visit.pcucodeperson = '$P!{p_pcucode}'
     and visit.pid = '$P!{p_pid}'

ORDER BY  visit.visitdate]]></queryString>

	<field name="visitdate" class="java.util.Date"/>
	<field name="person_sex" class="java.lang.String"/>
	<field name="visit_weight" class="java.math.BigDecimal"/>
	<field name="visit_height" class="java.math.BigDecimal"/>
	<field name="visit_waist" class="java.math.BigDecimal"/>
	<field name="visit_bmilevel" class="java.lang.String"/>
	<field name="bmi" class="java.math.BigDecimal"/>
	<field name="result" class="java.lang.String"/>

