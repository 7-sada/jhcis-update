					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement>
						<font fontName="Tahoma"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["อุณหภูมิ "+($F{temperature}==null||$F{temperature}.toPlainString().length()==0 ?"-":$F{temperature}.toString())
+" C ชีพจร "+($F{pulse}==null||$F{pulse}.toString().length()==0 ?"-":$F{pulse}.toString())
+"ครั้ง/นาที  หายใจ "+ ($F{respri}==null||$F{respri}.toString().length()==0 ?"-":$F{respri}.toString())
+"ครั้ง/นาที"
+" ความดัน "+($F{pressure}==null||$F{pressure}.length()==0 ?"-":$F{pressure}.toString())
+"mmHg นน. "+($F{weight}==null||$F{weight}.toPlainString().length()==0 ?"-":$F{weight}.toString())
+"กก. ส่วนสูง "+ ($F{height}==null||$F{height}.toPlainString().length()==0 ?"-":$F{height}.toString())
+" ซม."]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
