	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["07918"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["1879"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["d:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(v.visitdate,"%Y-%m-%d")AS visit_visitdate,
     v.pcucode ,
     v.`visitno`,
     v.`symptoms`,
     v.`weight`,
     v.`height`,
     v.`pressure`,
     v.`pressurelevel`,
     v.`temperature`,
     v.`pulse`,
     v.`respri`,
     v.`waist`,
     v.`healthsuggest1`,
     v.`healthsuggest2`,
     v.`bmilevel`,
     v.`vitalcheck`
FROM
     `visit` v 
WHERE
     v.pcucode = '$P!{p_pcucode}'
     and v.pid = '$P!{p_pid}'
ORDER BY
     v.visitdate ASC]]></queryString>

	<field name="visit_visitdate" class="java.util.Date"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="symptoms" class="java.lang.String"/>
	<field name="weight" class="java.math.BigDecimal"/>
	<field name="height" class="java.math.BigDecimal"/>
	<field name="pressure" class="java.lang.String"/>
	<field name="pressurelevel" class="java.lang.String"/>
	<field name="temperature" class="java.math.BigDecimal"/>
	<field name="pulse" class="java.lang.Integer"/>
	<field name="respri" class="java.lang.Integer"/>
	<field name="waist" class="java.math.BigDecimal"/>
	<field name="healthsuggest1" class="java.lang.String"/>
	<field name="healthsuggest2" class="java.lang.String"/>
	<field name="bmilevel" class="java.lang.String"/>
	<field name="vitalcheck" class="java.lang.String"/>

