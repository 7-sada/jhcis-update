	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4717"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     concat(person_A.`prename`,person_A.`fname`,'  ',person_A.`lname`)AS fathername,
     concat(person_B.`prename`,person_B.`fname`,'  ',person_B.`lname`)AS mothername,
     visitancdeliverchild.`weight` AS visitancdeliverchild_weight,
     visitancdeliverchild.`a1` AS visitancdeliverchild_a1,
     visitancdeliverchild.`p1` AS visitancdeliverchild_p1,
     visitancdeliverchild.`g1` AS visitancdeliverchild_g1,
     visitancdeliverchild.`x1` AS visitancdeliverchild_x1,
     visitancdeliverchild.`r1` AS visitancdeliverchild_r1,
     visitancdeliverchild.`a5` AS visitancdeliverchild_a5,
     visitancdeliverchild.`p5` AS visitancdeliverchild_p5,
     visitancdeliverchild.`g5` AS visitancdeliverchild_g5,
     visitancdeliverchild.`x5` AS visitancdeliverchild_x5,
     visitancdeliverchild.`r5` AS visitancdeliverchild_r5,
     visitancdeliverchild.`deliverplace` AS visitancdeliverchild_deliverplace,
     DATE_FORMAT(visitancdeliver.`datedeliver`,"%Y-%m-%d") AS visitancdeliver_datedeliver,
     visitancdeliver.`delivertime` AS visitancdeliver_delivertime,
     CASE visitancdeliverchild.`delivertype` WHEN '1' THEN 'ปกติ' WHEN '2' THEN 'ผ่า' WHEN '3' THEN 'ดูด' WHEN '4' THEN 'คีบ' END AS visitancdeliver_delivertype,
     CASE visitancdeliverchild.`deliverresult` WHEN 'ช'THEN 'ปกติ(เกิดมีชีพ)'WHEN 'ท'THEN 'แท้ง'WHEN 'ต'THEN 'เกิดไร้ชีพ)'END AS visitancdeliver_deliverresult,
     visitancdeliverchild.`tall` AS visitancdeliverchild_tall,
     visitancdeliverchild.`headcycle` AS visitancdeliverchild_headcycle
FROM
     `person` person_A RIGHT OUTER JOIN `person` person ON person_A.`idcard` = person.`fatherid`
     LEFT OUTER JOIN `person` person_B ON person.`motherid` = person_B.`idcard`
     INNER JOIN `visitancdeliverchild` visitancdeliverchild ON person.`pcucodeperson` = visitancdeliverchild.`pcucodechild`
     AND visitancdeliverchild.`pidchild` = person.`pid`
     INNER JOIN `visitancdeliver` visitancdeliver ON visitancdeliverchild.`pcucodeperson` = visitancdeliver.`pcucodeperson`
     AND visitancdeliver.`pid` = visitancdeliverchild.`pid`
     AND visitancdeliver.`pregno` = visitancdeliverchild.`pregno`
WHERE
     person.pcucodeperson = '$P!{p_pcucode}'
     and person.pid = '$P!{p_pid}']]></queryString>

