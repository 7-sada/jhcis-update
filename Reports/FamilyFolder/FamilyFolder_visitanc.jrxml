<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FamilyFolder_visitanc"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="811"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="1"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["D:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["03320"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["10114"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     person.`pid`,
     concat(person.pcucodeperson,person.pid)as ppid,
     concat(ifnull(ctitle.`titlename`,''),ifnull(`person`.`fname`,''),'  ',ifnull(`person`.`lname`,''))as name,
     ifnull(idcard,'...ไม่ระบุฯ')as idc,
     DATE_FORMAT(person.`birth`,"%Y-%m-%d")as birth,
     concat(person.pcucodeperson,'-',person.pid,'/',substring(curdate(),1,4)+543)as hnyear,
     hnomoi,
     mumoi,
     subdistname,
     subdistname,
     distname,
     provname,
     CONVERT(CONCAT(DATE_FORMAT(CURRENT_DATE,"%Y")-DATE_FORMAT(birth,"%Y")-(DATE_FORMAT(CURRENT_DATE,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d"))," ปี  "
	,CASE SIGN(DATE_FORMAT(CURRENT_DATE,"%m")-DATE_FORMAT(birth,"%m"))WHEN 0 THEN(11-DATE_FORMAT(birth,"%m")
	+DATE_FORMAT(CURRENT_DATE,"%m")-(DATE_FORMAT(birth,"00-00-%d")<DATE_FORMAT(birth,"00-00-%d")))
	WHEN -1 THEN(12-DATE_FORMAT(birth,"%m")+DATE_FORMAT(CURRENT_DATE,"%m")-(DATE_FORMAT(CURRENT_DATE,"00-00-%d")<DATE_FORMAT(birth,"00-00-%d")))
	WHEN 1 THEN(DATE_FORMAT(CURRENT_DATE,"%m")-DATE_FORMAT(birth,"%m")-(DATE_FORMAT(CURRENT_DATE,"00-00-%d")<DATE_FORMAT(birth,"00-00-%d")))END
	," เดือน  ",CASE SIGN(DATE_FORMAT(CURRENT_DATE,"%d")-DATE_FORMAT(birth,"%d"))WHEN 0 THEN(DATE_FORMAT(birth,"%d")-DATE_FORMAT(CURRENT_DATE,"%d"))
	WHEN -1 THEN(DATE_FORMAT(LAST_DAY(birth),"%d")+DATE_FORMAT(CURRENT_DATE,"%d")-DATE_FORMAT(birth,"%d"))
	WHEN 1 THEN(DATE_FORMAT(CURRENT_DATE,"%d")-DATE_FORMAT(birth,"%d")-(DATE_FORMAT(CURRENT_DATE,"%d")<DATE_FORMAT(birth,"%d")))END," วัน")USING utf8)AS age_ymd,
     CASE person.`sex` WHEN '1'THEN 'ชาย'WHEN '2'THEN 'หญิง'ELSE 'ไม่ระบุ'END AS person_sex,
     coccupa.`occupaname` AS coccupa_occupaname,
     creligion.`religionname` AS creligion_religionname,
     cstatus.`statusname` AS cstatus_statusname,
     cnation.`nationname` AS cnation_nationname,
     allergic,
     visitancpregnancy.`pregno` AS visitancpregnancy_pregno,
     visitancpregnancy.`firstdatecheck` AS visitancpregnancy_firstdatecheck,
     DATE_FORMAT(visitancpregnancy.`lmp`,"%Y-%m-%d") AS visitancpregnancy_lmp,
     visitancpregnancy.`fpbefore` AS visitancpregnancy_fpbefore,
     visitancpregnancy.`firstabnormal` AS visitancpregnancy_firstabnormal,
     DATE_FORMAT(visitancpregnancy.`edc`,"%Y-%m-%d") AS visitancpregnancy_edc
FROM
      person
	LEFT OUTER JOIN  cprovince ON  person.`provcodemoi`=cprovince.`provcode`
     	LEFT OUTER JOIN `cdistrict` cdistrict ON person.`provcodemoi` = cdistrict.`provcode`
     		AND cdistrict.`distcode` = person.`distcodemoi`
     	LEFT OUTER JOIN `csubdistrict` csubdistrict ON person.`provcodemoi` = csubdistrict.`provcode`
     		AND csubdistrict.`distcode` = person.`distcodemoi`
     		AND csubdistrict.`subdistcode` = person.`subdistcodemoi`
     	LEFT OUTER JOIN `coccupa` coccupa ON person.`occupa` = coccupa.`occupacode`
     	LEFT OUTER JOIN `creligion` creligion ON person.`religion` = creligion.`religioncode`
     	LEFT OUTER JOIN `cstatus` cstatus ON person.`marystatus` = cstatus.`statuscode`
     	LEFT OUTER JOIN `cnation` cnation ON person.`nation` = cnation.`nationcode`
        LEFT OUTER JOIN `ctitle` ctitle ON person.`prename` = ctitle.`titlecode`
     	INNER JOIN `visitancpregnancy` visitancpregnancy ON person.`pcucodeperson` = visitancpregnancy.`pcucodeperson`
     		AND person.`pid` = visitancpregnancy.`pid`
       
WHERE
     person.pcucodeperson = '$P!{p_pcucode}'
     and person.pid = '$P!{p_pid}']]></queryString>

