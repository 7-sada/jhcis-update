	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_visitno" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(0)]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     cdrug.`drugname` AS cdrug_drugname,
     v.`unit` AS visitdrug_unit,
     v.`dose` AS visitdrug_dose,
     cdrug.`unitsell` AS cdrug_unitsell
FROM
     `visitdrug` v INNER JOIN `cdrug` cdrug ON v.`drugcode` = cdrug.`drugcode`
WHERE
     v.pcucode = '$P!{p_pcucode}'
     and v.visitno = '$P!{p_visitno}']]></queryString>

