<jasperReport
		 name="familyfolder_sickhistory_visit_drug"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="160"
		 pageHeight="842"
		 columnWidth="160"
		 columnSpacing="0"
		 leftMargin="0"
