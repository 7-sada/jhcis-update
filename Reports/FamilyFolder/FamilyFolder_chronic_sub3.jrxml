	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["3741"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["D:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     cdisease.`diseasenamethai` AS cdisease_diseasename,
     date_format(visit.`visitdate`,'%Y-%m-%d') AS visit_visitdate,
     visit.`pressurelevel` AS visit_pressurelevel,
     visit.`pressure` AS visit_pressure,
     visit.`weight` AS visit_weight,
     visit.`symptoms` AS visit_symptoms,
     visit.`visitno` AS visitno,
     visitdiag.diagcode AS diagcode,
     date_format(visitdiag.`appointdate`,'%Y-%m-%d') AS visitdiag_appointdate,
     cdisease.diseasenamethai AS cdisease_codechronic,
     visitlabsugarurine.`sugarlevel` AS visitlabsugarurine_sugarlevel,
     visitlabsugarblood.`sugarnumdigit` AS visitlabsugarblood_sugarnumdigit
FROM
     `cdisease` cdisease INNER JOIN `visitdiag` visitdiag ON cdisease.`diseasecode` = visitdiag.`diagcode`
     INNER JOIN `visit` visit ON visitdiag.`pcucode` = visit.`pcucode`
     AND visit.`visitno` = visitdiag.`visitno`
     LEFT OUTER JOIN `visitlabsugarblood` visitlabsugarblood ON visit.`pcucode` = visitlabsugarblood.`pcucode`
     AND visit.`visitno` = visitlabsugarblood.`visitno`
     LEFT OUTER JOIN `visitlabsugarurine` visitlabsugarurine ON visit.`pcucode` = visitlabsugarurine.`pcucode`
     AND visit.`visitno` = visitlabsugarurine.`visitNo`
WHERE
     visit.pcucodeperson = '$P!{p_pcucode}'
     and visit.pid = '$P!{p_pid}'
     AND (cdisease.codechronic is not null and cdisease.codechronic <> '00')]]></queryString>

