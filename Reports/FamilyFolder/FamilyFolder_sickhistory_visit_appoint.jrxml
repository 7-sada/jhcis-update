<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="familyfolder_sickhistory_visit_appoint"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="160"
		 pageHeight="842"
		 columnWidth="160"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_visitno" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(1)]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(v.appointdate,"%Y-%m-%d") AS v_appointdate,
     v.`appointtype` AS v_appointtype,
     v.`remark` AS v_remark
FROM
     `visitdiag` v INNER JOIN `cdisease` cdisease ON v.`diagcode` = cdisease.`diseasecode`
WHERE
     v.pcucode = '$P!{p_pcucode}'
     and v.visitno = '$P!{p_visitno}']]></queryString>

	<field name="v_appointdate" class="java.util.Date"/>
	<field name="v_appointtype" class="java.lang.String"/>
	<field name="v_remark" class="java.lang.String"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="36"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="true" pattern="d MMM yy" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						mode="Transparent"
						x="0"
						y="0"
						width="112"
						height="17"
						backcolor="#0099FF"
						key="textField-1"
						positionType="Float"
						isPrintInFirstWholeBand="true"
						isPrintWhenDetailOverflows="true"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement>
						<font fontName="Tahoma"/>
					</textElement>
				<textFieldExpression   class="java.util.Date"><![CDATA[$F{v_appointdate}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						mode="Transparent"
						x="0"
						y="17"
						width="160"
						height="17"
						backcolor="#0099FF"
						key="textField-2"
						positionType="Float"
						isPrintInFirstWholeBand="true"
						isPrintWhenDetailOverflows="true"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement>
						<font fontName="Tahoma"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{v_appointtype}==null || $F{v_appointtype}.length()==0 ?"":
$F{v_appointtype}.equals( "1" )?"รับยา":$F{v_appointtype}.equals( "2" )?"ฟังผล(Follow up)":
$F{v_appointtype}.equals( "3" )?"ทำแผล/ล้าแผล":$F{v_appointtype}.equals( "1" )?"เจาะเลือด":"-"]]></textFieldExpression>
				</textField>
			</band>
		</detail>
		<columnFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnFooter>
		<pageFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageFooter>
		<summary>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</summary>
</jasperReport>
