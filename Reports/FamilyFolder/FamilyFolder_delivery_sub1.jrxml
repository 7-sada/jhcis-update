		<defaultValueExpression ><![CDATA["D:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     date_format(visitancpregnancy.`edc`,'%Y-%m-%d')AS visitancpregnancy_edc,
     date_format(visitancpregnancy.`lmp`,'%Y-%m-%d')AS visitancpregnancy_lmp,
     date_format(visitancdeliver.`datedeliver`,'%Y-%m-%d')AS visitancdeliver_datedeliver,
     floor(datediff(datedeliver,lmp)/7)AS pregagewks,
     datediff(datedeliver,lmp)%7 AS pregagedays,
     visitancdeliver.`operater` AS visitancdeliver_operater,
     visitancdeliver.`delivertime` AS visitancdeliver_delivertime,
     CASE visitancdeliver.`deliverresult` WHEN 'ช'THEN 'ปกติ(เกิดมีชีพ)'WHEN 'ท'THEN 'แท้ง'WHEN 'ต'THEN 'เกิดไร้ชีพ)'END AS visitancdeliver_deliverresult,
     visitancdeliver.`deliverend` AS visitancdeliver_deliverend,
     CASE visitancdeliver.`delivertype` WHEN '1' THEN 'ปกติ' WHEN '2' THEN 'ผ่า' WHEN '3' THEN 'ดูด' WHEN '4' THEN 'คีบ' END AS visitancdeliver_delivertype,
     CASE visitancdeliver.`deliverplace` WHEN '1'THEN 'ในสถานบริการ'WHEN '2'THEN 'นอกสถานบริการ'END AS visitancdeliver_deliverplace,
     visitancdeliver.`dateappointcare` AS visitancdeliver_dateappointcare,
     visitancdeliver.`signabnormalanc` AS visitancdeliver_signabnormalanc,
     visitancdeliver.`signabnormaldeliver` AS visitancdeliver_signabnormaldeliver,
     visitancdeliver.`hosservice` AS visitancdeliver_hosservice,
     visitancpregnancy.`pregno` AS visitancpregnancy_pregno,
     hosname,
     visitancdeliverchild.`childposition` AS visitancdeliverchild_childposition,
     CASE visitancdeliverchild.`delivertype` WHEN '1' THEN 'ปกติ' WHEN '2' THEN 'ผ่า' WHEN '3' THEN 'ดูด' WHEN '4' THEN 'คีบ' END AS visitancdeliverchild_delivertype,
     CASE visitancdeliverchild.`deliverresult` WHEN 'ช'THEN 'ปกติ(เกิดมีชีพ)'WHEN 'ท'THEN 'แท้ง'WHEN 'ต'THEN 'เกิดไร้ชีพ)'END AS visitancdeliverchild_deliverresult,
     visitancdeliverchild.`weight` AS visitancdeliverchild_weight,
     visitancdeliverchild.`tall` AS visitancdeliverchild_tall,
     visitancdeliverchild.`headcycle` AS visitancdeliverchild_headcycle,
     visitancdeliverchild.`a1` AS visitancdeliverchild_a1,
     visitancdeliverchild.`p1` AS visitancdeliverchild_p1,
     visitancdeliverchild.`g1` AS visitancdeliverchild_g1,
     visitancdeliverchild.`x1` AS visitancdeliverchild_x1,
     visitancdeliverchild.`r1` AS visitancdeliverchild_r1,
     visitancdeliverchild.`a5` AS visitancdeliverchild_a5,
     visitancdeliverchild.`p5` AS visitancdeliverchild_p5,
     visitancdeliverchild.`g5` AS visitancdeliverchild_g5,
     visitancdeliverchild.`x5` AS visitancdeliverchild_x5,
     visitancdeliverchild.`r5` AS visitancdeliverchild_r5,
     visitancdeliverchild.`deliverplace` AS visitancdeliverchild_deliverplace,
     visitancdeliverchild.`asphyxia` AS visitancdeliverchild_asphyxia,
     visitancdeliverchild.`childhealth` AS visitancdeliverchild_childhealth,
     visitancdeliverchild.`vitamink` AS visitancdeliverchild_vitamink,
     person.`sex` AS person_sex,
     visitancdeliverchild.`pcucodechild` AS visitancdeliverchild_pcucodechild,
     visitancdeliverchild.`pidchild` AS visitancdeliverchild_pidchild
FROM
     `visitancpregnancy` visitancpregnancy INNER JOIN `visitancdeliver` visitancdeliver ON visitancpregnancy.`pcucodeperson` = visitancdeliver.`pcucodeperson`
     AND visitancpregnancy.`pid` = visitancdeliver.`pid`
     AND visitancpregnancy.`pregno` = visitancdeliver.`pregno`
     LEFT OUTER JOIN `chospital` chospital ON visitancdeliver.`hosservice` = chospital.`hoscode`
     INNER JOIN `visitancdeliverchild` visitancdeliverchild ON visitancdeliver.`pcucodeperson` = visitancdeliverchild.`pcucodeperson`
     AND visitancdeliver.`pid` = visitancdeliverchild.`pid`
     AND visitancdeliver.`pregno` = visitancdeliverchild.`pregno`
     INNER JOIN `person` person ON visitancdeliverchild.`pcucodechild` = person.`pcucodeperson`
     AND person.`pid` = visitancdeliverchild.`pidchild`
WHERE
     visitancpregnancy.pcucodeperson = '$P!{p_pcucode}'
 AND visitancpregnancy.pid = '$P!{p_pid}'
ORDER BY
     visitancdeliver.`pregno` ASC]]></queryString>

