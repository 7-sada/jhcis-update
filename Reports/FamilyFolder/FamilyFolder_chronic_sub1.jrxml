	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["3897"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     personchronic.`pcucodeperson` AS personchronic_pcucodeperson,
     personchronic.`pid` AS personchronic_pid,
     personchronic.`chroniccode` AS personchronic_chroniccode,
     DATE_FORMAT(personchronic.`datefirstdiag`,"%Y-%m-%d")AS personchronic_datefirstdiag,
     DATE_FORMAT(personchronic.`datedxfirst`,"%Y-%m-%d")AS personchronic_datedxfirst,
     personchronic.`cup` AS personchronic_cup,
     personchronic.`behaviorrisk` AS personchronic_behaviorrisk,
     DATE_FORMAT(personchronic.`datedischart`,"%Y-%m-%d")AS personchronic_datedischart,
     personchronic.`typedischart` AS personchronic_typedischart,
     cdisease.`diseasename` AS cdisease_diseasename,
     chospital.`hosname` AS chospital_hosname
FROM
     `cdisease` cdisease INNER JOIN `personchronic` personchronic ON cdisease.`diseasecode` = personchronic.`chroniccode`
     LEFT OUTER JOIN `chospital` chospital ON personchronic.`cup` = chospital.`hoscode`
WHERE
     personchronic.pcucodeperson = '$P!{p_pcucode}'
     and personchronic.pid = '$P!{p_pid}']]></queryString>

