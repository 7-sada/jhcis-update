<jasperReport
		 name="FamilyFolder_nutrition"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["D:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4274"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     person.`pid`,
     concat(person.pcucodeperson,person.pid)as ppid,
     concat(ifnull(ctitle.`titlename`,''),ifnull(`person`.`fname`,''),'  ',ifnull(`person`.`lname`,''))as name,
     ifnull(idcard,'...ไม่ระบุฯ')as idc,
     person.`birth`,
     concat(person.pcucodeperson,'-',person.pid,'/',substring(curdate(),1,4)+543)as hnyear,
     hnomoi,
     mumoi,
     subdistname,
     subdistname,
     distname,
     provname
 FROM `person` person
      LEFT OUTER JOIN `cprovince` cprovince ON cprovince.`provcode` = person.`provcodemoi`
     LEFT OUTER JOIN `cdistrict` cdistrict ON person.`provcodemoi` = cdistrict.`provcode`
     AND cdistrict.`distcode` = person.`distcodemoi`
     LEFT OUTER JOIN `csubdistrict` csubdistrict ON person.`provcodemoi` = csubdistrict.`provcode`
     AND csubdistrict.`subdistcode` = person.`subdistcodemoi`
     AND csubdistrict.`distcode` = person.`distcodemoi`
     LEFT OUTER JOIN `ctitle` ctitle ON person.`prename` = ctitle.`titlecode`

WHERE
     person.pcucodeperson = '$P!{p_pcucode}'
     and person.pid = '$P!{p_pid}']]></queryString>

	<field name="pid" class="java.lang.Integer"/>
	<field name="ppid" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="idc" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="hnyear" class="java.lang.String"/>
	<field name="hnomoi" class="java.lang.String"/>
	<field name="mumoi" class="java.lang.String"/>
	<field name="subdistname" class="java.lang.String"/>
	<field name="distname" class="java.lang.String"/>
	<field name="provname" class="java.lang.String"/>

