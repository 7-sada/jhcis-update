<jasperReport
		 name="rb1k012hosmain"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="850"
		 pageHeight="595"
		 columnWidth="792"
		 columnSpacing="0"
