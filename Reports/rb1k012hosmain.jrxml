	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-10-12"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<property name="sdate" value="&apos;2007-01-01" />
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-05-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select DATE_FORMAT(vanc.datecheck, "%Y-%m-%d") as visitdate,vanc.visitno,vanc.pcucode
     ,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),p.fname,' ',p.lname) USING utf8)as personname,p.birth
     ,CONVERT(CONCAT(  DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), "/",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))  
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  "/",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))  
 	 WHEN 0 THEN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))  
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))  
 	 WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_ymd 
     ,CONVERT(case when p.subdistcodemoi is null  then 'นอกเขต' 
              when p.hnomoi is null then concat(' หมู่ที่ ',  p.`mumoi` ,' ต.',  csubd.`subdistname` )
              when p.mumoi is null then concat(p.`hnomoi`  ,' ต.',  csubd.`subdistname` )
              else concat(p.`hnomoi` ,' หมู่ที่ ',  p.`mumoi` ,' ต.',  csubd.`subdistname` ) end   USING utf8)  as address
     ,cd.distname,cpr.provname
    ,case when  vanc.ttno35= 'tt_in_Scop' then 'ระยะฯ'  
                      when (visitepi.visitno = vanc.visitno and visitepi.pcucode = vanc.pcucode and visitepi.dateepi = vanc.datecheck )  then MAX(visitepi.vaccinecode)
                      else '-' end   as vacc
     ,DATE_FORMAT(vanc.datecheck,"%Y-%m-%d") AS dateckeck
     ,vanc.caries
     ,case when vanc.gumfail=0 then 'ไม่พบ'       when vanc.gumfail=1 then 'พบ'  else '-' end  as gumfail
     ,case when vanc.tartar=0 then 'ไม่พบ'       when vanc.tartar=1 then 'พบ' else '-' end  as tartar
     ,(select Max(anc.ancno) from visitanc anc  where vanc.pid = anc.pid and vanc.pcucodeperson = anc.pcucodeperson and vanc.pregno = anc.pregno ) as ancno
     ,p.idcard
     ,v.rightno,v.rightcode
     ,CONVERT(case when cright.rightname is null then 'ไม่ระบุสิทธิ' else rightname end USING utf8) AS rightname
     ,vancdel.operater,vancdel.deliverresult
     ,case when (select count(pregno)  from visitancmothercare vv where vancdel.pid = vv.pid and vancdel.pcucodeperson  =vv.pcucodeperson  and vv.pregno = vancdel.pregno and vv.datecare >= vancdel.datedeliver group by vv.pid,vv.pcucodeperson )is null then "ยังไม่ตรวจ" else "ตรวจแล้ว" end as dd
     ,chospital.hosname as hosname
     ,CONVERT(concat(chospital.`hosname`,' ต.',csubdistricth.`subdistname`) USING utf8) AS hostname
     ,cdistricth.`distname` as dnameh ,cprovinceh.`provname` as pnameh
     ,chospitalc.hosname as subname
     ,chospitalm.hosname as hosmain
    
from   visitanc vanc
      left join person p on p.pid = vanc.pid   and p.pcucodeperson  = vanc.pcucodeperson 
      left join ctitle on p.prename = ctitle.titlecode
      left join visit v on p.pid = v.pid and p.pcucodeperson = v.pcucodeperson	
left join visitepi on vanc.visitno = visitepi.visitno and vanc.pcucode = visitepi.pcucode and vanc.datecheck = visitepi.dateepi
      left join visitancmothercare vm  on p.pid = vm.pid and v.pcucodeperson  = vm.pcucodeperson 
      left join visitancdeliver vancdel on v.visitno = vancdel.visitno and v.pcucode  = vancdel.pcucode and vanc.pregno = vancdel.pregno
      left join cright on v.rightcode = cright.rightcode
      left join csubdistrict csubd on p.subdistcodemoi = csubd.subdistcode and p.distcodemoi = csubd.distcode and p.provcodemoi = csubd.provcode
      left join cdistrict cd on p.distcodemoi = cd.distcode and p.provcodemoi = cd.provcode
      left join cprovince cpr on p.provcodemoi = cpr.provcode
      left join `chospital` chospital ON v.`pcucode` = chospital.`hoscode`  
      left join `csubdistrict` csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
      left join `cdistrict` cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
      left join `cprovince` cprovinceh ON chospital.provcode = cprovinceh.provcode
      left join `chospital` chospitalc ON v.`hossub` = chospitalc.`hoscode` 
      left join `chospital` chospitalm ON v.`hosmain` = chospitalm.`hoscode` 
      left join house ON p.hcode = house.hcode and p.pcucodeperson = house.pcucode
      left join village ON house.villcode = village.villcode  and village.pcucode = v.pcucode
where  vanc.datecheck between $P{sdate} and $P{edate} 
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
     and sex ='2'
      $P!{pcucode}
group by vanc.pid,vanc.pcucodeperson
order by v.pcucode,v.hosmain,vanc.datecheck]]></queryString>

