<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="stockcard"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="dateRepStart" isForPrompting="false" class="java.util.Date"/>
	<parameter name="dateRepEnd" isForPrompting="false" class="java.util.Date"/>
	<parameter name="drugbf" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(20)]]></defaultValueExpression>
	</parameter>
	<parameter name="whereDrug" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND d.drugcode = '1PRC' "]]></defaultValueExpression>
	</parameter>
	<parameter name="whereDateIn" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND  t.takendate between '2009-01-01' AND '2011-05-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="whereDateOut" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND o.outdate between '2009-01-01' AND '2011-05-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="drug" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["Paracetamol"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'15102'"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 1,DATE_FORMAT(t.takendate,'%Y-%m-%d') AS rdate,if(t.companyname is null,'-',t.companyname) AS companyname ,t.takenno AS 'taken/out', t.realno,d.lotno AS 'lot',CONCAT(d.packamount,' X') AS 'packamnunt', sum(d.lotamount) AS 'taken' ,0 AS 'out'
FROM drugrepositorytaken t inner join drugrepositorytakendetail d on t.takenno = d.takenno 
WHERE t.pcucode=$P!{pcucode} $P!{whereDrug} $P!{whereDateIn}
group by rdate, 'receive/out' 
UNION 
SELECT 1,DATE_FORMAT(o.outdate,'%Y-%m-%d') AS rdate,if(o.companyname is null,'-',o.companyname) AS companyname,o.outno,o.realno,d.lotno AS 'lot',CONCAT(d.packamount,' X') AS 'packamnunt', 0, sum(d.lotamount)
FROM drugrepositoryout o inner join drugrepositoryoutdetail d on o.outno = d.outno 
WHERE o.pcucode=$P!{pcucode} $P!{whereDrug} $P!{whereDateOut}
group by rdate, 'receive/out' 
ORDER BY rdate ASC]]></queryString>

	<field name="1" class="java.lang.Long"/>
	<field name="rdate" class="java.util.Date"/>
	<field name="companyname" class="java.lang.String"/>
	<field name="taken/out" class="java.lang.Integer"/>
	<field name="realno" class="java.lang.String"/>
	<field name="lot" class="java.lang.String"/>
	<field name="packamnunt" class="java.lang.String"/>
	<field name="taken" class="java.lang.Integer"/>
	<field name="out" class="java.lang.Integer"/>

	<variable name="accumulative_sum" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[new java.lang.Integer(  ($F{taken}.intValue()) -($F{out}.intValue()) )]]></variableExpression>
	</variable>
	<variable name="sum_taken" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{taken}]]></variableExpression>
	</variable>
	<variable name="sum_out" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{out}]]></variableExpression>
	</variable>

