	<variable name="reportHeader" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA["รายงานความครอบคลุมได้รับวัคซีนเด็กอายุครบ "+$P{age}+"  ปี "]]></variableExpression>
	</variable>
	<variable name="note" class="java.lang.String" resetType="None">
