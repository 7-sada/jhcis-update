<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="epi_0_5year_cover" pageWidth="846" pageHeight="595" orientation="Landscape" columnWidth="800" leftMargin="30" rightMargin="16" topMargin="20" bottomMargin="28" uuid="8a3ff1c8-641e-47ca-99b6-15fb883b37ff">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="48"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2009-10-26"]]></defaultValueExpression>
	</parameter>
	<parameter name="villno" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="monTh" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT visitepi.pid,visitepi.pcucodeperson,person.birth as bb,DATE_FORMAT(person.birth,'%Y-%m-%d' ) as birth
,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),' ',person.fname,'  ',person.lname) using utf8)  as name
,ROUND(DATEDIFF($P{pdate},birth) /30) AS age_ymd
,village.villno,person.hnomoi,person.father,person.mother
,visitepi.visitno,visitepi.pcucode
,house.hno AS hno_or_not
,village.villname, village.villno,sdt.subdistname,dt.distname,pp.provname
,chospital.hosname,cprovince.provname,cdistrict.distname,dateepi
,(select DATE_FORMAT(v1.dateepi,'%Y-%m-%d') from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='DTP1' group by v1.pid and v1.pcucodeperson) as dtp1
,(select DATE_FORMAT(v2.dateepi,'%Y-%m-%d') from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='DTP2' group by v2.pid and v2.pcucodeperson) as dtp2
,(select DATE_FORMAT(v3.dateepi,'%Y-%m-%d') from visitepi v3 where visitepi.pid = v3.pid and visitepi.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='DTP3' group by v3.pid and v3.pcucodeperson) as dtp3
,(select DATE_FORMAT(v4.dateepi,'%Y-%m-%d') from visitepi v4 where visitepi.pid = v4.pid and visitepi.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='DTP4' group by v4.pid and v4.pcucodeperson) as dtp4
,(select DATE_FORMAT(v5.dateepi,'%Y-%m-%d') from visitepi v5 where visitepi.pid = v5.pid and visitepi.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='DTP5' group by v5.pid and v5.pcucodeperson) as dtp5
,(select DATE_FORMAT(v1.dateepi,'%Y-%m-%d') from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='DHB1' group by v1.pid and v1.pcucodeperson) as dhb1
,(select DATE_FORMAT(v2.dateepi,'%Y-%m-%d') from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='DHB2' group by v2.pid and v2.pcucodeperson) as dhb2
,(select DATE_FORMAT(v3.dateepi,'%Y-%m-%d') from visitepi v3 where visitepi.pid = v3.pid and visitepi.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='DHB3' group by v3.pid and v3.pcucodeperson) as dhb3
,(select DATE_FORMAT(v16.dateepi,'%Y-%m-%d') from visitepi v16 where visitepi.pid = v16.pid and visitepi.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='HBV1' group by v16.pid and v16.pcucodeperson) as hbv1
,(select DATE_FORMAT(v6.dateepi,'%Y-%m-%d') from visitepi v6 where visitepi.pid = v6.pid and visitepi.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='HBV2' group by v6.pid and v6.pcucodeperson) as hbv2
,(select DATE_FORMAT(v7.dateepi,'%Y-%m-%d') from visitepi v7 where visitepi.pid = v7.pid and visitepi.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='HBV3' group by v7.pid and v7.pcucodeperson) as hbv3
,(select DATE_FORMAT(v8.dateepi,'%Y-%m-%d') from visitepi v8 where visitepi.pid = v8.pid and visitepi.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='JE1'  group by v8.pid and v8.pcucodeperson) as je1
,(select DATE_FORMAT(v9.dateepi,'%Y-%m-%d') from visitepi v9 where visitepi.pid = v9.pid and visitepi.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='JE2'  group by v9.pid and v9.pcucodeperson) as je2
,(select DATE_FORMAT(v15.dateepi,'%Y-%m-%d') from visitepi v15 where visitepi.pid = v15.pid and visitepi.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='JE3'  group by v15.pid and v15.pcucodeperson) as je3
,(select DATE_FORMAT(v10.dateepi,'%Y-%m-%d') from visitepi v10 where visitepi.pid = v10.pid and visitepi.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='OPV1' group by v10.pid and v10.pcucodeperson) as opv1
,(select DATE_FORMAT(v11.dateepi,'%Y-%m-%d') from visitepi v11 where visitepi.pid = v11.pid and visitepi.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='OPV2' group by v11.pid and v11.pcucodeperson) as opv2
,(select DATE_FORMAT(v12.dateepi,'%Y-%m-%d') from visitepi v12 where visitepi.pid = v12.pid and visitepi.pcucodeperson=v12.pcucodeperson and v12.vaccinecode='OPV3' group by v12.pid and v12.pcucodeperson) as opv3
,(select DATE_FORMAT(v13.dateepi,'%Y-%m-%d') from visitepi v13 where visitepi.pid = v13.pid and visitepi.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='OPV4' group by v13.pid and v13.pcucodeperson) as opv4
,(select DATE_FORMAT(v14.dateepi,'%Y-%m-%d') from visitepi v14 where visitepi.pid = v14.pid and visitepi.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='OPV5' group by v14.pid and v14.pcucodeperson) as opv5
,(select DATE_FORMAT(v17.dateepi,'%Y-%m-%d') from visitepi v17 where visitepi.pid = v17.pid and visitepi.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='BCG' group by v17.pid and v17.pcucodeperson) as bcg
,(select DATE_FORMAT(v18.dateepi,'%Y-%m-%d') from visitepi v18 where visitepi.pid = v18.pid and visitepi.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='MEAS' group by v18.pid and v18.pcucodeperson) as meas
,(select DATE_FORMAT(v18.dateepi,'%Y-%m-%d') from visitepi v18 where visitepi.pid = v18.pid and visitepi.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='MMR' group by v18.pid and v18.pcucodeperson) as mmr

FROM visit v
          left join visitepi on v.visitno = visitepi.visitno and v.pcucode = visitepi.pcucode
   	  left join person on (person.pid = visitepi.pid and person.pcucodeperson = visitepi.pcucodeperson)
	  left join ctitle on person.prename = ctitle.titlecode
	  left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	  left join village ON house.villcode = village.villcode and person.pcucodeperson = village.pcucode
          left join chospital ON (village.pcucode = chospital.hoscode)
	  left join cprovince ON (cprovince.provcode =chospital.provcode)
          left join cdistrict ON (cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode)
	  left join csubdistrict sdt on (sdt.subdistcode = person.subdistcodemoi and sdt.distcode = person.distcodemoi and sdt.provcode = person.provcodemoi)
          left join cdistrict dt on (dt.provcode = person.provcodemoi and dt.distcode = person.distcodemoi)
   	  left join cprovince pp on (pp.provcode = person.provcodemoi)
WHERE month($P{pdate})=month(birth) and (year($P{pdate})-year(birth)= $P{age})
        and substring(visitepi.vaccinecode,0,2) <> 'TT'
	and (birth IS NOT NULL OR birth NOT LIKE '0000%')
        and person.pid NOT IN (SELECT persondeath.pid FROM persondeath WHERE persondeath.pcucodeperson=$P{pcucode} and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{pdate}))
#and village.villno >= $P{villno}
$P!{pcucode}
group by visitepi.pid,visitepi.pcucodeperson
ORDER BY v.pcucode,village.villcode,person.birth DESC]]>
	</queryString>
