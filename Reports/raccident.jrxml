	<parameter name="DateRepStart_1" class="java.util.Date" isForPrompting="false"/>
	<parameter name="offAddress_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01838"]]></defaultValueExpression>
	</parameter>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="endDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2008-03-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="startDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2008-01-01"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT COUNT(DISTINCT IF((vd.diagcode BETWEEN 'V20' AND 'V29.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as v2029m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'V20' AND 'V29.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as v2029f,
 COUNT(DISTINCT IF(((vd.diagcode BETWEEN 'V01' AND 'V19.9' OR vd.diagcode BETWEEN 'V30' AND 'V89') AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as v0189m,
 COUNT(DISTINCT IF(((vd.diagcode BETWEEN 'V01' AND 'V19.9' OR vd.diagcode BETWEEN 'V30' AND 'V89') AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as v0189f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'V90' AND 'V99.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as v9099m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'V90' AND 'V99.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as v9099f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W00' AND 'W19.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as w0019m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W00' AND 'W19.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as w0019f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W20' AND 'W49.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as w2049m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W20' AND 'W49.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as w2049f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W50' AND 'W64.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as w5064m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W50' AND 'W64.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as w5064f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W65' AND 'W74.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as w6574m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W65' AND 'W74.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as w6574f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W75' AND 'W84.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as w7584m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W75' AND 'W84.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as w7584f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W85' AND 'W99.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as w8599m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'W85' AND 'W99.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as w8599f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X00' AND 'X09.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x0009m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X00' AND 'X09.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x0009f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X10' AND 'X19.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x1019m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X10' AND 'X19.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x1019f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X20' AND 'X29.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x2029m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X20' AND 'X29.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x2029f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X30' AND 'X39.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x3039m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X30' AND 'X39.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x3039f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X40' AND 'X49.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x4049m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X40' AND 'X49.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x4049f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X50' AND 'X57.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x5057m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X50' AND 'X57.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x5057f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X58' AND 'X59.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x5859m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X58' AND 'X59.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x5859f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X60' AND 'X84.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x6084m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'X60' AND 'X84.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x6084f,
 COUNT(DISTINCT IF(((vd.diagcode BETWEEN 'X85' AND 'X99.9' OR vd.diagcode BETWEEN 'Y00' AND 'Y09') AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as x8599m,
 COUNT(DISTINCT IF(((vd.diagcode BETWEEN 'X85' AND 'X99.9' OR vd.diagcode BETWEEN 'Y00' AND 'Y09') AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as x8599f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'Y10' AND 'Y33.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as y1033m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'Y10' AND 'Y33.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as y1033f,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'Y35' AND 'Y36.9' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as y3536m,
 COUNT(DISTINCT IF((vd.diagcode BETWEEN 'Y35' AND 'Y36.9' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as y3536f,
 COUNT(DISTINCT IF((vd.diagcode = 'Y34' AND p.sex = '1'),CONCAT(vd.pcucode,vd.visitno),null)) as y34m,
 COUNT(DISTINCT IF((vd.diagcode = 'Y34' AND p.sex = '2'),CONCAT(vd.pcucode,vd.visitno),null)) as y34f,
 COUNT(DISTINCT IF(((vd.diagcode BETWEEN 'V01' AND 'V99.9' OR vd.diagcode BETWEEN 'W00' AND 'W99.9' OR vd.diagcode BETWEEN 'X00' AND 'X99.9' OR vd.diagcode BETWEEN 'Y00' AND 'Y34.9') AND p.sex = '1' AND v.refer = '01'),CONCAT(vd.pcucode,vd.visitno),null)) as referm,
 COUNT(DISTINCT IF(((vd.diagcode BETWEEN 'V01' AND 'V99.9' OR vd.diagcode BETWEEN 'W00' AND 'W99.9' OR vd.diagcode BETWEEN 'X00' AND 'X99.9' OR vd.diagcode BETWEEN 'Y00' AND 'Y34.9') AND p.sex = '2' AND v.refer = '01'),CONCAT(vd.pcucode,vd.visitno),null)) as referf
FROM visitdiag vd INNER JOIN visit v ON v.visitno=vd.visitno AND v.pcucode=vd.pcucode
INNER JOIN person p ON p.pcucodeperson=v.pcucodeperson AND p.pid=v.pid
WHERE v.visitdate BETWEEN $P{startDate} AND  $P{endDate}
AND v.pcucode LIKE $P{pcucode}]]>
	</queryString>
