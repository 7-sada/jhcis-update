	<parameter name="where" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" WHERE  v.pcucode = '01856' AND v.visitdate BETWEEN  '2008-01-01' AND '2009-05-30'"]]></defaultValueExpression>
	</parameter>
