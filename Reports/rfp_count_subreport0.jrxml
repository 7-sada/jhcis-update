	<parameter name="DateFp" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[$P{DateFp}]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" AND datefp BETWEEN ('2008-12-01') AND ('2008-12-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND `visitfp`.`pcucode`='07260' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
`cdrug`.`drugname`,
Sum(`visitfp`.`pregtestunit`)
FROM
`visitfp`
Right Outer Join `cdrug` ON (`cdrug`.`drugcode` = `visitfp`.`pregtest`   ) 
WHERE `cdrug`.`drugtype` = '04' AND `cdrug`.`drugtypesub` = '0' AND cdrug.drugcode <> 'fp0000'  
$P!{pcucode} 
$P!{DateFp}
GROUP BY
`cdrug`.`drugname`]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="Sum(`visitfp`.`pregtestunit`)" class="java.lang.Double"/>

