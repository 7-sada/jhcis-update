		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[06326]]></parameterDescription>
		<defaultValueExpression ><![CDATA["'06326'"]]></defaultValueExpression>
	</parameter>
	<parameter name="vn" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[new Integer(2054)]]></parameterDescription>
		<defaultValueExpression ><![CDATA["'58039'"]]></defaultValueExpression>
	</parameter>
	<parameter name="appdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2010-11-24'"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT distinct 
cdisease.diseasenamethai AS disease,
CASE
when visitdiagappoint.appotype=1 then 'รับยาฯ...'
when visitdiagappoint.appotype=2 then 'ติดตามผลการรักษา(Follow Up)...'
when visitdiagappoint.appotype=3 then 'ทำแผล/ล้างแผล'
when visitdiagappoint.appotype=4 then 'เจาะเลือด'
when visitdiagappoint.appotype=5 then 'ตรวจน้ำตาล(DTX)'
when visitdiagappoint.appotype=6 then 'วัดความดันฯ'
else 'ไม่ระบุประเภทการนัด...' end AS `type`,
visitdiagappoint.`comment`
FROM visitdiagappoint 
Left Outer Join cdisease ON visitdiagappoint.diagcode = cdisease.diseasecode
WHERE
visitdiagappoint.visitno =  $P!{vn} AND visitdiagappoint.pcucode=$P!{pcucode} AND visitdiagappoint.appodate=$P!{appdate}]]></queryString>

	<field name="disease" class="java.lang.String"/>
	<field name="type" class="java.lang.String"/>
	<field name="comment" class="java.lang.String"/>

