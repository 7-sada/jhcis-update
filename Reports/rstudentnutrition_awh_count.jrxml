	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band height="115" splitType="Stretch">
			<staticText>
				<reportElement uuid="d33513fd-58cd-411d-bd9e-268661cf496c" key="staticText-1" x="0" y="0" width="383" height="18"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma"/>
				</textElement>
				<text><![CDATA[รายงานการติดตามภาวะโภชนาการเด็กนักเรียน : อายุ(เดือน) / น้ำหนัก(กก.) / ส่วนสูง(ซม.) -->]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="540b6ea3-8bf2-474a-8923-8061e97db73f" key="staticText-2" x="0" y="40" width="801" height="13"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  1.โปรแกรมคำนวณภาวะโภชนาการโดยคิดจากการชั่ง นน.และวัดส่วนสูง(ต้องชั่ง นน.และวัดส่วนสูงทั้ง 2 อย่าง) ครั้งล่าสุดของแต่ละเทอมฯ (เทอม 1->พค.-ตค. ของปีการศึกษา / เทอม 2 พย.ของปีการศึกษานั้น - เมย. ของปีถัดไป) ]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="6a3ac8a0-60e6-4560-b85d-cdb93f0e1627" key="staticText-3" x="0" y="53" width="801" height="13"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  2.จำนวนเด็กที่รับการตรวจโภชนาการตามสูตร:ส่วนสูง/น้ำหนักนี้จะต้องบันทึกน้ำหนักและส่วนสูงทั้ง 2 ค่า (ถ้ามีเพียงค่าใดค่าหนึ่งจะไม่นับจำนวนให้ในสูตรนี้ฯ) ดังนั้นเด็กตามสูตรนี้อาจไม่เท่ากับอีก 2 สูตร(อายุ/น้ไหนัก และ อายุ/ส่วนสูง)]]></text>
			</staticText>
			<textField isBlankWhenNull="false">
				<reportElement uuid="3f648e2d-cd48-41fd-bbcf-50d35f798cec" key="textField" x="383" y="0" width="416" height="18"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{team}+": "+$P{dTerm}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement uuid="e152474b-25d1-4d92-bea3-9a4432915046" key="staticText-49" x="0" y="66" width="782" height="13"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  3.จำนวนที่แปรผลไม่ได้ หมายถึง เด็กที่ส่วนสูง(ความยาว) ไม่ถึง 50 ซม. หรือส่วนสูงเกิน 180 ซม. ซึ่งไม่มีตัวเลขแปรผลในตารางค่าภาวะโภชนาการฯ หรือเด็กที่ไม่มีวันเดือนปีเกิด]]></text>
			</staticText>
			<textField isBlankWhenNull="false">
				<reportElement uuid="b46c680c-061a-48e6-8282-a20b8b1fbd38" key="textField-7" x="0" y="18" width="782" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma"/>
				</textElement>
				<textFieldExpression><![CDATA["สถานพยาบาล (สถานีอนามัย) "+$P{offAddress}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement uuid="ca5a237d-3b52-4363-8455-64c2817f4fca" key="staticText-3" x="1" y="81" width="782" height="16" forecolor="#FF0000"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  1. แสดงการคำนวณโภชนาการเฉพาะนักเรียนชั้น อนุบาล 1 - ม. 3 (เพื่อให้สอดคล้องกับรายงานจำนวนนักเรียน(ที่แสดงจำนวนฯ ถึงชั้น ม. 3))]]></text>
			</staticText>
			<textField>
				<reportElement uuid="5c62d31b-e436-4d3f-9278-c50c8c40b401" x="49" y="97" width="730" height="16"/>
				<textElement/>
				<textFieldExpression><![CDATA["2. "+$P{dTerm}]]></textFieldExpression>
			</textField>
		</band>
