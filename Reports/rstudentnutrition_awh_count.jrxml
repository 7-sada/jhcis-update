	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="team" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND villageschool.pcucode='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="dateservice" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND studenthealthnutrition.dateservice Between '2009-05-01' And '2009-10-30' "]]></defaultValueExpression>
	</parameter>
	<parameter name="persondeath" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath)"]]></defaultValueExpression>
	</parameter>
	<parameter name="dTerm" class="java.lang.String"/>
	<queryString>
		<![CDATA[(
SELECT  personstudent.pid,cschoolclass.classcode,
if(villageschool.schoolname is null,'ไม่ระบุฯ',villageschool.schoolname) as schoolname,
if(cschoolclass.classname is null,'ไม่ระบุฯ',cschoolclass.classname) as classname,
person.sex,
v.weight as weight,
v.tall as hight
,v.agemonth
FROM
personstudent
left JOIN(
	SELECT n.pcucodeperson ,n.pid ,MAX(n.mvd) as vd ,n.weight,n.tall
,getagemonth(n.birth,mvd) as agemonth
	FROM(
  SELECT v.pcucodeperson,v.pid,v.visitdate mvd,n.visitno,n.weight,n.tall
,birth
  from visit v join visitnutrition n
  on v.pcucode = n.pcucode and v.visitno = n.visitno
JOIN person p ON v.pcucodeperson=p.pcucodeperson AND v.pid=p.pid
  WHERE 1=1 $P!{dateservice}
  ORDER BY v.pid ,v.visitdate DESC
  ) AS n 	GROUP BY n.pid
) AS v ON personstudent.pcucodeperson=v.pcucodeperson AND personstudent.pid=v.pid
Left Outer Join villageschool ON personstudent.pcucode = villageschool.pcucode AND personstudent.villcode = villageschool.villcode AND personstudent.schoolno = villageschool.schoolno
Left Outer Join cschoolclass ON personstudent.classeducate = cschoolclass.classcode
Left Outer Join person ON personstudent.pcucodeperson = person.pcucodeperson AND personstudent.pid = person.pid
WHERE classeducate <13 ##AND v.weight IS NOT NULL AND v.tall IS NOT NULL
##$P!{dateservice}
$P!{pcucode}
$P!{persondeath}
)
UNION
(
SELECT  personstudent.pid,cschoolclass.classcode,
if(villageschool.schoolname is null,'ไม่ระบุฯ',villageschool.schoolname) as schoolname,
if(cschoolclass.classname is null,'ไม่ระบุฯ',cschoolclass.classname) as classname,
person.sex,
#null agemonth,
null weight,
null hight
,null agemonth
FROM
personstudent
Left Join villageschool ON personstudent.pcucode = villageschool.pcucode AND personstudent.villcode = villageschool.villcode AND personstudent.schoolno = villageschool.schoolno
Left Join cschoolclass ON personstudent.classeducate = cschoolclass.classcode
Left Join person ON personstudent.pcucodeperson = person.pcucodeperson AND personstudent.pid = person.pid
WHERE CONCAT(personstudent.pcucodeperson,personstudent.pid) not in (SELECT CONCAT(studenthealthnutrition.pcucodeperson,studenthealthnutrition.pid) FROM studenthealthnutrition WHERE studenthealthnutrition.weight IS NOT NULL
#$P!{dateservice}
)
 and classeducate <13
$P!{pcucode}
$P!{persondeath}
)
ORDER BY schoolname,classcode]]>
	</queryString>
