	<parameter name="p_sqlDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlOffice" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT

sum(CASE WHEN b.sex='1' and  a.org_code='99'  THEN 1 ELSE 0 END) AS m99 ,
sum(CASE WHEN b.sex='2' and  a.org_code='99'  THEN 1 ELSE 0 END) AS w99 ,
sum(CASE WHEN  a.org_code='99'  THEN 1 ELSE 0 END) AS total99 ,

sum(CASE WHEN b.sex='1' and a.org_code='01'  THEN 1 ELSE 0 END) AS m01 ,
sum(CASE WHEN b.sex='2' and a.org_code='01'  THEN 1 ELSE 0 END) AS w01 ,
sum(CASE WHEN a.org_code='01'  THEN 1 ELSE 0 END) AS total01 ,

sum(CASE WHEN b.sex='1' and a.org_code='02'  THEN 1 ELSE 0 END) AS m02 ,
sum(CASE WHEN b.sex='2' and a.org_code='02'  THEN 1 ELSE 0 END) AS w02 ,
sum(CASE WHEN a.org_code='02'  THEN 1 ELSE 0 END) AS total02 ,

sum(CASE WHEN b.sex='1' and a.org_code='03'  THEN 1 ELSE 0 END) AS m03 ,
sum(CASE WHEN b.sex='2' and a.org_code='03'  THEN 1 ELSE 0 END) AS w03 ,
sum(CASE WHEN a.org_code='03'  THEN 1 ELSE 0 END) AS total03 ,

sum(CASE WHEN b.sex='1' and a.org_code='04'  THEN 1 ELSE 0 END) AS m04 ,
sum(CASE WHEN b.sex='2' and a.org_code='04'  THEN 1 ELSE 0 END) AS w04 ,
sum(CASE WHEN a.org_code='04'  THEN 1 ELSE 0 END) AS total04 ,

sum(CASE WHEN b.sex='1' and a.org_code='05'  THEN 1 ELSE 0 END) AS m05 ,
sum(CASE WHEN b.sex='2' and a.org_code='05'  THEN 1 ELSE 0 END) AS w05 ,
sum(CASE WHEN  a.org_code='05'  THEN 1 ELSE 0 END) AS total05

FROM
     `ncd_person_ncd_hist_detail` a
     INNER JOIN ncd_person_ncd_screen ON a.`pcucode` = ncd_person_ncd_screen.`pcucode` AND a.`pid` = ncd_person_ncd_screen.`pid`
     INNER JOIN `ncd_person` b ON a.`pcucode` = b.`pcucode` AND a.`pid` = b.`pid`
     INNER JOIN `ncd_person_ncd_hist` c ON a.`pcucode` = c.`pcucode` AND a.`pid` = c.`pid`
WHERE c.dm_flag='1' and c.hbp_flag='1'
      $P!{p_sqlOffice} $P!{p_sqlDate}]]></queryString>

