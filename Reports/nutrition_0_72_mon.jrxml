vchild60mon_g_mu.villname,
vchild_60mon_weight_0.sex,
vchild_60mon_weight_0.agemonth,
vchild60mon_g_mu.countpid
FROM
vchild_60mon_weight_0
Inner Join vchild60mon_g_mu ON vchild_60mon_weight_0.villno = vchild60mon_g_mu.villno
ORDER BY
vchild_60mon_weight_0.villno ASC]]></queryString>

