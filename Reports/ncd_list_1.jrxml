	<queryString><![CDATA[SELECT
     a.`pcucode`,
     b.`pid`,
     concat(b.prename,b.fname,' ',b.lname)as name,
     b.`birth`,
     a.`age_year`,
     c.`cid`,
     c.`changwat`,
     c.`ampur`,
     c.`tambol`,
     c.`village`,
     house,
     a.`bsl`,
     a.`bmi`,
     a.`hbp_s1`,
     a.`hbp_d1`,
     a.`hbp_s2`,
     a.`hbp_d2`,
     a.`waist`,
     cprovince.`provname` AS provname,
     cdistrict.`distname` AS distname,
     csubdistrict.`subdistname` AS subdistname
FROM
     `ncd_person_ncd_screen` a INNER JOIN `person` b ON a.`pcucode` = b.`pcucodeperson`
     AND a.`pid` = b.`pid`
     INNER JOIN `ncd_person` c ON a.`pcucode` = c.`pcucode`
     AND a.`pid` = c.`pid`
     INNER JOIN `ncd_person_ncd` d ON a.`pcucode` = d.`pcucode`
     AND a.`pid` = d.`pid`
     LEFT OUTER JOIN `cprovince` cprovince ON c.`changwat` = cprovince.`provcode`
     LEFT OUTER JOIN `cdistrict` cdistrict ON c.`ampur` = concat(cdistrict.`provcode`,cdistrict.`distcode`)
     LEFT OUTER JOIN `csubdistrict` csubdistrict ON c.`tambol` = concat(csubdistrict.`provcode`,csubdistrict.`distcode`,csubdistrict.`subdistcode`)
WHERE
     1 = 1$P!{p_sqlOffice}$P!{p_sqlDate}
ORDER BY
     b.fname ASC,
     b.lname ASC]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="name" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="age_year" class="java.lang.Long"/>
	<field name="cid" class="java.lang.String"/>
