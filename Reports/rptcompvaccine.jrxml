<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptcompvaccine" pageWidth="595" pageHeight="785" columnWidth="479" leftMargin="86" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-10"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["AND v.pcucodeperson ='01035'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select house.villcode,villname,house.pcucode

,case when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 31  then 'แรกเกิด - 1 เดือน'
	when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 365  then 'แรกเกิด - 1 ปี '
	when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 730  then 'แรกเกิด - 2  ปี'
	when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 1095  then 'แรกเกิด - 3  ปี'
	when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 1825  then 'แรกเกิด - 5  ปี'
else '-' end as grname

,sum(case when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 31  then 1 else 0 end) as agegr1
,sum(case when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 365  then 1 else 0 end) as agegr2
,sum(case when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 730  then 1 else 0 end) as agegr3
,sum(case when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 1095  then 1 else 0 end) as agegr4
,sum(case when (datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 1825  then 1 else 0 end) as agegr5

,sum(case when  ((datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 31)  and  v.vaccinecode in('BCG','HBV1')  then 1 else 0 end ) as gr1
,sum(case when  ((datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 365)
	and (  v.vaccinecode in('BCG','HBV1','HBV2','DTP1','OPV1','DTP2','OPV2','HBV3','DTP3','OPV3','MEAS','MMR')
           OR  v.vaccinecode in('BCG','HBV1','DHB1','OPV1','DHB2','OPV2','DHB3','OPV3','MEAS','MMR'))  then 1 else 0 end ) as gr2

,sum(case when  ((datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 730  )
	and  (v.vaccinecode in('BCG','HBV1','HBV2','DTP1','OPV1','DTP2','OPV2','HBV3','DTP3','OPV3','MEAS','MMR','DTP4','OPV4','JE1','JE2')  OR
              v.vaccinecode in('BCG','HBV1','DHB1','OPV1','DHB2','OPV2','HBV3','DHB3','OPV3','MEAS','MMR' ,'DTP4','OPV4','JE1','JE2') ) then 1 else 0 end ) as gr3

,sum(case when  ((datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') ))  <= 1095 )
	and  (v.vaccinecode in('BCG','HBV1','HBV2','DTP1','OPV1','DTP2','OPV2','HBV3','DTP3','OPV3','MEAS','MMR' ,'DTP4','OPV4','JE1','JE2','JE3')  OR
              v.vaccinecode in('BCG','HBV1','DHB1','OPV1','DHB2','OPV2','DHB3','OPV3','MEAS','MMR' ,'DTP4','OPV4','JE1','JE2','JE3'))then 1 else 0 end ) as gr4

,sum(case when  ((datediff(date_format($P{pdate},'%Y-%m-%d') , date_format(birth,'%Y-%m-%d') )) <= 1825 )
	and ( v.vaccinecode in('BCG','HBV1','HBV2','DTP1','OPV1','DTP2','OPV2','HBV3','DTP3','OPV3','MEAS','MMR' ,'DTP4','OPV4','JE1','JE2','JE3','DTP5','OPV5')
        OR    v.vaccinecode in('BCG','HBV1','DHB1','OPV1','DHB2','OPV2','DHB3','OPV3','MEAS','MMR' ,'DTP4','OPV4','JE1','JE2','JE3','DTP5','OPV5') ) then 1 else 0 end ) as gr5

,date_format($P{pdate},'%Y-%m-%d') as currdate
from person left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
                      left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
		      left join visitepi v on person.pcucodeperson = v.pcucodeperson and person.pid = v.pid
where 1=1 $P!{pcucode}
group by house.villcode

order by house.villcode]]>
	</queryString>
