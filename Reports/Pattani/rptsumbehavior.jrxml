<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptsumbehavior"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="age" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(0)]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["04838"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-17"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
village.villcode,villname
,SUM(case  when exercise = 0 then 1 else 0 end) as  exe0
,SUM(case  when exercise =1  then 1 else 0 end) as exe1
,SUM(case  when exercise = 2 then 1 else 0 end) as exe2
,SUM(case  when exercise = 3 then 1 else 0 end) as exe3

,SUM(case 	when ciga = 0 then 1 else 0 end) as ciga0
,SUM(case  when ciga=1 then  1 else 0 end) as ciga1
,SUM(case 	when ciga = 2 then 1	else 0  end ) as ciga2

,SUM(case when wisky = 0  then 1 else 0 end) as wisky0
,SUM(case  when wisky =1  then 1 else 0 end) as wisky1
,SUM(case  when wisky = 2 then 1 else 0 end) as wisky2
,SUM(case 	when wisky = 3  then 1 else 0 end) as wisky3  
,SUM(case when wisky = 4  then  1 else 0 end) as wisky4
,SUM(case  when wisky = 5  then 1 else 0 end) as wisky5
 
,SUM(case when habitfoming = 0 then 1 else 0 end) as habit0
,SUM(case when habitfoming = 1 then 1 else 0 end) as habit1
,SUM(case when habitfoming = 2 then 1 else 0 end ) as habit2
,SUM(case when salt = 0  then 1 else 0 end) as salt0
,SUM(case  when salt = 1  then 1 else 0 end ) as salt1  
,SUM(case when sugar = 0 then 1 else 0 end) as sugar0
,SUM(case 	when sugar=1 then 1 else 0 end ) as sugar1
,SUM(case when drugbyyourseft =0 then 1 else 0 end) as durg0
,SUM(case when drugbyyourseft =1 then 1 else 0 end) as drug1

,SUM(case when bigaccidentever = 0 then 1 else 0 end) as biga0
,SUM(case when bigaccidentever = 1 then 1 else 0 end) as biga1

,SUM(case when ciga !=0 and wisky !=0 then 1 else 0 end) as cigawisky
,chospital.hosname,house.pcucode
FROM person left join personbehavior on person.pid = personbehavior.pid and person.pcucodeperson = personbehavior.pcucodeperson
            left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
            left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
            left join chospital on person.pcucodeperson = chospital.hoscode
WHERE  right(village.villcode,2) != '00'
                and person.pcucodeperson = $P{pcucode}
		and (DATEDIFF(DATE_FORMAT($P{edate},'%Y-%m-%d'), birth)/365) >= $P{age}
		and concat(person.pid,person.pcucodeperson) NOT IN (SELECT concat(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.pcucodeperson=person.pcucodeperson and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{edate})) 
GROUP BY village.villcode
ORDER BY village.villcode,hno]]></queryString>

