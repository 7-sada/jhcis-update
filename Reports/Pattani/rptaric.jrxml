				<staticText>
					<reportElement
						x="1"
						y="26"
						width="379"
						height="49"
						forecolor="#FF0000"
						key="staticText-9"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" size="8"/>
					</textElement>
				<text><![CDATA[หมายเหตุ : 
1. อายุ 0-5 ปี นับถึงเดือนที่เกิด(0-60 เดือน)
2. จะต้องกำหนดค่าของข้อมูลที่ column aric ในตารางรหัสโรค(cdisease) = 1
3. จะต้องกำหนดค่าของข้อมูลที่ column antibio ในตารางรหัสยา (cdrug) = 1]]></text>
				</staticText>
