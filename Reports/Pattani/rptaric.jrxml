				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{aric}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
