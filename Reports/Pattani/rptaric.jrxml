<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptaric"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="728"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="104"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["09353"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-04-02"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-25"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select visit.visitdate,chospital.hosname
,visit.pid,visit.pcucodeperson
,sum(case when (cdisease.aric='1' ) then 1 else 0 end  ) as aric
,sum(case when (cdisease.aric='1' and cdrug.antibio='1') then 1 else 0 end ) as aricdrug 

from visit 
	left join visitdiag ON visit.visitno = visitdiag.visitno and visit.pcucode = visitdiag.pcucode
   	left join cdisease ON visitdiag.diagcode = cdisease.diseasecode 
        left join visitdrug ON visit.visitno = visitdrug.visitno and visit.pcucode = visitdrug.pcucode
        left join cdrug ON visitdrug.drugcode = cdrug.drugcode
        left join person ON visit.pid = person.pid and visit.pcucodeperson = person.pcucodeperson
	left join chospital ON visit.pcucode = chospital.hoscode
where visit.pcucode =$P{pcucode}
	and DATEDIFF($P{sdate},birth) <= 1325
        and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
        and visit.pid not in (select v.pid from visit v where visit.pid = v.pid and visit.pcucodeperson = v.pcucodeperson and DATE_FORMAT(visit.visitdate,'%Y')= DATE_FORMAT($P{sdate},'%Y')GROUP BY visit.pid,visit.pcucodeperson)=0
group by visit.pcucode]]></queryString>

	<field name="visitdate" class="java.sql.Date"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="aric" class="java.math.BigDecimal"/>
	<field name="aricdrug" class="java.math.BigDecimal"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
