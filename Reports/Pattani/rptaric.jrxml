			<band height="77"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						mode="Opaque"
						x="0"
						y="1"
						width="535"
						height="38"
						key="staticText-1"/>
					<box topBorder="Thin" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" size="12"/>
					</textElement>
				<text><![CDATA[งานควบคุมโรคติดต่อระบบทางเดินหายใจ]]></text>
				</staticText>
				<staticText>
					<reportElement
						mode="Opaque"
						x="0"
						y="39"
						width="535"
						height="38"
						key="staticText-2"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" size="12"/>
					</textElement>
				<text><![CDATA[งานควบคุมโรคติดเชื้อเฉียบพลันระบบทางเดินหายใจในเด็ก (ARIC) ในเด็กอายุ 0-5 ปี (นับเฉพาะรายใหม่)]]></text>
				</staticText>
			</band>
		</columnHeader>
		<detail>
			<band height="66"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="0"
						y="0"
						width="417"
						height="33"
						key="staticText-3"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" size="10"/>
					</textElement>
				<text><![CDATA[ เป้าหมาย : จำนวนผู้ป่วยเด็กอายุต่ำกว่า 5 ปี เป็นไข้หวัด ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="0"
						y="33"
						width="417"
						height="33"
						key="staticText-4"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" size="10"/>
					</textElement>
				<text><![CDATA[ ผลงาน : จำนวนผู้ป่วยเด็กอายุต่ำกว่า 5 ปี เป็นไข้หวัดได้รับยาปฏิชีวนะ]]></text>
				</staticText>
