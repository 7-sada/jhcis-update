<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptscreenotherdisease_subreport0"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="visitno" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select  visitno,pcucode
,screenotherdiseasedesc 
,case when codescreen ='c01' and coderesult = '1' then 'ปกติ'  when codescreen ='c01' and coderesult ='2' then 'ผิดปกติ' 
	when codescreen ='c02' and coderesult ='1' then 'ปกติ'  when codescreen ='c02' and coderesult ='3' then 'เสี่ยง'  
	when codescreen ='c02' and coderesult ='4' then 'เสี่ยงปานกลาง'  when codescreen ='c02' and coderesult ='5' then 'เสี่ยงสูง'  
	when codescreen ='c03' and coderesult ='1' then 'ปกติ'  when codescreen ='c03' and coderesult ='2' then 'ผิดปกติ' 
 	when codescreen ='c04' and coderesult ='1' then 'ปกติ'  when codescreen ='c41' and coderesult ='2' then 'ผิดปกติ' 
	when codescreen ='c21' and coderesult ='1' then 'ปกติ'  when codescreen ='c21' and coderesult ='2' then 'ผิดปกติ' else '-'  end as coderesultc
from visitscreenspecialdisease vsd  
	left join cscreenotherdisease on vsd.codescreen = cscreenotherdisease.screenotherdiseasecode
where visitno= $P{visitno} and $P{pcucode}]]></queryString>

	<field name="visitno" class="java.lang.Integer"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="screenotherdiseasedesc" class="java.lang.String"/>
	<field name="coderesultc" class="java.lang.String"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="29"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="137"
						height="29"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" leftPadding="2" rightBorder="None" rightBorderColor="#000000" rightPadding="2" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{screenotherdiseasedesc}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="137"
						y="0"
						width="49"
						height="29"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" leftPadding="2" rightBorder="None" rightBorderColor="#000000" rightPadding="2" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{coderesultc}]]></textFieldExpression>
				</textField>
			</band>
		</detail>
		<columnFooter>
			<band height="0"  isSplitAllowed="true" >
