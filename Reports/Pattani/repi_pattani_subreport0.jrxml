		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'04914'"]]></defaultValueExpression>
	</parameter>
	<parameter name="age1year" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND  person.birth BETWEEN  '20080801' AND '20080831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="age2year" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND  person.birth BETWEEN  '20070801' AND '20070831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="age3year" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND  person.birth BETWEEN  '20060801' AND '20060831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="age5year" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND  person.birth BETWEEN  '20040801' AND '20040831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="dateepi1" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitepi.dateepi BETWEEN  '20080801' AND '20090831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="dateepi2" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitepi.dateepi BETWEEN  '20070801' AND '20090831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="dateepi3" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitepi.dateepi BETWEEN  '20060801' AND '20090831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="dateepi5" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitepi.dateepi BETWEEN  '20040801' AND '20090831' "]]></defaultValueExpression>
	</parameter>
	<parameter name="datedeliver" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitancdeliver.datedeliver BETWEEN  '20080801' AND '20090831' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
(SELECT COUNT(person.pid) FROM person WHERE person.pcucodeperson =$P!{pcucode} $P!{age1year} ) AS p1,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='BCG' $P!{dateepi1} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age1year})) AS BCG,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='HBV3' $P!{dateepi1} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age1year})) AS HBV3,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='DTP3' $P!{dateepi1} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age1year})) AS DTP3,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='OPV3' $P!{dateepi1} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age1year})) AS OPV3,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='MEAS' $P!{dateepi1} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age1year})) AS MEAS,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='MMR' $P!{dateepi1} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age1year})) AS MMR,
(SELECT COUNT(person.pid) FROM person WHERE person.pcucodeperson =$P!{pcucode} $P!{age2year} ) AS p2,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='DTP4' $P!{dateepi2} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age2year})) AS DTP4,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='OPV4' $P!{dateepi2} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age2year})) AS OPV4,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='JE2' $P!{dateepi2} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age2year})) AS JE2,
(SELECT COUNT(person.pid) FROM person WHERE person.pcucodeperson =$P!{pcucode} $P!{age3year} ) AS p3,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='JE3' $P!{dateepi3} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age3year})) AS JE3,
(SELECT COUNT(person.pid) FROM person WHERE person.pcucodeperson =$P!{pcucode} $P!{age5year} ) AS p5,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='DTP5' $P!{dateepi5} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age5year})) AS DTP5,
(SELECT COUNT(visitepi.pid) FROM visitepi WHERE visitepi.vaccinecode ='OPV5' $P!{dateepi5} AND visitepi.pcucodeperson = $P!{pcucode} AND CONCAT(visitepi.pcucodeperson,visitepi.pid) in (SELECT CONCAT(person.pcucodeperson,person.pid) FROM person WHERE  1=1 $P!{age5year})) AS OPV5,
(SELECT COUNT(visitancdeliver.pid) FROM visitancdeliver WHERE visitancdeliver.pcucodeperson=$P!{pcucode} $P!{datedeliver}) AS deliver,
(SELECT SUM(IF(visitanc.ttno35 > 'DTANC1',1,0)) FROM visitanc WHERE visitanc.pcucodeperson=$P!{pcucode} AND CONCAT(visitanc.pcucodeperson,visitanc.pid) in (SELECT CONCAT(visitancdeliver.pcucodeperson,visitancdeliver.pid)  FROM visitancdeliver WHERE visitancdeliver.pcucodeperson=$P!{pcucode} $P!{datedeliver} )) AS tanc]]></queryString>

	<field name="p1" class="java.lang.Long"/>
