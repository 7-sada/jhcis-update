<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="repi_pattani_subreport1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<queryString><![CDATA[SELECT
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='BCG', 1,0)) AS BCG,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='HBV1', 1,0)) AS HBV1,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='HBV2', 1,0)) AS HBV2,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='HBV3', 1,0)) AS HBV3,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='DTP1', 1,0)) AS DTP1,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='DTP2', 1,0)) AS DTP2,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='DTP3', 1,0)) AS DTP3,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='OPV1', 1,0)) AS OPV1,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='OPV2', 1,0)) AS OPV2,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='OPV3', 1,0)) AS OPV3,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='MEAS', 1,0)) AS MEAS,
SUM(IF(DATEDIFF(v.visitdate,p.birth) < 366 AND e.vaccinecode='MMR', 1,0)) AS MMR,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 366 AND 730 AND e.vaccinecode='DTP4', 1,0)) AS DTP4,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 366 AND 730 AND e.vaccinecode='OPV4', 1,0)) AS OPV4,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 366 AND 730 AND e.vaccinecode='JE1', 1,0)) AS JE1,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 366 AND 730 AND e.vaccinecode='JE2', 1,0)) AS JE2,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 366 AND 730 AND e.vaccinecode='JE3', 1,0)) AS JE3,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 1461 AND 1825 AND e.vaccinecode='DTP5', 1,0)) AS DTP5,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  BETWEEN 1461 AND 1825 AND e.vaccinecode='OPV5', 1,0)) AS OPV5,
SUM(IF(a.datecheck IS NOT NULL AND e.vaccinecode='TT1' , 1,0)) AS TANC1,
SUM(IF(a.datecheck IS NOT NULL AND e.vaccinecode='TT2' , 1,0)) AS TANC2,
SUM(IF(a.ttno35='0' , 1,0)) AS TANCCov,
SUM(IF(a.datecheck IS NULL AND e.vaccinecode='TT2' , 1,0)) AS  TT2,
SUM(IF(a.datecheck IS NULL AND e.vaccinecode='TT3' , 1,0)) AS  TT3
FROM 
person AS p
Left Join visit AS v ON p.pid = v.pid AND p.pcucodeperson = v.pcucodeperson
Left Join visitepi AS e ON v.visitno = e.visitno AND v.pcucodeperson = e.pcucodeperson
Left Join visitanc a ON a.pcucodeperson = e.pcucodeperson AND a.pid = e.pid AND e.visitno = a.visitno AND e.pcucode = a.pcucode AND a.datecheck = e.dateepi
WHERE v.visitdate BETWEEN '20090101' AND  '20090831'
AND v.pcucode = '06742' ]]></queryString>

