				<staticText>
					<reportElement
						mode="Opaque"
						x="459"
						y="0"
						width="76"
						height="36"
						key="staticText-5"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="1Point" bottomBorderColor="#000000"/>
