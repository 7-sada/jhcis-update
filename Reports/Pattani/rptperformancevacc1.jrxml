<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptperformancevacc1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="75"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["09353"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-05-25"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-08-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-08-31"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
 sum(case when  (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END)  =12 then 1 else 0 end) as child1y
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =12 and visitepi.vaccinecode='BCG'  then 1 else 0 end) as child1ybcg
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =12 and visitepi.vaccinecode='HBV3' then 1 else 0 end) as child1yhbv3
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =12 and visitepi.vaccinecode='DTP3' then 1 else 0 end) as child1ydpt3
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =12 and visitepi.vaccinecode='OPV3' then 1 else 0 end) as child1yopv3
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =12 and (visitepi.vaccinecode='MEAS' OR  visitepi.vaccinecode='MMR') then 1 else 0 end) as child1ymmr

,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =24  then 1 else 0 end) as child2y
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =24  and visitepi.vaccinecode='DTP4' then 1 else 0 end) as child2ydpt4
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =24  and visitepi.vaccinecode='OPV4' then 1 else 0 end) as child2yopv4
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =24  and visitepi.vaccinecode='JE2' then 1 else 0 end) as child2yje2

,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =36 then 1 else 0 end) as child3y
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =36 and visitepi.vaccinecode='JE3'  then 1 else 0 end) as child3yje3

,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =60 then 1 else 0 end) as child5y
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =60 and visitepi.vaccinecode ='DTP5' then 1 else 0 end) as child5ydtp5
,sum(case when (CASE SIGN(DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m"))  
 	 WHEN 0  THEN ( (DATE_FORMAT($P{sdate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	 WHEN -1 THEN ( ( (DATE_FORMAT($P{sdate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{sdate},"%m") )  
 	 WHEN 1  THEN  ( (DATE_FORMAT($P{sdate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{sdate},"%m") - DATE_FORMAT(birth,"%m") ) END) =60 and visitepi.vaccinecode ='OPV5' then 1 else 0 end) as child5yopv5
,sum(case when (MONTH(vd.datedeliver) = MONTH($P{sdate}) and  YEAR(vd.datedeliver) = YEAR($P{sdate})) then 1 else 0 end ) as deliverinm
,sum(case when 
         ((DATEDIFF((select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ,(select dateepi from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson = v1.pcucodeperson and vaccinecode ='dTA1' group by v1.pid,v1.pcucodeperson)  )  >= 30 ) and
          (DATEDIFF(datedeliver,(select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ) >= 30) )
         OR 
         ((DATEDIFF((select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ,(select dateepi from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson = v1.pcucodeperson and vaccinecode ='dTA1' group by v1.pid,v1.pcucodeperson)  )  >= 30 )and
          (DATEDIFF((select dateepi from visitepi v3 where visitepi.pid = v3.pid and visitepi.pcucodeperson = v3.pcucodeperson and vaccinecode ='dTANC3' group by v3.pid,v3.pcucodeperson) ,(select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTA2' group by v2.pid,v2.pcucodeperson) ) >= 180) )
	OR
	 ((DATEDIFF((select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ,(select dateepi from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson = v1.pcucodeperson and vaccinecode ='dTA1' group by v1.pid,v1.pcucodeperson)  )  >= 30 ) and
          (DATEDIFF(edc,(select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ) >= 1095))
        OR
         ((DATEDIFF((select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ,(select dateepi from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson = v1.pcucodeperson and vaccinecode ='dTA1' group by v1.pid,v1.pcucodeperson)  )  >= 30 )and
          (DATEDIFF((select dateepi from visitepi v3 where visitepi.pid = v3.pid and visitepi.pcucodeperson = v3.pcucodeperson and vaccinecode ='dTANC3' group by v3.pid,v3.pcucodeperson) ,(select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTA2' group by v2.pid,v2.pcucodeperson) ) >= 180) and
          (DATEDIFF(edc,(select dateepi from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson = v2.pcucodeperson and vaccinecode ='dTANC2' group by v2.pid,v2.pcucodeperson) ) >= 1825))
    then 1 else 0 end)  as deliverinmv
,chospital.hosname,birth
FROM  person LEFT JOIN visit ON person.pid= visit.pid and person.pcucodeperson = visit.pcucodeperson
             LEFT JOIN visitepi ON person.pid = visitepi.pid and person.pcucodeperson = visitepi.pcucodeperson
   	     LEFT JOIN visitancdeliver vd ON person.pid = vd.pid and person.pcucodeperson = vd.pcucodeperson
	     LEFT JOIN visitancpregnancy  ON person.pid = visitancpregnancy.pid and person.pcucodeperson = visitancpregnancy.pcucodeperson
             LEFT JOIN house ON person.hcode = house.hcode and person.pcucodeperson = house.pcucodeperson
	     LEFT JOIN chospital ON visit.pcucode = chospital.hoscode
WHERE  visit.pcucode= $P{pcucode}
     and visit.visitdate between $P{sdate} and $P{edate}
     and Right(house.villcode,2)!='00'
     and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
GROUP BY visit.pcucode]]></queryString>

	<field name="child1y" class="java.math.BigDecimal"/>
	<field name="child1ybcg" class="java.math.BigDecimal"/>
	<field name="child1yhbv3" class="java.math.BigDecimal"/>
	<field name="child1ydpt3" class="java.math.BigDecimal"/>
	<field name="child1yopv3" class="java.math.BigDecimal"/>
	<field name="child1ymmr" class="java.math.BigDecimal"/>
	<field name="child2y" class="java.math.BigDecimal"/>
	<field name="child2ydpt4" class="java.math.BigDecimal"/>
	<field name="child2yopv4" class="java.math.BigDecimal"/>
	<field name="child2yje2" class="java.math.BigDecimal"/>
	<field name="child3y" class="java.math.BigDecimal"/>
	<field name="child3yje3" class="java.math.BigDecimal"/>
	<field name="child5y" class="java.math.BigDecimal"/>
	<field name="child5ydtp5" class="java.math.BigDecimal"/>
	<field name="child5yopv5" class="java.math.BigDecimal"/>
	<field name="deliverinm" class="java.math.BigDecimal"/>
	<field name="deliverinmv" class="java.math.BigDecimal"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
