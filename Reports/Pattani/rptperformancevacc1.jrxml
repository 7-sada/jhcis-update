			</band>
		</columnHeader>
		<detail>
			<band height="496"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						mode="Opaque"
						x="0"
						y="0"
						width="395"
						height="36"
						key="staticText-2"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="1Point" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" isBold="true"/>
					</textElement>
				<text><![CDATA[ 1. ผลงานความครอบคลุม (รายงานเฉพาะเด็กในเขตพื้นที่รับผิดชอบ)]]></text>
				</staticText>
				<staticText>
					<reportElement
						mode="Transparent"
						x="0"
						y="36"
						width="395"
						height="27"
						key="staticText-3"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" size="8"/>
					</textElement>
				<text><![CDATA[   1.1 จำนวนเด็กที่มีอายุครบ 1 ปี ในเดือนที่รายงานทั้งหมด]]></text>
				</staticText>
				<staticText>
					<reportElement
						mode="Opaque"
