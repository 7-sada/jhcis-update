	<field name="hbv1" class="java.math.BigDecimal"/>
	<field name="hbv2" class="java.math.BigDecimal"/>
	<field name="hbv3" class="java.math.BigDecimal"/>
	<field name="dtp1" class="java.math.BigDecimal"/>
	<field name="opv1" class="java.math.BigDecimal"/>
