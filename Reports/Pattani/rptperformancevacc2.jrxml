<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptperformancevacc2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="76"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["09353"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-12-09"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-08-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-08-30"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
 sum( case when   visitepi.vaccinecode='BCG'   then 1 else 0 end) as bcg
,sum( case when   visitepi.vaccinecode='HBV1'  then 1 else 0 end) as hbv1
,sum( case when   visitepi.vaccinecode='HBV2'  then 1 else 0 end) as hbv2
,sum( case when   visitepi.vaccinecode='HBV3'  then 1 else 0 end) as hbv3
,sum( case when   visitepi.vaccinecode='DTP1'  then 1 else 0 end) as dtp1
,sum( case when   visitepi.vaccinecode='OPV1' then 1 else 0 end) as opv1
,sum( case when   visitepi.vaccinecode='DTP2'  then 1 else 0 end) as dtp2
,sum( case when   visitepi.vaccinecode='OPV2' then 1 else 0 end) as opv2
,sum( case when   visitepi.vaccinecode='DTP3'  then 1 else 0 end) as dtp3
,sum( case when   visitepi.vaccinecode='OPV3'  then 1 else 0 end) as opv3
,sum( case when  (visitepi.vaccinecode='MEAS'  OR  visitepi.vaccinecode='MMR' 
                  OR  visitepi.vaccinecode='MMR1' OR  visitepi.vaccinecode='MMR2')  
           then 1 else 0 end) as mmr
,sum( case when visitepi.vaccinecode='DTP4' then 1 else 0 end) as dtp4
,sum( case when visitepi.vaccinecode='OPV4' then 1 else 0 end) as opv4
,sum( case when visitepi.vaccinecode='JE1'  then 1 else 0 end) as je1
,sum( case when visitepi.vaccinecode='JE2'  then 1 else 0 end) as je2
,sum( case when visitepi.vaccinecode='JE3'  then 1 else 0 end) as je3
,sum( case when visitepi.vaccinecode='DTP5' then 1 else 0 end) as dtp5
,sum( case when visitepi.vaccinecode='OPV5' then 1 else 0 end) as opv5
,(select count(visitepi.vaccinecode) from visitepi,visitanc where (visitepi.visitno = visitanc.visitno and visitepi.pcucode = visitanc.pcucode) and (visitepi.vaccinecode='dTANC1' OR visitepi.vaccinecode='dTA1') and  (visitepi.dateepi  between $P{sdate} and $P{edate})  group by visitanc.pcucode) as ancvtt1
,(select count(visitepi.vaccinecode) from visitepi,visitanc where (visitepi.visitno = visitanc.visitno and visitepi.pcucode = visitanc.pcucode) and (visitepi.vaccinecode='dTANC2' OR visitepi.vaccinecode='dTA2') and  (visitepi.dateepi  between $P{sdate} and $P{edate})  group by visitanc.pcucode) as ancvtt2
,sum(case when visitanc.ttno35='tt_in_Scop' then 1 else 0 end) as ancttno35
,sum(case when visitepi.vaccinecode='TT2' then 1 else 0 end) as vtt2
,sum(case when (visitepi.vaccinecode='TT4' OR visitepi.vaccinecode='TT5') then 1 else 0 end) as vtt5
,chospital.hosname,birth
FROM  person LEFT JOIN visit ON person.pid= visit.pid and person.pcucodeperson = visit.pcucodeperson
             LEFT JOIN visitepi ON person.pid = visitepi.pid and person.pcucodeperson = visitepi.pcucodeperson
 	     LEFT JOIN visitanc ON person.pid = visitanc.pid and person.pcucodeperson = visitanc.pcucodeperson
	     LEFT JOIN chospital ON visit.pcucode = chospital.hoscode
WHERE  visit.pcucode= $P{pcucode}
     	and (CASE SIGN(DATE_FORMAT($P{edate},"%m") - DATE_FORMAT(birth,"%m"))  
 	         WHEN 0  THEN ( (DATE_FORMAT($P{edate},"%Y") -  DATE_FORMAT(birth,"%Y")   )*12 ) + ( DATE_FORMAT(birth,"%m") -  DATE_FORMAT($P{sdate},"%m") ) 
 	         WHEN -1 THEN ( ( (DATE_FORMAT($P{edate},"%Y")-1)  -  DATE_FORMAT(birth,"%Y")  )*12)  +  (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{edate},"%m") )  
 	         WHEN 1  THEN  ( (DATE_FORMAT($P{edate},"%Y")  -  DATE_FORMAT(birth,"%Y") )*12 ) + (DATE_FORMAT($P{edate},"%m") - DATE_FORMAT(birth,"%m") ) END) <=60
        and visitepi.dateepi between $P{sdate} and $P{edate} 
        and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
GROUP BY visit.pcucode]]></queryString>

