	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.7715610000000013"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["08449"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     chospital.`hosname` AS chospital_hosname,
     chospital.`mu` AS chospital_mu,
     ifnull(csubdistrict.`subdistname`,' ...') AS csubdistrict_subdistname,
     ifnull(cdistrict.`distname`,' ...') AS cdistrict_distname,
     cprovince.`provname` AS cprovince_provname
FROM
     `chospital` chospital
     INNER JOIN `office` office ON chospital.`hoscode` = office.`offid`
     left outer join `csubdistrict` csubdistrict ON chospital.`provcode` = csubdistrict.`provcode`
                                                        AND chospital.`distcode` = csubdistrict.`distcode`
                                                        AND chospital.`subdistcode` = csubdistrict.`subdistcode`
     INNER JOIN `cdistrict` cdistrict ON chospital.`provcode` = cdistrict.`provcode`
                                                  AND chospital.`distcode` = cdistrict.`distcode`
     INNER JOIN `cprovince` cprovince ON chospital.`provcode` = cprovince.`provcode`
WHERE chospital.hoscode = $P!{HCC}]]>
	</queryString>
	<field name="chospital_hosname" class="java.lang.String"/>
	<field name="chospital_mu" class="java.lang.String"/>
	<field name="csubdistrict_subdistname" class="java.lang.String"/>
	<field name="cdistrict_distname" class="java.lang.String"/>
	<field name="cprovince_provname" class="java.lang.String"/>
