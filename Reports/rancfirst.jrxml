<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rancfirst" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND v.pcucode = '01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="bDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2012-04-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="eDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2012-05-31'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT v.visitno,if(chospital.hosname is null,'ไม่ระบุโรงพยาบาลหลักฯ',CONCAT(chospital.hosname,' จ.',cprov.provname)) AS hosmain,
DATE_FORMAT(visitancpregnancy.firstdatecheck,'%Y-%m-%d') as visitdate,visitancpregnancy.pregno,
DATE_FORMAT(visitancpregnancy.lmp,'%Y-%m-%d') as lmp,(DATEDIFF(v.visitdate,visitancpregnancy.lmp)/7) AS pregage,
 visitancpregnancy.pid,concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname) as  pname,person.idcard,
 CONCAT(DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), "-",
  CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))  WHEN 0 THEN 0  WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  "-",
  CASE SIGN(DATE_FORMAT(v.visitdate,"%d")-DATE_FORMAT(birth,"%d"))  WHEN 0 THEN 0  WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))  WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END ) AS age,
 CONCAT(person.hnomoi,' ม.',person.mumoi) AS hnomoi,csubdistrict.subdistname,cdistrict.distname,cprovince.provname,
 v.rightcode,v.rightno
FROM visitancpregnancy LEFT OUTER JOIN visit v ON v.pid = visitancpregnancy.pid AND  v.pcucodeperson = visitancpregnancy.pcucodeperson
 INNER JOIN person ON v.pid = person.pid AND v.pcucodeperson = person.pcucodeperson
 Left Outer Join ctitle ON person.prename = ctitle.titlecode
 INNER JOIN chospital ON v.hosmain = chospital.hoscode
 INNER JOIN cprovince cprov ON chospital.provcode = cprov.provcode
 INNER JOIN cprovince ON person.provcodemoi = cprovince.provcode
 INNER JOIN cdistrict ON person.distcodemoi = cdistrict.distcode AND person.provcodemoi=cdistrict.provcode
 INNER JOIN csubdistrict ON person.subdistcodemoi = csubdistrict.subdistcode AND person.distcodemoi = csubdistrict.distcode AND person.provcodemoi=csubdistrict.provcode
WHERE  (DATEDIFF(v.visitdate,visitancpregnancy.lmp) BETWEEN 0 AND 280 OR lmp is null)
 $P!{pcucode}
 AND visitancpregnancy.firstdatecheck BETWEEN  $P!{bDate} AND $P!{eDate}
GROUP BY v.pid,visitancpregnancy.pregno
ORDER BY v.visitdate]]>
	</queryString>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="hosmain" class="java.lang.String"/>
	<field name="visitdate" class="java.util.Date"/>
	<field name="pregno" class="java.lang.Integer"/>
	<field name="lmp" class="java.util.Date"/>
	<field name="pregage" class="java.math.BigDecimal"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="pname" class="java.lang.String"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="age" class="java.lang.String"/>
	<field name="hnomoi" class="java.lang.String"/>
	<field name="subdistname" class="java.lang.String"/>
	<field name="distname" class="java.lang.String"/>
	<field name="provname" class="java.lang.String"/>
	<field name="rightcode" class="java.lang.String"/>
	<field name="rightno" class="java.lang.String"/>
