<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptanc" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="a161aa5c-2bd4-4b25-822a-8cde305f1000">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT   ifnull(titlename,ifnull(prename,'ไม่ระบุ') )  prename,fname,lname
,DATE_FORMAT(current_date,'%Y-%m_%d')  - DATE_FORMAT(birth,'%Y-%m-%d') as age
,if(house.hno != '' ,CONVERT(concat(house.hno,' ม.',villno) USING utf8),
                     CONVERT(concat('- ม.',villno) USING utf8) ) as address
,v.pcucode
,MAX(pregno) pregno

,(select DATE_FORMAT(MAX(v1.datecheck),'%Y-%m-%d')  from visitanc v1 where v1.pid = v.pid and v1.pcucodeperson = v.pcucodeperson and v1.ancno =1 and v1.pregage between '1' and '12'  and v1.pregno = (select max(v.pregno)) group by v.pid,v.pcucodeperson,v.pregno) as anc1
,(select DATE_FORMAT(MAX(v2.datecheck),'%Y-%m-%d')  from visitanc v2 where v2.pid = v.pid and v2.pcucodeperson = v.pcucodeperson and v2.ancno =2 and v2.pregage between '16' and '20' and v2.pregno = (select max(v.pregno)) group by v.pid,v.pcucodeperson,v.pregno) as anc2
,(select DATE_FORMAT(MAX(v3.datecheck),'%Y-%m-%d')  from visitanc v3 where v3.pid = v.pid and v3.pcucodeperson = v.pcucodeperson and v3.ancno =3 and v3.pregage between '24' and '28' and v3.pregno = (select max(v.pregno)) group by v.pid,v.pcucodeperson,v.pregno) as anc3
,(select DATE_FORMAT(MAX(v4.datecheck),'%Y-%m-%d')  from visitanc v4 where v4.pid = v.pid and v4.pcucodeperson = v.pcucodeperson and v4.ancno =4 and v4.pregage between '30' and '34' and v4.pregno = (select max(v.pregno)) group by v.pid,v.pcucodeperson,v.pregno) as anc4

,(select DATE_FORMAT(MAX(v5.datecheck),'%Y-%m-%d')  from visitanc v5 where v5.pid = v.pid and v5.pcucodeperson = v.pcucodeperson and v5.ancno =5 and v5.pregage between '36' and '40' and v5.pregno = (select max(v.pregno)) group by v.pid,v.pcucodeperson,v.pregno) as anc5

,if(toothcheck='0' ,'แข็งแรง','ฟันผุ') as toothcheck
,max(case when epi.files18epi ='201' then DATE_FORMAT(epi.dateepi,'%Y-%m-%d') ELSE null end ) as vac1
,max(case when epi.files18epi ='202' then DATE_FORMAT(epi.dateepi,'%Y-%m-%d') ELSE null end ) as vac2
,max(case when epi.files18epi ='203' then DATE_FORMAT(epi.dateepi,'%Y-%m-%d') ELSE null end ) as vac3
,max(case when epi.files18epi ='204' then DATE_FORMAT(epi.dateepi,'%Y-%m-%d') ELSE null end ) as vac4
,max(case when epi.files18epi ='205' then DATE_FORMAT(epi.dateepi,'%Y-%m-%d') ELSE null end ) as vac5
,case when v.ttno35 ='tt_in_Scop' then'อยู่ในระยะคุ่มครอง ' ELSE null end as 'scop'

,person.bloodgroup
,case when visitlabblood.vdrl = "0"  then "Non_Reactive"
	when visitlabblood.vdrl ="1" then "1:16"
	when visitlabblood.vdrl="2"  then "1:8"
        when visitlabblood.vdrl="3" then "1:4"
	when visitlabblood.vdrl="9"  then "ไม่ตรวจ"
        when visitlabblood.vdrl="x" then "รอผล"   else "-" end as vdrl
,visitlabblood.hct
,case when visitlabblood.hiv ="0" then "(-)"
 	when visitlabblood.hiv ="1" then "(+)"
	when visitlabblood.hiv ="9" then "ไม่ตรวจ"
	when visitlabblood.hiv ="x" then "รอผล"
	else "-" end as hiv
,case when visitlabblood.talas1 ="0" then "(-)"
	when visitlabblood.talas1 ="1" then "(+)"
	when visitlabblood.talas1 ="9" then "ไม่ตรวจ"
	when visitlabblood.talas1 ="x" then "รอผล"
	else "-" end talas1
,case when visitlabblood.talas2="0" then "(-)"
	when visitlabblood.talas2="1" then "(+)"
	when visitlabblood.talas2="9" then "ไม่ตรวจ"
	when visitlabblood.talas2="x" then "รอผล"
	else "-" end as talas2
,curdate() cdate
FROM visitanc v
	left join person on person.pid = v.pid and person.pcucodeperson = v.pcucodeperson
  	left join ctitle on person.prename = ctitle.titlecode
   	left join visitlabblood on v.pid = visitlabblood.pid and v.pcucodeperson = visitlabblood.pcucodeperson
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
  LEFT JOIN(SELECT visitepi.pid,visitepi.pcucodeperson,visitepi.dateepi,visitepi.vaccinecode,cdrug.files18epi
from visitepi
INNER JOIN cdrug on visitepi.vaccinecode=cdrug.drugcode
WHERE cdrug.files18epi in ('201','202','203','204','205'))as epi on person.pid=epi.pid and person.pcucodeperson=epi.pcucodeperson
WHERE v.datecheck between $P{sdate} and $P{edate}
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
and (v.datecheck IS NOT NULL OR v.datecheck NOT LIKE '0000%')
       $P!{pcucode}
GROUP BY v.pid,v.pcucodeperson,v.pregno]]>
	</queryString>
