<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpt_activeDent_person_subreport2" language="groovy" pageWidth="802" pageHeight="555" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
 sum(case when (cright.rightgroup ='3' ) then 1 else 0 end) as rightgr3
,sum(case when (cright.rightgroup ='4' ) then 1 else 0 end) as rightgr4
,sum(case when ( (cright.rightgroup in('3','4' ) ) and ( visit.incup ='2' ) and (visit.refer='5') )  then 1 else 0 end) as rightgr34outcup
,sum(case when (cright.rightgroup ='1' ) then 1 else 0 end) as rightgr1
,sum(case when (cright.rightgroup ='2' ) then 1 else 0 end) as rightgr2
,sum(case when ( (cright.rightgroup ='1') and ( visit.incup ='2' ))  then 1 else 0 end) as rightgr1outcup
,sum(case when  (cright.rightgroup in('5','x','6' ) )    then 1 else 0 end) as rightgr5x

from visit join cright on visit.rightcode  = cright.rightcode
  where visitdate between  $P{sdate} and $P{edate}
             $P!{pcucode}
  and concat(visit.pcucode,visit.visitno)
        in(select (concat(visitdrugdental.pcucode,visitdrugdental.visitno))
          from visitdrugdental where visit.pcucode = visitdrugdental.pcucode and visit.visitno = visitdrugdental.visitno)]]>
	</queryString>
	<field name="rightgr3" class="java.math.BigDecimal"/>
	<field name="rightgr4" class="java.math.BigDecimal"/>
	<field name="rightgr34outcup" class="java.math.BigDecimal"/>
	<field name="rightgr1" class="java.math.BigDecimal"/>
	<field name="rightgr2" class="java.math.BigDecimal"/>
	<field name="rightgr1outcup" class="java.math.BigDecimal"/>
	<field name="rightgr5x" class="java.math.BigDecimal"/>
	<variable name="Sum_rightgr3" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr3}]]></variableExpression>
	</variable>
	<variable name="Sum_rightgr4" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr4}]]></variableExpression>
	</variable>
	<variable name="Sum_right34outcup" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr34outcup}]]></variableExpression>
	</variable>
	<variable name="Sum_rightgr1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr1}]]></variableExpression>
	</variable>
	<variable name="Sum_rightgr2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr2}]]></variableExpression>
	</variable>
	<variable name="Sum_right1outcup" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr1outcup}]]></variableExpression>
	</variable>
	<variable name="Sum_right5x" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{rightgr5x}]]></variableExpression>
	</variable>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
