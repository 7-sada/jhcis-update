	<summary>
		<band height="25" splitType="Stretch">
			<textField isBlankWhenNull="true">
				<reportElement x="0" y="0" width="55" height="25" forecolor="#FF0000"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Tahoma" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$V{Sum_rightgr3}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="55" y="0" width="55" height="25" forecolor="#FF0000"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
