				</textElement>
				<textFieldExpression><![CDATA[$V{Sum_right34outcup}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="165" y="0" width="55" height="25" forecolor="#FF0000"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
