<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="vacc_dtp5"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-16"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-04-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select village.villno,village.villname,p.birth,csd.subdistname
,sum(case when (DATEDIFF($P{edate},birth)/30) between 48 and 60  then 1 else 0 end)  as tupa35
,sum(case when (DATEDIFF($P{edate},birth)/30) between 48 and 60 and vt.vaccinecode='DTP5' then 1 else 0 end ) as dtp5
,chospital.hosname,cprovince.provname,cdistrict.distname
from visit v 
     left join visitepi vt ON v.visitno=vt.visitno  and v.pcucode = vt.pcucode
     left join person p on(p.pid=vt.pid and p.pcucodeperson = vt.pcucodeperson)
     left join house ON p.hcode=house.hcode and p.pcucodeperson = house.pcucode
     left join village   ON house.villcode = village.villcode and  p.pcucodeperson = village.pcucode
     left join chospital ON (vt.pcucode = chospital.hoscode )
     left join cprovince ON (cprovince.provcode =chospital.provcode )
     left join cdistrict ON (cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode) 
     left join csubdistrict csd ON (left(village.villcode,6) = CONCAT(csd.provcode,csd.distcode,csd.subdistcode) )
where vt.dateepi in (select Max(dateepi) from visitepi where visitepi.pid = vt.pid and visitepi.pcucodeperson = vt.pcucodeperson  and (visitepi.dateepi  <= $P{edate}) group by visitepi.pid,visitepi.pcucodeperson)
      $P!{pcucode}
      and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
group by village.villcode
order by v.pcucode,village.villcode]]></queryString>

	<field name="villno" class="java.lang.Integer"/>
	<field name="villname" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="subdistname" class="java.lang.String"/>
	<field name="tupa35" class="java.math.BigDecimal"/>
	<field name="dtp5" class="java.math.BigDecimal"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="provname" class="java.lang.String"/>
	<field name="distname" class="java.lang.String"/>

	<variable name="SUM_dtp5_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{dtp5}]]></variableExpression>
	</variable>
	<variable name="SUM_tupa35_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{tupa35}]]></variableExpression>
	</variable>
	<variable name="SUM_dtp5_2" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{dtp5}]]></variableExpression>
	</variable>
	<variable name="SUM_dtp5_3" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{dtp5}]]></variableExpression>
	</variable>
