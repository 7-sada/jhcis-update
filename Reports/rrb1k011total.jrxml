	</parameter>
	<parameter name="zdiag" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and Lcase(left(visitdiag.diagcode,1)) !='z' "]]></defaultValueExpression>
	</parameter>
	<parameter name="note1" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pOderBy" class="java.lang.String" isForPrompting="false">
