<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptsumrightrayong" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="ReportDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and visit.visitdate  between '2012-01-01' and '2012-01-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select count(distinct concat(visit.pcucode,visit.visitno)) as ctime
,(select count(distinct visit.visitno,visit.pcucode)  from visit left join visitdrug on visit.visitno = visitdrug.visitno and visit.pcucode = visitdrug.pcucode
	left join visitdiag on visitdrug.visitno =visitdiag.visitno and visit.pcucode = visitdiag.pcucode
where  1=1 $P!{ReportDate} $P!{pcucode}
                 and diagcode  not like 'W%')   as cdiag

,(select count(distinct visit.visitno,visit.pcucode)  from visit left join visitdrug on visit.visitno = visitdrug.visitno and visit.pcucode = visitdrug.pcucode
	left join visitdiag on visitdrug.visitno =visitdiag.visitno and visit.pcucode = visitdiag.pcucode
where  1=1 $P!{ReportDate} $P!{pcucode}
                 and diagcode  like 'W%')   as caccid

,(select count(distinct visit.pid,visit.pcucodeperson)  from visit left join visitdrug on visit.visitno = visitdrug.visitno and visit.pcucode = visitdrug.pcucode
where 1=1 $P!{ReportDate} $P!{pcucode} ) as cperson

,chospital.hosname
,hmain.hosname as hosmain,visit.visitno
from visit left join visitdiag on visit.pcucode = visitdiag.pcucode and visit.visitno = visitdiag.visitno

	left join chospital on visit.pcucode = chospital.hoscode
 	left join chospital hmain on visit.hosmain = hmain.hoscode
where 1=1 $P!{ReportDate} $P!{pcucode}
group by visit.pcucode]]>
	</queryString>
	<field name="ctime" class="java.lang.Long"/>
	<field name="cdiag" class="java.lang.Long"/>
	<field name="caccid" class="java.lang.Long"/>
	<field name="cperson" class="java.lang.Long"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="hosmain" class="java.lang.String"/>
	<field name="visitno" class="java.lang.Integer"/>
