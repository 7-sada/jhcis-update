	<parameter name="visitno" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[new Integer (32325)]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String">
		<defaultValueExpression><![CDATA["03388"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["c:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT distinct
    ct.titlename AS person_prename,
     person.`fname` AS person_fname,
     person.`lname` AS person_lname,
     person.`pid` AS person_pid,
     visit.visitno,visit.pcucode,
    IF(visit.visitdate IS NULL,'',concat(convert(DAY(visit.visitdate) using utf8),' ',
   CASE WHEN MONTH(visit.visitdate)=1 THEN 'มกราคม'
   WHEN MONTH(visit.visitdate)=2 THEN 'กุมภาพันธ์' WHEN MONTH(visit.visitdate)=3 THEN 'มีนาคม'
   WHEN MONTH(visit.visitdate)=4 THEN 'เมษายน' WHEN MONTH(visit.visitdate)=5 THEN 'พฤษภาคม'
   WHEN MONTH(visit.visitdate)=6 THEN 'มิถุนายน' WHEN MONTH(visit.visitdate)=7 THEN 'กรกฎาคม'
   WHEN MONTH(visit.visitdate)=8 THEN 'สิงหาคม' WHEN MONTH(visit.visitdate)=9 THEN 'กันยายน'
   WHEN MONTH(visit.visitdate)=10 THEN 'ตุลาคม' WHEN MONTH(visit.visitdate)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(visit.visitdate)=12 THEN 'ธันวาคม' END,' ',YEAR(visit.visitdate)+543) )
   as visitdate,
     visit.`visitdate` AS visit_visitdate,
     DATE_FORMAT(visit.visitdate,'%Y-%m-%d') as dv,
     cdrug.`drugname` AS cdrug_drugname,
     chospital.`hosname` AS chospital_hosname,
     visitdrug.`unit` AS visitdrug_unit,
     cdrugunitsell.`unitsellname` AS cdrugunitsell,
     visitdrug.`realprice` AS visitdrug_realprice,
     visitdrug.realprice * visitdrug.unit as mt,
     visitdrug.`dose` AS visitdrug_dose
,visit.symptoms
,visit.pressure,visit.weight,visit.height,visit.username
,cright.rightname
#,doseprefix
FROM
     `person` person
     INNER JOIN `visit` visit ON person.`pcucodeperson` = visit.`pcucodeperson` AND person.`pid` = visit.`pid`
     Left Outer Join `visitdiag` visitdiag ON visit.`pcucode` = visitdiag.`pcucode` AND visit.`visitno` = visitdiag.`visitno`
     INNER JOIN `visitdrug` visitdrug ON visit.`pcucode` = visitdrug.`pcucode` AND visit.`visitno` = visitdrug.`visitno`
     Left Outer Join `chospital` chospital ON visit.pcucode = chospital.`hoscode`
     INNER JOIN `cdrug` cdrug ON visitdrug.`drugcode` = cdrug.`drugcode`
     INNER JOIN cright ON visit.rightcode = cright.rightcode
LEFT JOIN ctitle ct on (person.prename = ct.titlecode)
LEFT JOIN `cdrugunitsell` cdrugunitsell ON cdrug.`unitsell` = cdrugunitsell.`unitsellcode`

WHERE  visit.visitno=$P{visitno} and visit.pcucode =$P{pcucode} and (cdrug.drugtype = '01' || cdrug.drugtype ='10')
order by visit.visitdate,visit.visitno,visit.pcucode,visitdiag.diagcode]]>
	</queryString>
