<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="druguse" pageWidth="226" pageHeight="226" orientation="Landscape" columnWidth="220" leftMargin="5" rightMargin="1" topMargin="0" bottomMargin="2" uuid="d7ae8b84-b2b9-45ee-98a8-2ee5e5837ae3">
