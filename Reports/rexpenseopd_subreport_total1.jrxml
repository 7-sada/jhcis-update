<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rexpenseopd_subreport_total1" pageWidth="535" pageHeight="802" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="c95c6301-4107-41e6-89c9-0f809a089fd8">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="edate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="rightgroup" class="java.lang.String" isForPrompting="false"/>
	<parameter name="hosmain" class="java.lang.String" isForPrompting="false"/>
	<parameter name="zdiag" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select v.pcucode
,sum(case when (dr.drugcode ='897' ) or (cdr.drugtype = '06') then (dr.unit*dr.realprice) else 0 end) as dservice
,sum(case when (cdr.drugtype ='02' and cdr.drugtypesub in('1','2') ) then (dr.unit*dr.realprice) else 0 end) as denservice
,sum(case when (cdr.drugtype ='07') then (dr.unit*dr.realprice) else 0 end) as labservice
,sum(case when (cdr.drugtype ='02' and cdr.drugtypesub not in('1','2') )  then (dr.unit*dr.realprice) else 0 end) as cmservice
,sum(case when (cdr.drugtype  in('01','10','03')) then (dr.unit*dr.realprice) else 0 end) as drugservice
from  visitdrug dr
      left JOIN cdrug cdr on dr.drugcode = cdr.drugcode
      left join visit v on dr.visitno = v.visitno and dr.pcucode = v.pcucode
      left join cright on cright.rightcode = v.rightcode
JOIN(
     SELECT DISTINCT vv.pcucode,vv.visitno FROM visit vv JOIN visitdiag
         ON vv.pcucode=visitdiag.pcucode AND vv.visitno=visitdiag.visitno
     WHERE vv.visitdate BETWEEN $P{sdate} and $P{edate} $P!{zdiag}
    ) AS jj ON v.pcucode=jj.pcucode and v.visitno=jj.visitno
where v.visitdate between $P{sdate} and $P{edate}
      	and cright.rightgroup  = $P{rightgroup}
 #and concat(dr.pcucode,dr.visitno) in (select concat(visitdiag.pcucode,#visitdiag.visitno) from visitdiag where 1=1 $P!{zdiag})
group by v.pcucode]]>
	</queryString>
	<field name="pcucode" class="java.lang.String"/>
	<field name="dservice" class="java.math.BigDecimal"/>
	<field name="denservice" class="java.math.BigDecimal"/>
	<field name="labservice" class="java.math.BigDecimal"/>
	<field name="cmservice" class="java.math.BigDecimal"/>
	<field name="drugservice" class="java.math.BigDecimal"/>
