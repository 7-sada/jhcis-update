<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpersonright_list" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="43143d36-52fe-40ff-b8a3-e023c3ff78e5">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["current_date"]]></defaultValueExpression>
	</parameter>
	<parameter name="rightcode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'72'"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="TypeLive" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[ลักษณะการอยู่อาศัย ตามทะเบียนราษฎร์,อยู่จริง]]></parameterDescription>
		<defaultValueExpression><![CDATA["AND person.typelive < 3"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson ='01079']]></parameterDescription>
		<defaultValueExpression><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="offAddress2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="rigNa" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as pname,
`person`.`lname`,
`person`.`hnomoi`,
DATE_FORMAT(`person`.`birth`,'%Y-%m-%d') as birth,
concat((year($P!{ReportDate})-year(`person`.`birth`)-(right($P!{ReportDate},5)<right(`person`.`birth`,5))),'-',
(if (day($P!{ReportDate}) <day(`person`.`birth`),(if (right($P!{ReportDate},5)<right(`person`.`birth`,5),(12+ month($P!{ReportDate}))-month(`person`.`birth`),month($P!{ReportDate})-month(`person`.`birth`)))-1 ,(if (right($P!{ReportDate},5)<right(`person`.`birth`,5),(12+ month($P!{ReportDate}))-month(`person`.`birth`),month($P!{ReportDate})-month(`person`.`birth`))))) ,'-',
(if (day($P!{ReportDate}) < day(`person`.`birth`),((day(last_day(current_date())))+ day($P!{ReportDate}))-day(`person`.`birth`),day($P!{ReportDate})-day(`person`.`birth`)))) as age,
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8), ' ต.',getSubdist(LEFT(village.villcode,6)))  AS villname,
`person`.`rightno`,
`cright`.`rightname`,
if(person.typelive < 3,'ตามทะเบียนราษฎร์',if(person.typelive = 3,'ตามที่อาศัยอยู่จริง','')) as typelive
FROM person
Left Outer Join house ON person.hcode = house.hcode AND house.pcucode = person.pcucodeperson
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Left Outer Join village ON house.villcode = village.villcode AND village.pcucode = house.pcucode
Left Outer Join cright ON person.rightcode = cright.rightcode
Left Outer Join persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
WHERE right(`house`.`villcode`,2)  <>  '00'  $P!{TypeLive}
#AND `person`.`rightcode` = $P!{rightcode}
AND $P!{rightcode}
$P!{pcucode}  AND (persondeath.pid IS NULL OR deaddate > $P!{ReportDate})
AND (person.dateexpire >= $P!{ReportDate} OR person.dateexpire is null)
ORDER BY
     village.`villcode`,`person`.`hnomoi`]]>
	</queryString>
	<field name="pname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="hnomoi" class="java.lang.String"/>
	<field name="birth" class="java.util.Date"/>
	<field name="age" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<field name="rightno" class="java.lang.String"/>
	<field name="rightname" class="java.lang.String"/>
	<field name="typelive" class="java.lang.String"/>
