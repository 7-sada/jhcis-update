		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="TypeLive" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[ลักษณะการอยู่อาศัย ตามทะเบียนราษฎร์,อยู่จริง]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'03447'"]]></defaultValueExpression>
	</parameter>
	<parameter name="TypeFind" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["test"]]></defaultValueExpression>
	</parameter>
	<parameter name="mari" class="java.lang.String">
		<defaultValueExpression><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="nat" class="java.lang.String">
		<defaultValueExpression><![CDATA[" 1 "]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
#CONCAT(`person`.`prename`,`person`.`fname`) AS pname,
concat(ifnull(ctitle.titlename,ifnull(person.prename,'...')),person.fname) AS pname,
`person`.`lname`,
`person`.`hnomoi`,
zero2null(`person`.`birth`) as birth,
DATE_FORMAT(zero2null(person.`birth`),'%Y-%m-%d') AS birthvalue,
GetAgeYearNum(`person`.`birth`,$P!{ReportDate}) AS age,
`village`.`villcode`,
`village`.`villname`,
`village`.`villno`,
`person`.`idcard`,
house.area
FROM
`person`
left join ctitle on titlecode = prename
Left Join `house` ON `person`.`hcode` = `house`.`hcode` AND `house`.`pcucode` = `person`.`pcucodeperson`
Left Join `village` ON `house`.`villcode` = `village`.`villcode` AND `village`.`pcucode` = `house`.`pcucode`
WHERE SUBSTRING(`house`.`villcode`,7,2)<>'00'  $P!{TypeLive}
AND person.pcucodeperson=$P!{pcucode} AND $P!{mari} $P!{nat}
and length(DATE_FORMAT(zero2null(person.`birth`),'%Y-%m-%d')) = 10
and day(birth)>0 and month(birth)>0 and year(birth)>0
#and GetAgeYearNum(`person`.`birth`,$P!{ReportDate})=3
ORDER BY
     village.`villcode`,village.`villno`,house.area,`person`.`hcode`]]>
	</queryString>
