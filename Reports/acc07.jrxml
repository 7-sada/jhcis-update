<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="acc07" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="1f3de371-b562-4038-988c-078c0db5c571">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="datespec" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-04-04"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["15009"]]></defaultValueExpression>
	</parameter>
	<parameter name="repn" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["..."]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT person.pid, concat( ifnull(titlename,ifnull(person.prename,'...')) ," ", fname," ", lname) fname,
birth ,DATE_FORMAT(birth,'%Y-%m-%d') as d , CONVERT(CONCAT(getAgeYearNum(person.birth,CAST('2012-04-03' AS DATE)),' ปี ',
getAgeMonthNum(person.birth,CAST('2012-04-03' AS DATE)),' เดือน ',
getAgeDayNum(person.birth,CAST('2012-04-03' AS DATE)),' วัน ') USING utf8) AS age_ymd,if(deliverresult='ท',
CONVERT(CONCAT(visitanc.pregno,'(แท้ง)') USING utf8),convert(visitancpregnancy.pregno USING utf8)) as abort,
lmp,

DATE_ADD(lmp, INTERVAL 40 week ) as edc , round(DATEDIFF(cast($P{datespec} as date),lmp) /7) as pregage,
hnomoi,mumoi,villname
FROM person  left join ctitle on person.prename = titlecode
left join visitanc on (person.pid = visitanc.pid  and person.pcucodeperson = visitanc.pcucodeperson)
left join visitancpregnancy on (visitancpregnancy.pid = person.pid and
                                visitancpregnancy.pcucodeperson = person.pcucodeperson )
join house on (person.hcode = house.hcode and person.pcucodeperson = house.pcucode )
join village on (house.villcode = village.villcode and house.pcucode = village.pcucode )
left join visitancdeliver on visitancpregnancy.pcucodeperson = visitancdeliver.pcucodeperson AND
                             visitancpregnancy.pid = visitancdeliver.pid AND
                             visitancpregnancy.pregno = visitancdeliver.pregno
WHERE person.pcucodeperson ='15009'  and (DATEDIFF("2012-04-03",lmp) between 0 and 280)
                                     and Right(house.villcode,2)<> '00'
                                     and 1=1
                                     and person.pid NOT IN (SELECT persondeath.pid
                                                            FROM persondeath
                                                            WHERE person.pid = persondeath.pid and
                                                                  person.pcucodeperson = persondeath.pcucodeperson and
(persondeath.deaddate IS NULL OR persondeath.deaddate<='2012-04-03'))   GROUP BY person.pid]]>
	</queryString>
	<field name="pid" class="java.lang.Integer"/>
	<field name="fname" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="d" class="java.lang.String"/>
	<field name="age_ymd" class="java.lang.String"/>
	<field name="abort" class="java.lang.String"/>
	<field name="lmp" class="java.sql.Date"/>
	<field name="edc" class="java.sql.Date"/>
	<field name="pregage" class="java.math.BigDecimal"/>
	<field name="hnomoi" class="java.lang.String"/>
	<field name="mumoi" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
