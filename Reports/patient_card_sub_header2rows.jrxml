<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="patient_card_sub_header2rows"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="335"
		 pageHeight="802"
		 columnWidth="335"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["08640"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     concat('สถานบริการ: ',chospital.`hosname`,' หมู่ที่: ',ifnull(chospital.`mu`,'')) AS chospital_hosname,     
     csubdistrict.`subdistname` AS csubdistrict_subdistname,
concat('ต.',ifnull(csubdistrict.`subdistname`,'...'),' ',
            'อ.',ifnull(cdistrict.`distname`,'..'),' ',
            'จ.',ifnull(cprovince.`provname`,'.')) 
AS sdtdtpv,
     cdistrict.`distname` AS cdistrict_distname,
     cprovince.`provname` AS cprovince_provname
FROM
     `chospital` chospital INNER JOIN `office` office ON chospital.`hoscode` = office.`offid`
     INNER JOIN `csubdistrict` csubdistrict ON chospital.`provcode` = csubdistrict.`provcode`
     AND chospital.`subdistcode` = csubdistrict.`subdistcode`
     AND chospital.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cdistrict` cdistrict ON csubdistrict.`provcode` = cdistrict.`provcode`
     AND cdistrict.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cprovince` cprovince ON cdistrict.`provcode` = cprovince.`provcode`
WHERE 
     offid = $P!{pcucode}]]></queryString>

	<field name="chospital_hosname" class="java.lang.String"/>
	<field name="csubdistrict_subdistname" class="java.lang.String"/>
	<field name="sdtdtpv" class="java.lang.String"/>
	<field name="cdistrict_distname" class="java.lang.String"/>
	<field name="cprovince_provname" class="java.lang.String"/>

		<background>
