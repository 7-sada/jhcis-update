<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="appointment" pageWidth="240" pageHeight="198" orientation="Landscape" columnWidth="212" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" uuid="bda8716e-35c3-487f-b169-85966e77b690">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="2.8531167061100033"/>
	<property name="ireport.x" value="166"/>
	<property name="ireport.y" value="120"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="person" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
visit.pid,
#CONCAT(person.prename,person.fname,' ',person.lname) ptname,
concat(ifnull(ct1.titlename,ifnull(person.`prename`,'...')),person.`fname`,'  ',ifnull(person.`lname`,'...')) AS ptname,
'อายุรกรรม' AS clinic,
cdisease.diseasenamethai,
DATE_FORMAT(visitdiagappoint.appodate,'%Y-%m-%d') appodate1,
IF(appodate IS NULL,'',concat(convert(DAY(appodate) using utf8),' ',
   CASE WHEN MONTH(appodate)=1 THEN 'มค'
   WHEN MONTH(appodate)=2 THEN 'กพ' WHEN MONTH(appodate)=3 THEN 'มีค'
   WHEN MONTH(appodate)=4 THEN 'เมย' WHEN MONTH(appodate)=5 THEN 'พค'
   WHEN MONTH(appodate)=6 THEN 'มิย' WHEN MONTH(appodate)=7 THEN 'กค'
   WHEN MONTH(appodate)=8 THEN 'สค' WHEN MONTH(appodate)=9 THEN 'กย'
   WHEN MONTH(appodate)=10 THEN 'ตค' WHEN MONTH(appodate)=11 THEN 'พย'
   WHEN MONTH(appodate)=12 THEN 'ธค' END,' ',YEAR(appodate)+543) )
   as appodateTh,
CASE
WHEN visitdiagappoint.appotype='1' THEN 'รับยาฯ'
WHEN visitdiagappoint.appotype='2' THEN 'ฟังผลฯ, follow up'
WHEN visitdiagappoint.appotype='3' THEN 'ล้างแผล / ทำแผล'
WHEN visitdiagappoint.appotype='4' THEN 'เจาะเลือด'
WHEN visitdiagappoint.appotype='5' THEN 'ตรวจน้ำตาล'
WHEN visitdiagappoint.appotype='6' THEN 'วัความดัน'
WHEN visitdiagappoint.appotype='7' THEN 'บริการแพทย์แผนไทย'
WHEN visitdiagappoint.appotype='9' THEN 'บริการทันตกรรม'
WHEN visitdiagappoint.appotype='10' THEN 'วางแผนครอบครัว'
WHEN visitdiagappoint.appotype='49' THEN 'บริการอื่นๆ'
ELSE ifnull(comment,'...ไม่ระบุ') END AS apptype,
visitdiagappoint.comment,ifnull(visitdiagappoint.appotime,'..') appotime
,concat(ifnull(ct0.`titlename`,'...'),ifnull(`user`.`fname`,`user`.`fullName`),'   ',ifnull(`user`.`lname`,'...')) as fullName
FROM
visitdiagappoint
Left Join cdisease ON visitdiagappoint.diagcode = cdisease.diseasecode
Left Join visit ON visitdiagappoint.pcucode = visit.pcucode AND visitdiagappoint.visitno = visit.visitno
Left Join person ON visit.pcucodeperson = person.pcucodeperson AND visit.pid = person.pid
Left Join `user` ON visit.pcucode = `user`.pcucode AND visit.username = `user`.username
left join ctitle ct0 on `user`.prename = ct0.titlecode
left join ctitle ct1 on person.prename = ct1.titlecode
WHERE
$P!{person}]]>
	</queryString>
	<field name="pid" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="ptname" class="java.lang.String"/>
	<field name="clinic" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="diseasenamethai" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="appodate1" class="java.lang.String"/>
	<field name="appodateTh" class="java.lang.String"/>
	<field name="apptype" class="java.lang.String"/>
	<field name="comment" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="appotime" class="java.lang.String">
		<fieldDescription><![CDATA[เวลาที่นัด(ให้เป็น varchar เพื่อให้บันทึกเป็นช่วงเวลา เช่น 9.00-11.30 น)]]></fieldDescription>
	</field>
	<field name="fullName" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
