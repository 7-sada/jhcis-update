	</parameter>
	<queryString><![CDATA[select drugname,visitdrug.drugcode, count(distinct v.pcucode,v.pid) as ppid ,count(visitdrug.unit) as cunt
,sum(visitdrug.unit) unit,  visitdrug.costprice as costp 
,visitdrug.realprice as sel 
,sum(visitdrug.unit *visitdrug.realprice) as tsel  
,h.hosname,v.visitdate,v.pcucode
from visit v left join visitdrug on v.visitno = visitdrug.visitno and v.pcucode = visitdrug.pcucode
           left join cdrug on visitdrug.drugcode = cdrug.drugcode
           left join chospital h on v.pcucode = h.hoscode
where cdrug.drugtype='10'  and v.visitdate between  $P{sdate} and $P{edate}
$P!{pcucode}
group by cdrug.drugcode]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="drugcode" class="java.lang.String"/>
	<field name="ppid" class="java.lang.Long"/>
	<field name="cunt" class="java.lang.Long"/>
	<field name="unit" class="java.math.BigDecimal"/>
	<field name="costp" class="java.math.BigDecimal"/>
	<field name="sel" class="java.math.BigDecimal"/>
	<field name="tsel" class="java.math.BigDecimal"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="pcucode" class="java.lang.String"/>

	<variable name="SUM_cunt_1" class="java.lang.Long" resetType="Report" calculation="Sum">
