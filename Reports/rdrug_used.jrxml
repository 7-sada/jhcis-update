<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rdrug_used"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[WHERE cdrugremain.pcucode =  '02332' AND cdrug.drugflag = '1' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA["  "]]></defaultValueExpression>
	</parameter>
	<parameter name="between" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" BETWEEN '2010-11-01' AND '2010-12-31' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT CASE
 WHEN cdrug.drugtype =  '01'  THEN 'ยาฯ' 
 WHEN cdrug.drugtype =  '02'   THEN 'หัตถการ' 
 WHEN cdrug.drugtype =  '03'   THEN 'วัสดุการแพทย์' 
 WHEN cdrug.drugtype =  '04'  THEN 'เวชภัณฑ์คุมกำเนิด' 
 WHEN cdrug.drugtype =  '05'   THEN 'วัคซีน' 
 WHEN cdrug.drugtype =  '06'   THEN 'ค่าบริการฯ' 
 WHEN cdrug.drugtype =  '07'   THEN 'ค่าตรวจทางห้องปฏิบัติการฯ' 
 WHEN cdrug.drugtype =  '08'  THEN 'ทันตกรรม' 
 WHEN cdrug.drugtype =  '10'  THEN 'ยาสมุนไพร'
 WHEN cdrug.drugtype =  '11'  THEN 'เวชภัณฑ์ที่ไม่ใช่ยา'
 ELSE 'ไม่ระบุประเภทฯ' 
END AS drugtype,
cdrug.drugname AS drug,
SUM(v.unit) AS unit,
SUM(v.unit*v.costprice) AS costprice,
SUM(v.unit*v.realprice) AS realprice,
cdrug.unitusage
FROM
visit
Inner Join visitdrug v ON visit.pcucode = v.pcucode AND visit.visitno = v.visitno
Inner Join cdrug ON v.drugcode = cdrug.drugcode
WHERE cdrug.drugtype NOT IN ('04','05') AND visit.visitdate $P!{between} $P!{pcucode}
GROUP BY
drug
UNION
SELECT 'วัคซีน' AS drugtype,
CASE
 WHEN v.vaccinecode IN ('DT','DT1','DT2','DTS1','DTS2','DTS3','DTS4','DTANC1','DTANC2','DTANC3','DTANC4','DTANC5') OR v.vaccinecode =  'V120' THEN 'DT' 
 WHEN v.vaccinecode IN ('DTP','DTP1','DTP2','DTP3','DTP4','DTP5') OR v.vaccinecode =  'V121' THEN 'DTP'  
 WHEN v.vaccinecode IN ('HBV','HBV1','HBV2','HBV3') OR v.vaccinecode =  'V122' THEN 'HB'  
 WHEN v.vaccinecode IN ('JE','JE1','JE2','JE3') OR v.vaccinecode =  'V123' THEN 'JE'  
 WHEN v.vaccinecode IN ('MMR','MMR2') OR v.vaccinecode =  'V124' THEN 'MMR'  
 WHEN v.vaccinecode IN ('OPV','OPV1','OPV2','OPV3','OPV4','OPV5','OPVs1','OPVs2','OPVs3','OPVC') OR v.vaccinecode =  'V125' THEN 'OPV'  
 WHEN v.vaccinecode IN ('TT','TT1','TT2','TT3','TT4','TT5') OR v.vaccinecode =  'V126' THEN 'TT'  
 WHEN v.vaccinecode IN ('DHB','DHB1','DHB2','DHB3') OR v.vaccinecode =  'V127' THEN 'DTP+HB'  
 WHEN v.vaccinecode IN ('MEAS') OR v.vaccinecode =  'V128' THEN 'MEAS' 
 WHEN v.vaccinecode IN ('RB','RB1','RB2','RB3','RB4','RB5') THEN 'RB'
 ELSE v.vaccinecode END AS drug,
COUNT(v.visitno) AS unit,
COUNT(v.visitno)*cdrug.cost AS costprice,
COUNT(v.visitno)*cdrug.sell AS realprice,
cdrug.unitusage
FROM
 visitepi v
Inner Join cdrug ON  v.vaccinecode = cdrug.drugcode
WHERE v.dateepi $P!{between} $P!{pcucode}
GROUP BY
drug
UNION
SELECT
'เวชภัณฑ์คุมกำเนิด' AS drugtype,
cdrug.drugname AS drug,
SUM(v.unit) AS unit,
SUM(v.unit)*cdrug.cost AS costprice,
SUM(v.unit)*cdrug.sell AS realprice,
cdrug.unitusage
FROM
visitfp v
Inner Join cdrug ON v.fpcode = cdrug.drugcode
WHERE
v.fpcode <>  'fp0000' AND v.datefp $P!{between} $P!{pcucode}
GROUP BY
cdrug.drugname
UNION
SELECT
'เวชภัณฑ์คุมกำเนิด' AS drugtype,
cdrug.drugname AS drug,
SUM(v.pregtestunit) AS unit,
SUM(v.pregtestunit)*cdrug.cost AS costprice,
SUM(v.pregtestunit)*cdrug.sell AS realprice,
cdrug.unitusage
FROM
visitfp v
Inner Join cdrug ON v.pregtest = cdrug.drugcode
WHERE
v.fpcode <>  'fp0000' AND v.datefp $P!{between} $P!{pcucode}
GROUP BY cdrug.drugname
ORDER BY drugtype ASC,drug]]></queryString>

	<field name="drugtype" class="java.lang.String"/>
	<field name="drug" class="java.lang.String"/>
	<field name="unit" class="java.lang.Double"/>
	<field name="costprice" class="java.lang.Double"/>
	<field name="realprice" class="java.lang.Double"/>
	<field name="unitusage" class="java.lang.String"/>

