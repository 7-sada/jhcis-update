<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rperson_list" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="6535fe5b-2730-4726-b253-f6671d6c162f">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='06742']]></parameterDescription>
		<defaultValueExpression><![CDATA["  "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="where_person" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND (person.dischargedate is null OR person.dischargedate > '20080101') AND (person.datein is null OR person.datein <= '20080101')  AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.deaddate <= '20080101') "]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) AS pname,
person.lname,
person.hnomoi,
DATE_FORMAT(person.`birth`,'%Y-%m-%d') AS birth,
concat((year(current_date())-year(person.birth)-(right(current_date(),5)<right(person.birth,5))),' - ',
 (if (day(current_date()) <day(person.birth),(if (right(current_date(),5)<right(person.birth,5),(12+ month(current_date()))-month(person.birth),month(current_date())-month(person.birth)))-1 ,(if (right(current_date,5)<right(`person`.`birth`,5),(12+ month(current_date()))-month(person.birth),month(current_date())-month(person.birth))))) ,' - ',
 (if (day(current_date()) < day(person.birth),(day(last_day(current_date()))+ day(current_date()))-day(person.birth),day(current_date())-day(person.birth)))) AS age,
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8),' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,
cright.rightname
FROM
person
Left Join house ON person.hcode = house.hcode AND house.pcucode = person.pcucodeperson
Left Join village ON house.villcode = village.villcode AND village.pcucode = house.pcucode
Left Join cright ON person.rightcode = cright.rightcode
Left Join persondeath ON person.pcucodeperson = persondeath.pcucodeperson AND person.pid=persondeath.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
WHERE SUBSTRING(house.villcode,7,2)<>'00'
 $P!{pcucode}
 $P!{where_person}
ORDER BY
     village.villcode,person.hnomoi]]>
	</queryString>
