	<subDataset name="data" uuid="f660bd12-5496-475b-804d-a52305eb756e">
		<parameter name="_pid" class="java.lang.String"/>
		<queryString>
			<![CDATA[select ve.pid,ct.titlename,p.fname,p.lname,p.idcard,ifnull(p.prenameeng,"") as prenameeng,
ifnull(p.fnameeng,"") as fnameeng,ifnull(p.lnameeng,"") as lnameeng,
p.sex,if(p.sex = '1','Male','Female' ) as psexEng,if(p.sex = '1','ชาย','หญิง' ) as psexTha
,p.birth,date_format(p.birth,'%d/%m/%Y') as birtheng,
date_format(date_add(p.birth,interval 543 year),'%d/%m/%Y') as birthdatetha,ve.dateepi,ve.lotno,
ifnull(p.passpotnumber,"") as passpotnumber,ifnull(pa.hno,p.hnomoi) as houseNo,
ifnull(ifnull(pa.road,p.roadmoi),"-") as road
,ifnull(pa.mu,p.mumoi) as moo,ifnull(cs1.subdistname,cs2.subdistname) as tumbon,
ifnull(cd1.distname,cd2.distname) as ampur,
ifnull(cp1.provname,cp2.provname) as provname
,if(ve.vaccinecode='COVID19-1',"เข็มที่ 1 (1st dose)","เข็มที่ 2 (2nd dose)") as vaccinecode
,ve.hosservice,h.hosname,d.drugname
,date_format(date_add(ve.dateepi, interval 543 year),'%d/%m/%Y') as dateepith,cm.manufac_name,
ifnull(cm.trade_name,'ไม่ระบุ') as tradeName
from visitepi ve
left join person p on (ve.pid = p.pid and ve.pcucodeperson = ve.pcucodeperson)
left join personaddresscontact pa on (p.pid = pa.pid and p.pcucodeperson = pa.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join cdrug d on (ve.vaccinecode = d.drugcode)
left join csubdistrict cs1 on (pa.subdistcode = cs1.subdistcode and pa.distcode = cs1.distcode
and pa.provcode = cs1.provcode)
left join csubdistrict cs2 on (p.subdistcodemoi = cs2.subdistcode and p.distcodemoi = cs2.distcode
and p.provcodemoi = cs2.provcode)
left join cprovince cp1 on (pa.provcode = cp1.provcode)
left join cprovince cp2 on (p.provcodemoi = cp2.provcode)
left join cdistrict cd1 on (pa.distcode = cd1.distcode and pa.provcode = cd1.provcode)
left join cdistrict cd2 on (p.distcodemoi = cd2.distcode and p.provcodemoi = cd2.provcode)
left join chospital h on (ve.hosservice = h.hoscode)
left join ccovid19_vaccinemanufac cm on (ve.manufacturer = cm.manufac_vcodeprefix)
where ucase(ve.vaccinecode) in ('COVID19-1','COVID19-2')
and ve.pid = $P{_pid}
order by ve.dateepi]]>
		</queryString>
