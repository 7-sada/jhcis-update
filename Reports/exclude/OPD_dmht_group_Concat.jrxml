	<subDataset name="data1" uuid="6d859310-e9da-4c05-b4a9-b340721cc7c1">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<parameter name="showDate1" class="java.lang.String"/>
		<parameter name="showDate2" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT p.pid,fname,lname,v.visitdate,DATE_FORMAT(v.visitdate,'%Y-%m-%d') as vd,
group_concat(d.diagcode) as diagcode,getageymd(p.birth,v.visitdate) as age_m
FROM visitdiag d
JOIN visit v ON (v.pcucode=d.pcucode and v.visitno=d.visitno)
JOIN person p ON (v.pcucodeperson=p.pcucodeperson AND v.pid=p.pid)
WHERE (UCase(left(d.diagcode,3)) BETWEEN 'E10' AND 'E14' OR LCase(left(d.diagcode,3)) BETWEEN 'i10' AND 'i15')
AND v.visitdate BETWEEN $P{sdate} AND $P{edate}
group by p.pid,v.visitdate
order by v.visitdate]]>
		</queryString>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="visitdate" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="vd" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="diagcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="age_m" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="sdate" class="java.lang.String"/>
