	<subDataset name="datadrug" uuid="fb87a8d7-5372-4771-a48b-a5678d8f1607">
		<parameter name="visitno" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[select vd.drugcode,c.drugname,vd.unit
from visitdrug vd
join cdrug c on (vd.drugcode = c.drugcode)
where visitno = $P{visitno}
and c.drugtype <> '06']]>
		</queryString>
		<field name="drugcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="drugname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="unit" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<queryString>
		<![CDATA[select v.visitno,year(v.visitdate)+543 as NoYY,day(v.visitdate) as dd,v.numberrefer,
(CASE WHEN MONTH(v.visitdate)=1 THEN 'มกราคม'
   WHEN MONTH(v.visitdate)=2 THEN 'กุมภาพันธ์' WHEN MONTH(v.visitdate)=3 THEN 'มีนาคม'
   WHEN MONTH(v.visitdate)=4 THEN 'เมษายน' WHEN MONTH(v.visitdate)=5 THEN 'พฤษภาคม'
   WHEN MONTH(v.visitdate)=6 THEN 'มิถุนายน' WHEN MONTH(v.visitdate)=7 THEN 'กรกฎาคม'
   WHEN MONTH(v.visitdate)=8 THEN 'สิงหาคม' WHEN MONTH(v.visitdate)=9 THEN 'กันยายน'
   WHEN MONTH(v.visitdate)=10 THEN 'ตุลาคม' WHEN MONTH(v.visitdate)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(v.visitdate)=12 THEN 'ธันวาคม' end) as mm, (Year(v.visitdate)+543) as yy,
v.pcucode,ch1.hosname,
v.pid,t.titlenamelong,p.fname,p.lname,getAgeYearNum(p.birth,v.visitdate) as ageyy,
if(p.sex='1','ชาย','หญิง') as psex,ifnull(pa.hno,p.hnomoi) as hno,ifnull(pa.mu,p.mumoi) as moo,
ifnull(cs1.subdistname,cs.subdistname) as tumbon,
ifnull(cd1.distname,cd.distname) as ampur,ifnull(cp1.provname,cp.provname) as province,
v.refertohos,ch.hosname as hosrefer,
v.symptoms as presentdiag,v.symptomsco as pastdiag,
v.temperature as bt,v.pressure as bp,v.pulse as p,v.respri as r,v.weight,
(case when v.gaheent = '1' then 'ปกติ'
when v.gaheent = '2' then 'ผิดปกติ'
when v.gaheent = '9' then 'ไม่ตรวจ'
else 'n/a' end ) as HEENT,
(case when v.gahlart = '1' then 'ปกติ'
when v.gahlart = '2' then 'ผิดปกติ'
when v.gahlart = '9' then 'ไม่ตรวจ'
else 'n/a' end ) as HLART,
(case when v.galung = '1' then 'ปกติ'
when v.galung = '2' then 'ผิดปกติ'
when v.galung = '9' then 'ไม่ตรวจ'
else 'n/a' end ) as LUNG,
(case when v.gaab = '1' then 'ปกติ'
when v.gaab = '2' then 'ผิดปกติ'
when v.gaab = '9' then 'ไม่ตรวจ'
else 'n/a' end ) as Ab,
(case when v.gaext = '1' then 'ปกติ'
when v.gaext = '2' then 'ผิดปกติ'
when v.gaext = '9' then 'ไม่ตรวจ'
else 'n/a' end ) as Ext,
(case when v.ganeuro = '1' then 'ปกติ'
when v.ganeuro = '2' then 'ผิดปกติ'
when v.ganeuro = '9' then 'ไม่ตรวจ'
else 'n/a' end ) as Neuro,v.diagnote,vd.diagcode,
cdi.diseasenamethai,
(case when v.refer = '00' then 'ไม่ใช่  Case Refer'
when v.refer = '01' then 'เกินขีดความสามารถของหน่วยงานนี้'
when v.refer = '02' then 'อาการดีขึ้น จึงส่งไประดับล่าง'
when v.refer = '03' then 'เป็นความประสงค์ของผู้รับบริการ ฯ'
when v.refer = '04' then 'ส่งไปเพื่อการวินิจฉัยที่ถูกต้อง'
when v.refer = '05' then 'ส่งไปเพื่อทันตกรรม'
when v.refer = '06' then 'เพื่อการรักษาต่อเนื่อง'
when v.refer = '99' then 'อื่นๆ'
else 'n/a' end) as caseRefer,v7.request,u.officerposition,
ifnull(v.username,concat(ct1.titlenamelong,' ',u.fullname)) as officername
from visit v
left join person p on (v.pcucode = p.pcucodeperson) and (v.pid = p.pid)
left join ctitle t on (p.prename = t.titlecode)
left join personaddresscontact pa on (p.pid = pa.pid and p.pcucodeperson = pa.pcucodeperson)
left join csubdistrict cs on (p.subdistcodemoi = cs.subdistcode and p.distcodemoi = cs.distcode and p.provcodemoi = cs.provcode)
left join cdistrict cd on (p.distcodemoi = cd.distcode and p.provcodemoi = cd.provcode)
left join cprovince cp on (p.provcodemoi = cp.provcode)
left join csubdistrict cs1 on (pa.subdistcode = cs1.subdistcode and pa.distcode = cs1.distcode and pa.provcode = cs1.provcode)
left join cdistrict cd1 on (pa.distcode = cd1.distcode and pa.provcode = cd1.provcode)
left join cprovince cp1 on (pa.provcode = cp1.provcode)
left join chospital ch on (v.refertohos = ch.hoscode)
left join chospital ch1 on (v.pcucode = ch1.hoscode)
left join visit7referhisreferres v7 on (v.visitno = v7.visitno) and (v.pcucode = v7.pcucode)
left join visitdiag vd on (v.visitno = vd.visitno and v.pcucode =vd.pcucode)
left join cdisease cdi on (vd.diagcode = cdi.diseasecode)
left join user u on (v.username = u.username)
left join ctitle ct1 on (u.prename = ct1.titlecode)
where v.visitno = $P{visitno}
and v.refer <> '00'
and vd.dxtype = '01']]>
	</queryString>
	<field name="visitno" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="NoYY" class="java.lang.Long"/>
	<field name="dd" class="java.lang.Long"/>
