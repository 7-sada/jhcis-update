	<field name="hno" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="moo" class="java.lang.String">
		<fieldDescription><![CDATA[หมู่บ้าน(..น่าจะตามทะเบียนบ้านของเจ้าของสิทธิ)]]></fieldDescription>
	</field>
	<field name="tumbon" class="java.lang.String"/>
	<field name="ampur" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="province" class="java.lang.String"/>
	<field name="refertohos" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="hosrefer" class="java.lang.String"/>
	<field name="presentdiag" class="java.lang.String"/>
	<field name="pastdiag" class="java.lang.String"/>
	<field name="bt" class="java.math.BigDecimal"/>
	<field name="bp" class="java.lang.String"/>
	<field name="p" class="java.lang.Integer"/>
	<field name="r" class="java.lang.Integer"/>
	<field name="weight" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="HEENT" class="java.lang.String"/>
	<field name="HLART" class="java.lang.String"/>
	<field name="LUNG" class="java.lang.String"/>
	<field name="Ab" class="java.lang.String"/>
	<field name="Ext" class="java.lang.String"/>
	<field name="Neuro" class="java.lang.String"/>
	<field name="diagnote" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="diagcode" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="diseasenamethai" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="caseRefer" class="java.lang.String"/>
	<field name="request" class="java.lang.String">
		<fieldDescription><![CDATA[สิ่งที่ต้องการให้สถานบริการปลายทาง ดำเนินการ สำหรับส่งออกในแฟ้ม REFER_HISTORY]]></fieldDescription>
	</field>
	<field name="officerposition" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="officername" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="108">
			<staticText>
				<reportElement x="0" y="0" width="525" height="28" uuid="a5a4d2cb-9655-41df-ab21-1351d94b5c4d"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="18" isBold="true"/>
				</textElement>
				<text><![CDATA[ใบส่งตัวผู้ป่วยไปรับการตรวจหรือรักษาต่อ]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="345" y="28" width="163" height="20" uuid="8558b06a-9ebd-4086-91c4-f99bb91820f5"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["เลขที่ "+ $F{numberrefer}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="256" y="48" width="269" height="20" uuid="7efe2a71-1161-411d-af01-8e1ecbc271a0"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["วันที่ ..."+$F{dd}+" ... เดือน ..."+$F{mm}+" ... พศ....."+$F{yy}+". .."]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="68" width="345" height="20" uuid="8a2d8780-f0ca-44b3-9490-96a44a0cd5d3"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["จาก "+ $F{hosname}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="88" width="345" height="20" uuid="747981ab-944c-49e4-819e-4b7ee5362a83"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["ถึง   "+ $F{hosrefer}]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<pageHeader>
		<band height="55" splitType="Stretch">
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="0" width="525" height="55" uuid="e3c57ae5-cd12-422e-ab84-6dfa62cba941"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["                   "+"พร้อมหนังสือนี้ ขอส่งตัวผู้ป่วยชื่อ "+$F{titlenamelong}+" "+$F{fname}+" "+ $F{lname}
+" เพศ "+$F{psex}+" อายุ "+ $F{ageyy}+ " ปี อยู่บ้านเลขที่ "+$F{hno}+
" หมุ่ที่ "+ $F{moo}+ " ตำบล "+ $F{tumbon}+" อำเภอ "+$F{ampur}+
" จังหวัด "+ $F{province}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="50">
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="0" width="525" height="50" uuid="3c687431-6e3d-45d3-bf8a-ae4a6ae463d2"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["1. การเจ็บป่วยในอดีต"+"\n"+"..... "+$F{pastdiag}+"\n"+"2. ประวัติการป่วยในปัจจุบัน"
+"\n"+"..... V/S   BT = "+$F{bt}+" c BP "+$F{bp}+" mm/Hg"+" P "+$F{p}
+" mm"+" R "+$F{r}+" mn"+" นน. "+$F{weight}+" กก."+"\n"
+$F{presentdiag}+"\n"+"3. การตรวจชันสูตร" + "\n"+"..... HEENT: "+$F{HEENT}
+" HLART: "+$F{HLART}+" LUNG: "+$F{LUNG}+" Ab: "+$F{Ab}+" Ext: "
+$F{Ext}+" Neuro: "+$F{Neuro}+"\n"+"4. การวินิจฉัยโรคชั้นต้น "+"\n"+
"..... "+ $F{diagnote}+"\n"+
"..... ICD 10 : " + $F{diagcode} + " : "+$F{diseasenamethai}+
"\n"+"5. การรักษาที่ได้ให้ไว้แล้ว"]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<columnFooter>
		<band height="129" splitType="Stretch">
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="0" width="525" height="129" uuid="7bb955a0-3f27-4e38-a327-f49310be87ae"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["6. สาเหตุที่ส่ง : "+$F{caseRefer}+"\n"+"7. รายละเอียดอื่นๆ : "+$F{request}
+"\n"+"\n"+"\n"+"                                                                             "
+"ลงชื่อ .................................................................................."
+"\n"+"                                                                                           "
+"("+$F{officername}+")"
+"\n"+"                                                                            "
+"ตำแหน่ง    "+$F{officerposition}]]></textFieldExpression>
			</textField>
		</band>
	</columnFooter>
	<summary>
