<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="15_rpt_HT_LipidProfile" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bc700164-3c8c-41c3-b7c4-aa4b03fc4725">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="30"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<queryString>
		<![CDATA[select a.pid,a.pcucodeperson,p.idcard,concat(ct.titlename," ",p.fname," ",p.lname) as fullname,
date_add(a.datecheck, interval 543 year) as datecheck,a.seq,a.labcode,v.labresultdigit
,group_concat(distinct(pc.chroniccode)) as chroniccode
from
(select vl.pid,vl.pcucodeperson,vl.datecheck,max(seqonday) as seq,labcode
from visitlabchcyhembmsse vl
where vl.datecheck between '2019-01-01' and '2019-01-31'
and (lcase(labcode) in ('ch07','ch25','ch14','ch17'))
group by vl.datecheck,vl.pid,vl.labcode) as a
join visitlabchcyhembmsse v on (a.pid = v.pid and a.datecheck = v.datecheck and a.pcucodeperson
and a.seq = v.seqonday and a.labcode = v.labcode)
left join personchronic pc on (a.pid = pc.pid and a.pcucodeperson = pc.pcucodeperson)
left join person p on (a.pid = p.pid and a.pcucodeperson = p.pcucodeperson)
left join persondeath pd on (p.pid = pd.pid and p.pcucodeperson = pd.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
where (lcase(left(pc.chroniccode,3)) between 'i10' and 'i15')
and pd.pid is null
group by a.pid,a.datecheck,a.labcode
order by a.datecheck,a.pid]]>
	</queryString>
