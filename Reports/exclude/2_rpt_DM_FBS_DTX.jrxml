	<subDataset name="data2" uuid="6e538bb7-f6e3-4c3a-8f52-aa57feb0c2d1">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select p3.pid,p.idcard,ct.titlename,p.fname,p.lname,date_add(p3.visitdate,interval 543 year) as visitdate
,p3.visitno,group_concat(pc.chroniccode) as chroniccode,p3.typetesting,
(case when p3.typetesting = '1' then 'DTX'
when p3.typetesting = '2' then 'FBS'
else 'n/a' end) as meaning,p3.sugarnumdigit
from
(select p2.pid,p2.visitdate,p2.visitno,p2.typetesting,dd.sugarnumdigit
from
(select v.visitdate,v.visitno,v.pid,vb.typetesting,vb.sugarnumdigit
from visitlabsugarblood vb
join visit v on (vb.visitno = v.visitno and vb.pcucode = v.pcucode)
where v.visitdate between $P{sdate} and $P{edate}
order by v.pid,v.visitdate desc) as dd
join
(
select max(p1.visitdate) as visitdate,p1.typetesting,p1.pid,max(p1.visitno)as visitno
from
(select max(aa.visitdate) as visitdate,aa.typetesting,aa.pid,max(bb.visitno) as visitno
from
(select v.visitdate,max(vb.typetesting) as typetesting,v.pid
from visitlabsugarblood vb
join visit v on (vb.visitno = v.visitno and vb.pcucode = v.pcucode)
where v.visitdate between $P{sdate} and $P{edate}
group by v.visitdate,v.pid
order by v.pid,v.visitdate desc) as aa
join
(select v.visitdate,v.visitno,v.pid,vb.typetesting
from visitlabsugarblood vb
join visit v on (vb.visitno = v.visitno and vb.pcucode = v.pcucode)
where v.visitdate between $P{sdate} and $P{edate}
) bb on(aa.visitdate = bb.visitdate and aa.typetesting = bb.typetesting and aa.pid = bb.pid)
group by aa.typetesting,aa.pid
order by aa.visitdate desc)as p1
group by p1.pid) as p2 on (p2.visitdate = dd.visitdate and p2.pid = dd.pid and p2.visitno = dd.visitno)
group by p2.pid) as p3
join personchronic pc on (p3.pid = pc.pid)
join person p on (pc.pid = p.pid and pc.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join persondeath pd on (p.pid = pd.pid and p.pcucodeperson = pd.pcucodeperson)
where (lcase(left(pc.chroniccode,3)) between 'e10' and 'e14')
and pd.pid is null
group by p3.pid]]>
		</queryString>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="idcard" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="titlename" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="visitdate" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="visitno" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="chroniccode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="typetesting" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="meaning" class="java.lang.String"/>
		<field name="sugarnumdigit" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
