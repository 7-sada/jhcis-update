	<subDataset name="data3" uuid="81284df9-7c22-480e-87d5-726050ee630b">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select p1.pid,ct.titlename,p.fname,p.lname,p.idcard,Group_concat(distinct pc.chroniccode) as chroniccode,
date_add(p1.datefollow, interval 543 year) as datefollow, p1.examfoot,
(case when p1.examfoot = '0' then 'ตรวจ-ผลปกติ'
when p1.examfoot = '1' then 'Low-Risk'
when p1.examfoot = '2' then 'Moderate-Risk'
when p1.examfoot = '3' then 'High-Risk'
when p1.examfoot = '4' then 'Foot-Ulcer'
when p1.examfoot = '5' then 'Amputation'
else 'n/a' end) as value1
from

(select aa.pid,bb.datefollow,aa.examfoot,aa.pcucodeperson
from
(
select nd.pid,nd.datefollow,nd.examfoot,nd.pcucodeperson
from ncdservice nd
where nd.datefollow between $P{sdate} and $P{edate}
and nd.examfoot is not null
order by nd.pid)as aa
join
(
select pid,max(datefollow) as datefollow,pcucodeperson
from ncdservice
where datefollow between $P{sdate} and $P{edate}
group by pid
order by datefollow desc) as bb on (aa.datefollow = bb.datefollow and aa.pid = bb.pid)
group by aa.pid
order by aa.pid) as p1
join personchronic pc on (p1.pid = pc.pid and p1.pcucodeperson = pc.pcucodeperson)
join person p on (pc.pid = p.pid and pc.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join persondeath pd on (p.pid = pd.pid and p.pcucodeperson = pd.pcucodeperson)
where (lcase(left(pc.chroniccode,3)) between 'e10' and 'e14')
and pd.pid is null
group by p1.pid
order by p1.datefollow desc]]>
		</queryString>
		<field name="pid" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="titlename" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="idcard" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="chroniccode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="datefollow" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="examfoot" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="value1" class="java.lang.String"/>
	</subDataset>
