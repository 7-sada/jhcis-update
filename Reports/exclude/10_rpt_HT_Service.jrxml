	<subDataset name="DataRep1" uuid="5453abf0-55c1-4ae3-9db0-1e73164d364d">
		<queryString>
			<![CDATA[select pc.pid,p.idcard,ifnull(ct.titlename,'...') as title,
p.fname,p.lname,group_concat(pc.chroniccode) as chroniccode,pc.cup,pa.hno,ifnull(pa.mu,'-') as mu
,ifnull(pa.road,'-') as road,
cs.subdistname,cdi.distname,
ifnull(p.hnomoi,'-') as hnomoi,ifnull(p.mumoi,'-') as mumoi,
ifnull(p.roadmoi,'-') as roadmoi,cs1.subdistname as subdistnamemoi,cdi1.distname,ifnull(p.telephoneperson,p.mobile) as tel
from personchronic pc
left join person p on (pc.pid = p.pid and pc.pcucodeperson = p.pcucodeperson)
left join persondeath pd on (p.pid = pd.pid and p.pcucodeperson = pd.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join personaddresscontact pa on (p.pid = pa.pid and p.pcucodeperson = pa.pcucodeperson)
left join csubdistrict cs on (pa.provcode = cs.provcode and pa.distcode = cs.distcode and pa.subdistcode = cs.subdistcode)
left join cdistrict cdi on (pa.distcode = cdi.distcode and pa.provcode = cdi.provcode)
left join csubdistrict cs1 on (p.subdistcodemoi = cs1.subdistcode and p.distcodemoi = cs1.distcode and p.provcodemoi = cs1.provcode)
left join cdistrict cdi1 on (p.distcodemoi = cdi1.distcode and p.provcodemoi = cdi1.provcode)
where (lcase(left(pc.chroniccode,3)) between 'i10' and 'i15')
and pc.cup = '77511'
and pd.pid is null
group by pc.pid
order by pc.pid]]>
		</queryString>
