	<subDataset name="data3" uuid="81284df9-7c22-480e-87d5-726050ee630b">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select vl.pcucodeperson,vl.pid,p.idcard,ct.titlename,p.fname,p.lname,
date_add(max(vl.datecheck),interval 543 year) as datecheck,
group_concat(distinct if(vl.labcode = 'MS01020201',concat_ws('_',vl.pid,vl.datecheck,vl.seqonday,vl.labresultdigit),null) order by vl.pid,vl.datecheck desc,vl.seqonday desc) as MS01_list,
substring_index(group_concat(distinct if(vl.labcode = 'MS01020201',labresultdigit,null) order by vl.pid,vl.datecheck desc,vl.seqonday desc),',',1) as MS01,
substring_index(group_concat(distinct if(vl.labcode = 'MS01020202',labresultdigit,null) order by vl.pid,vl.datecheck desc,vl.seqonday desc),',',1) as MS02,
substring_index(group_concat(distinct if(vl.labcode = 'MSUPCR',labresultdigit,null) order by vl.pid,vl.datecheck desc,vl.seqonday desc),',',1) as MSUPCR,
group_concat(distinct pc.chroniccode) as DM,
group_concat(distinct pc1.chroniccode) as HT
from visitlabchcyhembmsse vl
join personchronic pc on (vl.pid = pc.pid and vl.pcucodeperson = pc.pcucodeperson)
join personchronic pc1 on (vl.pid = pc1.pid and vl.pcucodeperson = pc1.pcucodeperson)
left join person p on (vl.pid = p.pid and vl.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join persondeath pd on (p.pid = pd.pid and p.pcucodeperson = pd.pcucodeperson)
where ucase(vl.labcode in ('MS01020201','MS01020202','MSUPCR'))
and (lcase(left(pc.chroniccode,3)) between 'e10' and 'e14')
and (lcase(left(pc1.chroniccode,3)) between 'i10' and 'i15')
and vl.datecheck between $P{sdate} and $P{edate}
and pd.pid is null
group by vl.pid]]>
		</queryString>
		<field name="pcucodeperson" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="idcard" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="titlename" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="datecheck" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="MS01_list" class="java.lang.String"/>
		<field name="MS01" class="java.lang.String"/>
		<field name="MS02" class="java.lang.String"/>
		<field name="MSUPCR" class="java.lang.String"/>
		<field name="DM" class="java.lang.String"/>
		<field name="HT" class="java.lang.String"/>
	</subDataset>
	<parameter name="sdate" class="java.lang.String"/>
