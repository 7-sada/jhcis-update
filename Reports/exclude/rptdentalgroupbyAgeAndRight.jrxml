	<subDataset name="data1" uuid="50fc2208-0c89-4edf-aa77-ffb2c90dee92">
		<parameter name="edate" class="java.lang.String"/>
		<parameter name="sdate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select pp1.*,'0-2 ปี' as agegroup
from(
select m1.drugcode,m1.drugname,
p1.numhumanuc,p1.numtimesuc,p1.moneyuc,p1.ageuc,
p2.numhumanofc,p2.numtimesofc,p2.moneyofc,p2.ageofc,
p22.numhumanlgo,p22.numtimeslgo,p22.moneylgo,p22.agelgo,
p3.numhumanss,p3.numtimesss,p3.moneyss,p3.agess,
p4.numhumanpaid,p4.numtimespaid,p4.moneypaid,p4.agepaid
from
(select d.drugcode,d.drugname
from cdrug d
where d.drugtype = '02' and d.drugtypesub in ('1','2') and d.drugflag = '1') as m1
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as ageuc,v.pid,
count(distinct(v.pid)) as numhumanUC,count(vd.drugcode) as numTimesUC,sum(vd.unit*vd.realprice) as moneyUC,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
left join cdrug d on (vd.drugcode = d.drugcode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('3','4')
and getageyearnum(p.birth,v.visitdate) < 2
group by d.drugcode) p1 on (m1.drugcode = p1.drugcode)
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as ageofc,v.pid,
count(distinct(v.pid)) as numhumanOFC,count(vd.drugcode) as numTimesOFC,sum(vd.unit*vd.realprice) as moneyOFC,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
left join cdrug d on (vd.drugcode = d.drugcode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('1')
and getageyearnum(p.birth,v.visitdate) < 2
group by d.drugcode) p2
on (m1.drugcode = p2.drugcode)
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as agelgo,v.pid,
count(distinct(v.pid)) as numhumanlgo,count(vd.drugcode) as numTimeslgo,sum(vd.unit*vd.realprice) as moneylgo,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
left join cdrug d on (vd.drugcode = d.drugcode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('7')
and getageyearnum(p.birth,v.visitdate) < 2
group by d.drugcode) p22
on (m1.drugcode = p22.drugcode)
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as agess,v.pid,
count(distinct(v.pid)) as numhumanSS,count(vd.drugcode) as numTimesSS,sum(vd.unit*vd.realprice) as moneySS,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
left join cdrug d on (vd.drugcode = d.drugcode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('2')
and getageyearnum(p.birth,v.visitdate) < 2
group by d.drugcode) p3
on (m1.drugcode = p3.drugcode )
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as agepaid,v.pid,
count(distinct(v.pid)) as numhumanpaid,count(vd.drugcode) as numTimespaid,sum(vd.unit*vd.realprice) as moneypaid,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
left join cdrug d on (vd.drugcode = d.drugcode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('5','6','8','9')
and getageyearnum(p.birth,v.visitdate) < 2
group by d.drugcode) p4 on (m1.drugcode = p4.drugcode)) as pp1
where pp1.numhumanuc is not null or pp1.numhumanofc is not null or pp1.numhumanss is not null or pp1.numhumanpaid is not null
or pp1.numhumanlgo is not null
union all
select pp2.*,'2-4 ปี' as agegroup
from(
select m1.drugcode,m1.drugname,
p1.numhumanuc,p1.numtimesuc,p1.moneyuc,p1.ageuc,
p2.numhumanofc,p2.numtimesofc,p2.moneyofc,p2.ageofc,
p22.numhumanlgo,p22.numtimeslgo,p22.moneylgo,p22.agelgo,
