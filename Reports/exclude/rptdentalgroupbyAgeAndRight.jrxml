left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('7')
and getageyearnum(p.birth,v.visitdate) between 2 and 4
group by d.drugcode) p22
on (m1.drugcode = p22.drugcode)
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as agess,v.pid,
count(distinct(v.pid)) as numhumanSS,count(vd.drugcode) as numTimesSS,sum(vd.unit*vd.realprice) as moneySS,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
left join cdrug d on (vd.drugcode = d.drugcode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join cright r on (v.rightcode = r.rightcode)
left join crightgroup rg on (r.rightgroup = rg.rightgroupcode)
where v.visitdate between $P{sdate} and $P{edate}
and d.drugtype = '02' and d.drugtypesub in ('1','2')
and rg.rightgroupcode in ('2')
and getageyearnum(p.birth,v.visitdate) between 2 and 4
group by d.drugcode) p3
on (m1.drugcode = p3.drugcode )
left join
(select vd.drugcode,getageyearnum(p.birth,v.visitdate) as agepaid,v.pid,
count(distinct(v.pid)) as numhumanpaid,count(vd.drugcode) as numTimespaid,sum(vd.unit*vd.realprice) as moneypaid,v.visitdate
from visitdrug vd
left join visit v on (vd.visitno = v.visitno and vd.pcucode = v.pcucode)
