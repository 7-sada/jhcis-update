	<pageHeader>
		<band height="102" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="0" width="802" height="33" uuid="38bd80cc-153e-4237-8a6c-f60f6c70eb5a"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[แบบรายงานจำนวนครั้งของผู้รับบริการ]]></text>
			</staticText>
			<textField>
				<reportElement x="0" y="33" width="802" height="27" uuid="a701c248-4fd9-4fcf-a18d-1b82b8baa751"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="14" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{office}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="60" width="802" height="28" uuid="293144bc-351c-413b-b090-55715fbbca8f"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA["ระหว่างวันที่  "+$P{showDate1}+ " ถึงวันที่ "+$P{showDate2}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<columnFooter>
		<band height="72">
			<staticText>
				<reportElement x="0" y="0" width="802" height="72" uuid="506c7300-8f15-4a9c-92fb-ed8ab20263f7"/>
				<textElement>
					<font size="12"/>
				</textElement>
				<text><![CDATA[หมายเหตุ : 1. จำนวนผลรวมของทุกสิทธิ์ อาจคลาดเคลือนและไม่เท่ากับจำนวนรวมทั้งหมด เนื่องจากอาจมีข้อมูลบางรายการที่มีความขัดแย้ง เช่น มีสัญชาติไทย แต่ระบุประเภทสิทธิ์เป็นต่างด้าวขึ้นทะเบียน (Human & Data Error) เป็นต้น
                 2. ทั้งนี้ ผลตามข้อ 1. โดยทั่วไปจะเท่ากันหรือคลาดเคลื่อนกันเพียงเล็กน้อย โดยไม่ส่งผลต่อการใช้ประโยชน์ข้อมูลในเชิงนโยบาย
                 3. หากข้อมูลไม่เกิดความขัดแย้งตามตัวอย่างในข้อที่ 1 ผลรวมทุกสิทธิจะเท่ากับ ผลรวมทั้งหมดเสมอ]]></text>
			</staticText>
		</band>
	</columnFooter>
