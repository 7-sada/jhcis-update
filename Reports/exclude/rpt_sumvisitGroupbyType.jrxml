	<subDataset name="data" uuid="897feee8-5e82-45e3-9f04-3ac131152fff">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select (case
	when substr(section,1,1) = '1' then 'OPD + PP (ผู้ป่วยนอก + Service อื่นๆทั้งหมด)'
	when substr(section,1,1) = '2' then 'Dental ทันตกรรม'
	when substr(section,1,1) = '3' then 'Physicial thereapy กายภาพบำบัด'
	when substr(section,1,1) = '4' then 'Traditional Thailand Medicine แพทย์แผนไทย'
	when substr(section,1,1) = '5' then 'Mental Health  สุขภาพจิต'
	when substr(section,1,1) = '6' then 'การเยี่ยมบ้าน'
end ) as depart,
substr(section,1,1) as title, s.*
from _tbl_for_pathum_rep s]]>
		</queryString>
		<field name="depart" class="java.lang.String"/>
		<field name="title" class="java.lang.String"/>
