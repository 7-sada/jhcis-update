					<font fontName="Tahoma" size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["ระหว่างวันที่ "+$P{showDate1} + " ถึงวันที่ "+$P{showDate2}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
