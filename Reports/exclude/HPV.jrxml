	<subDataset name="hpv_data" uuid="abbde187-38cd-4f8d-b2d0-4a57aa26bcff">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select p.pid,v.vaccinecode,v.dateepi,p.pcucodeperson,
concat(ifnull(titlename,ifnull(p.prename,'...')) ,' ', fname,' ', lname) as pname
from person p
join visitepi v on (p.pid = v.pid and p.pcucodeperson = v.pcucodeperson)
left join ctitle t on (p.prename = t.titlecode)
where v.dateepi between $P{sdate} and $P{edate}
and v.vaccinecode like '%HPV%'
order by v.dateepi]]>
		</queryString>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="vaccinecode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dateepi" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pcucodeperson" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="sdate" class="java.lang.String">
		<defaultValueExpression><![CDATA[2016-01-01]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String">
		<defaultValueExpression><![CDATA[2017-12-01]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select 1 as dummy]]>
	</queryString>
	<field name="dummy" class="java.lang.Long"/>
