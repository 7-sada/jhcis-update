<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptoutcup"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="870"
		 pageHeight="595"
		 columnWidth="810"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\EditPrename\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-05-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
     DATE_FORMAT(v.visitdate, "%Y-%m-%d") AS visit_visitdate
,v.visitno,v.pcucode
,v.`rightno` AS visit_rightno
,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ) ,person.fname,' ', person.lname)   USING utf8) AS personname
,v.rightcode
, DATE_FORMAT(v.visitdate, "%Y-%m-%d") as vdate
, curdate() as curdate
,CONVERT(CONCAT(getAgeYearNum(DATE_FORMAT(birth,'%Y-%m-%d'),date_format(curdate(),'%Y-%m-%d')) ," ป  "
                 ,getAgeMonthNum(DATE_FORMAT(birth,'%Y-%m-%d'),date_format(curdate(),'%Y-%m-%d')) ," ด " 
	         ,getAgeDayNum(DATE_FORMAT(birth,'%Y-%m-%d'),date_format(curdate(),'%Y-%m-%d')) ," ว " ) USING utf8)  as dd
,if((person.idcard is null or person.idcard ='' ),'-', person.idcard) as idcard
,sum(case when drugtype='01'  then visitdrug.realprice else 0 end) AS drug01
,sum(case when drugtype='07' then visitdrug.realprice else 0 end) AS lab07
,sum(case when (drugtype='02' and (drugtypesub='1' or drugtypesub='2') ) then visitdrug.realprice else 0 end) AS dent
,sum(case when visitdrug.drugcode='897' then visitdrug.realprice else 0 end) AS dr06
,money2,v.hosmain as cup ,hc.hosname as cupname,village.cup as cupcode
,CONVERT(concat(chospital.`hosname`,' ต.',csubdistricth.`subdistname`,' อ.',cdistricth.`distname`,' จ.', cprovinceh.`provname`) using utf8 ) AS hostname

FROM visit v
     left JOIN person    ON person.pcucodeperson = v.pcucodeperson AND person.pid = v.pid
     left JOIN ctitle    ON person.prename = ctitle.titlecode
     left JOIN visitdrug ON v.pcucode = visitdrug.pcucode AND v.visitno = visitdrug.visitno 
     left JOIN cdrug on visitdrug.drugcode = cdrug.drugcode
     left join house on person.hcode = house.hcode and person.pcucodeperson =house.pcucode
     left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
     left join chospital hc on village.cup = hc.hoscode

# ที่อยู่สถานบยาบาล chospital
     left JOIN chospital ON v.pcucode = chospital.hoscode  
     left JOIN csubdistrict csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left JOIN cdistrict cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
     left JOIN cprovince cprovinceh ON chospital.provcode = cprovinceh.provcode

WHERE  (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
 $P!{pcucode}
and v.visitdate between $P{sdate} and $P{edate}  
and right(house.villcode,2) != '00'
and v.incup = '2'  

GROUP BY v.pcucodeperson,v.visitno
ORDER BY v.pcucode,v.visitdate]]></queryString>

	<field name="visit_visitdate" class="java.lang.String"/>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="visit_rightno" class="java.lang.String"/>
	<field name="personname" class="java.lang.String"/>
	<field name="rightcode" class="java.lang.String"/>
	<field name="vdate" class="java.lang.String"/>
	<field name="curdate" class="java.sql.Date"/>
	<field name="dd" class="java.lang.String"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="drug01" class="java.math.BigDecimal"/>
	<field name="lab07" class="java.math.BigDecimal"/>
	<field name="dent" class="java.math.BigDecimal"/>
	<field name="dr06" class="java.math.BigDecimal"/>
	<field name="money2" class="java.lang.Double"/>
	<field name="cup" class="java.lang.String"/>
	<field name="cupname" class="java.lang.String"/>
	<field name="cupcode" class="java.lang.String"/>
	<field name="hostname" class="java.lang.String"/>

	<variable name="SUM_money2_1" class="java.lang.Double" resetType="Report" calculation="Sum">
