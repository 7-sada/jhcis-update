			<band height="23"  isSplitAllowed="true" >
				<printWhenExpression><![CDATA[(  $P{awh} == "aw" ? 
	(
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักต่ำ") ||
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักต่ำมาก") ||
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักสูง") ||
