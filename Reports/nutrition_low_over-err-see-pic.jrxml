		<defaultValueExpression ><![CDATA["2008-10-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="enddate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2008-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2008-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="nformu" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["02312"]]></defaultValueExpression>
	</parameter>
	<parameter name="header_2" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header_1" isForPrompting="false" class="java.lang.String"/>
	<parameter name="awh" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["aw"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
CONCAT(person.prename,person.fname,'  ',person.lname) AS fullname,
vchild_60mon_weight_0.hno,
visit.visitdate,
DATE_FORMAT(visit.visitdate,"%y-%m-%d")AS svisitdate,
person.birth,
vchild_60mon_weight_0.agemonth,
person.sex,
vchild_60mon_weight_0.weight,
vchild_60mon_weight_0.tall,
vchild_60mon_weight_0.pid,
vchild_60mon_weight_0.villno,
vchild_60mon_weight_0.villcode,
vchild_60mon_weight_0.villname
FROM
person
Inner Join vchild_60mon_weight_0 ON person.pcucodeperson = vchild_60mon_weight_0.pcucodeperson AND person.pid = vchild_60mon_weight_0.pid
Inner Join visit ON vchild_60mon_weight_0.pcucodeperson = visit.pcucodeperson AND vchild_60mon_weight_0.lastvn = visit.visitno
Inner Join vnutrition_last_st2 ON visit.visitno = vnutrition_last_st2.lastvn

WHERE
visit.visitdate BETWEEN $P{startdate} AND $P{enddate}
$P{pcucode}
ORDER BY vchild_60mon_weight_0.villcode]]></queryString>

	<field name="fullname" class="java.lang.String"/>
	<field name="hno" class="java.lang.String"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="svisitdate" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="agemonth" class="java.lang.Long"/>
	<field name="sex" class="java.lang.String"/>
	<field name="weight" class="java.math.BigDecimal"/>
	<field name="tall" class="java.math.BigDecimal"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="villno" class="java.lang.Integer"/>
	<field name="villcode" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>

	<variable name="vcount" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[(  $P{awh} == "aw" ? 
	(
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักต่ำ") ||
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักต่ำมาก") ||
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักสูง") ||
	( SetupNu.UpdateNutritionStateAgeLessThen18AgeWeight($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})=="น้ำหนักสูงมาก")
	? new Integer(1) : new Integer(0) )
	: 
    	(  $P{awh} == "wh" ? 
       		(
		( SetupNu.UpdateNutritionStateAgeLessThen18WeightHeight($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex})=="ผอม") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18WeightHeight($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex})=="ค่อนข้างผอม") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18WeightHeight($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex})=="ค่อนข้างอ้วน") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18WeightHeight($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex})=="อ้วน") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18WeightHeight($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex})=="อ้วนมาก")
		? new Integer(1) : new Integer(0) )
       		: 
       		(
		( SetupNu.UpdateNutritionStateAgeLessThen18AgeHeight($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})=="เตี้ย") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18AgeHeight($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})=="ค่อนข้างเตี้ย") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18AgeHeight($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})=="ค่อนข้างสูง") ||
		( SetupNu.UpdateNutritionStateAgeLessThen18AgeHeight($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})=="สูงเกินเกณฑ์")
		? new Integer(1) : new Integer(0) )
    	)
)]]></variableExpression>
	</variable>

