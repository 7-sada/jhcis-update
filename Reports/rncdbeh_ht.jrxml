		<variableExpression><![CDATA[$F{fht}]]></variableExpression>
	</variable>
	<variable name="sum_odm" class="java.lang.Long" resetType="Group" resetGroup="pcu" calculation="Sum">
		<variableExpression><![CDATA[$F{oht}]]></variableExpression>
	</variable>
	<variable name="sum_edu" class="java.lang.Long" resetType="Group" resetGroup="pcu" calculation="Sum">
		<variableExpression><![CDATA[$F{edu}]]></variableExpression>
	</variable>
