<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rncdbeh_ht" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="fYear" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="bDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2008-10-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="eDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2010-09-30'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
_tmp_htsurvey.pcucode,getOffice(_tmp_htsurvey.pcucode) AS offname,_tmp_htsurvey.visitdate,
0 AS pop,
COUNT(DISTINCT _tmp_htsurvey.pcucodeperson,_tmp_htsurvey.pid,CASE WHEN _tmp_htsurvey.visitno IS NOT NULL THEN 1 ELSE null END) AS survey,
COUNT(DISTINCT _tmp_htsurvey.pcucodeperson,_tmp_htsurvey.pid,CASE WHEN _tmp_htsurvey.systolic > 130 AND _tmp_htsurvey.diastolic> 80 THEN 1 ELSE null END) AS preht,
COUNT(DISTINCT _tmp_htsurvey.pcucodeperson,_tmp_htsurvey.pid,CASE WHEN _tmp_htsurvey.chronicfirstdiag BETWEEN $P!{bDate} AND $P!{eDate} THEN 1 ELSE null END) AS fht,
COUNT(DISTINCT _tmp_htsurvey.pcucodeperson,_tmp_htsurvey.pid,CASE WHEN _tmp_htsurvey.chronicfirstdiag < $P!{bDate} THEN 1 ELSE null END) AS oht,
COUNT(DISTINCT _tmp_htsurvey.pcucodeperson,_tmp_htsurvey.pid,CASE WHEN _tmp_htsurvey.counselingcode IS NOT NULL THEN 1 ELSE null END) AS edu
FROM
_tmp_htsurvey
WHERE _tmp_htsurvey.visitdate BETWEEN $P!{bDate} AND $P!{eDate}
GROUP BY _tmp_htsurvey.pcucode,left(visitdate,7)
UNION
SELECT person.pcucodeperson,'' AS offname,DATE_FORMAT($P!{eDate},'%Y-%m-%d') AS visitdate
,COUNT(DISTINCT person.pcucodeperson,person.pid) AS pop
,0 AS survey
,0 AS predm
,0 AS fdm
,0 AS odm
,0 AS edu
FROM
person
WHERE DATE_FORMAT(FROM_DAYS(TO_DAYS($P!{eDate})-TO_DAYS(`person`.`birth`)),'%Y')+0 >= 35
GROUP BY
person.pcucodeperson

ORDER BY visitdate]]>
	</queryString>
	<field name="pcucode" class="java.lang.String"/>
	<field name="offname" class="java.lang.String"/>
	<field name="visitdate" class="java.util.Date"/>
	<field name="pop" class="java.lang.Long"/>
	<field name="survey" class="java.lang.Long"/>
	<field name="preht" class="java.lang.Long"/>
	<field name="fht" class="java.lang.Long"/>
	<field name="oht" class="java.lang.Long"/>
	<field name="edu" class="java.lang.Long"/>
	<variable name="sum_pop" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{pop}]]></variableExpression>
	</variable>
	<variable name="normal" class="java.lang.Long" resetType="Group" resetGroup="pcu">
		<variableExpression><![CDATA[new java.lang.Long(  ($F{survey}.longValue()) -($F{preht}.longValue()+$F{fht}.longValue()+$F{oht}.longValue()) )]]></variableExpression>
	</variable>
	<variable name="sum_survey" class="java.lang.Long" resetType="Group" resetGroup="pcu" calculation="Sum">
		<variableExpression><![CDATA[$F{survey}]]></variableExpression>
	</variable>
	<variable name="sum_predm" class="java.lang.Long" resetType="Group" resetGroup="pcu" calculation="Sum">
