			<textField isStretchWithOverflow="true" pattern="#,##0" isBlankWhenNull="true">
				<reportElement key="textField" x="305" y="0" width="42" height="20" uuid="8d973ef9-81b6-420e-a0f5-bae9dcfa1865"/>
				<box leftPadding="3">
