	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="where" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT cdrug.tmtcode,
CASE
 WHEN cdrug.drugtype =  '01'  THEN 'ยาฯ'
 WHEN cdrug.drugtype =  '02'   THEN 'หัตถการ'
 WHEN cdrug.drugtype =  '03'   THEN 'วัสดุการแพทย์'
 WHEN cdrug.drugtype =  '04'  THEN 'เวชภัณฑ์คุมกำเนิด'
 WHEN cdrug.drugtype =  '05'   THEN 'วัคซีน'
 WHEN cdrug.drugtype =  '06'   THEN 'ค่าบริการฯ'
 WHEN cdrug.drugtype =  '07'   THEN 'ค่าตรวจทางห้องปฏิบัติการฯ'
 WHEN cdrug.drugtype =  '08'  THEN 'ทันตกรรม'
 WHEN cdrug.drugtype =  '10'  THEN 'ยาสมุนไพร'
 WHEN cdrug.drugtype =  '11'  THEN 'เวชภัณฑ์ที่ไม่ใช่ยา'
 ELSE 'ไม่ระบุประเภทฯ'
END AS drugtype,
CASE
 WHEN cdrug.drugcode IN ('DT','DT1','DT2','DTS1','DTS2','DTS3','DTS4','DTANC1','DTANC2','DTANC3','DTANC4','DTANC5') OR cdrug.drugcode =  'V120' THEN 'DT'
 WHEN cdrug.drugcode IN ('DTP','DTP1','DTP2','DTP3','DTP4','DTP5') OR cdrug.drugcode =  'V121' THEN 'DTP'
 WHEN cdrug.drugcode IN ('HBV','HBV1','HBV2','HBV3') OR cdrug.drugcode =  'V122' THEN 'HB'
 WHEN cdrug.drugcode IN ('JE','JE1','JE2','JE3') OR cdrug.drugcode =  'V123' THEN 'JE'
 WHEN cdrug.drugcode IN ('MMR','MMR2') OR cdrug.drugcode =  'V124' THEN 'MMR'
 WHEN cdrug.drugcode IN ('OPV','OPV1','OPV2','OPV3','OPV4','OPV5','OPVs1','OPVs2','OPVs3','OPVC') OR cdrug.drugcode =  'V125' THEN 'OPV'
 WHEN cdrug.drugcode IN ('TT','TT1','TT2','TT3','TT4','TT5') OR cdrug.drugcode =  'V126' THEN 'TT'
 WHEN cdrug.drugcode IN ('DHB','DHB1','DHB2','DHB3') OR cdrug.drugcode =  'V127' THEN 'DTP+HB'
 WHEN cdrug.drugcode IN ('MEAS') OR cdrug.drugcode =  'V128' THEN 'MEAS'
 WHEN cdrug.drugcode IN ('RB','RB1','RB2','RB3','RB4','RB5','RB12','RB22','RB32','RB42','RB52') THEN 'RB'
 ELSE cdrug.drugcode END AS drugcode,
CASE
 WHEN cdrug.drugcode IN ('DT','DT1','DT2','DTS1','DTS2','DTS3','DTS4','DTANC1','DTANC2','DTANC3','DTANC4','DTANC5') OR cdrug.drugcode =  'V120' THEN 'DT'
 WHEN cdrug.drugcode IN ('DTP','DTP1','DTP2','DTP3','DTP4','DTP5') OR cdrug.drugcode =  'V121' THEN 'DTP'
 WHEN cdrug.drugcode IN ('HBV','HBV1','HBV2','HBV3') OR cdrug.drugcode =  'V122' THEN 'HB'
 WHEN cdrug.drugcode IN ('JE','JE1','JE2','JE3') OR cdrug.drugcode =  'V123' THEN 'JE'
 WHEN cdrug.drugcode IN ('MMR','MMR2') OR cdrug.drugcode =  'V124' THEN 'MMR'
 WHEN cdrug.drugcode IN ('OPV','OPV1','OPV2','OPV3','OPV4','OPV5','OPVs1','OPVs2','OPVs3','OPVC') OR cdrug.drugcode =  'V125' THEN 'OPV'
 WHEN cdrug.drugcode IN ('TT','TT1','TT2','TT3','TT4','TT5') OR cdrug.drugcode =  'V126' THEN 'TT'
 WHEN cdrug.drugcode IN ('DHB','DHB1','DHB2','DHB3') OR cdrug.drugcode =  'V127' THEN 'DTP+HB'
 WHEN cdrug.drugcode IN ('MEAS') OR cdrug.drugcode =  'V128' THEN 'MEAS'
 WHEN cdrug.drugcode IN ('RB','RB1','RB2','RB3','RB4','RB5','RB12','RB22','RB32','RB42','RB52') THEN 'RB'
 ELSE cdrug.drugname END AS drugname,
if((SELECT Sum(drugrepositoryoutdetail.lotamount) FROM drugrepositoryoutdetail WHERE  drugrepositoryoutdetail.drugcode=cdrug.drugcode and drugrepositoryoutdetail.packamount=t.packamount GROUP BY drugcode,packamount) is null,(SELECT Sum(drugrepositorytakendetail.lotamount) FROM drugrepositorytakendetail WHERE drugrepositorytakendetail.drugcode = cdrug.drugcode and drugrepositorytakendetail.packamount=t.packamount GROUP BY drugcode,packamount),(SELECT Sum(drugrepositorytakendetail.lotamount) FROM drugrepositorytakendetail WHERE drugrepositorytakendetail.drugcode = cdrug.drugcode and drugrepositorytakendetail.packamount=t.packamount GROUP BY drugcode,packamount) -(SELECT Sum(drugrepositoryoutdetail.lotamount) FROM drugrepositoryoutdetail WHERE  drugrepositoryoutdetail.drugcode=cdrug.drugcode and drugrepositoryoutdetail.packamount=t.packamount GROUP BY drugcode,packamount)) AS drem,
if((SELECT Sum(drugrepositoryoutdetail.lotamount*drugrepositoryoutdetail.lotprice) FROM drugrepositoryoutdetail WHERE  drugrepositoryoutdetail.drugcode=cdrug.drugcode and drugrepositoryoutdetail.packamount=t.packamount GROUP BY drugcode,packamount) is null,(SELECT Sum(drugrepositorytakendetail.lotamount*drugrepositorytakendetail.lotprice) FROM drugrepositorytakendetail WHERE drugrepositorytakendetail.drugcode = cdrug.drugcode and drugrepositorytakendetail.packamount=t.packamount GROUP BY drugcode,packamount),(SELECT Sum(drugrepositorytakendetail.lotamount*drugrepositorytakendetail.lotprice) FROM drugrepositorytakendetail WHERE drugrepositorytakendetail.drugcode = cdrug.drugcode and drugrepositorytakendetail.packamount=t.packamount GROUP BY drugcode,packamount) -(SELECT Sum(drugrepositoryoutdetail.lotamount*drugrepositoryoutdetail.lotprice) FROM drugrepositoryoutdetail WHERE  drugrepositoryoutdetail.drugcode=cdrug.drugcode and drugrepositoryoutdetail.packamount=t.packamount GROUP BY drugcode,packamount)) AS dprice
,t.lotprice,t.packamount,DATE_FORMAT(t.dateexpire,'%Y-%m-%d') AS dateexpire
FROM
drugrepositorytakendetail t Inner Join
cdrug on t.drugcode = cdrug.drugcode
$P!{where}

GROUP BY cdrug.drugtype,t.drugcode,t.packamount]]>
	</queryString>
	<field name="tmtcode" class="java.lang.String">
		<fieldDescription><![CDATA[...รหัสยาฯ สำหรับส่งออกให้งานสิทธิประกันสังคม]]></fieldDescription>
