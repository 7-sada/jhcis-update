	<field name="meas" class="java.lang.String"/>
	<field name="mmr" class="java.lang.String"/>
	<field name="mmr2" class="java.lang.String"/>
	<field name="mmrs" class="java.lang.String"/>
	<field name="ipv_p" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
