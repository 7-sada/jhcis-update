<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptSumDent_fluoride" pageWidth="782" pageHeight="555" columnWidth="782" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<parameter name="visitdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="round" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="byear" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT visitdrugdental.pcucode,DATE_FORMAT(visitdate,'%Y-%m') as visitdate
,count(distinct visitdrugdental.visitno,visitdrugdental.pcucode) as cpersondent
,count(concat(visitdrugdental.visitno,visitdrugdental.pcucode) ) as cnumtooth
FROM  visitdrugdental left join visit on   visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
WHERE case when $P{round} != 1 then
	visit.visitdate between CONCAT($P{byear} ,"-04-01")  and CONCAT($P{byear},"-09-30")
 	else visit.visitdate between CONCAT(($P{byear})-1 ,"-10-01")  and CONCAT($P{byear} ,"-03-31")   end
and dentcode in('2377020','2287020','2377021','2387021')
and DATE_FORMAT(visitdate,'%Y-%m')  = $P{visitdate}
$P!{pcucode}
GROUP BY visit.pcucode,DATE_FORMAT(visitdate,'%Y-%m')]]>
	</queryString>
	<field name="cpersondent" class="java.lang.Long"/>
	<field name="cnumtooth" class="java.lang.Long"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="25" splitType="Stretch">
			<textField pattern="###0" isBlankWhenNull="true">
				<reportElement key="textField" x="0" y="0" width="50" height="25" forecolor="#000000"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Tahoma" size="10" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cpersondent}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<columnFooter>
		<band splitType="Stretch"/>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
	<summary>
		<band splitType="Stretch"/>
	</summary>
</jasperReport>
