<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptvaccrabies"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-04-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select CONVERT(CONCAT(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),fname,' ',lname) using utf8)  as name
,curdate() as cdate
,dateepi ,DATE_FORMAT(birth,'%Y-%m-%d') as bb
,CONVERT(CONCAT(  DATE_FORMAT(visitepi.dateepi,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(visitepi.dateepi,"00-%m-%d")< DATE_FORMAT(birth,"00-%m-%d")), " ปี ",  
	CASE SIGN(DATE_FORMAT(visitepi.dateepi,"%m")-DATE_FORMAT(birth,"%m"))  
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visitepi.dateepi,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visitepi.dateepi,"%m") -  (DATE_FORMAT(visitepi.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN 1 THEN(DATE_FORMAT(visitepi.dateepi,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(visitepi.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " เดือน ",  
	CASE SIGN(DATE_FORMAT(visitepi.dateepi,"%d") - DATE_FORMAT(birth,"%d"))  
 	 WHEN 0 THEN(DATE_FORMAT(visitepi.dateepi,"%d") - DATE_FORMAT(birth,"%d") )  
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(visitepi.dateepi),"%d") + DATE_FORMAT(visitepi.dateepi, "%d")  -  DATE_FORMAT(birth, "%d"))  
 	 WHEN 1 THEN (DATE_FORMAT(visitepi.dateepi,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(visitepi.dateepi,"%d") < DATE_FORMAT(birth,"%d")))  END ,  " วัน " ) USING utf8) AS age_ymd
,CONVERT(case when p.subdistcodemoi is null  then 'นอกเขต' 
              when p.hnomoi is null then concat(' หมู่ที่ ',  p.`mumoi` ,' ต.',  tb.`subdistname` )
              when p.mumoi is null then concat(p.`hnomoi`  ,' ต.',  tb.`subdistname` )
              else concat(p.`hnomoi` ,' หมู่ที่ ',  p.`mumoi` ,' ต.',  tb.`subdistname` ) end   USING utf8)  AS address
,visitepi.lotno 
,h.hosname
,(select DATE_FORMAT(v1.dateepi,'%Y-%m-%d') from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='RB1' group by v1.pid and v1.pcucodeperson) as rb1
,(select DATE_FORMAT(v2.dateepi,'%Y-%m-%d') from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='RB2' group by v2.pid and v2.pcucodeperson) as rb2
,(select DATE_FORMAT(v3.dateepi,'%Y-%m-%d') from visitepi v3 where visitepi.pid = v3.pid and visitepi.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='RB3' group by v3.pid and v3.pcucodeperson) as rb3
,(select DATE_FORMAT(v4.dateepi,'%Y-%m-%d') from visitepi v4 where visitepi.pid = v4.pid and visitepi.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='RB4' group by v4.pid and v4.pcucodeperson) as rb4
,(select DATE_FORMAT(v5.dateepi,'%Y-%m-%d') from visitepi v5 where visitepi.pid = v5.pid and visitepi.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='RB5' group by v5.pid and v5.pcucodeperson) as rb5
from person p left join visit v on p.pid = v.pid and p.pcucodeperson = v.pcucodeperson
	      left join ctitle on p.prename = ctitle.titlecode
              left join visitepi  on v.visitno = visitepi.visitno and v.pcucode = visitepi.pcucode 
              left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
              left join village on house.villcode = village.villcode and v.pcucode = village.pcucode
              left join csubdistrict tb on CONCAT(tb.provcode,tb.distcode,tb.subdistcode) = left(village.villcode,6) 
              left join chospital h on v.pcucode = h.hoscode
              
where  (p.birth IS NOT NULL AND p.birth NOT LIKE '0000%')
and visitepi.dateepi between $P{sdate} and $P{edate}
and visitepi.vaccinecode in('RB1','RB2','RB3','RB4','RB5')
$P!{pcucode}
group by visitepi.pid,visitepi.pcucodeperson]]></queryString>

