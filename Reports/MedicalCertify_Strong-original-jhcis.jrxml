	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="VN" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[$P{VN}]]></parameterDescription>
		<defaultValueExpression><![CDATA["14261"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false"/>
	<parameter name="oid" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
concat('ข้าพเจ้า ',ifnull(tt1.`titlename`,'...'),ifnull(`user`.`fname`,`user`.`fullName`),'   ',ifnull(`user`.`lname`,'...')) as fullName,
concat('ใบอนุญาตประกอบวิชาชีพเวชกรรมเลขที่ ',`user`.`noofoccupation`) as noofoccupation,
concat('สถานที่ประกอบวิชาชีพเวชกรรม หรือสถานที่ปฏิบัติงานประจำ หรือที่อยู่ ',`user`.`workoffice`) as workoffice,
concat('ได้ตรวจร่างกาย ',ifnull(tt2.titlename,ifnull(`person`.`prename`,'..')),ifnull(`person`.`fname`,''),'   ',ifnull(`person`.`lname`,''),' HN: ',convert(visit.pid using utf8),' อายุ ' ,getageymd(person.birth,visit.visitdate)) as pfl,
concat(ifnull(tt2.titlename,ifnull(`person`.`prename`,'..')),ifnull(`person`.`fname`,''),'   ',ifnull(`person`.`lname`,''),' HN: ',convert(visit.pid using utf8),' อายุ ' ,getageymd(person.birth,visit.visitdate)) as pfl2,

concat('ที่อยู่: ',ifnull(pc.`hno`,'-'),' ม.',ifnull(convert(pc.`mu` using utf8),'-'),' ต.',ifnull(csd.`subdistname`,'-'),
                            ' อ.',ifnull(cd.`distname`,'-'),              ' จ.',ifnull(cw.`provname`,'-')) AS addr,
concat('บัตรประจำตัวประชาชน เลขที่ ',ifnull(`person`.`idcard`,'..')) as idcard
,concat(day(visitdate),' ',convert(case MONTH(visitdate) WHEN 1 THEN 'มกราคม'
WHEN 2 THEN 'กุมภาพันธ์' WHEN 3 THEN 'มีนาคม' WHEN 4 THEN 'เมษายน'
WHEN 5 THEN 'พฤษภาคม' WHEN 6 THEN 'มิถุนายน' WHEN 7 THEN 'กรกฎาคม' WHEN 8 THEN 'สิงหาคม' WHEN 9 THEN 'กันยายน'  WHEN 10 THEN 'ตุลาคม'
WHEN 11 THEN 'พฤศจิกายน' WHEN 12 THEN 'ธันวาคม' ELSE 'xx' END USING utf8),' ' ,IF(visitdate IS null OR TRIM(visitdate)='','',YEAR(visitdate)+543)) vd
,`visit`.`rightno`,
`cdisease`.`diseasenamethai`
FROM
`visit`
Left Outer Join `user` ON `user`.`username` = `visit`.`username`
Left Outer Join `person` ON `person`.`pid` = `visit`.`pid`
Left Outer Join `visitdiag` ON `visit`.`visitno` = `visitdiag`.`visitno`
Left Outer Join `cdisease` ON `visitdiag`.`diagcode` = `cdisease`.`diseasecode`

left outer join personaddresscontact pc on person.pcucodeperson = pc.pcucodeperson and person.pid = pc.pid
left outer JOIN `csubdistrict` csd ON csd.subdistcode = pc.subdistcode and csd.distcode = pc.distcode and csd.provcode = pc.provcode
left outer JOIN `cdistrict` cd ON cd.distcode = pc.distcode and cd.provcode = pc.provcode
left outer JOIN `cprovince` cw ON cw.provcode = pc.provcode
left join `ctitle` tt1 on `user`.`prename` = `tt1`.`titlecode`
left join `ctitle` tt2 on `person`.`prename` = `tt2`.`titlecode`
WHERE visit.visitno = $P!{VN}]]>
	</queryString>
