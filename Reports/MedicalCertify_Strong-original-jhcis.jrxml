				<reportElement uuid="1334a5e5-98e9-4071-a7c7-d4b388b4a094" key="staticText-15" x="0" y="536" width="525" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement/>
				<text><![CDATA[หมายเหตุ  (1) ต้องเป็นแพทย์ซึ่งได้ขึ้นทะเบียนรับใบอนุญาตประกอบวิชาชีพเวชกรรม  ]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="838bf784-769c-469b-ab04-765ac112dc65" key="staticText-16" x="0" y="556" width="525" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement/>
				<text><![CDATA[                (2) ให้แสดงว่าเป็นผู้มีร่างกายสมบูรณ์เพียงใด หรือหายจากโรคที่เป็นเหตุให้ออกจากราชการ]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="d8598650-b46a-4912-85e3-8d187c9356a3" key="staticText-17" x="0" y="576" width="525" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement/>
				<text><![CDATA[                ใบรับรองแพทย์ฉบับนี้ให้ใช้ได้ 1 เดือน นับแต่วันที่ตรวจร่างกาย]]></text>
			</staticText>
