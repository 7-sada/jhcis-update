			<textField isBlankWhenNull="true">
				<reportElement uuid="2cae729d-3ae7-4298-9971-092d08cd1111" key="textField-15" positionType="Float" stretchType="RelativeToTallestObject" x="47" y="217" width="478" height="26"/>
