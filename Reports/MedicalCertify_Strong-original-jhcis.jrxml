				<textFieldExpression><![CDATA["สรุปความเห็นและข้อแนะนำของแพทย์ ..................................................................................................."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement uuid="fed745f4-2397-4a3e-9d0e-95a7c1b7a691" key="textField-23" positionType="Float" stretchType="RelativeToTallestObject" x="0" y="424" width="525" height="21"/>
