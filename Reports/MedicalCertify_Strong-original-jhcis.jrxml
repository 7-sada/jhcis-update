				</textElement>
				<textFieldExpression><![CDATA["2. วัณโรคในระยะอันตราย"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement uuid="ed937da2-841f-4353-948f-24f876ebe8e9" key="textField-20" positionType="Float" stretchType="RelativeToTallestObject" x="47" y="346" width="478" height="26"/>
