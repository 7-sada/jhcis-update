				<textFieldExpression><![CDATA[$F{pfl2}+" ไม่ปรากฏอาการของโรคจิต หรือ"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement uuid="23139cd1-5e01-4776-af13-fd1e91a5d1ed" key="textField-16" positionType="Float" stretchType="RelativeToTallestObject" x="0" y="243" width="525" height="26"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
