				<textFieldExpression><![CDATA["3. โรคเท้าช้างในระยะที่ปรากฏอาการเป็นที่รังเกียจแก่สังคม"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement uuid="e499d0b8-13f7-4be4-92ca-2e1ebf0ee23c" key="textField-21" positionType="Float" stretchType="RelativeToTallestObject" x="47" y="372" width="478" height="26"/>
