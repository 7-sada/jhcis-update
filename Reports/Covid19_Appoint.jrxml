	<columnFooter>
		<band height="96">
			<staticText>
				<reportElement x="0" y="26" width="555" height="20" uuid="5afea7b8-648a-4d83-800e-1082e930ac94"/>
				<textElement markup="html">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[หากมีอาการต่อไปนี้หลังได้รับวัคซีน ให้รีบพบแพทย์ฯ ณ.สถานบริการใกล้บ้าน
]]></text>
			</staticText>
			<staticText>
				<reportElement x="35" y="46" width="155" height="49" uuid="4f639efc-afc5-4d9a-8158-192e2f5dfd51"/>
				<textElement markup="html">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[1. ไข้ หรือปวดศรีษะ<br>
3. อ่อนเพลีย/ไม่มีแรง<br>
5. คลื่นไส้ อาเจียน]]></text>
			</staticText>
			<staticText>
				<reportElement x="190" y="46" width="155" height="49" uuid="a9c97790-e4bd-476f-b2c3-4261926b3119"/>
				<textElement markup="html">
					<font fontName="TH SarabunPSK" size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[2. ปวด บวม แดง ร้อน บริเวณที่ฉีด <br>
4. ปวดเมื่อย<br>
6. อาการอื่นๆ เช่น ท้องเสีย]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="0" width="555" height="26" uuid="47d3e3e3-1212-4b33-950e-02ff4a58e6fb"/>
				<textElement verticalAlignment="Middle">
					<font fontName="TH SarabunPSK" size="16" isBold="true"/>
				</textElement>
				<text><![CDATA[หมายเหตุ : กรุณามาฉีดวัคซีนตามนัด และเดินทางมาถึงก่อนเวลาที่นัดหมายอย่างน้อย 30 นาที]]></text>
			</staticText>
			<line>
				<reportElement x="0" y="0" width="555" height="1" uuid="64cc3646-53dc-4b8c-996b-d2c462075fc0"/>
			</line>
		</band>
	</columnFooter>
