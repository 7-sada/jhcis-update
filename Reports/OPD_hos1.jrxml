	<subDataset name="data1" uuid="a64a74f5-36e6-4153-a198-4b9da4e58b2c">
		<parameter name="visitno" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[select vd.drugcode,d.drugname,vd.unit,vd.realprice,vd.dose,
(vd.realprice*ifnull(noclaimprice,1)) as price1,noclaimprice,
(1-ifnull(noclaimprice,0))*vd.unit*vd.realprice  as paid
,(ifnull(noclaimprice,0))*vd.unit*vd.realprice  as noclaim
from visitdrug vd
left join cdrug d on (vd.drugcode = d.drugcode)
where vd.visitno = $P{visitno}
and d.drugcode not like 'DF%' and (vd.noclaimprice < 1 or vd.noclaimprice is null)
order by d.drugtype]]>
		</queryString>
		<field name="drugcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="drugname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="unit" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="realprice" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dose" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="price1" class="java.math.BigDecimal"/>
		<field name="noclaimprice" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="paid" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="noclaim" class="java.math.BigDecimal"/>
		<variable name="Total" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{paid}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
	</subDataset>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Project_Java\\_DesktopApp\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="visitno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select v.pid,p.fname,p.lname,ct.titlename,ifnull(p.mobile,ifnull(p.telephoneperson,"")) as phone,
p.hcode,ifnull(pa.hno,"") as hno,if(pa.mu is null,"",concat("หมู่ที่ ",pa.mu)) as mu1,
if(pa.road is null,"",concat("ถนน ",pa.road)) as road,if(cs.subdistname is null,"",concat("แขวง",cs.subdistname)) as tumbon,
ifnull(cd.distname,"") as ampur,
ifnull(cp.provname,"") as province,ifnull(pa.postcode,"") as postcode,ifnull(p.idcard,"") as cid,getageyearnum(p.birth,v.visitdate) as age
,if(rg.rightgroupcode = '1','จ่ายตรง',"จ่ายตรงไม่ได้เนื่องจากไม่มีสิทธิ์") as paidright,if(rg.rightgroupcode = '1',cr.rightname,"") as detailrightgroup,
h.hosname
from visit v
left join chospital h on (v.pcucode = h.hoscode)
left join person p on(v.pcucodeperson = p.pcucodeperson and v.pid = p.pid)
left join personaddresscontact pa on (p.pcucodeperson = pa.pcucodeperson and p.pid = pa.pid)
left join cright cr on (v.rightcode = cr.rightcode)
left join crightgroup rg on (cr.rightgroup = rg.rightgroupcode)
left join ctitle ct on (p.prename = ct.titlecode)
left join csubdistrict cs on (pa.subdistcode = cs.subdistcode and pa.distcode = cs.distcode and pa.provcode = cs.provcode)
left join cdistrict cd on (pa.distcode = cd.distcode and pa.provcode = cd.provcode)
left join cprovince cp on (cp.provcode = pa.provcode)
where v.visitno = $P{visitno}]]>
	</queryString>
