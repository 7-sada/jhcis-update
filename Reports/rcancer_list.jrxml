	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date"/>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[(SELECT
`vcancer1`.`pid`,
`vcancer1`.`name`,
`vcancer1`.`hnomoi`,
`vcancer1`.`villno`,
DATE_FORMAT(`vcancer1`.`birth`,'%Y-%m-%d') as birth,
`vcancer1`.`age`,
DATE_FORMAT(`vcancer1`.`visitdate`,'%Y-%m-%d') as visitdate,
`vcancer1`.`breast`,
`vcancer1`.`cervic`,
`vcancer1`.`rightname`,
`vcancer1`.`hosname`,
`vcancer1`.`visitno`,
`vcancer1`.`rightno`,
`vcancer1`.`idcard`,
vcancer1.villcode
FROM
`vcancer1`
WHERE `vcancer1`.`visitno` not in (SELECT `vcancer2`.`visitno` FROM `vcancer2`))
union
(SELECT
`vcancer2`.`pid`,
`vcancer2`.`name`,
`vcancer2`.`hnomoi`,
`vcancer2`.`villno`,
DATE_FORMAT(`vcancer2`.`birth`,'%Y-%m-%d') as birth,
`vcancer2`.`age`,
DATE_FORMAT(`vcancer2`.`visitdate`,'%Y-%m-%d') as visitdate,
`vcancer2`.`breast`,
`vcancer2`.`cervic`,
`vcancer2`.`rightname`,
`vcancer2`.`hosname`,
`vcancer2`.`visitno`,
`vcancer2`.`rightno`,
`vcancer2`.`idcard`,
vcancer2.villcode
FROM
`vcancer2`
WHERE `vcancer2`.`visitno` not in (SELECT `vcancer1`.`visitno` FROM `vcancer1`))
union 
(SELECT
`vcancer12`.`pid`,
`vcancer12`.`name`,
`vcancer12`.`hnomoi`,
`vcancer12`.`villno`,
DATE_FORMAT(`vcancer12`.`birth`,'%Y-%m-%d') as birth,
`vcancer12`.`age`,
DATE_FORMAT(`vcancer12`.`visitdate`,'%Y-%m-%d') as visitdate,
`vcancer12`.`breast`,
`vcancer12`.`cervic`,
`vcancer12`.`rightname`,
`vcancer12`.`hosname`,
`vcancer12`.`visitno`,
`vcancer12`.`rightno`,
`vcancer12`.`idcard`,
vcancer12.villcode
FROM
`vcancer12`)
ORDER BY `hosname` ASC,`villcode` ASC,visitdate ASC,hnomoi ASC]]></queryString>

