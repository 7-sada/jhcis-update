<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDentAnc" language="groovy" pageWidth="1212" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="1172" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-10-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-09-30"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select visitdrugdental.pcucode,visitdrugdental.visitno
,count(distinct visitdrugdental.pcucode,visitdrugdental.visitno) as cperson
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-01'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt1
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-02'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt2
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-03'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt3
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-04'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt4
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-05'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt5
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-06'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt6
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-07'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt7
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-08'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt8
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-09'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt9
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-10'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt10
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-11'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt11
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-12'), count(distinct visitdrugdental.pcucode,visitdrugdental.visitno),0) as cpmt12

,count(concat(visitdrugdental.pcucode,visitdrugdental.visitno) ) as ctime
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-01'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt1
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-02'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt2
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-03'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt3
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-04'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt4
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-05'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt5
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-06'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt6
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-07'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt7
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-08'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt8
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-09'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt9
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-10'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt10
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-11'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt11
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-12'), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt12

, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-01'), (visitdrug.unit * visitdrug.realprice),0) as bmt1
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-02'), (visitdrug.unit * visitdrug.realprice),0) as bmt2
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-03'), (visitdrug.unit*visitdrug.realprice),0) as bmt3
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-04'), (visitdrug.unit*visitdrug.realprice),0) as bmt4
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-05'), (visitdrug.unit*visitdrug.realprice),0) as bmt5
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-06'), (visitdrug.unit*visitdrug.realprice),0) as bmt6
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-07'), (visitdrug.unit*visitdrug.realprice),0) as bmt7
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-08'), (visitdrug.unit*visitdrug.realprice),0) as bmt8
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-09'), (visitdrug.unit*visitdrug.realprice),0) as bmt9
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-10'), (visitdrug.unit*visitdrug.realprice),0) as bmt10
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-11'), (visitdrug.unit*visitdrug.realprice),0) as bmt11
, if(date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-12'), (visitdrug.unit*visitdrug.realprice),0) as bmt12
from visitdrugdental
     left join visit on visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
     left join visitdrug on visit.pcucode = visitdrug.pcucode and visit.visitno = visitdrug.visitno
     left join cright on visit.rightcode = cright.rightcode
     left join crightgroup  on cright.rightgroup = crightgroup.rightgroupcode
where  1=1
and (dentcode in('2337708','2337709','2337748','2337749') OR visit.dentprojectcode in('011','012','013','014','015','016'))
and visitdate between $P{sdate} and  $P{edate}
$P!{pcucode}
group by visitdrugdental.pcucode,visitdrugdental.visitno]]>
	</queryString>
