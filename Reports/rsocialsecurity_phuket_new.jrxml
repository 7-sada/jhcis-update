<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rsocialsecurity_phuket_new"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND (`visit`.`visitdate` between '2010-06-20' AND '2010-06-30')"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[" AND visit.pcucode='01856' "]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="zdiag" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitdiag.diagcode  NOT REGEXP '^[Zz]' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as pname,
`person`.`lname`,
DATE_FORMAT(`visit`.`visitdate`,"%Y-%m-%d") as visitdate,
`person`.`rightno`,
`person`.`idcard`,
`person`.`pid`,
`person`.`officework`,
if(visit.money2 is null or visit.money2 = 0 or visit.money2 = '' ,sum(distinct `visit`.`money1`) ,sum(distinct `visit`.`money2`) ) money2,
(if(chospital.hosname is null,'ไม่ระบุโรงพยาบาลหลัก',chospital.hosname)) AS hosname,`visit`.`visitdate` as vdate,
if(CONCAT("'",visitdiag.pcucode,visit.visitno,"'") is null,"''",CONCAT("'",visitdiag.pcucode,visit.visitno,"'")) person
FROM
`person`
Inner Join `visit` ON `person`.`pid` = `visit`.`pid` AND `visit`.`pcucodeperson` = `person`.`pcucodeperson`
Left Outer Join ctitle ON person.prename = ctitle.titlecode
LEFT OUTER Join `visitdiag` ON `visit`.`visitno` = `visitdiag`.`visitno` AND `visitdiag`.`pcucode` = `visit`.`pcucode`
Left Outer Join `chospital` ON visit.hosmain = chospital.hoscode
 Left Outer Join cright ON visit.rightcode = cright.rightcode
WHERE cright.rightgroup ='2' 
$P!{zdiag}
$P!{pcucode} 
$P!{ReportDate}
GROUP BY visit.pcucode,visit.visitno,visit.visitdate
ORDER BY `chospital`.`hosname`,visitdate]]></queryString>

	<field name="pname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="visitdate" class="java.lang.String"/>
	<field name="rightno" class="java.lang.String"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="officework" class="java.lang.String"/>
	<field name="money2" class="java.lang.Double"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="vdate" class="java.sql.Date"/>
	<field name="person" class="java.lang.String"/>

	<variable name="sum_money" class="java.lang.Double" resetType="Group" resetGroup="hosname" calculation="Sum">
