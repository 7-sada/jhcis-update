<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptancdeliver" pageWidth="842" pageHeight="595" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="4bba0875-28f2-4c25-9fd7-67c1ca43894d">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="216"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select b.id
,ifnull(titlename,ifnull(prename,'ไม่ระบุ') )  prename,fname,lname
,DATE_FORMAT(datedeliver,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d') as age
,if(house.hno != '' ,CONVERT(concat(house.hno,' ม.',villno) USING utf8),
                     CONVERT(concat('- ม.',villno) USING utf8) ) as address

,date_format(v.datedeliver,'%Y-%m-%d') as datedeliver
,case when v.deliverplace='1' then 'รพ.'
      when v.deliverplace='2' then 'สอ.'
      when v.deliverplace='3' then 'บ้าน'
      when v.deliverplace='4' then 'อื่น ๆ '
      else '-' end as deliverplace
,case when v.delivertype='1' then 'NORMAL'
      when v.delivertype='2' then 'CESAREAN'
      when v.delivertype='3' then 'VACCUME'
      when v.delivertype='4' then 'FORCEPS'
      when v.delivertype='5' then 'ท่าก้น'
      else '-' end  as delivertype
,(select  if(sex='1','ชาย','หญิง')  from person p
          where p.pid = visitancdeliverchild.pidchild
                and p.pcucodeperson = visitancdeliverchild.pcucodechild) as sexchild
,visitancdeliverchild.weight,house.pcucode
,current_date()
,IF(v.deliverresult='ท' ,'แท้ง' ,'เกิดมีชีพ') res
from visitancdeliver v
	left join person on v.pid = person.pid and v.pcucodeperson = person.pcucodeperson
	left join ctitle on person.prename = ctitle.titlecode
 	left join visitancdeliverchild on v.pid = visitancdeliverchild.pid and v.pcucodeperson = visitancdeliverchild.pcucodeperson
                                            and v.pregno = visitancdeliverchild.pregno
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
join _laborno_for_anvdeliver_rep b on v.pcucodeperson=b.pcucodeperson and v.pid=b.pid and v.pregno=b.pregno
where v.datedeliver between $P{sdate} and $P{edate}
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
	$P!{pcucode}
order by b.id ,v.pcucode,v.datedeliver]]>
	</queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="prename" class="java.lang.String"/>
	<field name="fname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="age" class="java.lang.Double"/>
	<field name="address" class="java.lang.String"/>
	<field name="datedeliver" class="java.lang.String"/>
	<field name="deliverplace" class="java.lang.String"/>
	<field name="delivertype" class="java.lang.String"/>
	<field name="sexchild" class="java.lang.String"/>
	<field name="weight" class="java.lang.Double"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="current_date()" class="java.sql.Date"/>
	<field name="res" class="java.lang.String"/>
