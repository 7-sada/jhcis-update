<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptncd"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["35"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-02-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-09-30"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT village.villcode,villname,ifnull(titlename,ifnull(prename,'ไม่ระบุ') ) prename,fname,lname,idcard
,DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d') as age
,if(sex='1','ชาย','หญิง')  as sex 
,v.rightcode
,weight,height
,case when bmilevel ='1' then 'ผอม' 
      when bmilevel ='2' then 'ค่อนข้างผอม' 
      when bmilevel ='3' then 'สมส่วน'
      when bmilevel ='4' then 'ค่อนข้างอ้วน'
      when bmilevel ='5' then 'อ้วน' 
      when bmilevel ='6' then 'อ้วนมาก' else '-' end  as bmilevel
,pressure
,if(LENGTH(SUBSTRING_INDEX(v.pressure,'/',1) )>4,"แปรผลไม่ได้"
   ,case when ( SUBSTRING_INDEX(v.pressure,'/',1) <= o.upperhypern &&  SUBSTRING_INDEX(v.pressure,'/',-1)<= o.lowerhypern)  then "ปกติ" 
         when ( SUBSTRING_INDEX(v.pressure,'/',1) < o.upperhypern  &&  (SUBSTRING_INDEX(v.pressure,'/',-1) between o.lowerhypern and o.lowerhyperr )) then "เสี่ยงแบบล่างสูง"
         when ((SUBSTRING_INDEX(v.pressure,'/',1) between o.upperhypern  and  o.upperhyperh )  &&  (SUBSTRING_INDEX(v.pressure,'/',-1) <= o.lowerhyperr)) then "เสี่ยงแบบบนสูง"
         when ( SUBSTRING_INDEX(v.pressure,'/',1) >= o.upperhyperh  ||  SUBSTRING_INDEX(v.pressure,'/',-1)>= o.lowerhyperr) then "สูง" else "แปรผลไม่ได้" end  ) as bp

,waist
, case when sex='1' and waist <=90 then 'ปกติ' when  sex='2' and waist <=80 then 'ปกติ'  
       when sex='1' and waist > 90 then 'อ้วน' when sex='2' and waist > 80 then 'อ้วน'  
           else '-' end as waistname

,sugarnumdigit
, case when  ((foodsuspend ='0' and sugarnumdigit < 111)  OR (foodsuspend ='1' and sugarnumdigit < 69))  then 'ต่ำ' 
	  when ((foodsuspend ='0' and sugarnumdigit < 180)  OR (foodsuspend ='1' and sugarnumdigit < 110))  then 'ปกติ' 
	  when ((foodsuspend ='0' and sugarnumdigit >= 180 )  OR (foodsuspend ='1' and sugarnumdigit >= 110 ) )  then 'เสี่ยง' 
         else '-'   end  as sugarname
,v.pcucode
,if(house.hno != '' ,CONVERT(concat(house.hno,' ม.',villno) USING utf8), CONVERT(concat('- ม.',villno) USING utf8) ) as address
FROM  person left join visit v ON person.pid = v.pid and person.pcucodeperson = v.pcucodeperson
	left join ctitle on person.prename = ctitle.titlecode
	left join visitlabsugarblood on v.visitno = visitlabsugarblood.visitno and v.pcucode = visitlabsugarblood.pcucode
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
 left join office o  on v.pcucode = o.offid
WHERE v.visitdate in(select MAX(v1.visitdate) from visit v1 where v.pid = v1.pid and v.pcucodeperson = v1.pcucodeperson)
      and concat(person.pid,person.pcucodeperson) not in(select concat(p.pid,p.pcucodeperson) from personchronic p where person.pid = p.pid and person.pcucodeperson = p.pcucodeperson and datedxfirst < $P{sdate} ) 
	and DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')  >= $P{age}
  	and v.visitdate between $P{sdate} and $P{edate}
	$P!{pcucode}
order by v.pcucode,house.villcode]]></queryString>

	<field name="villcode" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<field name="prename" class="java.lang.String"/>
	<field name="fname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="age" class="java.lang.Double"/>
	<field name="sex" class="java.lang.String"/>
	<field name="rightcode" class="java.lang.String"/>
	<field name="weight" class="java.math.BigDecimal"/>
	<field name="height" class="java.math.BigDecimal"/>
	<field name="bmilevel" class="java.lang.String"/>
	<field name="pressure" class="java.lang.String"/>
	<field name="bp" class="java.lang.String"/>
	<field name="waist" class="java.math.BigDecimal"/>
	<field name="waistname" class="java.lang.String"/>
	<field name="sugarnumdigit" class="java.lang.Double"/>
	<field name="sugarname" class="java.lang.String"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>


