	<field name="ppid" class="java.lang.String"/>
	<field name="pati" class="java.lang.String"/>
	<field name="idc" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="birt" class="java.lang.String"/>
