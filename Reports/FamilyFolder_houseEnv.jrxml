	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="p_hcode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["1490"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["03320"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_officename" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["----"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     house.`hid` AS house_hid,
     house.`hno` AS house_hno,
     village.villno AS moo,
     village.villname AS mooname,
     house.`road` AS house_road,
     house.`villcode` AS house_villcode,
     house.`waterdrink` AS house_waterdrink,
     case house.`waterdrinkeno` when '1'then 'เพียงพอ'when '0'then 'ไม่เพียงพอ'when '2'then 'ไม่ทราบ'Else ''END AS house_waterdrinkeno,
     house.`pcucode` AS house_pcucode,
     house.`hcode` AS house_hcode,
     cwatertype.`watertypename` AS cwatertype_watertypename,
     case house.`toilet` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_toilet,
     case house.`garbageware` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_garbageware,
     case house.`garbageerase` when '0'then 'ไม่มี'when '1'then ' ฝัง'when '2'then 'เผา'when '3'then 'หมักทำปุ๋ย'when '4'then 'ส่งต่อเช่น รถขนขยะ มาเก็บ'when '5'then 'อื่นๆ'END AS house_garbageerase,
     case house.`waterassuage` when '1'then 'มีระบบกำจัดน้ำเสีย'when '0'then 'ไม่มีีระบบกำจัดน้ำเสีย'when '2'then 'ไม่ทราบ'Else ''END AS house_waterassuage,
     case house.`houseendur` when '0'then 'ชั่วคราว(ไม่คงทน)'when '1'then 'คงทน 1-4 ปี'when '2'then 'คงทน 5 ปีขึ้นไป'Else 'ไม่ระบุ'END AS house_houseendur,
     Case house.`houseclean` when '0'Then 'ไม่สะอาด'when '1'Then 'สะอาด'when '2'Then 'ไม่ทราบ'END AS house_houseclean,
     case house.`housecomplete` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_housecomplete,
     case house.`houseairflow` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_houseairflow,
     case house.`houselight` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_houselight,
     case house.`foodcook` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodcook,
     case house.`foodkeepsafe` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodkeepsafe,
     case house.`foodware` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodware,
     case house.`foodwarewash` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodwarewash,
     case house.`foodwarekeep` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodwarekeep,
     case house.`foodgarbageware` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodgarbageware,
     case house.`foodcookroom` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodcookroom,
     case house.`foodsanitation` when '1'then 'มี'when '0'then 'ไม่มี'when '2'then 'ไม่ทราบ'Else ''END AS house_foodsanitation,
     case house.`iodeinsalt` when '1'then 'ใช้'when '0'then 'ไม่ใช้'Else 'ไม่ทราบ'END AS house_iodeinsalt,
     case house.`iodeinmaterial` when '1'then 'ใช้'when '0'then 'ไม่ใช้'Else 'ไม่ทราบ'END AS house_iodeinmaterial,
     case house.`iodeinuse` when '1'then 'ใช้'when '0'then 'ไม่ใช้'Else 'ไม่ทราบ'END AS house_iodeinuse,
     house.`controlrat` AS house_controlrat,
     house.`controlcockroach` AS house_controlcockroach,
     house.`controlhousefly` AS house_controlhousefly,
     house.`controlmqt` AS house_controlmqt,
     house.`controlinsetdisease` AS house_controlinsetdisease,
     house.`ftlj` AS house_ftlj,
     house.`whjrk` AS house_whjrk,
     house.`slpp` AS house_slpp,
     house.`cht` AS house_cht,
     house.`kmch` AS house_kmch,
     house.`pets` AS house_pets,
     house.`petsdung` AS house_petsdung,
     cprovince.`provname` AS cprovince_provname,
     cdistrict.`distname` AS distname,
     csubdistrict.subdistname AS subdistname
#อสม.
,ifnull(
(SELECT IF(ref_p.fname='' OR ref_p.fname IS NULL, 'ไม่ระบุ', CAST(CONCAT('อสม.:',ifnull(t.titlename,ref_p.prename),ifnull(ref_p.fname,'..ไม่ระบุฯ'),'  ',ifnull(ref_p.lname,'')) AS char))
  FROM house ref_h
    INNER JOIN person ref_p ON (ref_h.pcucodepersonvola=ref_p.pcucodeperson AND ref_h.pidvola=ref_p.pid)
    left outer join ctitle t on ref_p.prename=t.titlecode
  WHERE ref_h.pcucode=$P{p_pcucode} AND ref_h.hcode=$P{p_hcode}
),'..ยังไม่ระบุ อสม. ของบ้านนี้ฯ')
AS villagehealthvolunteer
FROM
`house` house
    LEFT OUTER JOIN  `cwatertype` cwatertype  ON cwatertype.`watertypecode` = house.`waterdrink`
              AND cwatertype.`watertypecode` = house.`wateruse`
     LEFT OUTER JOIN `cprovince` cprovince ON substring(house.`villcode`,1,2) = cprovince.`provcode`
     LEFT OUTER JOIN  cdistrict ON substring(house.`villcode`,1,2) = cdistrict.`provcode` AND substring(house.`villcode`,3,2) = cdistrict.`distcode`
     LEFT OUTER JOIN  csubdistrict ON substring(house.`villcode`,1,2) = csubdistrict.`provcode` AND substring(house.`villcode`,3,2) = csubdistrict.`distcode`
              AND substring(house.`villcode`,5,2) = csubdistrict.`subdistcode`
     LEFT OUTER JOIN  village  ON house.`villcode` = village.villcode AND  house.`pcucode` = village.pcucode
WHERE
     hcode = $P!{p_hcode}
 AND house.pcucode = '$P!{p_pcucode}']]>
	</queryString>
