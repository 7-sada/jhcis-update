	</parameter>
	<queryString><![CDATA[SELECT

     sum(CASE WHEN b.sex='1'  THEN 1 ELSE 0 END) AS screen_m,
     sum(CASE WHEN b.sex='2' THEN 1 ELSE 0 END) AS screen_w,
     sum(1) AS screen_total ,
     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and a.result_new_dm='1'  THEN 1 ELSE 0 END) AS dm1_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and a.result_new_dm='1' THEN 1 ELSE 0 END) AS dm1_w ,
     sum(CASE WHEN c.chronic_flag='0' and a.result_new_dm='1' THEN 1 ELSE 0 END) AS dm1_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and a.result_new_dm='2'  THEN 1 ELSE 0 END) AS dm2_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and a.result_new_dm='2' THEN 1 ELSE 0 END) AS dm2_w ,
     sum(CASE WHEN c.chronic_flag='0' and a.result_new_dm='2' THEN 1 ELSE 0 END) AS dm2_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='0' and a.result_new_dm='3'  THEN 1 ELSE 0 END) AS dm3_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='0' and a.result_new_dm='3' THEN 1 ELSE 0 END) AS dm3_w ,
     sum(CASE WHEN c.chronic_flag='0' and a.result_new_dm='3' THEN 1 ELSE 0 END) AS dm3_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.dm_flag='1'  THEN 1 ELSE 0 END) AS dm_old_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.dm_flag='1'  THEN 1 ELSE 0 END) AS dm_old_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.dm_flag='1'  THEN 1 ELSE 0 END) AS dm_old_total,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='1'  THEN 1 ELSE 0 END) AS dm_comp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS dm_comp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='1' THEN 1 ELSE 0 END) AS dm_comp_total ,

     sum(CASE WHEN b.sex='1' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='0'  THEN 1 ELSE 0 END) AS dm_nocomp_m,
     sum(CASE WHEN b.sex='2' and c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS dm_nocomp_w ,
     sum(CASE WHEN c.chronic_flag='1' and d.dm_flag='1' and d.has_symptom='0' THEN 1 ELSE 0 END) AS dm_nocomp_total 

FROM
     `ncd_person_ncd_screen` a
     INNER JOIN `ncd_person` b ON a.`pcucode` = b.`pcucode` AND a.`pid` = b.`pid`
     INNER JOIN `ncd_person_ncd` c ON a.`pcucode` = c.`pcucode` AND a.`pid` = c.`pid`
     LEFT OUTER JOIN `ncd_person_ncd_hist` d ON a.`pcucode` = d.`pcucode` AND a.`pid` = d.`pid`
WHERE 1=1 $P!{p_sqlOffice} $P!{p_sqlDate}]]></queryString>

