		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select house.villcode,village.villname
,sum(case when personchronic.chroniccode LIKE 'E10%' OR personchronic.chroniccode LIKE 'E11%' OR personchronic.chroniccode LIKE 'E12%' OR personchronic.chroniccode LIKE 'E13%' 
		         OR personchronic.chroniccode LIKE 'E14%' then 1 else 0 end) as dm

,sum(case when personchronic.chroniccode LIKE 'I10%' OR personchronic.chroniccode LIKE 'I11%' OR personchronic.chroniccode LIKE 'I12%' OR personchronic.chroniccode LIKE 'I13%' 
                          OR personchronic.chroniccode LIKE 'I14%' OR personchronic.chroniccode LIKE 'I15%' then 1 else 0 end) as ht

,sum(case when  personchronic.chroniccode LIKE 'E10%' OR personchronic.chroniccode LIKE 'E11%' OR personchronic.chroniccode LIKE 'E12%' OR personchronic.chroniccode LIKE 'E13%' 
		            OR personchronic.chroniccode LIKE 'E14%'  AND  
				personchronic.chroniccode LIKE 'I10%' OR personchronic.chroniccode LIKE 'I11%' OR personchronic.chroniccode LIKE 'I12%' 
			  OR personchronic.chroniccode LIKE 'I13%'   OR personchronic.chroniccode LIKE 'I14%' OR personchronic.chroniccode LIKE 'I15%'   then 1 else 0 end) as dmht
,house.pcucode,chospital.hosname
from personchronic 
	left join person on personchronic.pid = person.pid and personchronic.pcucodeperson = person.pcucodeperson
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode and house.pcucode =village.pcucode
	left join chospital on house.pcucode = chospital.hoscode
WHERE 1=1 and personchronic.datedxfirst between $P{sdate} and $P{edate}
	and concat(personchronic.pcucodeperson,personchronic.pid) not in (select concat(persondeath.pcucodeperson,persondeath.pid) from persondeath where personchronic.pid = persondeath.pid and personchronic.pcucodeperson = persondeath.pcucodeperson and deaddate <= $P{edate})
	$P!{pcucode}	
group by house.pcucode,house.villcode
order by house.pcucode,house.villcode]]></queryString>

	<field name="villcode" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<field name="dm" class="java.math.BigDecimal"/>
	<field name="ht" class="java.math.BigDecimal"/>
	<field name="dmht" class="java.math.BigDecimal"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>

