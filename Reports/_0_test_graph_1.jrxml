<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="_0_test_graph_1" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="84ea7b32-375c-4e7f-8c43-ff45244529a2">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="28"/>
	<queryString>
		<![CDATA[select sq.vc,v.villname ,sq.total
from(
select h.pcucode,h.villcode vc ,count(*) total
from house h join person p on h.pcucode=p.pcucodeperson and h.hcode=p.hcode
where right(h.villcode,2)<>'00'
group by h.villcode) as sq
join
village v on sq.pcucode=v.pcucode and sq.vc=v.villcode]]>
	</queryString>
	<field name="vc" class="java.lang.String"/>
	<field name="villname" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="total" class="java.lang.Long"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="7" splitType="Stretch"/>
	</title>
	<pageHeader>
		<band height="35" splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band height="4" splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="8" splitType="Stretch"/>
	</detail>
	<columnFooter>
		<band height="12" splitType="Stretch"/>
	</columnFooter>
	<pageFooter>
		<band height="5" splitType="Stretch"/>
	</pageFooter>
	<summary>
		<band height="279" splitType="Stretch">
			<barChart>
				<chart isShowLegend="true" renderType="draw">
					<reportElement uuid="22a69c94-8f32-4528-bdb1-3ae9c149f2ec" x="78" y="14" width="588" height="253"/>
					<chartTitle position="Bottom"/>
					<chartSubtitle>
						<font isStrikeThrough="true"/>
					</chartSubtitle>
					<chartLegend position="Top">
						<font isStrikeThrough="false"/>
					</chartLegend>
				</chart>
				<categoryDataset>
					<categorySeries>
						<seriesExpression><![CDATA[$F{vc}]]></seriesExpression>
						<categoryExpression><![CDATA[$F{villname}]]></categoryExpression>
						<valueExpression><![CDATA[$F{total}]]></valueExpression>
						<labelExpression><![CDATA[$F{villname}]]></labelExpression>
					</categorySeries>
				</categoryDataset>
				<barPlot>
					<plot/>
					<itemLabel/>
					<categoryAxisFormat>
						<axisFormat/>
					</categoryAxisFormat>
					<valueAxisFormat>
						<axisFormat/>
