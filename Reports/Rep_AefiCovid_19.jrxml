	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Project_Java\\_DesktopApp\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select va.pid,ct.titlename,p.fname,p.lname,getAgeymd(p.birth,now()) as age,
date_add(va.dateepi,interval 543 year) as  dateepi
,date_format(va.dateepi,'%d') as dd,
(case when date_format(va.dateepi,'%m') = '01' then 'มค.'
when date_format(va.dateepi,'%m') = '02' then 'กพ.'
when date_format(va.dateepi,'%m') = '03' then 'มีค.'
when date_format(va.dateepi,'%m') = '04' then 'เมย.'
when date_format(va.dateepi,'%m') = '05' then 'พค.'
when date_format(va.dateepi,'%m') = '06' then 'มิย.'
when date_format(va.dateepi,'%m') = '07' then 'กค.'
when date_format(va.dateepi,'%m') = '08' then 'สค.'
when date_format(va.dateepi,'%m') = '09' then 'กย.'
when date_format(va.dateepi,'%m') = '10' then 'ตค.'
when date_format(va.dateepi,'%m') = '11' then 'พย.'
when date_format(va.dateepi,'%m') = '12' then 'ธค.'
else 'n/a' end) as mm,
date_format(date_add(va.dateepi,interval 543 year),'%Y') as yy
,date_add(va.aefidate,interval 543 year) as aefidate,
date_format(va.aefidate,'%d') as dd1,
(case when date_format(va.aefidate,'%m') = '01' then 'มค.'
when date_format(va.aefidate,'%m') = '02' then 'กพ.'
when date_format(va.aefidate,'%m') = '03' then 'มีค.'
when date_format(va.aefidate,'%m') = '04' then 'เมย.'
when date_format(va.aefidate,'%m') = '05' then 'พค.'
when date_format(va.aefidate,'%m') = '06' then 'มิย.'
when date_format(va.aefidate,'%m') = '07' then 'กค.'
when date_format(va.aefidate,'%m') = '08' then 'สค.'
when date_format(va.aefidate,'%m') = '09' then 'กย.'
when date_format(va.aefidate,'%m') = '10' then 'ตค.'
when date_format(va.aefidate,'%m') = '11' then 'พย.'
when date_format(va.aefidate,'%m') = '12' then 'ธค.'
else 'n/a' end) as mm1,
date_format(date_add(va.aefidate,interval 543 year),'%Y') as yy1
,cc.aefidesc,
(case when va.aefi_reac_type = '1' then 'น้อย'
when va.aefi_reac_type = '2' then 'ปานกลาง'
else 'รุนแรงมาก'
end) as aefidatail,
if (va.aefi_reac_state = '1',"หลังฉีด 30 นาที","ออกจาก รพ. แล้ว")  as state,
if(va.aeficode10comment is null,"ไม่มี",va.aeficode10comment) as aeficode10comment
,if (va.vaccinecode = 'COVID19-1',"1","2") as no
from visitepicovid19aefi va
left join person p on (va.pid = p.pid and va.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (p.prename = ct.titlecode)
left join caeficovid cc on (va.aeficode = cc.aeficode)
where va.vaccinecode in ('COVID19-1','COVID19-2')
order by va.pid,va.dateepi,no]]>
	</queryString>
