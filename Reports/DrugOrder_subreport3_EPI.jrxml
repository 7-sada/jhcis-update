<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DrugOrder_subreport3_EPI" pageWidth="167" pageHeight="226" columnWidth="167" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="736123ac-4cb9-41a2-b2e9-85d58a2d38f5">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
     cdrug.`drugname` AS depi
FROM
`visitepi` visitepi INNER JOIN `cdrug` cdrug ON visitepi.`vaccinecode` = cdrug.`drugcode`

WHERE
     visitepi.`visitno` = $P{visitno} and visitepi.pcucode = $P{pcucode}]]>
	</queryString>
	<field name="depi" class="java.lang.String"/>
	<background>
