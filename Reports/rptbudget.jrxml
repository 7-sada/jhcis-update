<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptbudget"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-10-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pt" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[
"and concat(visit.pcucodeperson,visit.pid) not in (select concat(visitanc.pcucodeperson,visitanc.pid) from  visitanc where visitanc.pcucodeperson = person.pcucodeperson and visitanc.pid = person.pid )" +
"and concat(visit.pcucodeperson,visit.pid) not in (select concat(visitepi.pcucodeperson,visitepi.pid) from  visitepi where visitepi.pcucodeperson = person.pcucodeperson and visitepi.pid = person.pid )" +
"and concat(visit.pcucodeperson,visit.pid) not in (select concat(visitfp.pcucodeperson,visitfp.pid) from  visitfp where visitfp.pcucodeperson = person.pcucodeperson and visitfp.pid = person.pid )"
]]></defaultValueExpression>
	</parameter>
	<parameter name="anc" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and concat(visit.pcucodeperson,visit.pid) not in (select concat(visitanc.pcucodeperson,visitanc.pid) from  visitanc where visitanc.pcucodeperson = person.pcucodeperson and visitanc.pid = person.pid )"]]></defaultValueExpression>
	</parameter>
	<parameter name="epi" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and concat(visit.pcucodeperson,visit.pid) not in (select concat(visitepi.pcucodeperson,visitepi.pid) from  visitepi where visitepi.pcucodeperson = person.pcucodeperson and visitepi.pid = person.pid )"]]></defaultValueExpression>
	</parameter>
	<parameter name="fp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and concat(visit.pcucodeperson,visit.pid) not in (select concat(visitfp.pcucodeperson,visitfp.pid) from  visitfp where visitfp.pcucodeperson = person.pcucodeperson and visitfp.pid = person.pid )"]]></defaultValueExpression>
	</parameter>
	<parameter name="typeservice" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT  date_format(visitdate,'%Y-%m-%d') as visitdate
,date_format($P{edate},'%Y-%m-%d') as monthly
,sum(case when crightgroup.rightgroupcode='x' then visit.money3 else 0 end) as rightpay
,sum(case when crightgroup.rightgroupcode='1' then visit.money3 else 0 end) as rightofficer
,sum(case when crightgroup.rightgroupcode='2' then visit.money3 else 0 end) as rightsocial
,sum(case when crightgroup.rightgroupcode in ('3','4') then visit.money3 else 0 end) as rightuc
,sum(case when (crightgroup.rightgroupcode  not in ('1','2','3','4','x') or visit.rightcode is null)  then visit.money3 else 0 end) as rightother
FROM visit
	left join person on visit.pcucodeperson = person.pcucodeperson and visit.pid = person.pid
        left join cright on visit.rightcode = cright.rightcode
	left join crightgroup ON cright.rightgroup = crightgroup.rightgroupcode
	
WHERE visit.visitdate between $P{sdate} and $P{edate}
$P!{pcucode}
$P!{pt}
$P!{anc}
$P!{epi}
$P!{fp}
GROUP BY visit.visitdate
order by visit.visitdate]]></queryString>

	<field name="visitdate" class="java.util.Date"/>
	<field name="monthly" class="java.util.Date"/>
	<field name="rightpay" class="java.lang.Double"/>
	<field name="rightofficer" class="java.lang.Double"/>
	<field name="rightsocial" class="java.lang.Double"/>
	<field name="rightuc" class="java.lang.Double"/>
	<field name="rightother" class="java.lang.Double"/>

