<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ncd_pressure"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-25"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-02-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["40"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 1,ifnull(titlename,ifnull(prename,'ไม่ระบุ') )  prename,p.fname,p.lname,p.hnomoi
,CONVERT(if(village.villno=0," นอกเขต",village.villno) using utf8) villno
,DATE_FORMAT(birth, "%Y-%m-%d") as birth
,Max(DATE_FORMAT(v.visitdate,"%Y-%m-%d")) as visitdate
,CONVERT(CONCAT(  DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " - ",
   CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))
      WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
      WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
      WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " - ",
   CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))
      WHEN 0 THEN(DATE_FORMAT(v.visitdate,"%d")- DATE_FORMAT(birth,"%d") )
      WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))
      WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_ymd
,v.pressure ,c.rightname,v.rightno , p.idcard  ,zero2null(p.birth) as bb
,v.pcucode,p.hosmain ,h.hosname as hosname,hm.hosname as hosmainname
,tb.subdistname, d.distname,cw.provname

,if(LENGTH(SUBSTRING_INDEX(v.pressure,'/',1) )>4,"แปรผลไม่ได้"
   ,case when ( SUBSTRING_INDEX(v.pressure,'/',1) <= o.upperhypern &&  SUBSTRING_INDEX(v.pressure,'/',-1)<= o.lowerhypern)  then "ปกติ" 
         when ( SUBSTRING_INDEX(v.pressure,'/',1) < o.upperhypern  &&  (SUBSTRING_INDEX(v.pressure,'/',-1) between o.lowerhypern and o.lowerhyperr )) then "เสี่ยงแบบล่างสูง"
         when ((SUBSTRING_INDEX(v.pressure,'/',1) between o.upperhypern  and  o.upperhyperh )  &&  (SUBSTRING_INDEX(v.pressure,'/',-1) <= o.lowerhyperr)) then "เสี่ยงแบบบนสูง"
         when ( SUBSTRING_INDEX(v.pressure,'/',1) >= o.upperhyperh  ||  SUBSTRING_INDEX(v.pressure,'/',-1)>= o.lowerhyperr) then "สูง" else "นอกเงื่อนไข" end  ) as bp

FROM visit v
     left join person p on v.pid = p.pid and v.pcucodeperson = p.pcucodeperson
     left join ctitle on p.prename = ctitle.titlecode
     left join visitdiag  vd on v.visitno = vd.visitno and v.pcucode = vd.pcucode
     left join office o  on v.pcucode = o.offid
     left join house on p.hcode=house.hcode and p.pcucodeperson = house.pcucode
     left join village on house.villcode = village.villcode and v.pcucode = village.pcucode
     left join cright c on c.rightcode = v.rightcode
     left join chospital h on h.hoscode = v.pcucode
     left join chospital hm on hm.hoscode = p.hosmain 
     left join csubdistrict tb on tb.subdistcode = h.subdistcode and tb.distcode = h.distcode and tb.provcode = h.provcode 
     left join cdistrict d on d.distcode = h.distcode and d.provcode = h.provcode
     left join cprovince cw on cw.provcode=h.provcode
WHERE v.visitdate between $P{sdate} and $P{edate}
      and left(vd.diagcode,2) !=  'I1'
      and (birth IS NOT NULL OR birth NOT LIKE '0000%')
      and (datediff(v.visitdate,p.birth)/365) >= $P{age}
      and visitdate in (select Max(visitdate) from visit vv where vv.pid = v.pid and vv.pcucodeperson = v.pcucodeperson and vv.visitdate <=$P{edate} group by vv.pid,vv.pcucodeperson)
      and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
      $P!{pcucode}

group by v.pid,v.pcucodeperson
order by v.pcucode,village.villno,visitdate]]></queryString>

