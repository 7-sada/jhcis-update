					</textElement>
				<text><![CDATA[หมายเหตุ : 
1. อายุนับจากปีเกิดถึง 1 กรกฏาคม ของปีนั้น ๆ (กลางปี)   
2. แปรผลการตรวจคัดกรองความดันโลหิตจาก การกำหนดค่าเริ่มต้นของระบบ
3. ค่าความดันจะต้องมีเครื่องหมาย / ระหว่างค่าความดัน 
4. แสดงรายชื่อเฉพาะผู้ป่วยใหม่ (ไม่เป็นโรคเรื้องรัง)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="0"
						y="48"
						width="30"
						height="20"
						key="staticText-22"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="10" isUnderline="true" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[อายุ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="60"
						y="48"
						width="150"
						height="20"
						key="staticText-23"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
