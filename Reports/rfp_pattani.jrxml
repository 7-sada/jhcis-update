<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rfp_pattani"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson ='14460' "]]></defaultValueExpression>
	</parameter>
	<parameter name="datefp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND datefp BETWEEN '2008-01-01' AND '2008-12-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucodefp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitfp.pcucode='14460' "]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["current_date"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 
	Count(distinct(person.pid) )AS women,
	Sum( if(cdrug.drugtypesub = 1 AND visitfp.typefp = 1 $P!{pcucodefp}, 1, 0 ) ) AS ntab,
	Sum( if(cdrug.drugtypesub = 2 AND visitfp.typefp = 1 $P!{pcucodefp}, 1, 0 ) ) AS ninj,
	Sum( if(cdrug.drugtypesub = 3 AND visitfp.typefp = 1 $P!{pcucodefp}, 1, 0 ) ) AS ninte,
	Sum( if(cdrug.drugtypesub = 4 AND visitfp.typefp = 1 $P!{pcucodefp}, 1, 0 ) ) AS nloop,
	Sum( if(cdrug.drugtypesub = 5 AND visitfp.typefp = 1 $P!{pcucodefp}, 1, 0 ) ) AS ncondom,
	Sum( if(cdrug.drugtypesub = 6 , 1, 0 ) ) AS nfpmale ,
	Sum( if(cdrug.drugtypesub = 7 , 1, 0 ) ) AS nfpfemale,
	Sum( if(cdrug.drugtypesub = 1 $P!{pcucode} $P!{pcucodefp}, 1, 0 ) ) AS otab,
	Sum( if(cdrug.drugtypesub = 2 $P!{pcucode} $P!{pcucodefp}, 1, 0 ) ) AS oinj,
	Sum( if(cdrug.drugtypesub = 3 $P!{pcucode} $P!{pcucodefp}, 1, 0 ) ) AS ointe,
	Sum( if(cdrug.drugtypesub = 4 $P!{pcucode} $P!{pcucodefp}, 1, 0 ) ) AS oloop,
	Sum( if(cdrug.drugtypesub = 5 $P!{pcucode} $P!{pcucodefp}, 1, 0 ) ) AS ocondom,
	Sum( if(cdrug.drugtypesub = 6 , 1, 0 ) ) AS ofpmale ,
	Sum( if(cdrug.drugtypesub = 7 , 1, 0 ) ) AS ofpfemale  
FROM
person  
Left Outer Join visitfp ON  visitfp.pcucodeperson = person.pcucodeperson AND visitfp.pid = person.pid
Left Outer Join  cdrug ON visitfp.fpcode = cdrug.drugcode
WHERE marystatus in('2','f') AND person.sex ='2' AND (datefp is null OR zero2null(datefp) = (SELECT MAX(datefp) FROM visitfp a WHERE a.pid = person.pid)) AND
        DATEDIFF($P!{edate},birth) BETWEEN 5475 AND 16424  AND 
        person.pid not in (SELECT persondeath.pid FROM persondeath WHERE zero2null(persondeath.deaddate) <= $P!{edate}) 
	$P!{pcucode}]]></queryString>

	<field name="women" class="java.lang.Long"/>
	<field name="ntab" class="java.math.BigDecimal"/>
	<field name="ninj" class="java.math.BigDecimal"/>
	<field name="ninte" class="java.math.BigDecimal"/>
	<field name="nloop" class="java.math.BigDecimal"/>
	<field name="ncondom" class="java.math.BigDecimal"/>
	<field name="nfpmale" class="java.math.BigDecimal"/>
	<field name="nfpfemale" class="java.math.BigDecimal"/>
	<field name="otab" class="java.math.BigDecimal"/>
	<field name="oinj" class="java.math.BigDecimal"/>
	<field name="ointe" class="java.math.BigDecimal"/>
	<field name="oloop" class="java.math.BigDecimal"/>
	<field name="ocondom" class="java.math.BigDecimal"/>
	<field name="ofpmale" class="java.math.BigDecimal"/>
	<field name="ofpfemale" class="java.math.BigDecimal"/>

