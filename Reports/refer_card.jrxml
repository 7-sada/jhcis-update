	<subDataset name="datadrug" uuid="fb87a8d7-5372-4771-a48b-a5678d8f1607">
		<parameter name="visitno" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[select vd.drugcode,c.drugname,vd.unit,vd.dose
from visitdrug vd
join cdrug c on (vd.drugcode = c.drugcode)
where visitno = $P{visitno}
and c.drugtype <> '06']]>
		</queryString>
		<field name="drugcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="drugname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="unit" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dose" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<subDataset name="datadiag" uuid="8805c8c6-4f8f-4f0e-9916-dda3091da08c">
		<parameter name="visitno" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[SELECT vd.diagcode,cd.diseasename,
case  when dxtype = '01' then 'โรคหลัก (Principle Dx)'
when dxtype = '04' then 'อื่นๆ (Other)'
when dxtype = '05' then 'สาเหตุภายนอก (External Cause)'
when dxtype = '07' then 'เนื้องอก (Morphology)'
else '..ไม่ระบุ..'
end as dxname
from visitdiag vd
join cdisease cd on (vd.diagcode = cd.diseasecode)
where vd.visitno = $P{visitno}
ORDER BY vd.dxtype]]>
		</queryString>
		<field name="diagcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="diseasename" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dxname" class="java.lang.String"/>
	</subDataset>
	<parameter name="visitno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select v.visitno,year(v.visitdate)+543 as NoYY,day(v.visitdate) as dd,v.numberrefer,of.tel,
(CASE WHEN MONTH(v.visitdate)=1 THEN 'มกราคม'
   WHEN MONTH(v.visitdate)=2 THEN 'กุมภาพันธ์' WHEN MONTH(v.visitdate)=3 THEN 'มีนาคม'
   WHEN MONTH(v.visitdate)=4 THEN 'เมษายน' WHEN MONTH(v.visitdate)=5 THEN 'พฤษภาคม'
   WHEN MONTH(v.visitdate)=6 THEN 'มิถุนายน' WHEN MONTH(v.visitdate)=7 THEN 'กรกฎาคม'
   WHEN MONTH(v.visitdate)=8 THEN 'สิงหาคม' WHEN MONTH(v.visitdate)=9 THEN 'กันยายน'
   WHEN MONTH(v.visitdate)=10 THEN 'ตุลาคม' WHEN MONTH(v.visitdate)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(v.visitdate)=12 THEN 'ธันวาคม' end) as mm, (Year(v.visitdate)+543) as yy,
v.pcucode,ch1.hosname,
v.pid,t.titlenamelong,p.fname,p.lname,getAgeYearNum(p.birth,v.visitdate) as ageyy,
if(p.sex='1','ชาย','หญิง') as psex,ifnull(ifnull(pa.hno,p.hnomoi),'..ไม่ระบุ..') as hno,ifnull(ifnull(pa.mu,p.mumoi),'..ไม่ระบุุ..') as moo,
ifnull(ifnull(cs1.subdistname,cs.subdistname),'..ไม่ระบุ..') as tumbon,
ifnull(ifnull(cd1.distname,cd.distname),'..ไม่ระบุ..') as ampur,
ifnull(ifnull(cp1.provname,cp.provname),'..ไม่ระบุ..') as province,
v.refertohos,ch.hosname as hosrefer,
ifnull(v.symptoms,'.ไม่ระบุ..') as presentdiag,ifnull(v.symptomsco,'..ไม่ระบุ..') as pastdiag,
ifnull(cast(v.temperature as char),'..ไม่ระบุ..') as bt,ifnull(cast(v.pressure as char),'..ไม่ระบุ..') as bp,
ifnull(cast(v.pulse as char),'..ไม่ระบุ..') as p,ifnull(cast(v.respri as char),'..ไม่ระบุ..') as r,ifnull(cast(v.weight as char),'..ไม่ระบุ..') as weight,ifnull(cast(v.height as char),'..ไม่ระบุ..') as height,
(case when v.gaheent = '1' then 'ปกติ'
when v.gaheent = '2' then 'ผิดปกติ'
when v.gaheent = '9' then 'ไม่ตรวจ'
else '..ไม่ระบุ..' end ) as HEENT,
(case when v.gahlart = '1' then 'ปกติ'
when v.gahlart = '2' then 'ผิดปกติ'
when v.gahlart = '9' then 'ไม่ตรวจ'
else '..ไม่ระบุ..' end ) as HLART,
(case when v.galung = '1' then 'ปกติ'
when v.galung = '2' then 'ผิดปกติ'
when v.galung = '9' then 'ไม่ตรวจ'
else '..ไม่ระบุ..' end ) as LUNG,
(case when v.gaab = '1' then 'ปกติ'
when v.gaab = '2' then 'ผิดปกติ'
when v.gaab = '9' then 'ไม่ตรวจ'
else '..ไม่ระบุ..' end ) as Ab,
(case when v.gaext = '1' then 'ปกติ'
when v.gaext = '2' then 'ผิดปกติ'
when v.gaext = '9' then 'ไม่ตรวจ'
else '..ไม่ระบุ..' end ) as Ext,
(case when v.ganeuro = '1' then 'ปกติ'
when v.ganeuro = '2' then 'ผิดปกติ'
when v.ganeuro = '9' then 'ไม่ตรวจ'
else '..ไม่ระบุ..' end ) as Neuro,ifnull(v.diagnote,'..ไม่ระบุ..') as diagnote,
ifnull(v.vitalcheck,'..ไม่ระบุ..') as vitalcheck,
-- ifnull(vd.diagcode,'..ไม่ระบุ..') as diagcode,
-- ifnull(cdi.diseasenamethai,'..ไม่ระบุ..') as diseasenamethai,
(case when v.refer = '00' then 'ไม่ใช่  Case Refer'
when v.refer = '01' then 'เกินขีดความสามารถของหน่วยงานนี้'
when v.refer = '02' then 'อาการดีขึ้น จึงส่งไประดับล่าง'
when v.refer = '03' then 'เป็นความประสงค์ของผู้รับบริการ ฯ'
when v.refer = '04' then 'ส่งไปเพื่อการวินิจฉัยที่ถูกต้อง'
when v.refer = '05' then 'ส่งไปเพื่อทันตกรรม'
when v.refer = '06' then 'เพื่อการรักษาต่อเนื่อง'
when v.refer = '99' then 'อื่นๆ'
else '..ไม่ระบุ..' end) as caseRefer,
ifnull(cast(round(vb.sugarnumdigit,2) as char),'..ไม่ระบุ..') as sugarnumdigit1,
(case when vb.foodsuspend = '0' then 'งด'
when vb.foodsuspend = '1' then 'ไม่งด'
else '...ไม่ระบุ...' end) as foodsuspend
,(case when vb.typetesting = '1' then '1:DTX(หลอดเลือดฝอย)'
when vb.typetesting = '2' then '2:FBS(หลอดเลือดดำ)'
else '...ไม่ระบุ...' end) as typetesting,
(case when vb.interviewres = '1' then 'ปกติ'
when vb.interviewres = '2' then 'เสี่ยงน้อย'
when vb.interviewres = '3' then 'เสี่ยงปานกลาง'
when vb.interviewres = '4' then 'เสี่ยงสูง'
else '...ไม่ระบุ...' end) as interview,
ifnull(v7.request,'..ไม่ระบุ..') as request,u.officerposition,
ifnull(v.username,concat(ct1.titlenamelong,' ',u.fullname)) as officername,
concat(ct1.titlename,' ',u.fname,' ',u.lname) as officername1,
p.idcard,p.rightcode,ifnull(p.rightno,'..ไม่ระบุ..') as rightno,r.rightname,p.hosmain,h1.hosname as hospname1,
concat(ifnull(cast(day(p.dateexpire) as char),'..'),' ',
(CASE WHEN MONTH(p.dateexpire)=1 THEN 'มกราคม'
   WHEN MONTH(p.dateexpire)=2 THEN 'กุมภาพันธ์' WHEN MONTH(p.dateexpire)=3 THEN 'มีนาคม'
   WHEN MONTH(p.dateexpire)=4 THEN 'เมษายน' WHEN MONTH(p.dateexpire)=5 THEN 'พฤษภาคม'
   WHEN MONTH(p.dateexpire)=6 THEN 'มิถุนายน' WHEN MONTH(p.dateexpire)=7 THEN 'กรกฎาคม'
   WHEN MONTH(p.dateexpire)=8 THEN 'สิงหาคม' WHEN MONTH(p.dateexpire)=9 THEN 'กันยายน'
   WHEN MONTH(p.dateexpire)=10 THEN 'ตุลาคม' WHEN MONTH(p.dateexpire)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(p.dateexpire)=12 THEN 'ธันวาคม' else 'ไม่ระบุ' end),' ' ,
ifnull(cast(year(p.dateexpire)+543 as char),'..')) as dateexpire
from visit v
left join office of on (v.pcucode = of.offid)
left join person p on (v.pcucode = p.pcucodeperson) and (v.pid = p.pid)
left join ctitle t on (p.prename = t.titlecode)
left join cright r on (p.rightcode = r.rightcode)
left join chospital h1 on (h1.hoscode = p.hosmain)
left join personaddresscontact pa on (p.pid = pa.pid and p.pcucodeperson = pa.pcucodeperson)
left join csubdistrict cs on (p.subdistcodemoi = cs.subdistcode and p.distcodemoi = cs.distcode and p.provcodemoi = cs.provcode)
left join cdistrict cd on (p.distcodemoi = cd.distcode and p.provcodemoi = cd.provcode)
left join cprovince cp on (p.provcodemoi = cp.provcode)
left join csubdistrict cs1 on (pa.subdistcode = cs1.subdistcode and pa.distcode = cs1.distcode and pa.provcode = cs1.provcode)
left join cdistrict cd1 on (pa.distcode = cd1.distcode and pa.provcode = cd1.provcode)
left join cprovince cp1 on (pa.provcode = cp1.provcode)
left join chospital ch on (v.refertohos = ch.hoscode)
left join chospital ch1 on (v.pcucode = ch1.hoscode)
left join visit7referhisreferres v7 on (v.visitno = v7.visitno) and (v.pcucode = v7.pcucode)
left join visitlabsugarblood vb on (v.visitno = vb.visitno and v.pcucode = vb.pcucode)
-- left join visitdiag vd on (v.visitno = vd.visitno and v.pcucode =vd.pcucode)
-- left join cdisease cdi on (vd.diagcode = cdi.diseasecode)
left join user u on (v.username = u.username)
left join ctitle ct1 on (u.prename = ct1.titlecode)
where v.visitno = $P{visitno}
and v.refer <> '00']]>
	</queryString>
	<field name="visitno" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="NoYY" class="java.lang.Long"/>
	<field name="dd" class="java.lang.Long"/>
	<field name="numberrefer" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
