	<field name="presentdiag" class="java.lang.String"/>
	<field name="pastdiag" class="java.lang.String"/>
	<field name="bt" class="java.lang.String"/>
	<field name="bp" class="java.lang.String"/>
	<field name="p" class="java.lang.String"/>
	<field name="r" class="java.lang.String"/>
	<field name="weight" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="HEENT" class="java.lang.String"/>
	<field name="HLART" class="java.lang.String"/>
	<field name="LUNG" class="java.lang.String"/>
	<field name="Ab" class="java.lang.String"/>
	<field name="Ext" class="java.lang.String"/>
	<field name="Neuro" class="java.lang.String"/>
	<field name="diagnote" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="caseRefer" class="java.lang.String"/>
	<field name="sugarnumdigit1" class="java.lang.String"/>
	<field name="foodsuspend" class="java.lang.String">
