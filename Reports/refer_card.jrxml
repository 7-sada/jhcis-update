	<title>
		<band height="108">
			<staticText>
				<reportElement x="0" y="0" width="525" height="28" uuid="a5a4d2cb-9655-41df-ab21-1351d94b5c4d"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Tahoma" size="11" isBold="true" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[ใบส่งตัวผู้ป่วยไปรับการตรวจหรือรักษาต่อ]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="345" y="28" width="180" height="20" uuid="8558b06a-9ebd-4086-91c4-f99bb91820f5"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Tahoma" size="10" isBold="false" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["เลขที่........................................ "]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="256" y="48" width="269" height="20" uuid="7efe2a71-1161-411d-af01-8e1ecbc271a0"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="9" isBold="false" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["วันที่ "+$F{dd}+" เดือน "+$F{mm}+" พศ. "+$F{yy}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="68" width="430" height="20" uuid="8a2d8780-f0ca-44b3-9490-96a44a0cd5d3"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="9" isBold="false" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["จาก "+ $F{hosname}+"     เบอร์โทร : "+$F{tel}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="88" width="345" height="20" uuid="747981ab-944c-49e4-819e-4b7ee5362a83"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="9" isBold="false" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["ถึง   "+ $F{hosrefer}]]></textFieldExpression>
			</textField>
