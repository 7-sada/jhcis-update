	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="hoscode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT  chospital.`hosname` AS chospital_hosname, chospital.`mu` AS chospital_mu
     ,tb.`subdistname` AS csubdistrict_subdistname
     ,ap.`distname` AS cdistrict_distname
     ,cw.`provname` AS cprovince_provname
FROM `chospital` chospital
INNER JOIN `office` office ON chospital.`hoscode` = office.`offid`
left JOIN `cprovince` cw ON chospital.`provcode` = cw.`provcode`
LEFT JOIN `cdistrict` ap ON chospital.`provcode` = ap.`provcode`
        AND chospital.`distcode` = ap.`distcode`
LEFT JOIN `csubdistrict` tb ON chospital.`provcode` = tb.`provcode`
        AND chospital.`distcode` = tb.`distcode`
        AND chospital.`subdistcode` = tb.`subdistcode`
 WHERE offid=$P!{hoscode}]]>
	</queryString>
	<field name="chospital_hosname" class="java.lang.String"/>
	<field name="chospital_mu" class="java.lang.String"/>
	<field name="csubdistrict_subdistname" class="java.lang.String"/>
