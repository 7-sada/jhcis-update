<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rsocialsecurity_subreport1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="zdiag" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitdiag.diagcode  NOT REGEXP '^[Zz]' "]]></defaultValueExpression>
	</parameter>
	<parameter name="person" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'08731158535'"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
cdisease.diseasenamethai,visitdiag.diagcode,
CONCAT("'",visitdiag.pcucode,visitdiag.visitno,visitdiag.diagcode,"'") AS pdiag,visitdiag.causeill
FROM
visitdiag
Left Outer Join cdisease ON visitdiag.diagcode = cdisease.diseasecode
Left Join `visit` ON `visit`.`visitno` = `visitdiag`.`visitno` AND `visitdiag`.`pcucode` = `visit`.`pcucode`
WHERE
CONCAT(visitdiag.pcucode,visitdiag.visitno) = $P!{person} 
$P!{zdiag}
ORDER BY diagcode]]></queryString>

	<field name="diseasenamethai" class="java.lang.String"/>
	<field name="diagcode" class="java.lang.String"/>
	<field name="pdiag" class="java.lang.String"/>
	<field name="causeill" class="java.lang.String"/>

