	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" WHERE offid='08449'"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     chospital.`hosname` AS chospital_hosname,
     chospital.`mu` AS chospital_mu,
     csubdistrict.`subdistname` AS csubdistrict_subdistname,
     cdistrict.`distname` AS cdistrict_distname,
     cprovince.`provname` AS cprovince_provname
FROM
     `chospital` chospital INNER JOIN `office` office ON chospital.`hoscode` = office.`offid`
     INNER JOIN `csubdistrict` csubdistrict ON chospital.`provcode` = csubdistrict.`provcode`
     AND chospital.`subdistcode` = csubdistrict.`subdistcode`
     AND chospital.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cdistrict` cdistrict ON csubdistrict.`provcode` = cdistrict.`provcode`
     AND cdistrict.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cprovince` cprovince ON cdistrict.`provcode` = cprovince.`provcode`
$P!{pcucode}]]></queryString>

