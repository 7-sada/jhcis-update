<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptlistbehavior"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(15)]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-28"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT CONVERT(CONCAT(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),' ',fname,'  ',lname) using UTF8) as name
,if(sex=1,'ชาย','หญิง' ) as sex ,idcard
,birth,DATE_FORMAT(birth,'%Y-%m-%d') fdbirth
,chospital.hosname,house.pcucode
,CONVERT(CONCAT(  DATE_FORMAT($P{edate},"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT($P{edate},"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " /",  
   CASE SIGN(DATE_FORMAT($P{edate},"%m")-DATE_FORMAT(birth,"%m"))  
      WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{edate},"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
      WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT($P{edate},"%m") -  (DATE_FORMAT($P{edate},"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
      WHEN 1 THEN(DATE_FORMAT($P{edate},"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT($P{edate},"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " / ",  
   CASE SIGN(DATE_FORMAT($P{edate},"%d") - DATE_FORMAT(birth,"%d"))
      WHEN 0 THEN(DATE_FORMAT($P{edate},"%d")- DATE_FORMAT(birth,"%d") )
      WHEN -1 THEN (DATE_FORMAT(LAST_DAY($P{edate}),"%d") + DATE_FORMAT($P{edate}, "%d")  -  DATE_FORMAT(birth, "%d"))
      WHEN 1 THEN (DATE_FORMAT($P{edate},"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT($P{edate},"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8)   AS age_ymd 
,if(house.hno != '' ,CONVERT(concat(house.hno,' ม.',villno) USING utf8), CONVERT(concat('- ม.',villno) USING utf8) ) as address,village.villcode,villname
,CONVERT(case when exercise =0 then 'ไม่ทำ'    when exercise =1 then '<3 วัน/สัปดาห์'    when exercise =2 then '3-5 วัน/สัปดาห์'  when exercise = 3  then '>5 วัน/สัปดาห์'   else '-' end USING utf8)   as exercise
,CONVERT(case when ciga = 0 then 'ไม่สูบ'  when ciga=1 then 'สูบนาน ๆ ครั้ง' 	when ciga = 2 then 'สูบประจำ'  	else '-'   end  USING utf8) as ciga
,CONVERT(case when wisky = 0  then 'ไม่ดิ่ม'  when wisky =1  then 'ดิ่มนาน ๆ ครั้ง'  when wisky = 2  then '1-2 ครั้ง / เดือน' 	when wisky = 3  then '1-2 ครั้ง/ สัปดาห์'  
	      when wisky = 4  then '3-4  ครั้ง/สัปดาห์ '  when wisky = 5  then 'ดิ่มทุกวัน'   else '-'  end USING utf8) as wisky 
,CONVERT(case when habitfoming = 0 then 'ไม่ดิ่ม'  when habitfoming = 1 then 'ดื่มนาน ๆ ครั้ง'  when habitfoming = 2 then 'ดื่มทุกวัน' else '-' end USING utf8 ) as habitfoming
,CONVERT(case when salt = 0  then 'ปกติ'     when salt = 1  then 'เค็มจัด'  else '-' end USING utf8) as salt  
,CONVERT(case when sugar = 0 then 'ปกติ' 	when sugar=1 then 'หวานจัด'  	else '-' end USING utf8 ) as sugar
,CONVERT(case when drugbyyourseft =0 then 'ไม่เคย'    when drugbyyourseft = 1 then 'เคย' else '-' end USING utf8 ) as drugbyyourseft
,CONVERT(case when bigaccidentever = 0 then 'ไม่เคย'  when bigaccidentever = 1 then 'เคย' else '-' end USING utf8) as bigaccidentever
FROM person left join personbehavior on person.pid = personbehavior.pid and person.pcucodeperson = personbehavior.pcucodeperson
        left join ctitle on person.prename = ctitle.titlecode   
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
        left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
	left join chospital on person.pcucodeperson = chospital.hoscode
            
WHERE  right(village.villcode,2) != '00'
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
       $P!{pcucode}
       and (DATEDIFF(DATE_FORMAT($P{edate},'%Y-%m-%d'), birth)/365) >= $P{age}
       and concat(person.pid,person.pcucodeperson) NOT IN (SELECT concat(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.pcucodeperson=person.pcucodeperson and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{edate})) 
ORDER BY village.villcode,hno]]></queryString>

