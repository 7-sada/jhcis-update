	<variable name="sum_odx" class="java.lang.Long" resetType="Group" resetGroup="pcu" calculation="Sum">
		<variableExpression><![CDATA[$F{odx}]]></variableExpression>
	</variable>
	<variable name="opt" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{odx}]]></variableExpression>
	</variable>
	<variable name="accumulative_sum" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[new java.lang.Long(  ($V{opt}.longValue()) +($F{fdx}.longValue()) )]]></variableExpression>
	</variable>
	<variable name="normal" class="java.lang.Long" resetType="Group" resetGroup="pcu">
		<variableExpression><![CDATA[new java.lang.Long(  ($F{surv}.longValue()) -($F{risk}.longValue()+$F{fdx}.longValue()+$F{odx}.longValue()) )]]></variableExpression>
	</variable>
