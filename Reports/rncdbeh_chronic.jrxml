<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rncdbeh_chronic" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="header" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="fYear" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="bDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2010-10-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="eDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2011-09-30'"]]></defaultValueExpression>
	</parameter>
	<parameter name="caseWhen" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[case when(  (`_tmp_prechronic`.`rcode` IN ('01','02','09') AND `_tmp_prechronic`.`fchronic` IN ('07','03','13')) or (`_tmp_prechronic`.`ciga`<> '0') or ((((`_tmp_prechronic`.`systolic`) >= 170 AND (`_tmp_prechronic`.`diastolic`) >= 100) AND `_tmp_prechronic`.`visitdate` BETWEEN '2009-10-01' AND '2010-09-30') OR `_tmp_prechronic`.`vchro` ='01') or ((`_tmp_prechronic`.`sugar` >= 120  AND `_tmp_prechronic`.`visitdate` BETWEEN '2009-10-01' AND '2010-09-30') OR `_tmp_prechronic`.`vchro` ='10') or ((`_tmp_prechronic`.`labresulttext` >= '309' OR `_tmp_prechronic`.`labresultdigit` >= 309) AND `_tmp_prechronic`.`visitdate` BETWEEN '2009-10-01' AND '2010-09-30') or (((`_tmp_prechronic`.`sex` ='1' AND `_tmp_prechronic`.`waist` > 90) OR(`_tmp_prechronic`.`sex` ='2' AND `_tmp_prechronic`.`waist` > 80) OR `_tmp_prechronic`.`bmi` > 25) AND `_tmp_prechronic`.`visitdate` BETWEEN '2009-10-01' AND '2010-09-30') or (`_tmp_prechronic`.`vchro` ='07') or (`_tmp_prechronic`.`vchro` ='03' OR `_tmp_prechronic`.`vchro` ='13')) then 1 else null end]]></parameterDescription>
		<defaultValueExpression><![CDATA["''"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
`_tmp_prechronic`.`pcucode`,getOffice(`_tmp_prechronic`.`pcucode`) AS offname,
`_tmp_prechronic`.`visitdate` AS  vdate,
0 AS pop,
count(distinct `_tmp_prechronic`.`vpid`,`_tmp_prechronic`.`pcucode`) AS surv,
count(distinct `_tmp_prechronic`.`vpid`,`_tmp_prechronic`.`pcucode`, $P!{caseWhen}) AS risk,
count(distinct `_tmp_prechronic`.`vpid`,`_tmp_prechronic`.`pcucode`,case when((`_tmp_prechronic`.personchronic='03' OR `_tmp_prechronic`.personchronic='13') AND  _tmp_prechronic.chronicfirstdiag BETWEEN $P!{bDate} AND $P!{eDate}) THEN 1 ELSE null END) AS fdx,
count(distinct `_tmp_prechronic`.`vpid`,`_tmp_prechronic`.`pcucode`,case when((`_tmp_prechronic`.personchronic='03' OR `_tmp_prechronic`.personchronic='13') AND  _tmp_prechronic.chronicfirstdiag < $P!{bDate} ) THEN 1 ELSE null END) AS odx,
count(distinct `_tmp_prechronic`.`vpid`,`_tmp_prechronic`.`pcucode`,case when(`_tmp_prechronic`.`visitdate` BETWEEN $P!{bDate} AND $P!{eDate} AND (_tmp_prechronic.counsel ='04' OR _tmp_prechronic.counsel='99')) THEN 1 ELSE null END)  AS counsel
FROM
`_tmp_prechronic`
WHERE `_tmp_prechronic`.`visitdate` BETWEEN $P!{bDate} AND $P!{eDate}
GROUP BY pcucode,left(`_tmp_prechronic`.`visitdate`,7)
UNION
SELECT person.pcucodeperson AS pcucode,'' AS offname,DATE_FORMAT($P!{eDate},'%Y-%m-%d') AS vdate
,COUNT(DISTINCT person.pcucodeperson,person.pid) AS pop
,0 AS surv
,0 AS risk
,0 AS fdx
,0 AS odx
,0 AS counsel
FROM
person
WHERE DATE_FORMAT(FROM_DAYS(TO_DAYS($P!{eDate})-TO_DAYS(`person`.`birth`)),'%Y')+0 >= 35
GROUP BY
person.pcucodeperson
ORDER BY pcucode,vdate]]>
	</queryString>
