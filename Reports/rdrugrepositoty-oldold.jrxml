<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rdrugrepositoty" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="3870b47a-6d31-4fdc-81e2-5d12e9824634">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="sDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2020-10-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="eDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2020-10-31'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
CASE
 WHEN cdrug.drugtype =  '01'  THEN 'ยาฯ'
 WHEN cdrug.drugtype =  '02'   THEN 'หัตถการ'
 WHEN cdrug.drugtype =  '03'   THEN 'วัสดุการแพทย์'
 WHEN cdrug.drugtype =  '04'  THEN 'เวชภัณฑ์คุมกำเนิด'
 WHEN cdrug.drugtype =  '05'   THEN 'วัคซีน'
 WHEN cdrug.drugtype =  '06'   THEN 'ค่าบริการฯ'
 WHEN cdrug.drugtype =  '07'   THEN 'ค่าตรวจทางห้องปฏิบัติการฯ'
 WHEN cdrug.drugtype =  '08'  THEN 'ทันตกรรม'
 WHEN cdrug.drugtype =  '10'  THEN 'ยาสมุนไพร'
 WHEN cdrug.drugtype =  '11'  THEN 'เวชภัณฑ์ที่ไม่ใช่ยา'
 ELSE 'ไม่ระบุประเภทฯ'
END AS drugtype,
cdrug.drugcode,
cdrug.drugname,
(SELECT if(Sum(tm.dout) is null,if(Sum(tm.dtaken) is null,0,Sum(tm.dtaken)),Sum(tm.dtaken)-Sum(tm.dout)) FROM _tmp_drugstock tm WHERE tm.drugcode=d.drugcode AND tm.datestock < $P!{sDate} GROUP BY tm.drugcode)  AS drem,
(SELECT if(Sum(tm.dout) is null,Sum(tm.dtaken*tm.lotprice),Sum(tm.dtaken*tm.lotprice)-Sum(tm.dout*tm.lotprice)) FROM _tmp_drugstock tm WHERE tm.drugcode=d.drugcode AND tm.datestock < $P!{sDate} GROUP BY tm.drugcode)  AS drp,
(SELECT Sum(t.dtaken) FROM _tmp_drugstock t WHERE t.drugcode=d.drugcode AND t.datestock BETWEEN $P!{sDate} AND $P!{eDate} GROUP BY t.drugcode) AS dtaken,
(SELECT Sum(t.dtaken*t.lotprice) FROM _tmp_drugstock t WHERE t.drugcode=d.drugcode AND t.datestock BETWEEN $P!{sDate} AND $P!{eDate} GROUP BY t.drugcode) AS dtp,
(SELECT Sum(o.dout) FROM _tmp_drugstock o WHERE o.drugcode=d.drugcode AND o.datestock BETWEEN $P!{sDate} AND $P!{eDate} GROUP BY o.drugcode) AS dout,
(SELECT Sum(o.dout*lotprice) FROM _tmp_drugstock o WHERE o.drugcode=d.drugcode AND o.datestock BETWEEN $P!{sDate} AND $P!{eDate} GROUP BY o.drugcode) AS dop,
d.lotprice,
FORMAT(d.packamount,0) AS packamount,
cdrugunitsell.unitsellname
FROM
_tmp_drugstock d
Inner Join cdrug ON d.drugcode = cdrug.drugcode
Left Outer Join cdrugunitsell ON d.lotunit = cdrugunitsell.unitsellcode
WHERE d.datestock=(SELECT max(tmp.datestock) FROM _tmp_drugstock tmp WHERE tmp.drugcode=d.drugcode)
GROUP BY
cdrug.drugcode
ORDER BY drugtype,drugname]]>
	</queryString>
