<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rstudent_list" pageWidth="645" pageHeight="842" columnWidth="585" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="9fe3cd5d-41c8-44e0-b0a1-3003d24dcdc1">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND villageschool.pcucode='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="persondeath" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath) "]]></defaultValueExpression>
	</parameter>
	<parameter name="date1" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="date2" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="term" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="header_1" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT cschoolclass.classcode,
if(villageschool.schoolname is null,'ไม่ระบุฯ',villageschool.schoolname) as schoolname,
if(cschoolclass.classname is null,'ไม่ระบุฯ',cschoolclass.classname) as classname,
person.sex,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as fname,
person.lname,
person.hnomoi,
person.mumoi,
DATE_FORMAT(person.birth,'%Y-%m-%d') as birth
,concat((year(vdate)-year(`person`.`birth`)-(right(vdate,5)<right(`person`.`birth`,5))),'-',
(if (day(vdate) <day(`person`.`birth`),(if (right(vdate,5)<right(`person`.`birth`,5),(12+ month(vdate))-month(`person`.`birth`),month(vdate)-month(`person`.`birth`)))-1 ,(if (right(vdate,5)<right(`person`.`birth`,5),(12+ month(vdate))-month(`person`.`birth`),month(vdate)-month(`person`.`birth`))))) ,'-',
(if (day(vdate) < day(`person`.`birth`),(30+ day(vdate))-day(`person`.`birth`),day(vdate)-day(`person`.`birth`)))) as age
,if(person.birth is not null,getagemonth(person.birth,vdate),null) as agemonth
,n.weight,n.height
,DATE_FORMAT(vdate,'%Y-%m-%d') as dateservice
FROM visit v
JOIN (SELECT pcucode,visitno,pcucodeperson,pid,MAX(visitdate) vdate,weight
            ,height
      FROM (
            SELECT v.pcucode,v.visitno,v.pcucodeperson,v.pid,v.visitdate
                 , n.weight , n.tall as height
            FROM visitnutrition n
            JOIN visit v ON n.pcucode=v.pcucode AND n.visitno=v.visitno
            WHERE v.visitdate between $P!{date1} and $P!{date2}
            ORDER BY v.pid,v.visitdate DESC
           ) AS n
      GROUP BY pid
     ) AS n on v.pcucode=n.pcucode and v.visitno=n.visitno
JOIN personstudent ON v.pcucodeperson=personstudent.pcucodeperson AND v.pid=personstudent.pid
Left Outer Join villageschool ON personstudent.pcucode = villageschool.pcucode AND personstudent.villcode = villageschool.villcode AND personstudent.schoolno = villageschool.schoolno
Left Outer Join cschoolclass ON personstudent.classeducate = cschoolclass.classcode
Left Outer Join person ON personstudent.pcucodeperson = person.pcucodeperson AND personstudent.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
WHERE n.weight is not null
$P!{pcucode}
$P!{persondeath}
ORDER BY schoolname,classcode,sex,mumoi,hnomoi]]>
	</queryString>
