<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptsumrightrayong_drug" language="groovy" pageWidth="160" pageHeight="842" columnWidth="160" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="ReportDate" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select (select count(distinct visit.visitno,visit.pcucode)  from visit left join visitdrug on visit.visitno = visitdrug.visitno and visit.pcucode = visitdrug.pcucode
	left join cdrug on visitdrug.drugcode =cdrug.drugcode
where 1=1 $P!{ReportDate} $P!{pcucode}
                 and drugtype in ('01','04'))  as cdrugtime0104
,sum(case when cdrug.drugtype in ('01','04') then (visitdrug.realprice * visitdrug.unit )  else 0 end) as cdrugtype0104
,(select count(distinct visit.visitno,visit.pcucode)  from visit left join visitdrug on visit.visitno = visitdrug.visitno and visit.pcucode = visitdrug.pcucode
	left join cdrug on visitdrug.drugcode =cdrug.drugcode
where  1=1 $P!{ReportDate} $P!{pcucode}
                 and drugtype ='06') as ctimedruttype06
,sum(case when cdrug.drugtype = '06' then (visitdrug.realprice* visitdrug.unit ) else 0 end) as cdrugtype06

from visit
 	left join visitdrug on visit.pcucode = visitdrug.pcucode and visit.visitno = visitdrug.visitno
	left join cdrug on visitdrug.drugcode = cdrug.drugcode
	left join chospital on visit.pcucode = chospital.hoscode
 	left join chospital hmain on visit.hosmain = hmain.hoscode
where 1=1  $P!{ReportDate} $P!{pcucode}
group by visit.pcucode]]>
	</queryString>
	<field name="cdrugtime0104" class="java.math.BigDecimal"/>
	<field name="cdrugtype0104" class="java.math.BigDecimal"/>
	<field name="ctimedruttype06" class="java.math.BigDecimal"/>
	<field name="cdrugtype06" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="40" splitType="Stretch">
			<textField pattern="#,##0" isBlankWhenNull="true">
				<reportElement x="0" y="0" width="80" height="20"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.0"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Tahoma" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cdrugtime0104}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00" isBlankWhenNull="true">
				<reportElement x="80" y="0" width="80" height="20"/>
				<box>
