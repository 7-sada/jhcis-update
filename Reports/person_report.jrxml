	<subDataset name="New Dataset 1" uuid="1ea60015-1a51-4efb-8f51-a03b23d1009e">
		<parameter name="pid" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[select fname,lname,pid,idcard
from person
where pid = $P{pid} or $P{pid} = ''
limit 100;]]>
		</queryString>
