<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpt_activeDent_person" pageWidth="850" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="794" leftMargin="28" rightMargin="28" topMargin="45" bottomMargin="45">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and visit.pcucode = '01837' "]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-10-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2013-09-30"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT visit.pcucode,DATE_FORMAT(visitdate,'%Y-%m-%d') as mvisit
,DATE_FORMAT(visitdate,'%Y-%m') as visitdate,visit.pid

#,sum(case when ( (select count(distinct visitdrugdental.visitno,visitdrugdental.pcucode,dentcode ,DATE_FORMAT(visitdate,'%Y-%m')) from visitdrugdental where visit.visitno = visitdrugdental.visitno and visit.pcucode = visitdrugdental.pcucode) =1)  then 1 else 0 end) as cpnew
,count(distinct visit.pcucodeperson,visit.pid,DATE_FORMAT(visitdate,'%Y-%m')) as cpnew

#,sum(case when ( (select count(distinct visitdrugdental.visitno,visitdrugdental.pcucode,dentcode ,DATE_FORMAT(visitdate,'%Y-%m')) from visitdrugdental where visit.visitno = visitdrugdental.visitno and visit.pcucode = visitdrugdental.pcucode) >1)  then 1 else 0 end) as cpold
,count(concat(visit.pcucodeperson,visit.pid,DATE_FORMAT(visitdate,'%Y-%m'))) as cpold


,year($P{sdate})+543 as cyear
,year($P{sdate})+542 as bgyear
,hosname,curdate() as cdate
FROM visitdrugdental inner join visit on visitdrugdental.pcucode = visit.pcucode and visitdrugdental.visitno = visit.visitno
	left join person ON visit.pid = person.pid and visit.pcucodeperson = person.pcucodeperson
	left join cright ON visit.rightcode = cright.rightcode
	left join chospital on visit.pcucode = chospital.hoscode
WHERE visitdate between  $P{sdate} and $P{edate}
	$P!{pcucode}
GROUP BY visit.pcucode,DATE_FORMAT(visitdate,'%Y-%m')]]>
	</queryString>
	<field name="pcucode" class="java.lang.String"/>
	<field name="mvisit" class="java.lang.String"/>
	<field name="visitdate" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="cpnew" class="java.lang.Long"/>
	<field name="cpold" class="java.lang.Long"/>
	<field name="cyear" class="java.lang.Long"/>
	<field name="bgyear" class="java.lang.Long"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
	<variable name="SUM_cpnew_1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{cpnew}]]></variableExpression>
	</variable>
	<variable name="SUM_cpold_1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{cpold}]]></variableExpression>
	</variable>
