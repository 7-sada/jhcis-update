	<queryString>
		<![CDATA[SELECT
vchild_60mon_weight_0.pid,
vchild_60mon_weight_0.lastvn,
vchild_60mon_weight_0.weight,
vchild_60mon_weight_0.tall,
vchild_60mon_weight_0.villcode,
vchild60mon_g_mu.villno,
vchild60mon_g_mu.villname,
vchild_60mon_weight_0.sex,
vchild_60mon_weight_0.agemonth,
IF((vchild_60mon_weight_0.growdevelop is null OR vchild_60mon_weight_0.growdevelop = '1' OR vchild_60mon_weight_0.growdevelop = '0' OR vchild_60mon_weight_0.growdevelop = '' ),1,0) AS growdevelop,
vchild60mon_g_mu.countpid
FROM
vchild_60mon_weight_0
LEFT JOIN vchild60mon_g_mu ON vchild_60mon_weight_0.villcode = vchild60mon_g_mu.villcode
ORDER BY
vchild_60mon_weight_0.villcode ASC]]>
	</queryString>
