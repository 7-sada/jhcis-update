<jasperReport
		 name="refer_patient_subreport_1"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="594"
		 pageHeight="842"
		 columnWidth="594"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
