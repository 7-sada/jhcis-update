		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucodeperson" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["08727"]]></defaultValueExpression>
	</parameter>
	<parameter name="pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["34"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     cdisease.`diseasenamethai` AS diseasename,
     chospital.`hosname` 
FROM personchronic LEFT OUTER  JOIN chospital ON chospital.`hoscode` = personchronic.`cup`
     LEFT OUTER  JOIN cdisease ON personchronic.chroniccode = cdisease.diseasecode
WHERE personchronic.pcucodeperson = $P!{pcucodeperson} AND personchronic.pid = $P!{pid}]]></queryString>

	<field name="diseasename" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>

