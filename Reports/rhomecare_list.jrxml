	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="VisitDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND `visit`.`visitdate` BETWEEN  '2007-01-01' AND '2007-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ AND `visithomehealthindividual`.`pcucode` =  '02332' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname) as name,
`visithomehealthindividual`.`patientsign`,
`visithomehealthindividual`.`homehealthdetail`,
`visithomehealthindividual`.`homehealthresult`,
`visithomehealthindividual`.`homehealthplan`,
DATE_FORMAT(`visithomehealthindividual`.`dateappoint`,'%Y-%m-%d') as dateappoint,
DATE_FORMAT(`visit`.`visitdate`,'%Y-%m-%d') as visitdate,
if(CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM  `persondeath`),'ยังมีชีวิต','เสียชีวิต') AS pstatus,
`village`.`villno`,
CONCAT(village.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname
FROM
`visithomehealthindividual`
Left Join `visit` ON `visit`.`pcucode` = `visithomehealthindividual`.`pcucode` AND `visit`.`visitno` = `visithomehealthindividual`.`visitno`
Left Join `person` ON `person`.`pcucodeperson` = `visit`.`pcucodeperson` AND `person`.`pid` = `visit`.`pid`
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Left Join `house` ON `house`.`pcucode` = `person`.`pcucodeperson` AND `house`.`hcode` = `person`.`hcode`
Left Join `village` ON `village`.`pcucode` = `house`.`pcucode` AND `village`.`villcode` = `house`.`villcode`
WHERE
right(`village`.`villcode`,2) <>  '00' $P!{VisitDate} $P!{pcucode}
ORDER BY `village`.`villcode`]]></queryString>

	<field name="name" class="java.lang.String"/>
	<field name="patientsign" class="java.lang.String"/>
	<field name="homehealthdetail" class="java.lang.String"/>
	<field name="homehealthresult" class="java.lang.String"/>
	<field name="homehealthplan" class="java.lang.String"/>
	<field name="dateappoint" class="java.util.Date"/>
	<field name="visitdate" class="java.util.Date"/>
	<field name="pstatus" class="java.lang.String"/>
	<field name="villno" class="java.lang.Integer"/>
	<field name="villname" class="java.lang.String"/>


