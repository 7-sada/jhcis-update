						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="10" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[3. จำนวนวัคซีนเปิดใช้ = จำนวนขวด x ขนาดบรรจุต่อขวด]]></text>
				</staticText>
			</band>
		</summary>
</jasperReport>
