<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rrb1k011total_subreport0" pageWidth="253" pageHeight="802" columnWidth="253" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="387559b5-5551-489c-89a1-d960eeccec0b">
	<property name="ireport.scriptlethandling" value="0"/>
