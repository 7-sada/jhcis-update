	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<parameter name="visitdate" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select drugname,unit
from visitdrug
      inner join cdrug on visitdrug.drugcode = cdrug.drugcode
      inner join visit on visitdrug.visitno = visit.visitno and visitdrug.pcucode = visit.pcucode
where visitdrug.visitno = $P{visitno} and visitdrug.pcucode =$P{pcucode} and visit.visitdate = $P{visitdate}]]>
	</queryString>
	<field name="drugname" class="java.lang.String"/>
	<field name="unit" class="java.lang.Integer"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
