<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rfp_listhosmain"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="822"
		 columnSpacing="0"
		 leftMargin="10"
		 rightMargin="10"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[".\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="eFpDate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="bFpDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2008-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFp" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND `person`.`rightcode` =  '02' AND datefp BETWEEN ('2008-01-01') AND ('2008-12-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visitfp.`pcucode` ='02332' "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT DISTINCT
DATE_FORMAT(`visitfp`.`datefp`,'%Y-%m-%d') as datefp,
CASE
when `visitfp`.`typefp`=0 then 'เก่า'
when `visitfp`.`typefp`=1 then 'ใหม่'
end as typefp,
concat(`person`.`prename`,`person`.`fname`,' ',`person`.`lname`) as visitname,
concat((year($P!{bFpDate})-year(`person`.`birth`)-(right($P!{bFpDate},5)<right(`person`.`birth`,5))),'-',(if (day($P!{bFpDate}) <day(`person`.`birth`),(if (right($P!{bFpDate},5)<right(`person`.`birth`,5),(12+ month($P!{bFpDate}))-month(`person`.`birth`),month($P!{bFpDate})-month(`person`.`birth`)))-1 ,(if (right($P!{bFpDate},5)<right(`person`.`birth`,5),(12+ month($P!{bFpDate}))-month(`person`.`birth`),month($P!{bFpDate})-month(`person`.`birth`)))))) as age,
concat(`person`.`hnomoi`,' ม.',`person`.`mumoi`,' ',`csubdistrict`.`subdistname`,' ',`cdistrict`.`distname`,' ',`cprovince`.`provname`) as addr,
CASE
when `cdrug`.`drugtypesub`=1 then 'ยาเม็ด'
when `cdrug`.`drugtypesub`=2 then 'ยาฉีด'
when `cdrug`.`drugtypesub`=3 then 'ยาฝัง'
when `cdrug`.`drugtypesub`=4 then 'ห่วงอนามัย'
when `cdrug`.`drugtypesub`=5 then 'ถุงยางฯ'
else 'อื่น ๆ' end AS `type`,
`visitfp`.`unit`,
`person`.`rightcode`,
`person`.`rightno`,
`person`.`idcard`,
`visit`.`weight`,
`visit`.`pressure`,
`chospital`.`hosname`,
CONCAT(person.pcucodeperson,visitfp.visitno) person
FROM
`cprovince`
Inner Join `cdistrict` ON `cprovince`.`provcode` = `cdistrict`.`provcode`
Inner Join `csubdistrict` ON `cdistrict`.`provcode` = `csubdistrict`.`provcode` AND `cdistrict`.`distcode` = `csubdistrict`.`distcode`
Inner Join `person` ON `csubdistrict`.`provcode` = `person`.`provcodemoi` AND `csubdistrict`.`distcode` = `person`.`distcodemoi` AND `csubdistrict`.`subdistcode` = `person`.`subdistcodemoi`
Inner Join `visit` ON `person`.`pid` = `visit`.`pid` AND `person`.`pcucodeperson` = `visit`.`pcucodeperson`
Inner Join `visitfp` ON `visit`.`pid` = `visitfp`.`pid` AND `visit`.`visitdate` = `visitfp`.`datefp` AND `visit`.`pcucodeperson` = `visitfp`.`pcucodeperson` AND `visit`.`pcucode` = `visitfp`.`pcucode` and `visit`.`visitno` = `visitfp`.`visitno`
Left Outer Join `cdrug` ON `visitfp`.`fpcode` = `cdrug`.`drugcode`
Left Outer Join `chospital` ON `person`.`hosmain` = `chospital`.`hoscode`
 WHERE 1=1 $P!{pcucode}  $P!{DateFp}
ORDER BY `chospital`.`hoscode`,`visitfp`.`datefp`]]></queryString>

	<field name="datefp" class="java.util.Date"/>
	<field name="typefp" class="java.lang.String"/>
	<field name="visitname" class="java.lang.String"/>
	<field name="age" class="java.lang.String"/>
	<field name="addr" class="java.lang.String"/>
	<field name="type" class="java.lang.String"/>
	<field name="unit" class="java.lang.Integer"/>
	<field name="rightcode" class="java.lang.String"/>
	<field name="rightno" class="java.lang.String"/>
