<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="population_v" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f783c0b8-b4fe-4601-b264-fb50166daf48">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="PYear" class="java.lang.String">
		<defaultValueExpression><![CDATA["2012"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String">
		<defaultValueExpression><![CDATA[" AND person.pcucodeperson='01024' "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT concat(person.pcucodeperson,'-',person.pid) person,
getAgeYearNum(person.birth,'$P!{PYear}-07-01') age,if(person.sex=1,'ชาย',if(person.sex=2,'หญิง','ไม่ระบุ')) sex,
 concat('ต.',csubdistrict.subdistname) as subdist
,concat('ม.',convert(village.villno using utf8),' ',village.villname) as village
FROM person left join village
on person.provcodemoi=substring(village.villcode,1,2)
 AND person.distcodemoi=substring(village.villcode,3,2)
 AND person.subdistcodemoi=substring(village.villcode,5,2)
 AND if(length(person.mumoi)=1,concat('0',person.mumoi),person.mumoi)=substring(village.villcode,7,2)
left join csubdistrict
on csubdistrict.provcode=substring(village.villcode,1,2)
 AND csubdistrict.distcode=substring(village.villcode,3,2)
 AND csubdistrict.subdistcode=substring(village.villcode,5,2)
where person.mumoi <> '0' AND getAgeYearNum(person.birth,'$P!{PYear}-07-01')>=0 $P!{pcucode}]]>
	</queryString>
	<field name="person" class="java.lang.String"/>
	<field name="age" class="java.lang.Integer"/>
	<field name="sex" class="java.lang.String"/>
	<field name="subdist" class="java.lang.String"/>
	<field name="village" class="java.lang.String"/>
