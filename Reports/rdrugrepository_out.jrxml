<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rdrugrepository_out"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="2" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="where" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" WHERE drugrepositoryout.outdate  BETWEEN '2010-04-01' AND '2011-05-31'  AND d.pcucode='15102'  "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
drugrepositoryout.outno,
DATE_FORMAT(drugrepositoryout.outdate,'%Y-%m-%d') AS outdate,
drugrepositoryout.realno,
CASE WHEN drugrepositoryout.outtype=1 THEN 'ให้ยืม'
 WHEN drugrepositoryout.outtype=2 THEN 'ใช้คืน'
 WHEN drugrepositoryout.outtype=3 THEN 'เข้าคลังยานอก'
 ELSE 'ไม่ระบุ' END AS outtype,
d.drugcode,
cdrug.drugname,
d.packamount,
d.lotamount,
d.lotprice,
cdrugunitsell.unitsellname,
(d.lotamount*d.lotprice) AS price,
DATE_FORMAT(d.dateexpire,'%Y-%m-%d') AS dateexpire
FROM
drugrepositoryout
Inner Join drugrepositoryoutdetail d ON drugrepositoryout.pcucode = d.pcucode AND drugrepositoryout.outno = d.outno
Inner Join cdrug ON d.drugcode = cdrug.drugcode
Left Outer Join cdrugunitsell ON d.lotunit = cdrugunitsell.unitsellcode
$P!{where}
ORDER BY outno,outdate,drugcode,dateexpire]]></queryString>

	<field name="outno" class="java.lang.Integer"/>
	<field name="outdate" class="java.util.Date"/>
	<field name="realno" class="java.lang.String"/>
	<field name="outtype" class="java.lang.String"/>
	<field name="drugcode" class="java.lang.String"/>
	<field name="drugname" class="java.lang.String"/>
	<field name="packamount" class="java.lang.Integer"/>
	<field name="lotamount" class="java.lang.Integer"/>
	<field name="lotprice" class="java.lang.Integer"/>
	<field name="unitsellname" class="java.lang.String"/>
	<field name="price" class="java.lang.Long"/>
	<field name="dateexpire" class="java.util.Date"/>

	<variable name="sum_all_price" class="java.lang.Long" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{price}]]></variableExpression>
	</variable>
