	</parameter>
	<parameter name="p_sqlDisease" class="java.lang.String">
		<defaultValueExpression><![CDATA[" AND cdisease.diseasecode in('J00','I10') "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["D:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlPcu" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    diseasecode,
    diseasename,
    diseasenamethai
FROM
    cdisease
WHERE
     1 = 1 $P!{p_sqlDisease}
ORDER BY diseasecode]]>
	</queryString>
	<field name="diseasecode" class="java.lang.String"/>
	<field name="diseasename" class="java.lang.String"/>
	<field name="diseasenamethai" class="java.lang.String"/>
	<variable name="reportOffice" class="java.lang.String">
