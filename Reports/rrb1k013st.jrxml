<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rrb1k013st" pageWidth="783" pageHeight="595" orientation="Landscape" columnWidth="723" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="5b71ab73-79f1-462a-bb2d-e0467f89a99e">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2009-10-12"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2009-12-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2009-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["c:\\iReport-2.0.0"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select v.visitno,v.pcucode,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),fname,' ' ,lname) using utf8) as personname
     ,h.hosname,dh.distname,ph.provname,p.birth,p.idcard
     ,DATE_FORMAT(v.visitdate, "%Y-%m-%d") as visitdate,p.rightno
     ,if(birth is not null , CONVERT(CONCAT(  DATE_FORMAT(vepi.dateepi,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(vepi.dateepi,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), "/",
	CASE SIGN(DATE_FORMAT(vepi.dateepi,"%m")-DATE_FORMAT(birth,"%m"))
 	   WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(vepi.dateepi,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	   WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(vepi.dateepi,"%m") -  (DATE_FORMAT(vepi.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	   WHEN 1 THEN(DATE_FORMAT(vepi.dateepi,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(vepi.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  "/",
	CASE SIGN(DATE_FORMAT(vepi.dateepi,"%d") - DATE_FORMAT(birth,"%d"))
 	   WHEN 0 THEN(DATE_FORMAT(vepi.dateepi,"%d") - DATE_FORMAT(birth,"%d"))
	   WHEN -1 THEN (DATE_FORMAT(LAST_DAY(vepi.dateepi),"%d") + DATE_FORMAT(vepi.dateepi, "%d")  -  DATE_FORMAT(birth, "%d"))
 	   WHEN 1 THEN (DATE_FORMAT(vepi.dateepi,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(vepi.dateepi,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8),"ไม่มีวันเกิด") AS age_ymd
     ,CONVERT(case when p.subdistcodemoi is null  then 'นอกเขต'
              when p.hnomoi is null then concat(' ม.',  p.`mumoi` ,' ต.',  t.`subdistname` )
              when p.mumoi is null then concat(p.`hnomoi`  ,' ต.',  t.`subdistname` )
              else concat(p.`hnomoi` ,' ม.',  p.`mumoi` ,' ต.',  t.`subdistname` ) end   USING utf8)  as address
     ,case when (v.rightcode is null or v.rightcode ='') then 'ไม่ระบุสิทธิ' else crg.rightgroupname end as rightname
     ,(select if(v1.vaccinecode='BCG' ,'Y',null) from visitepi v1 where vepi.pid = v1.pid and vepi.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='BCG'  and (v1.dateepi between $P{sdate} and $P{edate})  group by v1.pid,v1.pcucodeperson) as bcg
     ,(select if(v2.vaccinecode='HBV1' ,'Y',null) from visitepi v2 where vepi.pid = v2.pid and vepi.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='HBV1' and (v2.dateepi between $P{sdate} and $P{edate}) group by v2.pid,v2.pcucodeperson) as hbv1
     ,(select if(v3.vaccinecode='HBV2', 'Y',null) from visitepi v3 where vepi.pid = v3.pid and vepi.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='HBV2' and (v3.dateepi between $P{sdate} and $P{edate}) group by v3.pid,v3.pcucodeperson) as hbv2
     ,(select if(v4.vaccinecode ='HBV3', 'Y',null) from visitepi v4 where vepi.pid = v4.pid and vepi.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='HBV3' and (v4.dateepi between $P{sdate} and $P{edate}) group by v4.pid,v4.pcucodeperson) as hbv3
     ,(select if(v5.vaccinecode='DTP1', 'Y',null)  from visitepi v5 where vepi.pid = v5.pid and vepi.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='DTP1'  and (v5.dateepi between $P{sdate} and $P{edate}) group by v5.pid,v5.pcucodeperson) as dtp1
     ,(select if(v6.vaccinecode ='DTP2', 'Y',null)  from visitepi v6 where vepi.pid = v6.pid and vepi.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='DTP2' and (v6.dateepi between $P{sdate} and $P{edate}) group by v6.pid,v6.pcucodeperson) as dtp2
     ,(select if(v7.vaccinecode ='DTP3', 'Y',null) from visitepi v7 where vepi.pid = v7.pid and vepi.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='DTP3' and (v7.dateepi between $P{sdate} and $P{edate}) group by v7.pid,v7.pcucodeperson) as dtp3
     ,(select if(v8.vaccinecode ='DTP4', 'Y',null) from visitepi v8 where vepi.pid = v8.pid and vepi.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='DTP4 ' and (v8.dateepi between $P{sdate} and $P{edate}) group by v8.pid,v8.pcucodeperson) as dtp4
     ,(select if(v9.vaccinecode ='DTP5', 'Y',null) from visitepi v9 where vepi.pid = v9.pid and vepi.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='DTP5' and (v9.dateepi between $P{sdate} and $P{edate}) group by v9.pid,v9.pcucodeperson) as dtp5
     ,(select if(v10.vaccinecode ='OPV1', 'Y',null) from visitepi v10 where vepi.pid = v10.pid and vepi.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='OPV1' and (v10.dateepi between $P{sdate} and $P{edate}) group by v10.pid,v10.pcucodeperson) as opv1
     ,(select if(v11.vaccinecode ='OPV2', 'Y',null) from visitepi v11 where vepi.pid = v11.pid and vepi.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='OPV2' and (v11.dateepi between $P{sdate} and $P{edate}) group by v11.pid,v11.pcucodeperson) as opv2
     ,(select if(v12.vaccinecode ='OPV3', 'Y',null) from visitepi v12 where vepi.pid = v12.pid and vepi.pcucodeperson=v12.pcucodeperson and v12.vaccinecode='OPV3' and (v12.dateepi between $P{sdate} and $P{edate}) group by v12.pid,v12.pcucodeperson) as opv3
     ,(select if(v13.vaccinecode='OPV4', 'Y',null) from visitepi v13 where vepi.pid = v13.pid and vepi.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='OPV4' and (v13.dateepi between $P{sdate} and $P{edate}) group by v13.pid,v13.pcucodeperson) as opv4
     ,(select if(v14.vaccinecode ='OPV5', 'Y',null) from visitepi v14 where vepi.pid = v14.pid and vepi.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='OPV5' and (v14.dateepi between $P{sdate} and $P{edate}) group by v14.pid,v14.pcucodeperson) as opv5
     ,(select if(v15.vaccinecode='MEAS', 'Y',null) from visitepi v15 where vepi.pid = v15.pid and vepi.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='MEAS'  and (v15.dateepi between $P{sdate} and $P{edate}) group by v15.pid,v15.pcucodeperson) as meas
     ,(select if(v16.vaccinecode ='JE1', 'Y',null) from visitepi v16 where vepi.pid = v16.pid and vepi.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='JE1' and (v16.dateepi between $P{sdate} and $P{edate}) group by v16.pid,v16.pcucodeperson) as je1
     ,(select if(v17.vaccinecode='JE2', 'Y',null) from visitepi v17 where vepi.pid = v17.pid and vepi.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='JE2'  and (v17.dateepi between $P{sdate} and $P{edate}) group by v17.pid,v17.pcucodeperson) as je2
     ,(select if(v18.vaccinecode='JE3', 'Y',null) from visitepi v18 where vepi.pid = v18.pid and vepi.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='JE3' and (v18.dateepi between $P{sdate} and $P{edate}) group by v18.pid,v18.pcucodeperson) as je3
##
,(select if(UCase(v18.vaccinecode)='J11', 'Y',null)
  from visitepi v18
  where vepi.pid = v18.pid and vepi.pcucodeperson=v18.pcucodeperson and UCASE(v18.vaccinecode)='J11'
    and (v18.dateepi between $P{sdate} and $P{edate}) group by v18.pid,v18.pcucodeperson
 ) as j11
,(select if(UCase(v18.vaccinecode)='J12', 'Y',null)
  from visitepi v18
  where vepi.pid = v18.pid and vepi.pcucodeperson=v18.pcucodeperson and UCASE(v18.vaccinecode)='J12'
    and (v18.dateepi between $P{sdate} and $P{edate}) group by v18.pid,v18.pcucodeperson
 ) as j12
,(select if(UCase(v18.vaccinecode)='IPV-P', 'Y',null)
  from visitepi v18
  where vepi.pid = v18.pid and vepi.pcucodeperson=v18.pcucodeperson and UCASE(v18.vaccinecode)='IPV-P'
    and (v18.dateepi between $P{sdate} and $P{edate}) group by v18.pid,v18.pcucodeperson
 ) as ipv_p
##
     ,(select if(v19.vaccinecode='DHB1', 'Y',null) from visitepi v19 where vepi.pid = v19.pid and vepi.pcucodeperson=v19.pcucodeperson and v19.vaccinecode='DHB1' and (v19.dateepi between $P{sdate} and $P{edate}) group by v19.pid,v19.pcucodeperson) as dhb1
     ,(select if(v20.vaccinecode='DHB2', 'Y',null) from visitepi v20 where vepi.pid = v20.pid and vepi.pcucodeperson=v20.pcucodeperson and v20.vaccinecode='DHB2' and (v20.dateepi between $P{sdate} and $P{edate}) group by v20.pid,v20.pcucodeperson) as dhb2
     ,(select if( v21.vaccinecode='DHB3', 'Y',null) from visitepi v21 where vepi.pid = v21.pid and vepi.pcucodeperson=v21.pcucodeperson and v21.vaccinecode='DHB3' and (v21.dateepi between $P{sdate} and $P{edate}) group by v21.pid,v21.pcucodeperson) as dhb3
,(select if(UCase(v24.vaccinecode) in('MMR','MMR1'), 'Y',null) from visitepi v24 where vepi.pid = v24.pid and vepi.pcucodeperson=v24.pcucodeperson and UCase(v24.vaccinecode) in('MMR','MMR1') and v24.dateepi between $P{sdate} and $P{edate}  group by v24.pid,v24.pcucodeperson) as mmr
,(select if(UCase(v25.vaccinecode)='MMR2', 'Y',null) from visitepi v25 where vepi.pid = v25.pid and vepi.pcucodeperson=v25.pcucodeperson and UCase(v25.vaccinecode)='MMR2' and v25.dateepi between $P{sdate} and $P{edate}  group by v25.pid,v25.pcucodeperson) as mmr2
,(select if(UCase(v25.vaccinecode)='MMRS', 'Y',null) from visitepi v25 where vepi.pid = v25.pid and vepi.pcucodeperson=v25.pcucodeperson and UCase(v25.vaccinecode)='MMRS' and v25.dateepi between $P{sdate} and $P{edate}  group by v25.pid,v25.pcucodeperson) as mmrs

    ,case when vepi.pid  in(select person.pid from person where vepi.pid = person.pid and vepi.pcucode = person.pcucodeperson
           and DATE_FORMAT(vepi.dateepi,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(vepi.dateepi,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d"))<= 6 ) then 'เด็ก'  else 'นร' end as persontype
from  visit v
     left join person p on v.pid=p.pid and v.pcucodeperson = p.pcucodeperson
     left join ctitle on p.prename = ctitle.titlecode
     left join visitepi vepi on v.visitno = vepi.visitno and v.pcucodeperson = vepi.pcucodeperson
     left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
     left join village on house.villcode = village.villcode and v.pcucode = village.pcucode
     left join csubdistrict t on CONCAT(t.provcode,t.distcode,t.subdistcode)  = left(village.villcode,6)
     left join chospital h on h.hoscode = vepi.pcucode
     left join cdistrict dh on dh.distcode = h.distcode and dh.provcode = h.provcode
     left join cprovince ph on ph.provcode = h.provcode
     left join cright cr on cr.rightcode = p.rightcode
     left join crightgroup crg on crg.rightgroupcode = cr.rightgroup
where v.visitdate between $P{sdate} and $P{edate}
      and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
      $P!{pcucode}
      and DATEDIFF(vepi.dateepi,birth)/365 <= 19
and typelive in('0','1','3')
group by v.pid,v.pcucodeperson
order by v.pcucode,v.visitdate]]>
	</queryString>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="personname" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="distname" class="java.lang.String"/>
	<field name="provname" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="visitdate" class="java.lang.String"/>
	<field name="rightno" class="java.lang.String"/>
	<field name="age_ymd" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
	<field name="rightname" class="java.lang.String"/>
	<field name="bcg" class="java.lang.String"/>
	<field name="hbv1" class="java.lang.String"/>
	<field name="hbv2" class="java.lang.String"/>
	<field name="hbv3" class="java.lang.String"/>
	<field name="dtp1" class="java.lang.String"/>
	<field name="dtp2" class="java.lang.String"/>
	<field name="dtp3" class="java.lang.String"/>
	<field name="dtp4" class="java.lang.String"/>
	<field name="dtp5" class="java.lang.String"/>
	<field name="opv1" class="java.lang.String"/>
	<field name="opv2" class="java.lang.String"/>
	<field name="opv3" class="java.lang.String"/>
	<field name="opv4" class="java.lang.String"/>
	<field name="opv5" class="java.lang.String"/>
	<field name="meas" class="java.lang.String"/>
	<field name="je1" class="java.lang.String"/>
	<field name="je2" class="java.lang.String"/>
	<field name="je3" class="java.lang.String"/>
	<field name="dhb1" class="java.lang.String"/>
	<field name="dhb2" class="java.lang.String"/>
	<field name="dhb3" class="java.lang.String"/>
	<field name="mmr" class="java.lang.String"/>
	<field name="mmr2" class="java.lang.String"/>
	<field name="mmrs" class="java.lang.String"/>
	<field name="persontype" class="java.lang.String"/>
	<field name="j11" class="java.lang.String"/>
	<field name="j12" class="java.lang.String"/>
	<field name="ipv_p" class="java.lang.String"/>
	<group name="pcucode" isStartNewPage="true">
		<groupExpression><![CDATA[$F{hosname}]]></groupExpression>
