				<text><![CDATA[2]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="03192c4d-3c4c-44fe-9a08-250f0ec5abef" key="staticText" x="321" y="125" width="15" height="24"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#0000CC"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#0000CC"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Tahoma" size="8" pdfFontName="tahoma.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[3]]></text>
