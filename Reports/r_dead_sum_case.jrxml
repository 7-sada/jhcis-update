	<parameter name="header_1" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header_2" isForPrompting="false" class="java.lang.String"/>
	<parameter name="startDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2008-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2008-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["14695"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT if(cdisease.diseasename is null,'ไม่ระบุสาเหตุการตาย',cdisease.diseasename) AS dc, 
Count(persondeath.pid) AS tot
FROM person
Inner Join persondeath ON person.pcucodeperson = persondeath.pcucodeperson AND person.pid = persondeath.pid 
LEFT JOIN cdisease ON persondeath.deadcause = cdisease.diseasecode
LEFT JOIN village ON (if(mumoi < 9 ,(concat(person.provcodemoi,person.distcodemoi,person.subdistcodemoi,'0',person.mumoi )) , 
                                              concat(person.provcodemoi,person.distcodemoi,person.subdistcodemoi,person.mumoi )) = village.villcode and person.pcucodeperson = village.pcucode)
WHERE persondeath.deaddate BETWEEN $P{startDate} AND  $P{endDate}
AND persondeath.pcucodeperson = $P{pcucode}
GROUP BY cdisease.diseasename
;]]></queryString>

	<field name="dc" class="java.lang.String"/>
	<field name="tot" class="java.lang.Long"/>

	<variable name="sum_tot" class="java.lang.Long" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{tot}]]></variableExpression>
	</variable>
