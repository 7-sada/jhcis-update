	<field name="visitdate" class="java.sql.Date"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="twhms" class="java.math.BigDecimal"/>
	<field name="twhfms" class="java.math.BigDecimal"/>
	<field name="whms" class="java.math.BigDecimal"/>
	<field name="whfms" class="java.math.BigDecimal"/>
	<field name="whm" class="java.math.BigDecimal"/>
	<field name="whfm" class="java.math.BigDecimal"/>
	<field name="am" class="java.math.BigDecimal"/>
	<field name="afm" class="java.math.BigDecimal"/>
	<field name="bm" class="java.math.BigDecimal"/>
	<field name="bfm" class="java.math.BigDecimal"/>

	<variable name="SUM_whm_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
