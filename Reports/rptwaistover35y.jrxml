<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptwaistover35y"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="558"
		 columnWidth="754"
		 columnSpacing="0"
		 leftMargin="58"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-02-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(15)]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT chospital.hosname,csubdistrict.subdistname,cdistrict.distname,cprovince.provname
,village.villname,village.villcode
,v.visitdate,v.pcucode
,sum(case when (person.sex='1' and v.waist !='') and  CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30') then 1 else 0 end) as twhms
,sum(case when (person.sex='2' and v.waist !='') and  CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30') then 1 else 0 end) as twhfms

,sum(case when (person.sex='1' and v.waist !='') and (v.visitdate between CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30')) then 1 else 0 end) as whms
,sum(case when (person.sex='2' and v.waist !='') and (v.visitdate between CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30')) then 1 else 0 end) as whfms
,sum(case when (person.sex='1' and v.waist !='') and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end) as whm
,sum(case when (person.sex='2' and v.waist !='') and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end) as whfm
,sum(case when (person.sex='1' and v.waist !='' and v.waist <= 90)and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as am
,sum(case when (person.sex='2' and v.waist !='' and v.waist <= 80)and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as afm
,sum(case when (person.sex='1' and v.waist !='' and v.waist > 90)and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as bm
,sum(case when (person.sex='2' and v.waist !='' and v.waist > 80)and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as bfm

FROM visit v 
    left join person on person.pid = v.pid and person.pcucodeperson = v.pcucodeperson
    left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode 
    left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
    left join chospital on v.pcucode = chospital.hoscode
    left join csubdistrict on csubdistrict.provcode= chospital.provcode and csubdistrict.distcode= chospital.distcode and csubdistrict.subdistcode = chospital.subdistcode
    left join cdistrict on  cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode
    left join cprovince on  cprovince.provcode = chospital.provcode

WHERE  DATEDIFF(concat(YEAR($P{pdate}),'-12','-31'),person.birth)/365 >= $P{age}
        and (person.typelive ='1' or person.typelive ='3' or person.typelive is null or person.typelive='0' )
     	and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
	$P!{pcucode}
 	and person.pid NOT IN (SELECT persondeath.pid FROM persondeath WHERE persondeath.pcucodeperson=$P{pcucode} and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{edate})) 
	and right(village.villcode,2) !='00'
        and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
GROUP BY v.pcucode,village.villcode]]></queryString>

