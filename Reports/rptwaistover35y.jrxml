	</variable>
	<variable name="SUM_twhfms_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{twhfms}]]></variableExpression>
	</variable>
	<variable name="SUM_twhms_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{twhms}]]></variableExpression>
	</variable>
	<variable name="SUM_SUM_twhfms_1_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{SUM_twhfms_1}]]></variableExpression>
	</variable>
