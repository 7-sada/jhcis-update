					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" size="8"/>
					</textElement>
				<textFieldExpression   class="java.util.Date"><![CDATA[$F{visitdate}.valueOf( $P{pdate})]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="91"
						width="754"
						height="68"
						forecolor="#FF0033"
						key="textField-11"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Top" lineSpacing="1_1_2">
						<font fontName="Tahoma" size="8"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["หมายเหตุ : \n1.เฉพาะคนในเขตฯ ที่อาศัยอยู่จริง (TypeLive = 1 หรือ 3 ) 2.อายุเต็ม " +$P{age}+ " ปีบริบูรณ์ นับถึงวันที่ 31 ธันวาคม ของปีที่รายงาน    \n3.ผลการตรวจฯ ให้ใช้ครั้งล่าสุดของการตรวจวัน(น้ำหนัก/ส่วนสูง) ภายในวันที่  ที่รายงาน  (เช่น นาย ก ได้รับตรวจวัดฯ 2 ครั้งคือ 3พค.52 และ 10มิย.52)  ถ้าออกรายงานถึง 31 พค.52 ก็ให้ใช้ผลการตรวจวัดเมื่อวันที่ 3 พค.52 (ไม่ใช่ 10 มิย. 52 )) 4.รอบเอว :-> ชาย:<= 90 ซม. =ปกติ ,> 90 ซม. =เกิน / หญิง:<= 80 ซม. =ปกติ ,> 80 ซม. =เกิน 5. สะสม หมายถึงปีงบประมาณ"]]></textFieldExpression>
				</textField>
				<staticText>
