	<queryString>
		<![CDATA[SELECT
cdrug.drugname,
drugrepositoryoutdetail.lotno,
drugrepositoryoutdetail.lotamount,
drugrepositoryoutdetail.packamount,
drugrepositoryoutdetail.remain
FROM
drugrepositoryoutdetail
Inner Join cdrug ON drugrepositoryoutdetail.drugcode = cdrug.drugcode
WHERE
drugrepositoryoutdetail.outno =  $P!{outNo}]]>
	</queryString>
