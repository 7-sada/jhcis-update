<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rpersonout_list"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="DateRep" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND visit.pcucode='01856']]></parameterDescription>
		<defaultValueExpression ><![CDATA["  "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="where_cup" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.hosmain = village.cup  AND visit.visitdate <= current_date  "]]></defaultValueExpression>
	</parameter>
	<parameter name="header" isForPrompting="false" class="java.lang.String"/>
	<parameter name="from_prov" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" Left Join office ON office.offid = visit.hosmain Left Join chospital ON chospital.hoscode = office.offid "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
if(cright.rightname is null,'ไม่ระบุสิทธิ',cright.rightname) rightname,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) AS fname,
person.lname,
if(csubdistrict.subdistname is null OR cdistrict.distname is null OR cprovince.provname,CONCAT(person.hnomoi,' ม.',person.mumoi),CONCAT(person.hnomoi,' ม.',person.mumoi,' ต.',csubdistrict.subdistname,' อ.',cdistrict.distname,' จ.',cprovince.provname)) AS address,
DATE_FORMAT(person.birth,'%Y-%m-%d') AS birth,
concat((year(current_date)-year(person.birth)-(right(current_date,5)<right(person.birth,5))),' - ',
 (if (day(current_date) <day(person.birth),(if (right(current_date,5)<right(person.birth,5),(12+ month(current_date))-month(person.birth),month(current_date)-month(person.birth)))-1 ,(if (right(current_date,5)<right(`person`.`birth`,5),(12+ month(current_date))-month(person.birth),month(current_date)-month(person.birth))))) ,' - ',
 (if (day(current_date) < day(person.birth),((day(last_day(current_date())))+ day(current_date))-day(person.birth),day(current_date)-day(person.birth)))) AS age
FROM
visit
Left Outer Join person ON visit.pcucode = person.pcucodeperson AND visit.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Left Outer Join csubdistrict ON person.subdistcodemoi = csubdistrict.subdistcode AND person.distcodemoi = csubdistrict.distcode AND person.provcodemoi = csubdistrict.provcode
Left Outer Join cdistrict ON csubdistrict.provcode = cdistrict.provcode AND csubdistrict.distcode = cdistrict.distcode
Left Outer Join cprovince ON cdistrict.provcode = cprovince.provcode
Left Outer Join cright ON person.rightcode = cright.rightcode
Left Outer Join house ON person.pcucodeperson = house.pcucode AND person.hcode = house.hcode
Left Outer Join village ON house.villcode = village.villcode
Left Outer Join persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
$P!{from_prov}
WHERE
 1=1
 $P!{pcucode}
 $P!{where_cup}
GROUP BY person.pid,person.pcucodeperson
ORDER BY cright.rightname,person.hnomoi,person.mumoi,cprovince.provcode,cdistrict.distcode,csubdistrict.subdistcode]]></queryString>

