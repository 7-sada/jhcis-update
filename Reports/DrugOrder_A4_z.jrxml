		<groupHeader>
			<band height="53" splitType="Stretch">
				<staticText>
					<reportElement key="staticText-39" positionType="Float" x="1" y="2" width="529" height="16" forecolor="#0000CC" uuid="78eedcd1-8d4c-4859-812a-996b949bf26f"/>
					<box>
