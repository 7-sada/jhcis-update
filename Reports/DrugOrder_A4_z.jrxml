				<line>
					<reportElement key="line-1" x="0" y="1" width="478" height="1" uuid="a03e6ea6-755e-4a39-8e3a-feff1a296426"/>
				</line>
				<subreport isUsingCache="false">
					<reportElement positionType="Float" x="7" y="18" width="523" height="17" uuid="7ae45db6-0963-4797-bc62-30367a783c53"/>
					<subreportParameter name="visitno">
						<subreportParameterExpression><![CDATA[$P{visitno}]]></subreportParameterExpression>
					</subreportParameter>
					<subreportParameter name="pcucode">
						<subreportParameterExpression><![CDATA[$F{visit_pcucode}]]></subreportParameterExpression>
					</subreportParameter>
					<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
					<subreportExpression><![CDATA[$P{SUBREPORT_DIR} + "\\DrugOrder_subreport1_z.jasper"]]></subreportExpression>
				</subreport>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true">
					<reportElement positionType="Float" x="3" y="35" width="451" height="17" forecolor="#CC0033" uuid="364eaee9-9de0-4c27-8d7d-be76e45c927e"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" size="8" isBold="true"/>
