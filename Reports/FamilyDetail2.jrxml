<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FamilyDetail2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucodeperson" isForPrompting="false" class="java.lang.String"/>
	<parameter name="hcode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="reportdate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="familyno" isForPrompting="false" class="java.lang.Integer"/>
	<queryString><![CDATA[SELECT P.pcucodeperson,P.hcode,P.familyno,P.idcard,P.birth,P.allergic,P.privatedoc,  
  P.income,P.datein,P.rightcode, 
  CAST(CONCAT(P.bloodgroup,'',P.bloodrh) AS CHAR) AS bloodgroup, 
  CAST((CASE P.sex WHEN '1' THEN 'ชาย' WHEN '2' THEN 'หญิง' ELSE 'ไม่ระบุ' END) AS char) AS sex,
  IF(P.fname IS NULL AND P.lname IS NULL, '', CAST(CONCAT(P.prename,P.fname,'  ',P.lname) AS char)) AS fullname, 
  CAST( CONCAT( getAgeYearNum(P.birth, $P{reportdate}),'-',getAgeMonthNum(P.birth, $P{reportdate}),'-',getAgeDayNum(P.birth, $P{reportdate}) ) AS char) AS ageymd,    
  (SELECT CAST(CONCAT(REF_P.prename,REF_P.fname,'  ',REF_P.lname) AS char) FROM person REF_P WHERE REF_P.pcucodeperson=$P{pcucodeperson} AND REF_P.hcode=$P{hcode} AND REF_P.familyposition='1') AS familyleader,
  (SELECT IF(cfamilyposition.famposname IS NOT NULL,cfamilyposition.famposname,'ไม่ระบุ') AS famposname FROM cfamilyposition WHERE cfamilyposition.famposcode=P.familyposition) AS familyposition,
  (SELECT IF(cstatus.statusname IS NOT NULL,cstatus.statusname,'ไม่ระบุ') AS statusname FROM cstatus WHERE cstatus.statuscode=P.marystatus) AS marystatus,
  (SELECT IF(ceducation.educationname IS NOT NULL,ceducation.educationname,'ไม่ระบุ') AS educationname FROM ceducation WHERE ceducation.educationcode=P.educate) AS educate, 
  (SELECT IF(coccupa.occupaname IS NOT NULL,coccupa.occupaname,'ไม่ระบุ') AS occupaname FROM coccupa WHERE coccupa.occupacode=P.occupa) AS occupa, 
  (SELECT IF(creligion.religionname IS NOT NULL,creligion.religionname,'ไม่ระบุ') AS religionname FROM creligion WHERE creligion.religioncode=P.religion) AS religion,  

  /*  ตำแหน่งในชุมชน */
  (SELECT ref_cpt.persontypename    
  FROM persontype ref_pt 
    INNER JOIN cpersontype ref_cpt ON (ref_pt.typecode=ref_cpt.persontypecode)  
  WHERE ref_pt.pcucodeperson=P.pcucodeperson AND ref_pt.pid=P.pid) AS communityposition,  

  (CASE PB.ciga WHEN '0' THEN 'ไม่สูบ' WHEN '1' THEN 'สูบนานๆครั้ง' WHEN '2' THEN 'สูบประจำ' ELSE 'ไม่ระบุ' END) AS cigar,  
  (CASE PB.wisky WHEN '0' THEN 'ไม่ดื่ม' WHEN '1' THEN 'ดื่มนานๆครั้ง' WHEN '2' THEN 'ดื่ม1-2 ครั้ง/เดือน' ELSE 'ไม่ระบุ' END) AS whisky,  
  (CASE PB.exercise WHEN '0' THEN 'ไม่ทำ' WHEN '1' THEN '< 3 วัน/สัปดาห์' WHEN '2' THEN '3-5 วัน/สัปดาห์' ELSE 'ไม่ระบุ' END) AS exercise 

FROM person P 
  LEFT OUTER JOIN personbehavior PB ON (PB.pcucodeperson=P.pcucodeperson AND PB.pid=P.pid)     

WHERE P.pcucodeperson=$P{pcucodeperson} AND P.hcode=$P{hcode} AND P.familyno=$P{familyno} 
ORDER BY P.pcucodeperson ASC, P.hcode ASC, P.familyno ASC, P.familyposition ASC]]></queryString>

	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="hcode" class="java.lang.Integer"/>
	<field name="familyno" class="java.lang.Integer"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
