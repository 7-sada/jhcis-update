	<subDataset name="DrugDetail" uuid="5625acb4-a15f-412c-92ce-061b2746e8b4">
		<parameter name="sdate" class="java.lang.String" isForPrompting="false"/>
		<parameter name="edate" class="java.lang.String" isForPrompting="false"/>
		<queryString>
			<![CDATA[select IF(v.visitdate IS NULL,'ไม่ระบุ',concat(convert(DAY(v.visitdate) using utf8),' ',
   CASE WHEN MONTH(v.visitdate)=1 THEN 'มค.'
   WHEN MONTH(v.visitdate)=2 THEN 'กพ.' WHEN MONTH(v.visitdate)=3 THEN 'มีค.'
   WHEN MONTH(v.visitdate)=4 THEN 'เมย.' WHEN MONTH(v.visitdate)=5 THEN 'พค.'
   WHEN MONTH(v.visitdate)=6 THEN 'มิย.' WHEN MONTH(v.visitdate)=7 THEN 'กค.'
   WHEN MONTH(v.visitdate)=8 THEN 'สค' WHEN MONTH(v.visitdate)=9 THEN 'กย.'
   WHEN MONTH(v.visitdate)=10 THEN 'ตค.' WHEN MONTH(v.visitdate)=11 THEN 'พย.'
   WHEN MONTH(v.visitdate)=12 THEN 'ธค.' END,' ',right((year(visitdate)+543),2)))
   as visitdate,
vd.visitno,v.pid as HN,concat(ifnull(titlename,ifnull(p.prename,'...')) ,' ', fname,' ', lname) as name,
p.idcard,ifnull(vd.clinic,"อายุรกรรม") as clinic,concat(d.drugname,"/",d.drugcode) as name_drugcode,r.rightname,ifnull(vd.doctor1,vd.doctor2) as doctorName,
vd.unit as Qty,cs.unitsellname as unitname,IF(v.visitdate IS NULL,'ไม่ระบุ',concat(convert(DAY(v.visitdate) using utf8),' ',
   CASE WHEN MONTH(v.visitdate)=1 THEN 'มค.'
   WHEN MONTH(v.visitdate)=2 THEN 'กพ.' WHEN MONTH(v.visitdate)=3 THEN 'มีค.'
   WHEN MONTH(v.visitdate)=4 THEN 'เมย.' WHEN MONTH(v.visitdate)=5 THEN 'พค.'
   WHEN MONTH(v.visitdate)=6 THEN 'มิย.' WHEN MONTH(v.visitdate)=7 THEN 'กค.'
   WHEN MONTH(v.visitdate)=8 THEN 'สค.' WHEN MONTH(v.visitdate)=9 THEN 'กย.'
   WHEN MONTH(v.visitdate)=10 THEN 'ตค.' WHEN MONTH(v.visitdate)=11 THEN 'พย.'
   WHEN MONTH(v.visitdate)=12 THEN 'ธค.' END,' ',right((year(visitdate)+543),2)) ) as Entry_date,
(vd.realprice*vd.unit) as Amt
from visitdrug vd
join visit v on (vd.pcucode=v.pcucode and vd.visitno = v.visitno)
LEFT join cright r on (v.rightcode = r.rightcode)
join cdrug  d on (vd.drugcode = d.drugcode)
LEFT JOIN cdrugunitsell cs on (d.unitsell = cs.unitsellcode)
join person p on (v.pcucodeperson= p.pcucodeperson AND v.pid = p.pid)
left join ctitle t on (p.prename = t.titlecode)
where d.drugcode24 = '124846000003972121781506'
and v.visitdate between $P{sdate} and $P{edate}]]>
		</queryString>
		<field name="visitdate" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="visitno" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="HN" class="java.lang.Integer"/>
		<field name="name" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="idcard" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="clinic" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="name_drugcode" class="java.lang.String"/>
		<field name="rightname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="doctorName" class="java.lang.String"/>
		<field name="Qty" class="java.lang.Integer"/>
		<field name="unitname" class="java.lang.String"/>
		<field name="Entry_date" class="java.lang.String"/>
		<field name="Amt" class="java.math.BigDecimal"/>
	</subDataset>
	<parameter name="sdate" class="java.lang.String"/>
	<parameter name="edate" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select 1 as dummy]]>
	</queryString>
	<field name="dummy" class="java.lang.Long"/>
