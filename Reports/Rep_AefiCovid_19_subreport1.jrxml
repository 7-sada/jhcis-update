	<field name="aeficode10comment" class="java.lang.String">
		<fieldDescription><![CDATA[บันทึกเพิ่มเติม กรณีที่มีอาการไม่พึงประสงค์(AEFI)อื่น(รหัส 10)]]></fieldDescription>
	</field>
	<field name="no" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
