<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDentPrecessAnc" language="groovy" pageWidth="1250" pageHeight="600" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="1210" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-10-31"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select date_format(visit.visitdate,'%Y-%m') ymt
,hosname
,curdate() as cdate
from visitanc
     left join visit on visitanc.visitno = visit.visitno and visitanc.pcucode = visit.pcucode
     left join visitdrug on visit.pcucode = visitdrug.pcucode and visit.visitno = visitdrug.visitno
     left join cright on visit.rightcode = cright.rightcode
     left join crightgroup  on cright.rightgroup = crightgroup.rightgroupcode
     left join chospital on visit.pcucode = chospital.hoscode
where  1=1
and visitdate between $P{sdate} and  $P{edate}
$P!{pcucode}
group by timeservice]]>
	</queryString>
	<field name="ymt" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
