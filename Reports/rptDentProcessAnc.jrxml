				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<text><![CDATA[รายงาน ระหว่างวันที่]]></text>
			</staticText>
			<textField pattern="d MMMMM yyyy" isBlankWhenNull="true">
				<reportElement x="222" y="0" width="100" height="30"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cdate}.valueOf( $P{sdate} )]]></textFieldExpression>
			</textField>
			<textField pattern="d MMMMM yyyy" isBlankWhenNull="true">
				<reportElement x="334" y="0" width="100" height="30"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cdate}.valueOf( $P{edate} )]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<columnHeader>
		<band height="145" splitType="Stretch">
			<subreport>
				<reportElement stretchType="RelativeToBandHeight" x="0" y="0" width="1132" height="28"/>
				<subreportParameter name="SUBREPORT_DIR"/>
				<subreportParameter name="pcucode">
					<subreportParameterExpression><![CDATA[$P{pcucode}]]></subreportParameterExpression>
				</subreportParameter>
				<subreportParameter name="edate">
					<subreportParameterExpression><![CDATA[$P{edate}]]></subreportParameterExpression>
				</subreportParameter>
				<subreportParameter name="sdate">
					<subreportParameterExpression><![CDATA[$P{sdate}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<subreportExpression><![CDATA[$P{SUBREPORT_DIR} + "rptDentAncToothCheck.jasper"]]></subreportExpression>
			</subreport>
