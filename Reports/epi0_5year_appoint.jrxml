<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="epi_0_5year_2_in_area" pageWidth="846" pageHeight="595" orientation="Landscape" columnWidth="800" leftMargin="30" rightMargin="16" topMargin="20" bottomMargin="28" uuid="803b2b82-04d3-4736-bcc1-0d623a26b90f">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and v.pcucodeperson ='01035' "]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-12-03"]]></defaultValueExpression>
	</parameter>
	<parameter name="villno" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT v.pid,v.pcucodeperson
,person.birth as bb
,DATE_FORMAT(person.birth,'%Y-%m-%d' ) as birth
,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),' ',person.fname,'  ',person.lname) using utf8) as name
, ROUND(DATEDIFF($P{pdate},birth) /30) AS age_ymd
,village.villno,person.hnomoi
,v.visitno,v.pcucode
,house.hno AS hno_or_not
,village.villname
,chospital.hosname
,visitdate
,(select DATE_FORMAT(v1.dateappoint,'%Y-%m-%d')  from visitepiappoint v1  where v.pid = v1.pid  and v.pcucodeperson=v1.pcucodeperson  and v1.vaccinecode='DTP1'  and (v1.dateappoint  IS NOT NULL OR  left(v1.dateappoint,4) != '0000'  ) and dateappoint  >= $P{pdate}  order by v1.dateappoint desc limit 1) as dtp1
,(select DATE_FORMAT(v2.dateappoint,'%Y-%m-%d')  from visitepiappoint v2  where v.pid = v2.pid  and v.pcucodeperson=v2.pcucodeperson  and v2.vaccinecode='DTP2'  and (v2.dateappoint  IS NOT NULL OR  left(v2.dateappoint,4) != '0000'  ) and dateappoint  >= $P{pdate} order by v2.dateappoint desc limit 1) as dtp2
,(select DATE_FORMAT(v3.dateappoint,'%Y-%m-%d')  from visitepiappoint v3  where v.pid = v3.pid  and v.pcucodeperson=v3.pcucodeperson  and v3.vaccinecode='DTP3'  and (v3.dateappoint  IS NOT NULL OR  left(v3.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v3.dateappoint desc limit 1) as dtp3
,(select DATE_FORMAT(v4.dateappoint,'%Y-%m-%d')  from visitepiappoint v4  where v.pid = v4.pid  and v.pcucodeperson=v4.pcucodeperson  and v4.vaccinecode='DTP4'  and (v4.dateappoint  IS NOT NULL OR  left(v4.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v4.dateappoint desc limit 1) as dtp4
,(select DATE_FORMAT(v5.dateappoint,'%Y-%m-%d')  from visitepiappoint v5  where v.pid = v5.pid  and v.pcucodeperson=v5.pcucodeperson  and v5.vaccinecode='DTP5'  and (v5.dateappoint  IS NOT NULL OR  left(v5.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v5.dateappoint desc limit 1) as dtp5
,(select DATE_FORMAT(v6.dateappoint,'%Y-%m-%d')  from visitepiappoint v6  where v.pid = v6.pid  and v.pcucodeperson=v6.pcucodeperson  and v6.vaccinecode='DHB1'  and (v6.dateappoint  IS NOT NULL OR  left(v6.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v6.dateappoint desc limit 1) as dhb1
,(select DATE_FORMAT(v7.dateappoint,'%Y-%m-%d')  from visitepiappoint v7  where v.pid = v7.pid  and v.pcucodeperson=v7.pcucodeperson  and v7.vaccinecode='DHB2'  and (v7.dateappoint  IS NOT NULL OR  left(v7.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v7.dateappoint desc limit 1) as dhb2
,(select DATE_FORMAT(v8.dateappoint,'%Y-%m-%d')  from visitepiappoint v8  where v.pid = v8.pid  and v.pcucodeperson=v8.pcucodeperson  and v8.vaccinecode='DHB3'  and (v8.dateappoint  IS NOT NULL OR  left(v8.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v8.dateappoint  desc limit 1) as dhb3
,(select DATE_FORMAT(v9.dateappoint,'%Y-%m-%d')  from visitepiappoint v9  where v.pid = v9.pid  and v.pcucodeperson=v9.pcucodeperson  and v9.vaccinecode='HBV1'  and (v9.dateappoint  IS NOT NULL OR  left(v9.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v9.dateappoint  desc limit 1) as hbv1
,(select DATE_FORMAT(v10.dateappoint,'%Y-%m-%d') from visitepiappoint v10 where v.pid = v10.pid and v.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='HBV2' and (v10.dateappoint IS NOT NULL OR  left(v10.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v10.dateappoint desc limit 1) as hbv2
,(select DATE_FORMAT(v11.dateappoint,'%Y-%m-%d') from visitepiappoint v11 where v.pid = v11.pid and v.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='HBV3' and (v11.dateappoint IS NOT NULL OR  left(v11.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v11.dateappoint desc limit 1) as hbv3
,(select DATE_FORMAT(v12.dateappoint,'%Y-%m-%d') from visitepiappoint v12 where v.pid = v12.pid and v.pcucodeperson=v12.pcucodeperson and v12.vaccinecode='JE1'  and (v12.dateappoint IS NOT NULL OR  left(v12.dateappoint,4) !=  '0000'  )  and dateappoint  >= $P{pdate} order by v12.dateappoint desc limit 1) as je1
,(select DATE_FORMAT(v13.dateappoint,'%Y-%m-%d') from visitepiappoint v13 where v.pid = v13.pid and v.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='JE2'  and (v13.dateappoint IS NOT NULL OR  left(v13.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v13.dateappoint desc limit 1) as je2
,(select DATE_FORMAT(v14.dateappoint,'%Y-%m-%d') from visitepiappoint v14 where v.pid = v14.pid and v.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='JE3'  and (v14.dateappoint IS NOT NULL OR  left(v14.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v14.dateappoint desc limit 1) as je3
,(select DATE_FORMAT(v15.dateappoint,'%Y-%m-%d') from visitepiappoint v15 where v.pid = v15.pid and v.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='OPV1' and (v15.dateappoint IS NOT NULL OR  left(v15.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v15.dateappoint desc limit 1 ) as opv1
,(select DATE_FORMAT(v16.dateappoint,'%Y-%m-%d') from visitepiappoint v16 where v.pid = v16.pid and v.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='OPV2' and (v16.dateappoint IS NOT NULL OR  left(v16.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v16.dateappoint desc limit 1) as opv2
,(select DATE_FORMAT(v17.dateappoint,'%Y-%m-%d') from visitepiappoint v17 where v.pid = v17.pid and v.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='OPV3' and (v17.dateappoint IS NOT NULL OR  left(v17.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v17.dateappoint desc limit 1) as opv3
,(select DATE_FORMAT(v18.dateappoint,'%Y-%m-%d') from visitepiappoint v18 where v.pid = v18.pid and v.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='OPV4' and (v18.dateappoint IS NOT NULL OR  left(v18.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v18.dateappoint desc limit 1) as opv4
,(select DATE_FORMAT(v19.dateappoint,'%Y-%m-%d') from visitepiappoint v19 where v.pid = v19.pid and v.pcucodeperson=v19.pcucodeperson and v19.vaccinecode='OPV5' and (v19.dateappoint IS NOT NULL OR  left(v19.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v19.dateappoint  desc limit 1) as opv5
,(select DATE_FORMAT(v20.dateappoint,'%Y-%m-%d') from visitepiappoint v20 where v.pid = v20.pid and v.pcucodeperson=v20.pcucodeperson and v20.vaccinecode='BCG'  and (v20.dateappoint IS NOT NULL OR  left(v20.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v20.dateappoint desc limit 1) as bcg
,(select DATE_FORMAT(v21.dateappoint,'%Y-%m-%d') from visitepiappoint v21 where v.pid = v21.pid and v.pcucodeperson=v21.pcucodeperson and v21.vaccinecode='MEAS' and (v21.dateappoint IS NOT NULL OR  left(v21.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate}  order by v21.dateappoint  desc limit 1) as meas
,(select DATE_FORMAT(v22.dateappoint,'%Y-%m-%d') from visitepiappoint v22 where v.pid = v22.pid and v.pcucodeperson=v22.pcucodeperson and v22.vaccinecode like'MMR%' and (v22.dateappoint IS NOT NULL OR left(v22.dateappoint,4) !=  '0000'  ) and dateappoint  >= $P{pdate} order by v22.dateappoint desc limit 1) as mmr
,curdate() cdate
FROM  person
          left join visitepiappoint v on person.pid = v.pid and person.pcucodeperson = v.pcucodeperson
   	  left join  visit  on (person.pid = visit.pid and person.pcucodeperson = visit.pcucodeperson)
          left join ctitle t on person.prename = t.titlecode
	  left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	  left join village ON house.villcode = village.villcode and house.pcucode = village.pcucode
          left join chospital ON (village.pcucode = chospital.hoscode)
	  left join cprovince ON (cprovince.provcode =chospital.provcode)

WHERE ROUND(DATEDIFF($P{pdate},birth) /30) <= 60 and birth <= $P{pdate}
	and (birth IS NOT NULL OR left(birth,4) != '0000')
        and substring(v.vaccinecode,0,2) <> 'TT'
        and CONCAT(person.pid,person.pcucodeperson) NOT IN (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.pid = person.pid and persondeath.pcucodeperson= person.pcucodeperson and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{pdate}))
	and village.villno >= $P{villno}
        $P!{pcucode}

        and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
group by person.pid,person.pcucodeperson
ORDER BY house.pcucode,village.villcode,person.birth DESC]]>
	</queryString>
	<field name="pid" class="java.lang.Integer"/>
	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="bb" class="java.sql.Date"/>
	<field name="birth" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="age_ymd" class="java.math.BigDecimal"/>
	<field name="villno" class="java.lang.Integer"/>
	<field name="hnomoi" class="java.lang.String"/>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hno_or_not" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="dtp1" class="java.lang.String"/>
	<field name="dtp2" class="java.lang.String"/>
	<field name="dtp3" class="java.lang.String"/>
	<field name="dtp4" class="java.lang.String"/>
	<field name="dtp5" class="java.lang.String"/>
	<field name="dhb1" class="java.lang.String"/>
	<field name="dhb2" class="java.lang.String"/>
	<field name="dhb3" class="java.lang.String"/>
	<field name="hbv1" class="java.lang.String"/>
	<field name="hbv2" class="java.lang.String"/>
	<field name="hbv3" class="java.lang.String"/>
	<field name="je1" class="java.lang.String"/>
	<field name="je2" class="java.lang.String"/>
	<field name="je3" class="java.lang.String"/>
	<field name="opv1" class="java.lang.String"/>
	<field name="opv2" class="java.lang.String"/>
	<field name="opv3" class="java.lang.String"/>
	<field name="opv4" class="java.lang.String"/>
	<field name="opv5" class="java.lang.String"/>
	<field name="bcg" class="java.lang.String"/>
	<field name="meas" class="java.lang.String"/>
	<field name="mmr" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
	<group name="pcucode" isStartNewPage="true">
		<groupExpression><![CDATA[$F{hosname}]]></groupExpression>
		<groupHeader>
			<band splitType="Stretch"/>
		</groupHeader>
		<groupFooter>
			<band splitType="Stretch"/>
		</groupFooter>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
