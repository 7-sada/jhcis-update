<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Receipt_hos_incomplete_Preview" pageWidth="431" pageHeight="576" columnWidth="397" leftMargin="20" rightMargin="14" topMargin="28" bottomMargin="20" uuid="349f41ee-ec35-44d5-81d2-22f3b4bf73da">
	<property name="ireport.zoom" value="1.610510000000001"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="115"/>
	<parameter name="visitno" class="java.lang.String"/>
	<parameter name="receiptno" class="java.lang.String"/>
	<parameter name="username" class="java.lang.String"/>
	<parameter name="position" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Project_Java\\_DesktopApp\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="PayMoney" class="java.lang.String"/>
	<queryString>
		<![CDATA[select p2.*
from(
select v.pcucode,v.visitno,ifnull(bb.diagcode,"ไม่ระบุรหัสการวินิจฉัย") as diagcode,ifnull(di.diseasenamethai,"") asdiseasenamethai
,date_add(v.visitdate,interval 543 year) as visit_datethai,
v.pid,p.fname,p.lname,ct.titlename
,p1.drugcode,
(case when p1.drugtype = '10' then '01'
when p1.drugtype = '11' then '03'
else p1.drugtype
end) as drugtype,p1.drugname,p1.prefix,p1.noclaim,p1.paid,v.username,u.fname as uname,u.lname as ulname,u.officerposition
from visit v
left join
(
select vi.pcucode,vi.visitno,vi.diagcode
from visitdiag vi
where vi.dxtype = '01' and vi.visitno = $P{visitno}
group by vi.visitno ) as bb on (v.visitno = bb.visitno and v.pcucode = bb.pcucode)
join (
select aa.visitno,aa.drugcode,aa.drugtype,
(case when aa.drugtype in('01','10') and aa.nationaccount = '1' then 'ค่ายาในบัญชียาหลักแห่งชาติ'
when aa.drugtype in('01','10') and aa.nationaccount = '2' then 'ค่ายานอกบัญชียาหลักแห่งชาติ'
when aa.drugtype in('03','11') and aa.nationaccount = '1' then 'ค่าอุปกรณ์ในบัญชียาหลักแห่งชาติ'
when aa.drugtype in ('03','11') and aa.nationaccount = '2' then 'ค่าอุปกรณ์นอกบัญชียาหลักแห่งชาติ'
when aa.drugtype in ('06') and aa.nationaccount = '14' then 'ค่าบริการทางกายภาพบำบัด'
else aa.drugname
end) as drugname,
ifnull(concat("(",aa.drugcodeaccountdept,")"),"") as prefix,aa.noclaim,aa.paid
from (
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
sum(if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2))) as noclaim
,sum(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and (cd.drugtype in  ('10','01')) and cd.nationaccount = '2'
group by vd.visitno
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
sum(if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2))) as noclaim
,sum(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and (cd.drugtype in  ('10','01')) and cd.nationaccount = '1'
group by vd.visitno
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
sum(if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2))) as noclaim
,sum(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and (cd.drugtype in  ('03','11')) and cd.nationaccount = '1'
group by vd.visitno
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,ifnull(cd.nationaccount,'2') as nationaccount,cd.drugcodeaccountdept,
sum(if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2))) as noclaim
,sum(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and (cd.drugtype in  ('03','11')) and (cd.nationaccount = '2' or cd.nationaccount is null)
group by vd.visitno
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.chargeitem as nationaccount,cd.drugcodeaccountdept,
sum(if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2))) as noclaim
,sum(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and (cd.drugcode like 'K%' and cd.chargeitem = '14')
group by vd.visitno
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2)) as noclaim
,(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and cd.drugtype in  ('07')
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2)) as noclaim
,(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and cd.drugtype in  ('91') and cd.drugcode not like "DF%"
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2)) as noclaim
,(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and cd.drugtype in  ('02')
union all
select vd.visitno,vd.drugcode,cd.drugname,cd.drugtype,cd.nationaccount,cd.drugcodeaccountdept,
if(round((vd.unit*vd.realprice*vd.noclaimprice),2) is NULL,0,round((vd.unit*vd.realprice*vd.noclaimprice),2)) as noclaim
,(round(((1-ifnull(vd.noclaimprice,0))*vd.unit*vd.realprice),2)) as paid
from visitdrug vd
left join cdrug cd on (vd.drugcode = cd.drugcode)
where vd.visitno = $P{visitno}
and (cd.drugtype = '06' and cd.drugcode not like 'K%'))
as aa)
as p1 on (v.visitno = p1.visitno)
left join cdisease di on (bb.diagcode = di.diseasecode)
left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join ctitle ct on (ct.titlecode = p.prename)
left join user u on (u.username = v.username)
order by p1.drugtype) as p2
order by p2.drugtype]]>
	</queryString>
