<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptdentis" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="792" leftMargin="30" rightMargin="20" topMargin="20" bottomMargin="20" whenResourceMissingType="Empty">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-31"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  visitdate,convert(concat(ifnull(titlename,ifnull(prename,'-')) ,fname,' ',lname)  using utf8) as staffname
,visitdrugdental.visitno,dentcode,drugname,tootharea,visitdrug.realprice,visit.username,officerposition
,hosname,curdate() as cdate
from visitdrugdental left join visit on visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
	left join visitdrug on visitdrugdental.visitno = visitdrug.visitno and visitdrugdental.pcucode = visitdrug.pcucode
				                                    and visitdrugdental.dentcode = visitdrug.drugcode
	left join user on visit.username = user.username
	left join ctitle on user.prename = ctitle.titlecode
          left join chospital on visit.pcucode = chospital.hoscode
	left join cdrug on visitdrugdental.dentcode = cdrug.drugcode
where visit.visitdate between $P{sdate} and $P{edate}
order by visit.username,visitdate]]>
	</queryString>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="staffname" class="java.lang.String"/>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="dentcode" class="java.lang.String"/>
	<field name="drugname" class="java.lang.String"/>
	<field name="tootharea" class="java.lang.String"/>
	<field name="realprice" class="java.math.BigDecimal"/>
	<field name="username" class="java.lang.String"/>
	<field name="officerposition" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
	<variable name="Sum_realprice" class="java.math.BigDecimal" resetType="Group" resetGroup="staff" calculation="Sum">
		<variableExpression><![CDATA[$F{realprice}]]></variableExpression>
	</variable>
	<group name="staff" isStartNewPage="true">
		<groupExpression><![CDATA[$F{username}]]></groupExpression>
		<groupHeader>
			<band height="29">
				<textField>
					<reportElement mode="Opaque" x="1" y="0" width="791" height="29" backcolor="#EBE7E7"/>
					<box>
						<pen lineWidth="0.25"/>
						<topPen lineWidth="0.25"/>
						<leftPen lineWidth="0.25"/>
						<bottomPen lineWidth="0.25"/>
						<rightPen lineWidth="0.25"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" size="12"/>
					</textElement>
					<textFieldExpression><![CDATA["ทันตแพทย์ / ทันตภิบาล : "+$F{staffname} +"  ("+$F{officerposition} +')']]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="35">
				<textField pattern="#,##0" isBlankWhenNull="true">
					<reportElement stretchType="RelativeToBandHeight" x="609" y="0" width="108" height="35" forecolor="#FF0000"/>
