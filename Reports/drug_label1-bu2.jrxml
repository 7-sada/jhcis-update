<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="drug_label1" pageWidth="227" pageHeight="142" orientation="Landscape" columnWidth="227" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="19cfe6eb-feb6-4ef0-957e-28bcf164ace6">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="vn" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["71149"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01871"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
`person`.`pid`,
Concat(ifnull(titlename,ifnull(`person`.`prename`,'...')),`person`.`fname`,'  ',`person`.
`lname`,'(HN:',convert(visit.pid using utf8),') อายุ-ปดว:',getAgeYearNum(birth,visitdate),'-',getAgeMonthNum(birth,visitdate),'-',getAgeDayNum(birth,visitdate)) as pati
,IF(visitdate IS NULL,'',concat(convert(DAY(visitdate) using utf8),' ',
   CASE WHEN MONTH(visitdate)=1 THEN 'มค'
   WHEN MONTH(visitdate)=2 THEN 'กพ' WHEN MONTH(visitdate)=3 THEN 'มีค'
   WHEN MONTH(visitdate)=4 THEN 'เมย' WHEN MONTH(visitdate)=5 THEN 'พค'
   WHEN MONTH(visitdate)=6 THEN 'มิย' WHEN MONTH(visitdate)=7 THEN 'กค'
   WHEN MONTH(visitdate)=8 THEN 'สค' WHEN MONTH(visitdate)=9 THEN 'กย'
   WHEN MONTH(visitdate)=10 THEN 'ตค' WHEN MONTH(visitdate)=11 THEN 'พย'
   WHEN MONTH(visitdate)=12 THEN 'ธค' END,' ',YEAR(visitdate)+543) )
   as visitdate
,date_format(`visit`.`visitdate`,'%Y-%m-%d') as vsd,
Concat('ยา: ',`cdrug`.`drugname`) as drugn,
Concat(CAST(`visitdrug`.`unit` As Char), ' ', ifnull(IFNULL(`unitsellname`,unitsell),'หน่วย')) as unt,
Concat('วิธีใช้: ',`visitdrug`.`dose`) as used,
Concat(`chospital`.`hosname`,' จ.',`cprovince`.`provname`) as hos,
concat('คำเตือน: ',IFNULL(cdrug.drugcaution,'-')) as caution,
concat('สรรพคุณ: ',IFNULL(cdrug.drugproperties,'-')) as drugproperties,
cdrug.drugcode
#,cdrug.dateexpire as dateexpire
,IF(cdrug.dateexpire IS NULL OR DAY(cdrug.dateexpire)='0','',concat('หมดอายุ:',convert(DAY(cdrug.dateexpire) using utf8),' ',CASE WHEN MONTH(cdrug.dateexpire)=1 THEN 'มค'
   WHEN MONTH(cdrug.dateexpire)=2 THEN 'กพ' WHEN MONTH(cdrug.dateexpire)=3 THEN 'มีค'
   WHEN MONTH(cdrug.dateexpire)=4 THEN 'เมย' WHEN MONTH(cdrug.dateexpire)=5 THEN 'พค' WHEN MONTH(cdrug.dateexpire)=6 THEN 'มิย'
   WHEN MONTH(cdrug.dateexpire)=7 THEN 'กค' WHEN MONTH(cdrug.dateexpire)=8 THEN 'สค' WHEN MONTH(cdrug.dateexpire)=9 THEN 'กย'
   WHEN MONTH(cdrug.dateexpire)=10 THEN 'ตค' WHEN MONTH(cdrug.dateexpire)=11 THEN 'พย' WHEN MONTH(cdrug.dateexpire)=12 THEN 'ธค'
   END,' ',YEAR(cdrug.dateexpire)+543)) as dateexpire
, IFNULL(`office`.`tel`,'') as tel
FROM
`visit`
Inner Join `person` ON `person`.`pid` = `visit`.`pid` and person.pcucodeperson = visit.pcucodeperson
left join ctitle on person.prename = titlecode
Inner Join `visitdrug` ON `visit`.`visitno` = `visitdrug`.`visitno` and visit.pcucode = visitdrug.pcucode
Inner Join `cdrug` ON `visitdrug`.`drugcode` = `cdrug`.`drugcode`
left join cdrugunitsell on unitsell = unitsellcode
,`office`
Inner Join `chospital` ON `office`.`offid` = `chospital`.`hoscode`
Inner Join `cprovince` ON `chospital`.`provcode` = `cprovince`.`provcode`

where
	visit.visitno = '$P!{vn}' and visit.pcucode = '$P!{HCC}'
        and visitdrug.dose is not null
        and trim(visitdrug.dose)<>""
	and (cdrug.drugtype ='01' || cdrug.drugtype ='10')
        and chospital.hoscode = '$P!{HCC}']]>
	</queryString>
	<field name="pid" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="pati" class="java.lang.String"/>
	<field name="visitdate" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="vsd" class="java.lang.String"/>
	<field name="drugn" class="java.lang.String"/>
	<field name="unt" class="java.lang.String"/>
	<field name="used" class="java.lang.String"/>
	<field name="hos" class="java.lang.String"/>
	<field name="caution" class="java.lang.String"/>
	<field name="drugproperties" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="drugcode" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="dateexpire" class="java.lang.String">
		<fieldDescription><![CDATA[วันหมดอายุฯ]]></fieldDescription>
	</field>
	<field name="tel" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
