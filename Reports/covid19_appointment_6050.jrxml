<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="covid19_appointment_6050" pageWidth="184" pageHeight="141" orientation="Landscape" columnWidth="156" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" uuid="bda8716e-35c3-487f-b169-85966e77b690">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="2.5937424601000028"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="person" class="java.lang.String" isForPrompting="false"/>
	<parameter name="_pid" class="java.lang.String"/>
	<queryString>
		<![CDATA[select ch.hosname as hosname1
,va.pid
,p.prename
,IFNULL(ct1.titlename,'คุณ') as titlename
,p.fname
,IFNULL(p.lname,'') AS lname
,va.vaccinecode
,if(va.vaccinecode = 'COVID19-1',
'นัดฉีดวัคซีน  Covid-19 เข็มที่ 1',
if(va.vaccinecode = 'COVID19-2',
'นัดฉีดวัคซีน  Covid-19 เข็มที่ 2','นัดฉีดวัคซีน  Covid-19 เข็มที่ 3')
) as apporeason
,va.dateappoint
,date_format(va.dateappoint,'%d') as dd_appo,
(case when date_format(va.dateappoint,'%m') = '01' then 'ม.ค.'
when date_format(va.dateappoint,'%m') = '02' then 'ก.พ.'
when date_format(va.dateappoint,'%m') = '03' then 'มี.ค.'
when date_format(va.dateappoint,'%m') = '04' then 'เม.ษ.'
when date_format(va.dateappoint,'%m') = '05' then 'พ.ค.'
when date_format(va.dateappoint,'%m') = '06' then 'มิ.ย.'
when date_format(va.dateappoint,'%m') = '07' then 'ก.ค.'
when date_format(va.dateappoint,'%m') = '08' then 'ส.ค.'
when date_format(va.dateappoint,'%m') = '09' then 'ก.ย.'
when date_format(va.dateappoint,'%m') = '10' then 'ต.ค.'
when date_format(va.dateappoint,'%m') = '11' then 'พ.ย.'
when date_format(va.dateappoint,'%m') = '12' then 'ธ.ค.'
else 'n/a' end) as mm_appo
,substring((date_format(va.dateappoint,'%Y')+543),3,2) as yy_appo
,IFNULL(va.hoscodeappoint,'ไม่ระบุ') as hoscodeappoint
,IFNULL(h.hosname,'ไม่ระบุ') as hosname_appo
,IFNULL(va.userappoint,'ไม่ระบุ') as userappoint
,u.prename
,IFNULL(ct.titlename,'ไม่ระบุ') as titilapp
,IFNULL(u.fname,'ไม่ระบุ') as nameappo
,IFNULL(u.lname,'ไม่ระบุ') as lnameapp
,IFNULL(va.manufacturer,'ไม่ระบุ') as manufacturer
,IFNULL(va.preparebeforeinj,'ไม่ระบุ') as preparebeforeinj
,IFNULL(vm.manufac_name,'ไม่ระบุ') as manufac_name
from visitepiappoint va
left join ccovid19_vaccinemanufac vm on(va.manufacturer = vm.manufac_vcodeprefix)
left join person p on (va.pid = p.pid and va.pcucodeperson = p.pcucodeperson)
left join ctitle ct1 on (p.prename = ct1.titlecode)
left join chospital h on (va.hoscodeappoint = h.hoscode)
left join chospital ch on (va.pcucodeperson = ch.hoscode)
left join user u on (va.userappoint = u.username)
left join ctitle ct on (u.prename = ct.titlecode)
where ucase(va.vaccinecode) in  ('COVID19-1','COVID19-2','COVID19-3')
and va.pid =  $P{_pid}
order by va.dateappoint]]>
	</queryString>
	<field name="hosname1" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
