	<field name="yy_appo" class="java.lang.Object"/>
	<field name="hoscodeappoint" class="java.lang.String">
		<fieldDescription><![CDATA[สถานบริการที่นัดฉีดวัคซีนโควิด-19(และวัคซีนอื่นๆ)]]></fieldDescription>
	</field>
	<field name="hosname_appo" class="java.lang.String"/>
	<field name="userappoint" class="java.lang.String">
		<fieldDescription><![CDATA[แพทย์ หรือ จนท. ผู้นัดฯ]]></fieldDescription>
	</field>
	<field name="titilapp" class="java.lang.String"/>
