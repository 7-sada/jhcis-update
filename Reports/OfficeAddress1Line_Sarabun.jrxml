<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="OfficeAddress1Line_Sarabun" pageWidth="535" pageHeight="802" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="e4e74d73-25a6-465e-a6de-a2204c1109f6">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Program Files (x86)\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'08989'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     chospital.`hosname` AS chospital_hosname,
     chospital.`mu` AS chospital_mu,
     csubdistrict.`subdistname` AS csubdistrict_subdistname,
     cdistrict.`distname` AS cdistrict_distname,
     cprovince.`provname` AS cprovince_provname
FROM
     `chospital` chospital INNER JOIN `office` office ON chospital.`hoscode` = office.`offid`
     INNER JOIN `csubdistrict` csubdistrict ON chospital.`provcode` = csubdistrict.`provcode`
     AND chospital.`subdistcode` = csubdistrict.`subdistcode`
     AND chospital.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cdistrict` cdistrict ON csubdistrict.`provcode` = cdistrict.`provcode`
     AND cdistrict.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cprovince` cprovince ON cdistrict.`provcode` = cprovince.`provcode`
WHERE offid=$P!{pcucode}]]>
	</queryString>
	<field name="chospital_hosname" class="java.lang.String"/>
	<field name="chospital_mu" class="java.lang.String"/>
	<field name="csubdistrict_subdistname" class="java.lang.String"/>
	<field name="cdistrict_distname" class="java.lang.String"/>
	<field name="cprovince_provname" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="37" splitType="Stretch">
			<textField isBlankWhenNull="false">
				<reportElement uuid="ed23917c-ab65-4568-a11d-fb0e4c00df57" key="textField" x="43" y="7" width="492" height="22"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="TH SarabunPSK" size="16" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["สถานบริการ : "+$F{chospital_hosname}+
"  ต."+$F{csubdistrict_subdistname}+
"  อ."+$F{cdistrict_distname}+
"  จ."+$F{cprovince_provname}]]></textFieldExpression>
			</textField>
			<image>
				<reportElement uuid="7f26b987-ba11-4e9c-8c5a-0cc79ef796bc" x="2" y="0" width="41" height="37"/>
				<imageExpression><![CDATA[$P{SUBREPORT_DIR}+"\\logo_tbhphosp.jpg"]]></imageExpression>
			</image>
		</band>
