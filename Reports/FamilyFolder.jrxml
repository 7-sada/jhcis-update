	<queryString>
		<![CDATA[SELECT `P`.`pcucodeperson`, `P`.`hcode`,
     CONCAT(`P`.`prename`,`P`.`fname`) AS `fname`, `P`.`lname`, `P`.`familyno`
FROM `person` `P`
WHERE `P`.`pcucodeperson`=$P{pcucodeperson} AND `P`.`hcode`=$P{hcode}
ORDER BY `P`.`familyno` ASC]]>
	</queryString>
