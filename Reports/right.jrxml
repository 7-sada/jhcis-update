	<queryString>
		<![CDATA[SELECT
vright_2_tp.rightcode,
cright.rightname,
crightgroup.rightgroupname,
vright_2_tp.rightgroup,
vright_2_tp.countpid,
vright_2.m_True,
vright_2.m_fac,
vright_2.m,
vright_2.freq,
vright_new_in_mon.newpid
FROM
cright
Inner Join crightgroup ON cright.rightgroup = crightgroup.rightgroupcode
Left Join vright_2_tp ON cright.rightcode = vright_2_tp.rightcode
Left Join vright_2 ON cright.rightcode = vright_2.rightcode
Left Join vright_new_in_mon ON cright.rightcode = vright_new_in_mon.rs_sh
ORDER BY
cright.rightgroup ASC,
vright_2_tp.rightcode ASC]]>
	</queryString>
