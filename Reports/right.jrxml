				</box>
				<textElement>
					<font fontName="Tahoma" size="10"/>
				</textElement>
				<text><![CDATA[หมายเหตุ: หากรายงานนี้แสดงข้อมูลที่ไม่สมเหตุสมผล เช่นจำนวนสิทธิขาดหรือเกิน / จำนวนในบรรทัดรวมไม่เท่ากับจำนวนรายการย่อยรวมกัน ให้ไปตรวจสอบ]]></text>
			</staticText>
			<staticText>
				<reportElement key="staticText-8" x="4" y="27" width="525" height="16" uuid="1e4293b9-cdfe-4bf7-89f2-b09181ab3674"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font fontName="Tahoma" size="10"/>
				</textElement>
				<text><![CDATA[                 รหัส สิทธิการรักษา และรหัส ประเภทสิทธิเทียบกับในรายงานรหัส....ใหม่(ที่เมนูรายงาน / ปุ่มคำสั่ง รหัส...ใหม่)----โดยจะต้องกำหนดค่าสิทธิการรักษา]]></text>
			</staticText>
			<staticText>
				<reportElement key="staticText-9" x="4" y="42" width="525" height="17" uuid="196c1be9-6e3d-404c-b1a7-a20a1103f9c4"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font fontName="Tahoma" size="10"/>
				</textElement>
				<text><![CDATA[                 และประเภทสิทธิ ให้ตรงกับในรายงาน รหัส....ใหม่]]></text>
			</staticText>
