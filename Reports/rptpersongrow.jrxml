<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptpersongrow"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="76"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="round" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(1)]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\EditPrename\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and person.pcucodeperson ='09900'"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-05-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="budgetyear" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT  case when  (getagemonth(birth,persongrow.datesurvey ) < 1)  then "A" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  1 and 2)  then "B" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  3 and 4)  then "C" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  5 and 6)  then "D" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  7 and 8)  then "E" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  9 and 10)  then "F" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  11 and 12)  then "G" 
          when  (getagemonth(birth,persongrow.datesurvey )  between  13 and 15)  then "H" 
          when  (getagemonth(birth,persongrow.datesurvey )  between 16 and 18)  then "I" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  19 and 24)  then "J" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  25 and 30)  then "K" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  31 and 36)  then "L"
	 when  (getagemonth(birth,persongrow.datesurvey)  between  37 and 48)  then "M"
	 when  (getagemonth(birth,persongrow.datesurvey)  between  39 and 60)  then "N"
	 when  (getagemonth(birth,persongrow.datesurvey)  between  61 and 72)  then "O"
           else "P" end as agemonthsort
,case when  (getagemonth(birth,persongrow.datesurvey) < 1)  then "แรกเกิด   -   1 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  1 and 2)  then "  1 เดือน - 2 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  3 and 4)  then "3 เดือน - 4 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  5 and 6)  then "5 เดือน - 6 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  7 and 8)  then "7 เดือน - 8 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  9 and 10)  then "9 เดือน - 10 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  11 and 12)  then "11 เดือน - 12 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  13 and 15)  then "13 เดือน - 15 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  16 and 18)  then "16 เดือน - 18 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  19 and 24)  then "19 เดือน - 24 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  25 and 30)  then "25 เดือน - 30 เดือน" 
          when  (getagemonth(birth,persongrow.datesurvey)  between  31 and 36)  then "31 เดือน - 36 เดือน"
          when  (getagemonth(birth,persongrow.datesurvey)  between  37 and 48)  then "37 เดือน - 48 เดือน"
          when  (getagemonth(birth,persongrow.datesurvey)  between  49 and 60)  then "49 เดือน - 60 เดือน"
          when  (getagemonth(birth,persongrow.datesurvey)  between  61 and 72)  then "61 เดือน - 72 เดือน"
           else "ไม่บันทึกวันตรวจ" end as agemonth

,count(distinct person.pid,person.pcucodeperson) as cperson
,count(distinct persongrow.pid,persongrow.pcucodeperson) as cpersongrow

,sum(case when (persongrow.agemonthcan <= cgrow.growstd  ) then 1 else 0 end) as sumgood
,sum(case when (persongrow.agemonthcan > cgrow.growstd  ) then 1 else 0 end) as sumfail
,DATE_FORMAT(curdate(),'%Y-%m-%d') currentDate
,curdate() cdate
,person.pcucodeperson pcucode
,hosname
,$P{budgetyear}+543 as cyear
,($P{budgetyear}+543)-1 as byear
FROM person 
	inner join persongrow on person.pid = persongrow.pid and person.pcucodeperson = persongrow.pcucodeperson
	inner join cgrow on persongrow.growcode = cgrow.growcode
        inner join chospital on person.pcucodeperson = chospital.hoscode
	inner join visit on persongrow.pid = visit.pid and persongrow.pcucodeperson = visit.pcucodeperson
WHERE getagemonth(birth,visitdate) < 73
     and
     case when $P{round}= 1 then
        persongrow.datesurvey between CONCAT(($P{budgetyear})-1 ,"-10","-01")  and CONCAT($P{budgetyear} ,"-03","-31") 
     else
        persongrow.datesurvey between CONCAT($P{budgetyear} ,"-04","-01")  and CONCAT($P{budgetyear},"-09","-30") end
      $P!{pcucode}
GROUP BY agemonth
ORDER BY agemonthsort]]></queryString>

	<field name="agemonthsort" class="java.lang.String"/>
	<field name="agemonth" class="java.lang.String"/>
	<field name="cperson" class="java.lang.Long"/>
	<field name="cpersongrow" class="java.lang.Long"/>
	<field name="sumgood" class="java.math.BigDecimal"/>
	<field name="sumfail" class="java.math.BigDecimal"/>
	<field name="currentDate" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="cyear" class="java.lang.Long"/>
	<field name="byear" class="java.lang.Double"/>

	<variable name="SUM_cperson_1" class="java.lang.Long" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{cperson}]]></variableExpression>
	</variable>
	<variable name="SUM_cpersongrow_1" class="java.lang.Long" resetType="Report" calculation="Sum">
