	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="startdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2008-10-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="enddate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2008-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01838"]]></defaultValueExpression>
	</parameter>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="offAddress" class="java.lang.String"/>
	<parameter name="ye_r" class="java.lang.String"/>
	<parameter name="ye_rt" class="java.lang.Integer"/>
	<parameter name="d15Y" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT villname,a.villcode
,IFNULL(a.male,0)+IFNULL(a.female,0) aall
,a.male m1
,FORMAT(a.male*100/(IFNULL(a.male,0)+IFNULL(a.female,0)),2) pm1
,a.female f1
,FORMAT(a.female*100/(IFNULL(a.male,0)+IFNULL(a.female,0)),2) pf1
,IFNULL(b.male,0)+IFNULL(b.female,0) ball
,b.male m2
,FORMAT(b.male*100/(IFNULL(b.male,0)+IFNULL(b.female,0)),2) pm2
,b.female f2
,FORMAT(b.female*100/(IFNULL(b.male,0)+IFNULL(b.female,0)),2) pf2
,IFNULL(c.male,0)+IFNULL(c.female,0) ctot
,c.male m3
,c.female f3
FROM
(SELECT d.villcode,SUM(case WHEN sex='1' THEN 1 ELSE 0 END) male, SUM(case WHEN sex='2' THEN 1 ELSE 0 END) female
 FROM
	(SELECT c.* FROM
		(SELECT a1.* FROM
			(SELECT  h.villcode, p.sex, p.pcucodeperson, p.pid, p.birth
			 FROM person p
			 JOIN house h ON p.pcucodeperson=h.pcucode AND p.hcode=h.hcode
                               WHERE getAgeYearNum(birth,$P{d15Y}) >14
                                  AND RIGHT(villcode,2)<>'00'
			 ORDER BY villcode, p.pid
			) AS a1
			GROUP BY a1.pid
		) AS c
	) AS d GROUP BY d.villcode
) AS a
LEFT JOIN
(SELECT d.villcode,SUM(case WHEN sex='1' THEN 1 ELSE 0 END) male, SUM(case WHEN sex='2' THEN 1 ELSE 0 END) female
 FROM
	(SELECT c.* FROM
		(SELECT a1.*,MAX(dateserv) maxD FROM
			(SELECT  h.villcode, p.sex, f.pcucodeperson, f.pid, f.dateserv, f.ppspecial, p.birth
			 FROM f43specialpp f JOIN person p ON f.pcucodeperson=p.pcucodeperson AND f.pid=p.pid
			 JOIN house h ON p.pcucodeperson=h.pcucode AND p.hcode=h.hcode
			 WHERE UCase(left(ppspecial,3)) IN('1B5') AND RIGHT(villcode,2)<>'00' AND f.dateserv < $P{d15Y}
			 ORDER BY villcode, p.pid,f.dateserv DESC
			) AS a1
			GROUP BY a1.pid
		) AS c
		WHERE getAgeYearNum(birth,maxD) >14
	) AS d GROUP BY d.villcode
) AS b
ON a.villcode=b.villcode
LEFT JOIN
(SELECT d.villcode,SUM(case WHEN sex='1' THEN 1 ELSE 0 END) male, SUM(case WHEN sex='2' THEN 1 ELSE 0 END) female
 FROM
	(SELECT c.* FROM
		(SELECT a1.*,MAX(dateserv) maxD FROM
			(SELECT  h.villcode, p.sex, f.pcucodeperson, f.pid, f.dateserv, f.ppspecial, p.birth
			 FROM f43specialpp f JOIN person p ON f.pcucodeperson=p.pcucodeperson AND f.pid=p.pid
			 JOIN house h ON p.pcucodeperson=h.pcucode AND p.hcode=h.hcode
			 WHERE UCase(left(ppspecial,3)) IN('1B5') AND RIGHT(villcode,2)<>'00' AND f.dateserv < $P{d15Y}
			 ORDER BY villcode, p.pid,f.dateserv DESC
			) AS a1
			GROUP BY a1.pid
		) AS c
		WHERE getAgeYearNum(birth,maxD) >14
			AND (UCASE(LEFT(c.ppspecial,4)) in('1B50','1B53')
					 OR UCASE(LEFT(c.ppspecial,5)) in('1B540','1B541','1B550','1B551','1B560','1B561'))
	) AS d GROUP BY d.villcode
) AS c
ON a.villcode=c.villcode
JOIN village v ON a.villcode=v.villcode
ORDER BY v.villcode]]>
	</queryString>
