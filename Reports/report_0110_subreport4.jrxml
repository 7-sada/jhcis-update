	<queryString>
		<![CDATA[SELECT
     v0110_5_rgroup.`rname` AS v0110_5_rgroup_rname,
     v0110_5_canc_pap_new.`ncount` AS v0110_5_canc_pap_new_ncount,
     v0110_5_canc_breast_new.`ncount` AS v0110_5_canc_breast_new_ncount,
     v0110_5_thal_new.`ncount` AS v0110_5_thal_new_ncount,
     v0110_5_thalcon_new.`ncount` AS v0110_5_thalcon_new_ncount,
     v0110_5_thal_childc_new.`ncount` AS v0110_5_thal_childc_new_ncount,
     v0110_5_thal_endpreg.`ncount` AS v0110_5_thal_endpreg_ncount,
     v0110_5_tr_new.`ncount` AS v0110_5_tr_new_ncount,
     v0110_5_tr_ocon.`ncount` AS v0110_5_tr_ocon_ncount,
     v0110_5_tr_udrug_new.`ncount` AS v0110_5_tr_udrug_new_ncount,
     v0110_5_healthperf.`ncount` AS v0110_5_healthperf_ncount,
     v0110_visithome_coun.`ncount` AS v0110_visithome_coun_ncount,
     v0110_visithome_count.`ncount` AS v0110_visithome_coun_hh_coun,
     v0110_healthserv_sch.`ncount` AS v0110_healthserv_sch_ncount,
     v0110_healthserv_sch.`serv_coun` AS v0110_healthserv_sch_serv_coun,
     v0110_healthserv_other.`ncount` AS v0110_healthserv_other_ncount,
     v0110_healthserv_other.`serv_coun` AS v0110_healthserv_other_serv_coun
FROM
     `v0110_5_rgroup` v0110_5_rgroup LEFT OUTER JOIN `v0110_5_canc_pap_new` v0110_5_canc_pap_new ON v0110_5_rgroup.`rgroup` = v0110_5_canc_pap_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_canc_breast_new` v0110_5_canc_breast_new ON v0110_5_rgroup.`rgroup` = v0110_5_canc_breast_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_thal_new` v0110_5_thal_new ON v0110_5_rgroup.`rgroup` = v0110_5_thal_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_thalcon_new` v0110_5_thalcon_new ON v0110_5_rgroup.`rgroup` = v0110_5_thalcon_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_thal_childc_new` v0110_5_thal_childc_new ON v0110_5_rgroup.`rgroup` = v0110_5_thal_childc_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_thal_endpreg` v0110_5_thal_endpreg ON v0110_5_rgroup.`rgroup` = v0110_5_thal_endpreg.`rgroup`
     LEFT OUTER JOIN `v0110_5_tr_new` v0110_5_tr_new ON v0110_5_rgroup.`rgroup` = v0110_5_tr_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_tr_ocon` v0110_5_tr_ocon ON v0110_5_rgroup.`rgroup` = v0110_5_tr_ocon.`rgroup`
     LEFT OUTER JOIN `v0110_5_tr_udrug_new` v0110_5_tr_udrug_new ON v0110_5_rgroup.`rgroup` = v0110_5_tr_udrug_new.`rgroup`
     LEFT OUTER JOIN `v0110_5_healthperf` v0110_5_healthperf ON v0110_5_rgroup.`rgroup` = v0110_5_healthperf.`rgroup`
     LEFT OUTER JOIN `v0110_visithome_count` v0110_visithome_count ON v0110_5_rgroup.`rgroup` = v0110_visithome_count.`rgroup`
     LEFT OUTER JOIN `v0110_visithome_coun` v0110_visithome_coun ON v0110_5_rgroup.`rgroup` = v0110_visithome_coun.`rgroup`
     LEFT OUTER JOIN `v0110_healthserv_sch` v0110_healthserv_sch ON v0110_5_rgroup.`rgroup` = v0110_healthserv_sch.`rgroup`
     LEFT OUTER JOIN `v0110_healthserv_other` v0110_healthserv_other ON v0110_5_rgroup.`rgroup` = v0110_healthserv_other.`rgroup`]]>
	</queryString>
