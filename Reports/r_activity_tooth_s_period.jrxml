	<queryString>
		<![CDATA[SELECT
v_activity_tooth_s_tot.ay AS ayasc,
v_activity_tooth_s_tot.s_period_counp,
v_activity_tooth_s_tot.s_t_tot,
v_activity_tooth_s_tot.s_t_fail,
v_activity_tooth_s_fail.s_period_counp_fail
FROM
v_activity_tooth_s_tot
Left Join v_activity_tooth_s_fail ON v_activity_tooth_s_tot.ay = v_activity_tooth_s_fail.ay]]>
	</queryString>
	<field name="ayasc" class="java.lang.Double"/>
	<field name="s_period_counp" class="java.lang.Long"/>
	<field name="s_t_tot" class="java.math.BigDecimal"/>
	<field name="s_t_fail" class="java.math.BigDecimal"/>
	<field name="s_period_counp_fail" class="java.lang.Long"/>
	<variable name="failRate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  ($F{s_period_counp_fail}.doubleValue())/$F{s_period_counp}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="failAvg" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  ($F{s_t_fail}.doubleValue())/$F{s_period_counp}.doubleValue())]]></variableExpression>
	</variable>
