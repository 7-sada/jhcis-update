<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="report1xxxx" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b781abec-33aa-40d3-8a35-4f9021d9a30a">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[select case when getAgeYearNum(birth, CURRENT_DATE) <5 then "0-4"
when getAgeYearNum(birth, CURRENT_DATE) >4 and getAgeYearNum(birth, CURRENT_DATE)<10 then "5-9"   when getAgeYearNum(birth, CURRENT_DATE) >9 then "10+" end ag
,sum(case when sex ='1' then 1 else 0 end) m
,sum(case when sex ='2' then 1 else 0 end) f
,sum(case when sex ='1' then 1 else 0 end)+sum(case when sex ='2' then 1 else 0 end) total
from
  person
group by
 case when getAgeYearNum(birth, CURRENT_DATE) <5 then "0-4"
when getAgeYearNum(birth, CURRENT_DATE) >4 and getAgeYearNum(birth, CURRENT_DATE)<10 then "5-9"   when getAgeYearNum(birth, CURRENT_DATE) >9 then "10+" end
order by case when getAgeYearNum(birth, CURRENT_DATE) <5 then "1"
when getAgeYearNum(birth, CURRENT_DATE) >4 and getAgeYearNum(birth, CURRENT_DATE)<10 then "2"   when getAgeYearNum(birth, CURRENT_DATE) >9 then "3" end]]>
	</queryString>
	<field name="ag" class="java.lang.String"/>
	<field name="m" class="java.math.BigDecimal"/>
	<field name="f" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
