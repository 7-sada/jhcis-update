	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucp" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["06654"]]></defaultValueExpression>
	</parameter>
	<parameter name="hn" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["6"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select IF(p2.drugcode IS NULL,null,@i:=@i+1) AS rowno ,ifnull(p1.allergic,'..ไม่ระบุฯ') allergic,p2.pcucodeperson,p2.pid,p2.drugcode,d.drugname
from person p1 left join personalergic p2 on p1.pcucodeperson=p2.pcucodeperson AND p1.pid=p2.pid
               left join cdrug d on p2.drugcode = d.drugcode, (SELECT @i:=0) AS foo
where p1.pcucodeperson = $P{pcucp} and p1.pid = $P{hn}]]>
	</queryString>
	<field name="allergic" class="java.lang.String"/>
	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="drugcode" class="java.lang.String"/>
	<field name="drugname" class="java.lang.String"/>
	<field name="rowno" class="java.lang.Number"/>
