<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="r_activity_gum_stat" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT v_activity_toothgum_st3.ay AS ayAsc,
Sum( if(v_activity_toothgum_st2.gumstatus = 0 , 1, 0 ) ) AS gum0,
Sum( if(v_activity_toothgum_st2.gumstatus = 1 , 1, 0 ) ) AS gum1,
Sum( if(v_activity_toothgum_st2.gumstatus = 2 , 1, 0 ) ) AS gum2,
Sum( if(v_activity_toothgum_st2.gumstatus = 3 , 1, 0 ) ) AS gum3,
Count(v_activity_toothgum_st2.pid) AS s_gum_counp_tot
FROM v_activity_toothgum_st2
Inner Join v_activity_toothgum_st3 ON v_activity_toothgum_st3.pid = v_activity_toothgum_st2.pid
WHERE
v_activity_toothgum_st2.gumstatus <>  '9' AND
v_activity_toothgum_st2.gumstatus IS NOT NULL
GROUP BY v_activity_toothgum_st3.ay
ORDER BY ayAsc ASC]]>
	</queryString>
	<field name="ayAsc" class="java.lang.Double"/>
	<field name="gum0" class="java.math.BigDecimal"/>
	<field name="gum1" class="java.math.BigDecimal"/>
	<field name="gum2" class="java.math.BigDecimal"/>
	<field name="gum3" class="java.math.BigDecimal"/>
	<field name="s_gum_counp_tot" class="java.lang.Long"/>
	<variable name="gumNormalRate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  ($F{gum0}.doubleValue())/$F{s_gum_counp_tot}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="gum1Rate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  ($F{gum1}.doubleValue())/$F{s_gum_counp_tot}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="gum2Rate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  ($F{gum2}.doubleValue())/$F{s_gum_counp_tot}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="gum3Rate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  ($F{gum3}.doubleValue())/$F{s_gum_counp_tot}.doubleValue())]]></variableExpression>
	</variable>
