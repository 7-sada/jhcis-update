	<parameter name="VN" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[$P{VN}]]></parameterDescription>
		<defaultValueExpression><![CDATA["116499"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01179"]]></defaultValueExpression>
	</parameter>
	<parameter name="diagOrNot" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[Receive diagOrNot from class visitdiag]]></parameterDescription>
		<defaultValueExpression><![CDATA["... diagOrNot ..."]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
concat(chospital.`hosname`,' ต.',ifnull(csubdistricth.`subdistname`,'-'),' อ.',ifnull(cdistricth.`distname`,'-'),' จ.',ifnull(cprovinceh.`provname`,'-')) AS hostname,
#concat('ข้าพเจ้า ',ifnull(ctt1.`titlename`,'...'),ifnull(`user`.`fname`,`user`.`fullName`),'   ',ifnull(`user`.`lname`,'...')) as fullName,
concat('ข้าพเจ้า ',' ',docc.doc) as fullName,
#concat(ifnull(ctt1.`titlename`,'...'),ifnull(`user`.`fname`,`user`.`fullName`),'   ',ifnull(`user`.`lname`,'...')) as fullName2,
docc.doc as fullName2,
#`user`.`fullname` as pfl,
docc.doc as pfl,
ifnull(`user`.`officerposition`,'') as officerposition,
#concat(`person`.`prename`,`person`.`fname`) AS `fname`,
#concat(ifnull(ctt2.`titlename`,'...'),ifnull(`person`.`fname`,'...'),'   นามสกุล ',ifnull(`person`.`lname`,'...')) as `fname`,
concat(ifnull(ctt2.`titlename`,'...'),ifnull(`person`.`fname`,'...')) as `fname`,
`person`.`lname`,
`person`.`officework`,
`visit`.`visitno`,
#`visit`.`visitdate`,
convert(if(visitdate is null,'',concat(day(visitdate),' ',case when month(visitdate)=1 then 'มกราคม' when month(visitdate)=2 then 'กุมภาพันธ์' when month(visitdate)=3 then 'มีนาคม' when month(visitdate)=4 then 'เมษายน' when month(visitdate)=5 then 'พฤษภาคม' when month(visitdate)=6 then 'มิถุนายน' when month(visitdate)=7 then 'กรกฎาคม' when month(visitdate)=8 then 'สิงหาคม' when month(visitdate)=9 then 'กันยายน' when month(visitdate)=10 then 'ตุลาคม' when month(visitdate)=11 then 'พฤศจิกายน' when month(visitdate)=12 then 'ธันวาคม' else '..' end,' ',year(visitdate)+543)) using utf8) visitdate,
`visit`.`rightno`,
`visit`.`visitno`,
`visit`.`pid`,
concat('               ',ifnull(`visit`.`symptoms`,'...')) as symt,
concat('               ',ifnull(`visit`.`vitalcheck`,'...')) as vita,

concat('- ',`cdisease`.`diseasenamethai`,'(',visitdiag.diagcode,')') as diseasenamethai
FROM
`visit`
#Left Join `user` ON `user`.`username` = `visit`.`username` AND `user`.`pcucode` = `visit`.`pcucode`
LEFT JOIN(
SELECT CONCAT(IFNULL(titlename,''),IFNULL(fname,''),' ',IFNULL(lname,'')) doc ,vd.pcucode, vd.visitno, u.username
FROM visitdiag vd JOIN visit v ON v.pcucode=v.pcucode AND v.visitno=vd.visitno
LEFT JOIN `user` u ON vd.doctordiag=u.username
LEFT JOIN ctitle t ON u.prename=t.titlecode
WHERE vd.visitno=$P!{VN} GROUP BY vd.visitno ORDER BY doctordiag DESC LIMIT 1
) docc ON visit.pcucode=docc.pcucode and visit.visitno=docc.visitno
Left Join `user` ON docc.`username` = `user`.`username` AND `docc`.`pcucode` = `user`.`pcucode`
Left Join `person` ON `person`.`pid` = `visit`.`pid` AND `person`.`pcucodeperson` = `visit`.`pcucodeperson`
Left Join `visitdiag` ON `visit`.`visitno` = `visitdiag`.`visitno` AND `visit`.`pcucode` = `visitdiag`.`pcucode` #AND Lcase(left(visitdiag.diagcode,1)) <>'z'
AND (Lcase(left(visitdiag.diagcode,1) between 'a' and 'y') OR Lcase(visitdiag.diagcode) IN('z48.0'))
Left Join `cdisease` ON `visitdiag`.`diagcode` = `cdisease`.`diseasecode`
left join `ctitle` ctt1 on `user`.`prename` = `ctt1`.`titlecode`
left join `ctitle` ctt2 on `person`.`prename` = `ctt2`.`titlecode`
JOIN `chospital` chospital ON visit.`pcucode` = chospital.`hoscode`
left JOIN `csubdistrict` csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left outer JOIN `cdistrict` cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
     left outer JOIN `cprovince` cprovinceh ON chospital.provcode = cprovinceh.provcode
WHERE visit.visitno = $P!{VN} and visit.pcucode = $P!{HCC}]]>
	</queryString>
