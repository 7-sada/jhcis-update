<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDentProcess51" language="groovy" pageWidth="900" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="860" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-11-08"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-11-08"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select if(cright.rightgroup ='3','(UC ไม่มี ท)' ,'(UC มี ท )') as rightgroupname,date_format(visit.visitdate,'%Y-%m') ymt
,hosname
,curdate() as cdate
from visitdrugdental inner join visit on visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
inner join cright on visit.rightcode = cright.rightcode
left join crightgroup  on cright.rightgroup = crightgroup.rightgroupcode
inner join chospital on chospital.hoscode = visitdrugdental.pcucode
where  1=1
and cright.rightgroup in('3','4')
and visitdate between $P{sdate} and  $P{edate}
$P!{pcucode}
group by rightgroup,date_format(visit.visitdate,'%Y-%m')]]>
	</queryString>
	<field name="rightgroupname" class="java.lang.String"/>
	<field name="ymt" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
	<group name="rightname">
		<groupExpression><![CDATA[$F{rightgroupname}]]></groupExpression>
		<groupHeader>
			<band/>
		</groupHeader>
		<groupFooter>
			<band/>
		</groupFooter>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band height="41" splitType="Stretch">
			<staticText>
				<reportElement x="458" y="0" width="41" height="41"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<text><![CDATA[ของ]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="499" y="0" width="301" height="41"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{hosname}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="1" y="0" width="138" height="41"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<text><![CDATA[รายงานระหว่างวันที่ ]]></text>
			</staticText>
			<textField pattern="d MMMMM yyyy" isBlankWhenNull="true">
				<reportElement x="139" y="0" width="100" height="41"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cdate}.valueOf( $P{sdate} )]]></textFieldExpression>
			</textField>
			<textField pattern="d MMMMM yyyy" isBlankWhenNull="true">
				<reportElement x="266" y="0" width="100" height="41"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cdate}.valueOf( $P{edate} )]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<columnHeader>
		<band height="204" splitType="Stretch">
			<subreport>
				<reportElement stretchType="RelativeToBandHeight" x="0" y="0" width="803" height="25"/>
				<subreportParameter name="pcucode">
					<subreportParameterExpression><![CDATA[$P{pcucode}]]></subreportParameterExpression>
				</subreportParameter>
				<subreportParameter name="edate">
					<subreportParameterExpression><![CDATA[$P{edate}]]></subreportParameterExpression>
				</subreportParameter>
				<subreportParameter name="sdate">
					<subreportParameterExpression><![CDATA[$P{sdate}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<subreportExpression><![CDATA[$P{SUBREPORT_DIR} + "rptDentProcess51.jasper"]]></subreportExpression>
			</subreport>
