<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DrugOrder_subreport1_z" pageWidth="535" pageHeight="802" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="6e2cc792-1796-414b-b2bc-ab92faf182df">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Integer(161660)]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["06775"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     concat(if(dxtype is null or trim(dxtype)='','( )',concat('(',dxtype,')')),'-',diseasecode,' - ',cdisease.`diseasenamethai`) AS cdisease_diseasenamethai
FROM
`visitdiag` visitdiag
     INNER JOIN `cdisease` cdisease ON visitdiag.`diagcode` = cdisease.`diseasecode`
WHERE
     visitdiag.`visitno` = $P{visitno} AND visitdiag.pcucode = $P{pcucode}
order by visitdiag.`dxtype`]]>
	</queryString>
	<field name="cdisease_diseasenamethai" class="java.lang.String"/>
