<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpersonunable_list" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="22980d7f-e4f7-421f-916e-b9e22ee0901f">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT CONCAT(village.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,village.villno,
if(personunable1type.typecode is null,'ไม่ระบุความพิการ',cpersonincomplete.incompletename) AS incompletename,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname) AS pname,
CONCAT(DATE_FORMAT(CURRENT_DATE(),"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(CURRENT_DATE(),"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), "-",
 CASE SIGN(DATE_FORMAT(CURRENT_DATE(),"%m")-DATE_FORMAT(birth,"%m"))
  WHEN 0 THEN 0  WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(CURRENT_DATE(),"%m") -  (DATE_FORMAT(CURRENT_DATE(),"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
  WHEN 1 THEN(DATE_FORMAT(CURRENT_DATE(),"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(CURRENT_DATE(),"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  "-",
 CASE SIGN(DATE_FORMAT(CURRENT_DATE(),"%d") - DATE_FORMAT(birth,"%d"))
  WHEN 0 THEN 0  WHEN -1 THEN (DATE_FORMAT(LAST_DAY(birth),"%d") + DATE_FORMAT(CURRENT_DATE(), "%d")  -  DATE_FORMAT(birth, "%d"))
  WHEN 1 THEN (DATE_FORMAT(CURRENT_DATE(),"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(CURRENT_DATE(),"%d") < DATE_FORMAT(birth,"%d")))  END ) AS age,
person.hnomoi,
personunable.registerno,
CASE WHEN personunable1type.unablelevel=1 THEN 'ช่วยเหลือตัวเองได้'
 WHEN personunable1type.unablelevel=2 THEN 'ควรให้ความช่วยเหลือ'
 WHEN personunable1type.unablelevel=3 THEN 'ต้องช่วยเหลือด่วน !'
 WHEN personunable1type.unablelevel=9 THEN 'หายจากการพิการ' ELSE null END AS unablelevel,
DATE_FORMAT(personunable1type.datefound,'%Y-%m-%d') as datefound,
DATE_FORMAT(personunable.dateregister,'%Y-%m-%d') as dateregister
FROM
person
Inner Join personunable ON person.pcucodeperson = personunable.pcucodeperson AND person.pid = personunable.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
left outer Join personunable1type ON personunable.pcucodeperson = personunable1type.pcucodeperson AND personunable.pid = personunable1type.pid
left outer Join cpersonincomplete ON cpersonincomplete.incompletecode = personunable1type.typecode
Inner Join house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
Inner Join village ON village.villcode = house.villcode AND village.pcucode = house.pcucode
WHERE (person.mumoi is not null AND right(`house`.`villcode`,2) != '00')  AND
CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath) $P!{pcucode}
ORDER BY village.villcode,cpersonincomplete.incompletename,person.hnomoi]]>
	</queryString>
