	<field name="villno" class="java.lang.Integer"/>
	<field name="incompletename" class="java.lang.String"/>
	<field name="pname" class="java.lang.String"/>
	<field name="age" class="java.lang.String"/>
	<field name="hnomoi" class="java.lang.String"/>
	<field name="registerno" class="java.lang.String"/>
	<field name="unablelevel" class="java.lang.String"/>
	<field name="datefound" class="java.util.Date"/>
	<field name="dateregister" class="java.util.Date"/>
