	<subDataset name="data1" uuid="3edbe313-80ae-4423-a964-18af3b62cdb7">
		<parameter name="visitno" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[select vd.drugcode,d.drugname,vd.unit,vd.realprice,d.drugcodeaccountdept,
(vd.realprice*unit) as price1,noclaimprice,
(1-ifnull(noclaimprice,0))*vd.unit*vd.realprice  as paid
from visitdrug vd
join cdrug d on (vd.drugcode = d.drugcode)
where vd.visitno = $P{visitno}
and d.drugcode not like 'DF%' and (noclaimprice < 1 or noclaimprice is null)
order by d.drugtype]]>
		</queryString>
		<field name="drugcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="drugname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="unit" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="realprice" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="drugcodeaccountdept" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="price1" class="java.math.BigDecimal"/>
		<field name="noclaimprice" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="paid" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<variable name="sumtotal" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{paid}]]></variableExpression>
			<initialValueExpression><![CDATA[new Double(0.00)]]></initialValueExpression>
		</variable>
	</subDataset>
	<parameter name="visitno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select aa.pid,p.fname,p.lname,ct.titlename,ifnull(p.idcard,"ไม่ระบุเลขบัตรประชาชน") as idcard,aa.visitno,vr.receiptno,
IF(aa.visitdate IS NULL,'',concat(convert(DAY(aa.visitdate) using utf8),' ',
   CASE WHEN MONTH(aa.visitdate)=1 THEN 'ม.ค.'
   WHEN MONTH(aa.visitdate)=2 THEN 'ก.พ.' WHEN MONTH(aa.visitdate)=3 THEN 'มี.ค'
   WHEN MONTH(aa.visitdate)=4 THEN 'เม.ย.' WHEN MONTH(aa.visitdate)=5 THEN 'พ.ค.'
   WHEN MONTH(aa.visitdate)=6 THEN 'มิ.ย.' WHEN MONTH(aa.visitdate)=7 THEN 'ก.ค.'
   WHEN MONTH(aa.visitdate)=8 THEN 'ส.ค.' WHEN MONTH(aa.visitdate)=9 THEN 'ก.ย.'
   WHEN MONTH(aa.visitdate)=10 THEN 'ต.ค.' WHEN MONTH(aa.visitdate)=11 THEN 'พ.ย.'
   WHEN MONTH(aa.visitdate)=12 THEN 'ธ.ค.' END,' ',YEAR(visitdate)+543) )
   as visitdate,
concat(ifnull(aa.drugname1,"")," ",ifnull(diseasenamethai1,"")) as druganddisease,aa.pcucode,aa.pcucodeperson,aa.visitdate,aa.visitno,ch.hosname,o.tel
from
(
select p1.pid,group_concat(distinct p1.drugname) as drugname1,p1.visitno,group_concat(distinct p2.diseasenamethai) as diseasenamethai1
,p1.pcucode,p1.pcucodeperson,p1.visitdate
from
(select v.pid,pa.drugcode,v.visitno,v.pcucode,v.pcucodeperson,cd.drugname,v.visitdate
from visit v
left join personalergic pa on (v.pid = pa.pid and v.pcucodeperson = pa.pcucodeperson)
left join cdrug cd on (cd.drugcode = pa.drugcode)
where v.visitno = $P{visitno}) as p1
left join
(select v.pid,v.visitno,v.pcucode,pc.chroniccode,v.pcucodeperson,d1.diseasenamethai
from visit v
left join personchronic pc on (v.pid = pc.pid and v.pcucodeperson = pc.pcucodeperson)
left join cdisease d1 on (pc.chroniccode = d1.diseasecode)
where v.visitno = $P{visitno}) as p2
on (p1.pid = p2.pid and p1.visitno = p2.visitno and p1.pcucode = p2.pcucode)
group by p1.pid
) as aa
join chospital ch on (aa.pcucode = ch.hoscode)
left join office o on (ch.hoscode = o.offid)
left join visitreceiptno vr on (aa.visitno = vr.visitno)
join person p on (p.pid = aa.pid and p.pcucodeperson = aa.pcucodeperson)
left join ctitle ct on (ct.titlecode = p.prename)
where vr.visitno = $P{visitno} and vr.flag is null and vr.datetime_cancel is null ]]>
	</queryString>
