<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rrb1k01pregnancy"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="694"
		 pageHeight="595"
		 columnWidth="694"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="56"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-06-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-05-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select v.visitno,v.pcucode,v.visitdate
     ,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),p.fname,' ',p.lname) using utf8) as personname
     ,house.hno,village.villname
     ,DATE_FORMAT(p.birth, "%Y-%m-%d") as birth,p.birth as bb 
     ,DATE_FORMAT(vanc.dateappointcheck,"%Y-%m-%d")as dateappointcheck
     ,if(birth is not null ,
     CONVERT(CONCAT(  DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " / ",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))  
 	   WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	   WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	   WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " / ",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))
      	   WHEN 0 THEN(DATE_FORMAT(v.visitdate,"%d")- DATE_FORMAT(birth,"%d") )
      	   WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.visitdate),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))
      	   WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) ,'ไม่มีวันเกิด')  AS age_ymd 
     ,MAX(vanc.pregno),  round(DATEDIFF(dateappointcheck,lmp) /7 ) preage
     ,h.hosname,d.distname,pr.provname
from person p 
     left join  visit v  on v.pid= p.pid and v.pcucodeperson = p.pcucodeperson
     left join visitanc vanc on p.pid = vanc.pid  and p.pcucodeperson =  vanc.pcucodeperson
     left join ctitle on p.prename = ctitle.titlecode 
     left join visitancpregnancy on  p.pid = visitancpregnancy.pid   and p.pcucodeperson  = visitancpregnancy.pcucodeperson   and vanc.pregno = visitancpregnancy.pregno
     left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
     left join village on village.villcode = house.villcode and village.pcucode = v.pcucode
     left join chospital h on h.hoscode=v.pcucode 
     left join cdistrict d on d.distcode = h.distcode and d.provcode = h.provcode
     left join cprovince pr on pr.provcode = h.provcode    
where vanc.dateappointcheck between $P{sdate} and $P{edate}
     and visitdate in (select Max(visitdate) from visit vc where vc.visitno = v.visitno and vc.pcucode = v.pcucode and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 ) group by vc.visitno,vc.pcucode)
     and p.pid in(select visitanc.pid from visitanc where visitanc.pid = p.pid and visitanc.pcucodeperson = p.pcucodeperson)
     $P!{pcucode} 
group by v.pid,v.pcucodeperson
order by v.pcucode,village.villcode,vanc.dateappointcheck]]></queryString>

