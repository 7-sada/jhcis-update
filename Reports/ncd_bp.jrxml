<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="ncd_bp"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-05-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["c:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["15"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select village.villno
,village.villname,village.villcode,v.visitdate

,o.upperhypern,o.upperhyperh,o.lowerhypern,o.lowerhyperr
,sum(case when ( SUBSTRING_INDEX(v.pressure,'/',1) < o.upperhypern  &&  SUBSTRING_INDEX(v.pressure,'/',-1) < o.lowerhypern ) then 1 else 0 end) as g1
,sum(case when ( SUBSTRING_INDEX(v.pressure,'/',1) < o.upperhypern  &&  SUBSTRING_INDEX(v.pressure,'/',-1) > o.lowerhyperr ) then 1 else 0 end) as g2
,sum(case when ( (SUBSTRING_INDEX(v.pressure,'/',1) between o.upperhypern and o.upperhyperh ) && SUBSTRING_INDEX(v.pressure,'/',-1) <= o.lowerhyperr ) then 1 else 0 end) as g3
,sum(case when ( SUBSTRING_INDEX(v.pressure,'/',1) >= o.upperhyperh  &&  SUBSTRING_INDEX(v.pressure,'/',-1) >= o.lowerhyperr ) then 1 else 0 end) as g4

,( (sum(case when ( SUBSTRING_INDEX(v.pressure,'/',1) < o.upperhypern  &&  SUBSTRING_INDEX(v.pressure,'/',-1) < o.lowerhypern ) then 1 else 0 end))
+ (sum(case when ( SUBSTRING_INDEX(v.pressure,'/',1) < o.upperhypern  &&  SUBSTRING_INDEX(v.pressure,'/',-1) > o.lowerhyperr ) then 1 else 0 end))
+ (sum(case when ( (SUBSTRING_INDEX(v.pressure,'/',1) between o.upperhypern and o.upperhyperh ) && SUBSTRING_INDEX(v.pressure,'/',-1) <= o.lowerhyperr ) then 1 else 0 end)) 
+ (sum(case when ( SUBSTRING_INDEX(v.pressure,'/',1) >= o.upperhyperh  &&  SUBSTRING_INDEX(v.pressure,'/',-1) >= o.lowerhyperr ) then 1 else 0 end)) ) as tt

,v.pcucode
,chospital.hosname,cprovince.provname,cdistrict.distname
,csd.subdistname
from visit v 
        left join person p on(p.pid=v.pid and p.pcucodeperson = v.pcucodeperson)
        left join visitdiag  vd on v.visitno = vd.visitno and v.pcucode=vd.pcucode 
        left join office o on v.pcucode = o.offid
        left join house ON p.hcode = house.hcode and p.pcucodeperson = house.pcucode
	left join village  ON house.villcode = village.villcode and house.pcucode = village.pcucode
        left join chospital ON v.pcucode = chospital.hoscode
	left join cprovince ON cprovince.provcode =chospital.provcode
        left join cdistrict ON cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode 
             left join csubdistrict csd on csd.provcode = left(village.villcode,2) and csd.distcode = substring(village.villcode,3,2) and csd.subdistcode = substring(village.villcode,5,2)
where DATEDIFF(concat(YEAR($P{pdate}),'-','07','-','01'),p.birth)/365 >= $P{age}
	and (birth IS NOT NULL OR birth NOT LIKE '0000%')
        and visitdate in (select Max(visitdate) from visit vv where vv.pid = v.pid and vv.pcucodeperson = v.pcucodeperson and vv.visitdate between $P{sdate} and $P{edate} group by vv.pid,vv.pcucodeperson)
       	and right(village.villcode,2)<>'00'  
        and left(vd.diagcode,2) !=  'I1'
        and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
  	$P!{pcucode}
group by village.villcode]]></queryString>

	<field name="villno" class="java.lang.Integer"/>
	<field name="villname" class="java.lang.String"/>
	<field name="villcode" class="java.lang.String"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="upperhypern" class="java.lang.Integer"/>
	<field name="upperhyperh" class="java.lang.Integer"/>
	<field name="lowerhypern" class="java.lang.Integer"/>
	<field name="lowerhyperr" class="java.lang.Integer"/>
	<field name="g1" class="java.math.BigDecimal"/>
	<field name="g2" class="java.math.BigDecimal"/>
	<field name="g3" class="java.math.BigDecimal"/>
	<field name="g4" class="java.math.BigDecimal"/>
	<field name="tt" class="java.math.BigDecimal"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="provname" class="java.lang.String"/>
	<field name="distname" class="java.lang.String"/>
	<field name="subdistname" class="java.lang.String"/>

	<variable name="SUM_g1_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{g1}]]></variableExpression>
	</variable>
	<variable name="SUM_g2_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{g2}]]></variableExpression>
	</variable>
	<variable name="SUM_g3_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{g3}]]></variableExpression>
	</variable>
	<variable name="SUM_g4_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{g4}]]></variableExpression>
	</variable>
	<variable name="SUM_tt_1" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{tt}]]></variableExpression>
	</variable>
