	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="where_person" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND (person.datein is null OR person.datein <= '2009-03-31')  AND (persondeath.deaddate is null OR persondeath.deaddate >= '2009-03-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND person.pcucodeperson='01856' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRep" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="sum_pop" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[",SUM(CASE WHEN person.sex='1' AND getagemonth(person.birth,'2009-03-31') BETWEEN 9 AND 15  THEN 1 ELSE null END) AS m,SUM(CASE WHEN person.sex='2' AND getagemonth(person.birth,'2009-03-31') BETWEEN 9 AND 15 THEN 1 ELSE null END) AS w "]]></defaultValueExpression>
	</parameter>
	<parameter name="header" isForPrompting="false" class="java.lang.String"/>
	<parameter name="period" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 1,CONCAT(village.villname,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,village.villno $P!{sum_pop}				
FROM
person
Left Join house ON person.hcode = house.hcode AND house.pcucode = person.pcucodeperson
Left Join village ON house.villcode = village.villcode AND village.pcucode = house.pcucode
Left Join cright ON person.rightcode = cright.rightcode
Left Join persondeath ON person.pcucodeperson = persondeath.pcucodeperson AND person.pid=persondeath.pid
WHERE SUBSTRING(house.villcode,7,2)<>'00' 
 $P!{pcucode}
 $P!{where_person}
GROUP BY house.villcode
ORDER BY village.villcode]]></queryString>

