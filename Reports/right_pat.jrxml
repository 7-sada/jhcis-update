					<textElement>
						<font fontName="Tahoma" size="10"/>
					</textElement>
				<text><![CDATA[หมายเหตุ: หากรายงานนี้แสดงข้อมูลที่ไม่สมเหตุสมผล เช่นจำนวนสิทธิขาดหรือเกิน / จำนวนในบรรทัดรวมไม่เท่ากับจำนวนรายการย่อยรวมกัน ให้ไปตรวจสอบ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="4"
						y="22"
						width="525"
						height="16"
						key="staticText-8"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement>
						<font fontName="Tahoma" size="10"/>
					</textElement>
				<text><![CDATA[                 รหัส สิทธิการรักษา และรหัส ประเภทสิทธิเทียบกับในรายงานรหัส....ใหม่(ที่เมนูรายงาน / ปุ่มคำสั่ง รหัส...ใหม่)----โดยจะต้องกำหนดค่าสิทธิการรักษา]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="4"
						y="37"
