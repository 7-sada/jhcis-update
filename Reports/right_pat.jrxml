	<queryString><![CDATA[SELECT
vright_2_tp_pat.rightcode,
cright.rightname,
crightgroup.rightgroupname,
vright_2_tp_pat.rightgroup,
vright_2_tp_pat.countpid,
vright_2_pat.m_True,
vright_2_pat.m_fac,
vright_2_pat.m,
vright_2_pat.freq,
vright_new_in_mon_pat.newpid
FROM
cright
Inner Join crightgroup ON cright.rightgroup = crightgroup.rightgroupcode
Left Join vright_2_tp_pat ON cright.rightcode = vright_2_tp_pat.rightcode
Left Join vright_2_pat ON cright.rightcode = vright_2_pat.rightcode
Left Join vright_new_in_mon_pat ON cright.rightcode = vright_new_in_mon_pat.rs_in_Mon
ORDER BY
cright.rightgroup ASC,
vright_2_tp_pat.rightcode ASC]]></queryString>

