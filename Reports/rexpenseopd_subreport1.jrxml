<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rexpenseopd_subreport1" pageWidth="535" pageHeight="802" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="e829a609-c626-4117-addb-2eca2273792c">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="edate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="hosmain" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select dr.visitno
,sum(case when (dr.drugcode ='897' or cdr.drugtype = '06') then (dr.unit*dr.realprice) else 0 end) as dservice
,sum(case when (cdr.drugtype ='02' and (cdr.drugtypesub in('1','2'))) then (dr.unit*dr.realprice) else 0 end) as denservice
,sum(case when (cdr.drugtype ='07') then (dr.unit*dr.realprice) else 0 end) as labservice
,sum(case when ((cdr.drugtype ='02') and (cdr.drugtypesub not in ('1','2'))) then (dr.unit*dr.realprice) else 0 end) as cmservice
,sum(case when cdr.drugtype in('01','10','03') then (dr.unit*dr.realprice) else 0 end) as drugservice

from  visitdrug dr
     left JOIN cdrug cdr on dr.drugcode = cdr.drugcode
     left JOIN visit v on dr.visitno = v.visitno and dr.pcucode = v.pcucode
where  dr.pcucode = $P{pcucode}
 and dr.visitno = $P{visitno}
 and v.visitdate between $P{sdate} and $P{edate}
 and v.hosmain = $P{hosmain}
group by dr.pcucode,dr.visitno]]>
	</queryString>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="dservice" class="java.math.BigDecimal"/>
	<field name="denservice" class="java.math.BigDecimal"/>
	<field name="labservice" class="java.math.BigDecimal"/>
	<field name="cmservice" class="java.math.BigDecimal"/>
	<field name="drugservice" class="java.math.BigDecimal"/>
	<variable name="SUM_dservice_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{dservice}]]></variableExpression>
	</variable>
	<variable name="SUM_denservice_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{denservice}]]></variableExpression>
	</variable>
	<variable name="SUM_labservice_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{labservice}]]></variableExpression>
	</variable>
	<variable name="SUM_cmservice_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{cmservice}]]></variableExpression>
	</variable>
	<variable name="SUM_cmservice_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{cmservice}]]></variableExpression>
	</variable>
	<variable name="SUM_drugservice_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{drugservice}]]></variableExpression>
	</variable>
