<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="OPD_hos1_subreport1" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="ae95dbb1-5ab2-45bd-936a-d931020adde4">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="visitno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select p3.*,if(p3.pay_type = '1',p3.total,null) as cash,if(p3.pay_type in ('2','3'),p3.total,null) as credit
from
(select ifnull(v.temperature,'') as temperature,ifnull(v.height,'') as height,ifnull(v.weight,'') as weight
,ifnull(v.pressure,'') as pressure,ifnull(v.pulse,'') as pulse,ifnull(v.respri,'') as breth,
IF(v.visitdate IS NULL,'',concat(convert(DAY(v.visitdate) using utf8),' ',
   CASE WHEN MONTH(v.visitdate)=1 THEN 'มกราคม'
   WHEN MONTH(v.visitdate)=2 THEN 'กุมภาพันธ์' WHEN MONTH(v.visitdate)=3 THEN 'มีนาคม'
   WHEN MONTH(v.visitdate)=4 THEN 'เมษายน' WHEN MONTH(v.visitdate)=5 THEN 'พฤษภาคม'
   WHEN MONTH(v.visitdate)=6 THEN 'มิถุนายน' WHEN MONTH(v.visitdate)=7 THEN 'กรกฎาคม'
   WHEN MONTH(v.visitdate)=8 THEN 'สิงหาคม' WHEN MONTH(v.visitdate)=9 THEN 'กันยายน'
   WHEN MONTH(v.visitdate)=10 THEN 'ตุลาคม' WHEN MONTH(v.visitdate)=11 THEN 'พฤศจิกายน'
   WHEN MONTH(v.visitdate)=12 THEN 'ธันวาคม' END,' ',YEAR(v.visitdate)+543) )
   as visitdate,ifnull(vdi.doctor,"") as doctor,if(ifnull(vdlab.lab,"") = 0,"",ifnull(vdlab.lab,"")) as doctorprice,if(vdlab.lab = 0,null,vdlab.lab) as dp,
ifnull(vddrug.drug,0) as drug,(ifnull(vdlab.lab,0)+ifnull(vddrug.drug,0)) as total,
ifnull(v.symptoms,'') as akan,ifnull(v.diagnote,'') as diagnote,v.visitno,p2.receiptno,p2.pay_type,
 (case when p2.pay_type = '1' then 'เงินสด'
 when p2.pay_type = '2' then 'VISA'
 when p2.pay_type = '3' then 'Master Card'
 else "" end) as PayType
from visit v
left join (select if(p1.noclaimprice = 1 or p1.realprice = 0,"",p1.doctor) as doctor,p1.visitno,p1.pcucode
from
(select vd.doctor1,u.fname as doctor,
vd.realprice,noclaimprice,vd.visitno,vd.pcucode
from visitdrug vd
left join user u on (vd.doctor1 = u.username)
where vd.visitno = $P{visitno}
and vd.drugcode like 'DF%') as p1) as vdi
on (vdi.pcucode = v.pcucode and vdi.visitno = v.visitno)
left join
(select (1-ifnull(noclaimprice,0))*vd.unit*vd.realprice as lab,vd.pcucode,vd.visitno
from visitdrug vd
where vd.visitno = $P{visitno}
and vd.drugcode like 'DF%') as vdlab
on (vdlab.visitno = v.visitno and vdlab.pcucode = v.pcucode)
left join
(select sum(((1-ifnull(noclaimprice,0))*v.unit*v.realprice)) as drug,v.pcucode,v.visitno
from visitdrug v
join cdrug d on (v.drugcode = d.drugcode)
and d.drugcode not like 'DF%'
and v.visitno = $P{visitno}
group by v.visitno ) vddrug
on (v.visitno = vddrug.visitno and v.pcucode = vddrug.pcucode)
join
(select p1.receiptno,p1.visitno,p1.prn,p1.pay_type
from (
select v2.receiptno,v2.visitno,v2.prn,v1.pay_type
from
(select max(receiptno)as receiptno ,vr.visitno,max(vr.datetime_prn) as prn
from visitreceiptno vr
where vr.visitno = $P{visitno}
group by vr.visitno) v2
join visitreceiptno v1 on (v2.receiptno = v1.receiptno and v2.visitno = v1.visitno  and v2.prn = v1.datetime_prn)
) as p1) as p2
on (v.visitno and p2.visitno)
where v.visitno = $P{visitno}) as p3]]>
	</queryString>
