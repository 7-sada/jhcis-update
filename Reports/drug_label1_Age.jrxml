		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="dateexpireTh" class="java.lang.String"/>
	<field name="u" class="java.lang.String"/>
	<field name="tel" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
