	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND (`visitanc`.`datecheck` between '2005-01-01' AND '2008-12-31')"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND visitanc.pcucode='01032' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
`visitanc`.`pid`,
Count(`visitanc`.`datecheck`) as countchk,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) as fname,
`person`.`lname`,
`person`.`hnomoi`,
`visitanc`.`pregno`,
DATE_FORMAT(visitancpregnancy.firstdatecheck,'%Y-%m-%d') as firstdatecheck,
CONCAT(convert(village.villno using utf8),' ',`village`.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villno,
DATE_FORMAT(visitancpregnancy.edc,'%Y-%m-%d') as edc
FROM
`visitanc`
Inner Join `person` ON `visitanc`.`pid` = `person`.`pid` AND `person`.`pcucodeperson` = `visitanc`.`pcucodeperson`
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join `house` ON `house`.`hcode` = `person`.`hcode` AND `house`.`pcucode` = `person`.`pcucodeperson`
Inner Join `village` ON `house`.`villcode` = `village`.`villcode` AND `village`.`pcucode` = `house`.`pcucode`
Inner Join `visitancpregnancy` ON `visitancpregnancy`.`pid` = `visitanc`.`pid` AND `visitancpregnancy`.`pregno` = `visitanc`.`pregno` AND `visitancpregnancy`.`pcucodeperson` = `visitanc`.`pcucodeperson`
WHERE
right(`village`.`villcode`,2)  <>  '00' $P!{pcucode}
$P!{ReportDate}
GROUP BY
`visitanc`.`pid`,`visitanc`.`pregno`
order by `village`.`villcode`,`person`.`hnomoi`]]></queryString>

