<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Gen_Chart" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="828" leftMargin="7" rightMargin="7" topMargin="20" bottomMargin="20" uuid="a40b1eb5-7fd3-4e0f-88a0-616a6a859a5f">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="288"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\1234\\Desktop\\Moph_rep\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="hcode" class="java.lang.Integer"/>
	<parameter name="pidHead" class="java.lang.String"/>
	<parameter name="pcucode" class="java.lang.String"/>
	<queryString>
		<![CDATA[select pf.hcode,pf.pidhead,concat(ct1.titlename, " " ,p.fname, " ",p.lname) as namehead
,if(p.birth is null,"ไม่ระบุ", date_format(date_add(p.birth,interval 543 year), '%d/%m/%Y')) as birthhead
,ifnull(pch.chroniccode,"ไม่ระบุ") as chroniccodeh,convert(ifnull(cdh.diseasename,"ไม่ระบุ" ) using utf8) as chronicnameh
,pf.pidmate,if(pm.fname is null,"ไม่ระบุ",concat(ct2.titlename," "," ",pm.fname," ",pm.lname)) as namemaid
,if(pm.birth is null,"ไม่ระบุ",date_format(date_add(pm.birth,interval 543 year), '%d/%m/%Y')) as birthmaid
,ifnull(pcm.chroniccode,"ไม่ระบุ") as chroniccodem,convert(ifnull(cdm.diseasename,"ไม่ระบุ ")    using utf8) as chronicnamem
,pf.fathernameh,pf.mothernameh,
if(pf.fatherbirthh is null,"ไม่ระบุ",date_format(date_add(pf.fatherbirthh,interval 543 year), '%d/%m/%Y')) as fatherbirthh
,if(pf.motherbirthh is null,"ไม่ระบุ",date_format(date_add(pf.motherbirthh,interval 543 year), '%d/%m/%Y')) as motherbirthh
,pf.fatherchronich,pf.motherchronich
,if(pf.fatheraliveh='1',"มีชีวิต","เสียชีวิต") as fatheraliveh
,if(pf.motheraliveh='1',"มีชีวิต","เสัยชีวิต") as motheraliveh
,pf.fathernamemate,pf.mothernamemate
,if(pf.fatherbirthmate is null,"ไม่ระบุ",date_format(date_add(pf.fatherbirthmate,interval 543 year), '%d/%m/%Y')) as fatherbirthmate
,if(pf.motherbirthmate is null,"ไม่ระบุ",date_format(date_add(pf.motherbirthmate,interval 543 year), '%d/%m/%Y')) as motherbirthmate
,pf.fatherchronicmate,pf.motherchronicmate
,if(pf.fatheralivemate='1',"มีชีวิต","เสียชีวิต") as fatheralivemate,
if(pf.motheralivemate='1',"มีชีวิต","เสียชีวิต") as motheralivemate
,ifnull(pf.grandfathernamepuh,"ไม่ระบุ") as grandfathernamepuh
,if(pf.grandfatherbirthpuh is null,"ไม่ระบุ",date_format(date_add(pf.grandfatherbirthpuh,interval 543 year), '%d/%m/%Y')) as grandfatherbirthpuh
,ifnull(pf.grandfatherchronicpuh,"ไม่ระบุ") as grandfatherchronicpuh,
if(pf.grandfatheralivepuh='1',"มีชีวิต","เสียชีวิต") as grandfatheralivepuh,
ifnull(pf.grandmothernameyah,"ไม่ระบุ") as grandmothernameyah
,if(pf.grandmotherbirthyah is null,"ไม่ระบุ",date_format(date_add(pf.grandmotherbirthyah,interval 543 year), '%d/%m/%Y')) as grandmotherbirthyah
,ifnull(pf.grandmotherchronicyah,"ไม่ระบุ") as grandmotherchronicyah,
if(pf.grandmotheraliveyah ='1',"มีชีวิต","เสียชีวิต") as grandmotheraliveyah,
ifnull(pf.grandfathernametah,"ไม่ระบุ") as grandfathernametah,
ifnull(pf.grandfatherchronictah,"ไม่ระบุ") as grandfatherchronictah
,if(pf.grandfatherbirthtah is null,"ไม่ระบุ",date_format(date_add(pf.grandfatherbirthtah,interval 543 year), '%d/%m/%Y')) as grandfatherbirthtah
,if(pf.grandfatheralivetah ='1',"มีชีวิต","เสียชีวิต") as grandfatheralivetah,
ifnull(pf.grandmothernameyaih,"ไม่ระบุ") as grandmothernameyaih
,ifnull(pf.grandmotherchronicyaih,"ไม่ระบุ") as grandmotherchronicyaih
,if(pf.grandmotherbirthyaih is null,"ไม่ระบุ",date_format(date_add(pf.grandmotherbirthyaih,interval 543 year), '%d/%m/%Y')) as grandmotherbirthyaih
,if(pf.grandmotheraliveyaih ='1',"มีชีวิต","เสียชีวิต") as grandmotheraliveyaih
,ifnull(pf.grandfathernamepumate,"ไม่ระบุ") as grandfathernamepumate
,if(pf.grandfatherbirthpumate is null,"ไม่ระบุ",date_format(date_add(pf.grandfatherbirthpumate,interval 543 year),'%d/%m/%Y'))as grandfatherbirthpumate
,ifnull(pf.grandfatherchronicpumate,"ไม่ระบุ") as grandfatherchronicpumate
,if(pf.grandfatheralivepumate ='1',"มีชีวิต","เสียชีวิต") as grandfatheralivepumate
,ifnull(pf.grandmothernameyamate,"ไม่ระบุ") as grandmothernameyamate
,if(pf.grandmotherbirthyamate is null,"ไม่ระบุ",date_format(date_add(pf.grandmotherbirthyamate,interval 543 year),'%d/%m/%Y'))as grandmotherbirthyamate
,ifnull(pf.grandmotherchronicyamate,"ไม่ระบุ") as grandmotherchronicyamate
,if(pf.grandmotheraliveyamate ='1',"มีชีวิต","เสียชีวิต") as grandmotheraliveyamate
,ifnull(pf.grandfathernametamate,"ไม่ระบุ") as grandfathernametamate
,if(pf.grandfatherbirthtamate is null,"ไม่ระบุ",date_format(date_add(pf.grandfatherbirthtamate,interval 543 year),'%d/%m/%Y'))as grandfatherbirthtamate
,ifnull(pf.grandfatherchronictamate,"ไม่ระบุ") as grandfatherchronictamate
,if(pf.grandfatheralivetamate ='1',"มีชีวิต","เสียชีวิต") as grandfatheralivetamate
,ifnull(pf.grandmothernameyaimate,"ไม่ระบุ") as grandmothernameyaimate
,if(pf.grandmotherbirthyaimate is null,"ไม่ระบุ",date_format(date_add(pf.grandmotherbirthyaimate,interval 543 year), '%d/%m/%Y')) as grandmotherbirthyaimate
,ifnull(pf.grandmotherchronicyaimate,"ไม่ระบุ") as grandmotherchronicyaimate
,if(pf.grandmotheraliveyaimate = '1',"มีชีวิต","เสียชีวิต") as grandmotheraliveyaimate
,ifnull(pf.greatgrandpufahead,"ไม่ระบุ") as greatgrandpufahead
,ifnull(pf.greatgrandyafahead,"ไม่ระบุ") as greatgrandyafahead
,ifnull(pf.greatgrandtafahead,"ไม่ระบุ") as greatgrandtafahead
,ifnull(pf.greatgrandyaifahead,"ไม่ระบุ") as greatgrandyaifahead

,ifnull(pf.greatgrandpumohead,"ไม่ระบุ") as greatgrandpumohead
,ifnull(pf.greatgrandyamohead,"ไม่ระบุ") as greatgrandyamohead
,ifnull(pf.greatgrandtamohead,"ไม่ระบุ") as greatgrandtamohead
,ifnull(pf.greatgrandyaimohead,"ไม่ระบุ") as greatgrandyaimohead

,ifnull(pf.greatgrandpufamate,"ไม่ระบุ") as greatgrandpufamate
,ifnull(pf.greatgrandyafamate,"ไม่ระบุ") as greatgrandyafamate
,ifnull(pf.greatgrandtafamate,"ไม่ระบุ") as greatgrandtafamate
,ifnull(pf.greatgrandyaifamate,"ไม่ระบุ") as greatgrandyaifamate

,ifnull(pf.greatgrandpumomate,"ไม่ระบุ") as greatgrandpumomate
,ifnull(pf.greatgrandyamomate,"ไม่ระบุ") as greatgrandyamomate
,ifnull(pf.greatgrandtamomate,"ไม่ระบุ") as greatgrandtamomate
,ifnull(pf.greatgrandyaimomate,"ไม่ระบุ") as greatgrandyaimomate

from personfamilyfolder as pf
left join person p on (pf.pidhead = p.pid) and (pf.pcucode = p.pcucodeperson)
left join ctitle ct1 on (p.prename = ct1.titlecode)
left join person pm on (pf.pidmate = pm.pid) and (pf.pcucode = pm.pcucodeperson)
left join ctitle ct2 on (pm.prename = ct2.titlecode)
left join personchronic pch on (pf.pidhead = pch.pid and pf.pcucode = pch.pcucodeperson)
left join cdisease cdh on (pch.chroniccode = cdh.diseasecode)
left join personchronic pcm on (pf.pidmate = pcm.pid and pf.pcucode = pch.pcucodeperson)
left join cdisease cdm on (pcm.chroniccode = cdm.diseasecode)
where pf.hcode = $P{hcode}
and pf.pidhead = $P{pidHead}
and pf.pcucode = $P{pcucode}]]>
	</queryString>
