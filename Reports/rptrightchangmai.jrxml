<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptrightchangmai"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-10-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select  cright.rightcode,cright.rightname
,count(distinct visit.pcucodeperson,visit.pid) as tperson
,count(distinct visit.pcucode,visit.visitno) as ttime
,sum(case when drugtype in ('01','04','05','10','03') then (visitdrug.unit  * visitdrug.costprice) else 0 end) as tdrug
,sum(case when drugtype in ('11','91') then  ((visit.money3) -  (visitdrug.unit  * visitdrug.costprice) )  else 0 end) as tother
,sum(case when drugtype ='07'  then (visitdrug.unit  * visitdrug.costprice) else 0 end) as tlab
,sum(case when (drugtype ='02'  )  then (visitdrug.unit  * visitdrug.costprice) else 0 end) as tproce
,sum(visit.money3) as totcost
,if((sum(visit.money2)) >(sum(visit.money3))   ,null,((sum(visit.money3)) - (sum(visit.money2)) ))  as thelp
,sum(visit.money2) as totrec
,chospital.hosname
,date_format($P{sdate},'%Y-%m-%d') as startdate
,date_format($P{edate},'%Y-%m-%d') as enddate
from visitdrug left join visit on visitdrug.visitno = visit.visitno and visitdrug.pcucode = visit.pcucode
               left join cdrug on visitdrug.drugcode = cdrug.drugcode
	       left join cright on visit.rightcode = cright.rightcode
	       left join crightgroup on cright.rightgroup = crightgroup.rightgroupcode
	       left join chospital on visit.pcucode = chospital.hoscode
where visit.visitdate between  $P{sdate} and $P{edate}
$P!{pcucode}
group by  cright.rightcode]]></queryString>

	<field name="rightcode" class="java.lang.String"/>
	<field name="rightname" class="java.lang.String"/>
	<field name="tperson" class="java.lang.Long"/>
	<field name="ttime" class="java.lang.Long"/>
	<field name="tdrug" class="java.math.BigDecimal"/>
	<field name="tother" class="java.lang.Double"/>
	<field name="tlab" class="java.math.BigDecimal"/>
