<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rrb1k013total" pageWidth="1224" pageHeight="792" orientation="Landscape" columnWidth="1152" leftMargin="43" rightMargin="29" topMargin="48" bottomMargin="48" uuid="01330898-67af-4818-9faa-2080932004f3">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="481"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["4429"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-12-22"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select visitepi.pid,visitepi.pcucodeperson
,visitepi.visitno,visitepi.pcucode
,(select if(v1.vaccinecode='BCG' ,'Y',null) from visitepi v1 where visitepi.pid = v1.pid and visitepi.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='BCG' and v1.dateepi between $P{sdate} and $P{edate}  group by v1.pid,v1.pcucodeperson) as bcg
,(select if( v2.vaccinecode='HBV1' ,'Y',null) from visitepi v2 where visitepi.pid = v2.pid and visitepi.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='HBV1'and v2.dateepi between $P{sdate} and $P{edate}  group by v2.pid,v2.pcucodeperson) as hbv1
,(select if(v3.vaccinecode='HBV2', 'Y',null) from visitepi v3 where visitepi.pid = v3.pid and visitepi.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='HBV2' and v3.dateepi between $P{sdate} and $P{edate}  group by v3.pid,v3.pcucodeperson) as hbv2
,(select if(v4.vaccinecode ='HBV3', 'Y',null) from visitepi v4 where visitepi.pid = v4.pid and visitepi.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='HBV3' and v4.dateepi between $P{sdate} and $P{edate}  group by v4.pid,v4.pcucodeperson) as hbv3
,(select if(v5.vaccinecode='DTP1', 'Y',null)  from visitepi v5 where visitepi.pid = v5.pid and visitepi.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='DTP1' and v5.dateepi between $P{sdate} and $P{edate}   group by v5.pid,v5.pcucodeperson) as dtp1
,(select if(v6.vaccinecode ='DTP2', 'Y',null)  from visitepi v6 where visitepi.pid = v6.pid and visitepi.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='DTP2' and v6.dateepi between $P{sdate} and $P{edate}  group by v6.pid,v6.pcucodeperson) as dtp2
,(select if(v7.vaccinecode ='DTP3', 'Y',null) from visitepi v7 where visitepi.pid = v7.pid and visitepi.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='DTP3' and v7.dateepi between $P{sdate} and $P{edate}   group by v7.pid,v7.pcucodeperson) as dtp3
,(select if(v8.vaccinecode ='DTP4', 'Y',null) from visitepi v8 where visitepi.pid = v8.pid and visitepi.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='DTP4 ' and v8.dateepi between $P{sdate} and $P{edate}  group by v8.pid,v8.pcucodeperson) as dtp4
,(select if( v9.vaccinecode ='DTP5', 'Y',null) from visitepi v9 where visitepi.pid = v9.pid and visitepi.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='DTP5' and v9.dateepi between $P{sdate} and $P{edate}  group by v9.pid,v9.pcucodeperson) as dtp5
,(select if(v10.vaccinecode ='OPV1', 'Y',null) from visitepi v10 where visitepi.pid = v10.pid and visitepi.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='OPV1' and v10.dateepi between $P{sdate} and $P{edate}  group by v10.pid,v10.pcucodeperson) as opv1
,(select if(v11.vaccinecode ='OPV2', 'Y',null) from visitepi v11 where visitepi.pid = v11.pid and visitepi.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='OPV2' and v11.dateepi between $P{sdate} and $P{edate}  group by v11.pid,v11.pcucodeperson) as opv2
,(select if( v12.vaccinecode ='OPV3', 'Y',null) from visitepi v12 where visitepi.pid = v12.pid and visitepi.pcucodeperson=v12.pcucodeperson and v12.vaccinecode='OPV3' and v12.dateepi between $P{sdate} and $P{edate}  group by v12.pid,v12.pcucodeperson) as opv3
,(select if(v13.vaccinecode='OPV4', 'Y',null) from visitepi v13 where visitepi.pid = v13.pid and visitepi.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='OPV4' and v13.dateepi between $P{sdate} and $P{edate}  group by v13.pid,v13.pcucodeperson) as opv4
,(select if(v14.vaccinecode ='OPV5', 'Y',null) from visitepi v14 where visitepi.pid = v14.pid and visitepi.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='OPV5' and v14.dateepi between $P{sdate} and $P{edate}  group by v14.pid,v14.pcucodeperson) as opv5
,(select if( v15.vaccinecode='MEAS', 'Y',null) from visitepi v15 where visitepi.pid = v15.pid and visitepi.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='MEAS' and v15.dateepi between $P{sdate} and $P{edate}  group by v15.pid,v15.pcucodeperson) as meas
,(select if(v16.vaccinecode ='JE1', 'Y',null) from visitepi v16 where visitepi.pid = v16.pid and visitepi.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='JE1' and v16.dateepi between $P{sdate} and $P{edate}  group by v16.pid,v16.pcucodeperson) as je1
,(select if(v17.vaccinecode='JE2', 'Y',null) from visitepi v17 where visitepi.pid = v17.pid and visitepi.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='JE2' and v17.dateepi between $P{sdate} and $P{edate}  group by v17.pid,v17.pcucodeperson) as je2
,(select if(v18.vaccinecode='JE3', 'Y',null) from visitepi v18 where visitepi.pid = v18.pid and visitepi.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='JE3' and v18.dateepi between $P{sdate} and $P{edate}   group by v18.pid,v18.pcucodeperson) as je3
#
,(select if(UCASE(v191.vaccinecode)='J11', 'Y',null) from visitepi v191 where visitepi.pid = v191.pid and visitepi.pcucodeperson=v191.pcucodeperson and v191.vaccinecode='J11' and v191.dateepi between $P{sdate} and $P{edate}   group by v191.pid,v191.pcucodeperson) as j11
,(select if(UCASE(v201.vaccinecode)='J12', 'Y',null) from visitepi v201 where visitepi.pid = v201.pid and visitepi.pcucodeperson=v201.pcucodeperson and v201.vaccinecode='J12' and v201.dateepi between $P{sdate} and $P{edate}   group by v201.pid,v201.pcucodeperson) as j12
#
,(select if(v19.vaccinecode='DHB1', 'Y',null) from visitepi v19 where visitepi.pid = v19.pid and visitepi.pcucodeperson=v19.pcucodeperson and v19.vaccinecode='DHB1' and v19.dateepi between $P{sdate} and $P{edate}  group by v19.pid,v19.pcucodeperson) as dhb1
,(select if(v20.vaccinecode='DHB2', 'Y',null) from visitepi v20 where visitepi.pid = v20.pid and visitepi.pcucodeperson=v20.pcucodeperson and v20.vaccinecode='DHB2' and v20.dateepi between $P{sdate} and $P{edate}  group by v20.pid,v20.pcucodeperson) as dhb2
,(select if(v21.vaccinecode='DHB3', 'Y',null) from visitepi v21 where visitepi.pid = v21.pid and visitepi.pcucodeperson=v21.pcucodeperson and v21.vaccinecode='DHB3' and v21.dateepi between $P{sdate} and $P{edate}  group by v21.pid,v21.pcucodeperson) as dhb3

,(select if(v22.vaccinecode in('DT1','DT2','DT3','DT4','DT5'), 'Y',null) from visitepi v22 where visitepi.pid = v22.pid and visitepi.pcucodeperson=v22.pcucodeperson and v22.vaccinecode in('DT1','DT2','DT3','DT4','DT5') and v22.dateepi between $P{sdate} and $P{edate}  group by v22.pid,v22.pcucodeperson) as dt
,(select if(left(v23.vaccinecode,2)='TT', 'Y',null) from visitepi v23 where visitepi.pid = v23.pid and visitepi.pcucodeperson=v23.pcucodeperson and left(v23.vaccinecode,2)='TT' and v23.dateepi between $P{sdate} and $P{edate}  group by v23.pid,v23.pcucodeperson) as tt

,(select if(v24.vaccinecode in('MMR','MMR1'), 'Y',null) from visitepi v24 where visitepi.pid = v24.pid and visitepi.pcucodeperson=v24.pcucodeperson and v24.vaccinecode in('MMR','MMR1') and v24.dateepi between $P{sdate} and $P{edate}  group by v24.pid,v24.pcucodeperson) as mmr
,(select if(v25.vaccinecode='MMR2', 'Y',null) from visitepi v25 where visitepi.pid = v25.pid and visitepi.pcucodeperson=v25.pcucodeperson and v25.vaccinecode='MMR2' and v25.dateepi between $P{sdate} and $P{edate}  group by v25.pid,v25.pcucodeperson) as mmr2
,(select if(UCase(v25.vaccinecode)='MMRS', 'Y',null) from visitepi v25 where visitepi.pid = v25.pid and visitepi.pcucodeperson=v25.pcucodeperson and UCase(v25.vaccinecode)='MMRS' and v25.dateepi between $P{sdate} and $P{edate}  group by v25.pid,v25.pcucodeperson) as mmrs
,(select if(UCase(v25.vaccinecode)='MRC', 'Y',null) from visitepi v25 where visitepi.pid = v25.pid and visitepi.pcucodeperson=v25.pcucodeperson and UCase(v25.vaccinecode)='MRC' and v25.dateepi between $P{sdate} and $P{edate}  group by v25.pid,v25.pcucodeperson) as mrc
,(select if(UCase(v26.vaccinecode)='MMRC', 'Y',null) from visitepi v26
  where visitepi.pid = v26.pid and visitepi.pcucodeperson=v26.pcucodeperson
    and UCase(v26.vaccinecode)='MMRC' and v26.dateepi between $P{sdate} and $P{edate}
  group by v26.pid,v26.pcucodeperson) as mmrc
#####
,DATE_FORMAT(v.visitdate,'%Y-%m-%d') as visitdate
,CONVERT(CONCAT(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),p.fname,' ',p.lname) USING utf8 )as personname
,DATE_FORMAT(visitepi.dateepi, "%Y-%m-%d") AS dateepi,p.birth

,if(birth is not null ,CONVERT(CONCAT(  DATE_FORMAT(visitepi.dateepi,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(visitepi.dateepi,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), "/",
	CASE SIGN(DATE_FORMAT(visitepi.dateepi,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visitepi.dateepi,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visitepi.dateepi,"%m") -  (DATE_FORMAT(visitepi.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(visitepi.dateepi,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(visitepi.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  "/",
	CASE SIGN(DATE_FORMAT(visitepi.dateepi,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN(DATE_FORMAT(visitepi.dateepi,"%d") - DATE_FORMAT(birth,"%d") )
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(visitepi.dateepi),"%d") + DATE_FORMAT(visitepi.dateepi, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(visitepi.dateepi,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(visitepi.dateepi,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8),"ไม่มีวันเกิด") AS age_ymd
,p.rightno,p.idcard
,h.hoscode as hosmain,h.hosname as hosname
,hh.hosname as pcuname ,dh.distname,ph.provname
,CONVERT(case when p.subdistcodemoi is null  then 'นอกเขต'
              when p.hnomoi is null then concat(' ม.',  p.`mumoi` ,' ต.',  t.`subdistname` )
              when p.mumoi is null then concat(p.`hnomoi`  ,' ต.',  t.`subdistname` )
              else concat(p.`hnomoi` ,' ม.',  p.`mumoi` ,' ต.',  t.`subdistname` ) end   USING utf8)  as address
,vc.weight,vb.locatecare
FROM visitepi  	  left join visit v on visitepi.visitno = v.visitno and visitepi.pcucode = v.pcucode
		  left join person p on visitepi.pid=p.pid and visitepi.pcucodeperson = p.pcucodeperson
		  left join ctitle on p.prename = ctitle.titlecode
		  left join visitancdeliverchild vc on p.pid = vc.pid and vc.pcucodeperson = p.pcucodeperson
		  left join visitbabycare vb on vb.pid = p.pid and p.pcucodeperson = vb.pcucodeperson
                  left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
                  left join village on house.villcode = village.villcode and village.pcucode = v.pcucode
                  left join csubdistrict t on t.subdistcode=p.subdistcodemoi and t.distcode=p.distcodemoi and t.provcode = p.provcodemoi
                  left join cdistrict d on d.distcode = p.distcodemoi and d.provcode =p.provcodemoi
                  left join cprovince pr on pr.provcode = p.provcodemoi
                  left join chospital h on h.hoscode = v.hosmain
	          left join chospital hh on hh.hoscode = visitepi.pcucode
                  left join cdistrict dh on dh.distcode = hh.distcode and dh.provcode = hh.provcode
                  left join cprovince ph on ph.provcode = hh.provcode
                  left join cright cr on cr.rightcode = v.rightcode
                  left join crightgroup crg on crg.rightgroupcode = cr.rightgroup
where v.visitdate between $P{sdate} and $P{edate}
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
     $P!{pcucode}

    and DATEDIFF(visitepi.dateepi,birth)/ 365 <= 15
group by visitepi.pid,visitepi.pcucodeperson
order by v.pcucode,v.visitdate]]>
	</queryString>
