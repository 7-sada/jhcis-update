	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-04-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-04-15"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-15"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pttype" isForPrompting="false" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["c:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="zdiag" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and Lcase(left(visitdiag.diagcode,1)) !='z'"]]></defaultValueExpression>
	</parameter>
	<parameter name="note1" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
     DATE_FORMAT(visit.visitdate, "%Y-%m-%d") AS visit_visitdate
,visit.`pcucode` AS visit_pcucode, visit.`visitno` AS visit_visitno
,visit.pid as hn,visit.pcucodeperson
,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ) ,person.`fname`,' ', person.`lname`) using utf8) AS personname
,person.`birth` AS person_birth,person.officework
,CONVERT(CONCAT(  DATE_FORMAT(visit.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(visit.visitdate,"00-%m-%d")< DATE_FORMAT(birth,"00-%m-%d")), " ปี ",  
	CASE SIGN(DATE_FORMAT(visit.visitdate,"%m")-DATE_FORMAT(birth,"%m"))  
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visit.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visit.visitdate,"%m") -  (DATE_FORMAT(visit.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN 1 THEN(DATE_FORMAT(visit.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(visit.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " เดือน ",  
	CASE SIGN(DATE_FORMAT(visit.visitdate,"%d") - DATE_FORMAT(birth,"%d"))  
 	 WHEN 0 THEN(DATE_FORMAT(visit.visitdate,"%d") - DATE_FORMAT(birth,"%d") )  
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(visit.visitdate),"%d") + DATE_FORMAT(visit.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))  
 	 WHEN 1 THEN (DATE_FORMAT(visit.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(visit.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END ,  " วัน " ) USING utf8) AS age_ymd 
 ,CONVERT(case when person.subdistcodemoi is null  then 'นอกเขต' 
       when person.hnomoi is null then concat(' ม.',  person.`mumoi` ,' ต.',  csubdistrict.`subdistname` )
       when person.mumoi is null then concat(person.`hnomoi`  ,' ต.',  csubdistrict.`subdistname` )
       else concat(person.`hnomoi` ,' ม.',  person.`mumoi` ,' ต.',  csubdistrict.`subdistname` ) end USING utf8)   AS address

,crightgroup.rightgroupname  AS rightgroupname

,person.idcard,visit.symptoms,visitdiag.diagcode,chospitalm.hosname
,visit.`rightno` AS visit_rightno
,visit.money1,visit.money2,visit.money3
,if(visit.money1 > visit.money2 ,(visit.money1- visit.money2),(visit.money2- visit.money1)) AS diff
,CONVERT(concat(chospital.`hosname`,' ต.',csubdistricth.`subdistname`,' อ.',cdistricth.`distname`,' จ.', cprovinceh.`provname`) using utf8 ) AS hostname

,chospitalh.hosname as hosmainname
,visit.hosmain
FROM visit
     left JOIN person    ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
     left join ctitle    ON person.prename = ctitle.titlecode
     left JOIN visitdrug ON visit.pcucode = visitdrug.pcucode AND visit.visitno = visitdrug.visitno 
     left JOIN visitdiag ON visit.pcucode = visitdiag.pcucode AND visit.visitno = visitdiag.visitno 
     left JOIN cright    ON visit.rightcode = cright.rightcode
     left JOIN crightgroup ON cright.rightgroup = crightgroup.rightgroupcode
     left JOIN chospital ON visit.pcucode = chospital.hoscode  
     left JOIN csubdistrict csubdistrict  ON csubdistrict.subdistcode = person.subdistcodemoi and person.distcodemoi = csubdistrict.distcode and person.provcodemoi = csubdistrict.provcode
     left JOIN cdistrict cdistrict        ON person.distcodemoi = cdistrict.distcode and person.provcodemoi = cdistrict.provcode
     left JOIN cprovince cprovince        ON person.provcodemoi = cprovince.provcode
     left JOIN csubdistrict csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left JOIN cdistrict cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
     left JOIN cprovince cprovinceh ON chospital.provcode = cprovinceh.provcode
     left JOIN chospital chospitalm ON visit.hossub = chospitalm.hoscode 
     left JOIN chospital chospitalh ON visit.hosmain = chospitalh.hoscode
WHERE crightgroup.rightgroupcode ="2"
     $P!{pcucode} 
     and visit.visitdate between $P{sdate} and $P{edate} 
     and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
     $P!{zdiag}
GROUP BY visit.pcucode,visit.visitno
ORDER BY visit.pcucode,visit.hosmain,visit.visitdate]]></queryString>

