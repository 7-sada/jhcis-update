			<fieldDescription><![CDATA[รหัสการให้บริการส่งเสริม ป้องกันโรค(กำหนดโดย สนย)]]></fieldDescription>
		</field>
		<field name="ppname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pcucode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
