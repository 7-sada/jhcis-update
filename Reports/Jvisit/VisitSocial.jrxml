						<jr:column width="65" uuid="889678a1-50ae-417f-a3d6-c04ab9d1d4fc">
							<jr:columnHeader style="table 1_CH" height="30" rowSpan="1">
								<staticText>
									<reportElement uuid="d9e632ac-1202-4823-ae24-3427628e6ceb" x="0" y="0" width="65" height="30"/>
									<textElement textAlignment="Center" verticalAlignment="Middle">
