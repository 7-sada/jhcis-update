	<subDataset name="VisitData" uuid="a8017a4a-7def-4a5c-8a64-fd94afb7102b">
		<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="DateRepEnd" class="java.util.Date" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select A.*
from
(select cc.pid,concat(ifnull(titlename,ifnull(p1.prename,'...')) ," ", fname," ", lname) as fullname,
getAgeYearNum(p1.birth,cc.dateserv) as Age,p1.mumoi,h.villcode,p4.villname,
(case when right(h.villcode,2) = '00' then p4.villname
else concat("หมู่ที่่ ",right(h.villcode,2)," ", p4.villname)
end ) as fullvill,cc.pcucodeperson,
cc.dateserv,concat((cast(extract(day from cc.dateserv) as char)),
((case when (extract(month from cc.dateserv)) = 1 then ' ม.ค. '
      when (extract(month from cc.dateserv)) = 2 then ' ก.พ. '
      when (extract(month from cc.dateserv)) = 3 then ' มี.ค. '
      when (extract(month from cc.dateserv)) = 4 then ' เม.ษ. '
      when (extract(month from cc.dateserv)) = 5 then ' พ.ค. '
      when (extract(month from cc.dateserv)) = 6 then ' มิ.ย. '
      when (extract(month from cc.dateserv)) = 7 then ' ก.ค. '
      when (extract(month from cc.dateserv)) = 8 then ' ส.ค. '
      when (extract(month from cc.dateserv)) = 9 then ' ก.ย. '
      when (extract(month from cc.dateserv)) = 10 then ' ต.ค. '
      when (extract(month from cc.dateserv)) = 11 then ' พ.ย. '
      when (extract(month from cc.dateserv)) = 12 then ' ธ.ค. '
      else 'n/a' end)),
(cast((extract(year from cc.dateserv)+543) as char(20)))) as thaidate,
cc.ppspecial,cs.ppname,fs.pcucode,fs.visitno,vh.patientsign,vh.homehealthdetail,vh.homehealthresult
,vh.homehealthplan,vh.dateappoint,
concat((cast(extract(day from vh.dateappoint) as char)),
((case when (extract(month from vh.dateappoint)) = 1 then ' ม.ค. '
      when (extract(month from vh.dateappoint)) = 2 then ' ก.พ. '
      when (extract(month from vh.dateappoint)) = 3 then ' มี.ค. '
      when (extract(month from vh.dateappoint)) = 4 then ' เม.ษ. '
      when (extract(month from vh.dateappoint)) = 5 then ' พ.ค. '
      when (extract(month from vh.dateappoint)) = 6 then ' มิ.ย. '
      when (extract(month from vh.dateappoint)) = 7 then ' ก.ค. '
      when (extract(month from vh.dateappoint)) = 8 then ' ส.ค. '
      when (extract(month from vh.dateappoint)) = 9 then ' ก.ย. '
      when (extract(month from vh.dateappoint)) = 10 then ' ต.ค. '
      when (extract(month from vh.dateappoint)) = 11 then ' พ.ย. '
      when (extract(month from vh.dateappoint)) = 12 then ' ธ.ค. '
      else 'n/a' end)),
(cast((extract(year from vh.dateappoint)+543) as char(20)))) as dateappointhai
from
(select aa.pid,aa.dateserv,max(aa.ppspecial) as ppspecial,aa.pcucodeperson
from f43specialpp aa
where aa.dateserv = (select max(bb.dateserv) from f43specialpp bb where aa.pid = bb.pid
                  and bb.dateserv between $P!{DateRepStart}  and $P!{DateRepEnd})
and aa.ppspecial in ('1B1282','1B1281','1B1280')
group by aa.pid) cc
join cspecialpp cs on (cc.ppspecial = cs.ppcode)
join f43specialpp fs on (cc.pid = fs.pid and cc.dateserv = fs.dateserv
               and cc.ppspecial = fs.ppspecial and cc.pcucodeperson = fs.pcucodeperson)
left join visithomehealthindividual vh on (fs.pcucode = vh.pcucode) and (fs.visitno = vh.visitno)
join person p1 on (p1.pid = cc.pid and p1.pcucodeperson = cc.pcucodeperson)
join ctitle p2 on p1.prename = p2.titlecode
left join house h on (p1.hcode = h.hcode and p1.pcucodeperson = h.pcucode)
left join village p4 on (h.villcode = p4.villcode and h.pcucode = p4.pcucode)
where cc.ppspecial = '1B1280'
and right(h.villcode,2)<>'00')A
group by A.pid,A.fullname,A.age,A.mumoi,A.villcode,A.villname,A.pcucodeperson,A.fullvill,
A.dateserv,A.thaidate,A.ppspecial,A.ppname,A.pcucode,A.visitNo]]>
		</queryString>
