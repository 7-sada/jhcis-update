<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rhealthvolun_house_list_subreport0" pageWidth="535" pageHeight="802" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="house" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'067662'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) AS pname,
`person`.`lname`
FROM
`persontype`
Inner Join `person` ON `persontype`.`pcucodeperson` = `person`.`pcucodeperson` AND `persontype`.`pid` = `person`.`pid`
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join `house` ON `person`.`hcode` = `house`.`hcode` AND `house`.`pcucodepersonvola` = `person`.`pcucodeperson`
WHERE
`persontype`.`typecode` =  '10'
 AND CONCAT(house.pcucode,house.hcode) = $P!{house}]]>
	</queryString>
	<field name="pname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="13" splitType="Stretch">
			<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
				<reportElement key="textField" x="0" y="1" width="145" height="11"/>
				<box leftPadding="2" rightPadding="2">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font fontName="Tahoma" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{pname}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
				<reportElement key="textField" x="145" y="1" width="267" height="11"/>
				<box leftPadding="2" rightPadding="2">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font fontName="Tahoma" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{lname}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<columnFooter>
