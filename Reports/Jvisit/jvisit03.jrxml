<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="jvisit03" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="121610c0-830b-4944-a870-fc68f4380d29">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="464"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="VisitDate" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND `visit`.`visitdate` BETWEEN  '2012-01-01' AND '2013-12-31']]></parameterDescription>
		<defaultValueExpression><![CDATA[" AND `visit`.`visitdate` BETWEEN  '2012-01-01' AND '2013-12-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND `visithomehealthindividual`.`pcucode` =  '10136']]></parameterDescription>
		<defaultValueExpression><![CDATA[" AND `visithomehealthindividual`.`pcucode` =  '10136' "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT ifnull(chomehealthtype.homehealthmeaning,"ไม่ระบุประเภทการเยี่ยม") as type,visithomehealthindividual.visitno,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname) as name,
`visithomehealthindividual`.`patientsign`,
`visithomehealthindividual`.`homehealthdetail`,
`visithomehealthindividual`.`homehealthresult`,
`visithomehealthindividual`.`homehealthplan`,
DATE_FORMAT(`visithomehealthindividual`.`dateappoint`,'%Y-%m-%d') as dateappoint,
DATE_FORMAT(`visit`.`visitdate`,'%Y-%m-%d') as visitdate,
if(CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM  `persondeath`),'ยังมีชีวิต','เสียชีวิต') AS pstatus,
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8),' ต.',getSubdist(LEFT(village.villcode,6))) AS villname
FROM
`visithomehealthindividual`
Left Join `visit` ON `visit`.`pcucode` = `visithomehealthindividual`.`pcucode` AND `visit`.`visitno` = `visithomehealthindividual`.`visitno`
Left Join chomehealthtype ON  `visithomehealthindividual`.homehealthtype = chomehealthtype.homehealthcode
Left Join `person` ON `person`.`pcucodeperson` = `visit`.`pcucodeperson` AND `person`.`pid` = `visit`.`pid`
Left Join ctitle ON person.prename = ctitle.titlecode
Left Join `house` ON `house`.`pcucode` = `person`.`pcucodeperson` AND `house`.`hcode` = `person`.`hcode`
Left Join `village` ON `village`.`pcucode` = `house`.`pcucode` AND `village`.`villcode` = `house`.`villcode`
WHERE
right(`village`.`villcode`,2) <>  '00'  $P!{VisitDate} $P!{pcucode}
ORDER BY  `visithomehealthindividual`.homehealthtype]]>
	</queryString>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="visitdate" class="java.util.Date"/>
	<field name="villname" class="java.lang.String"/>
	<field name="type" class="java.lang.String"/>
	<field name="pstatus" class="java.lang.String"/>
	<field name="patientsign" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="homehealthresult" class="java.lang.String"/>
	<field name="homehealthplan" class="java.lang.String"/>
	<field name="homehealthdetail" class="java.lang.String"/>
	<field name="dateappoint" class="java.util.Date"/>
