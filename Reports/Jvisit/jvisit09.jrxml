	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="where_person" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND (person.dischargedate is null OR person.dischargedate > '20080101') AND (person.datein is null OR person.datein <= '20080101')  AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.deaddate <= '20080101') "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='10136']]></parameterDescription>
		<defaultValueExpression><![CDATA[" AND person.pcucodeperson='10136' "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 1,CONCAT(village.villname,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,village.villno,
	SUM(if(u.typecode='101' ,1,0)) AS r1,
	SUM(if(u.typecode='102' ,1,0)) AS r2,
	SUM(if(u.typecode='103' ,1,0)) AS r3,
	SUM(if(u.typecode='104' ,1,0)) AS r4,
	SUM(if(u.typecode='105' ,1,0)) AS r5,
	SUM(if(u.typecode='106' ,1,0)) AS r6,
	SUM(if(u.typecode='109' ,1,0)) AS r7,
	SUM(1) AS p
from person left join ctitle on titlecode=person.prename
left join house on house.pcucode=person.pcucodeperson and house.hcode=person.hcode
left join village on village.villcode=house.villcode
left join visitancpregnancy a on a.pcucodeperson=person.pcucodeperson and a.pid=person.pid
left join personchronic c on c.pcucodeperson=person.pcucodeperson and c.pid=person.pid
left join personunable1type u on u.pcucodeperson=person.pcucodeperson and u.pid=person.pid
WHERE SUBSTRING(house.villcode,7,2)<>'00'
  $P!{pcucode}
GROUP BY house.villcode]]>
	</queryString>
