	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="where_person" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND (person.dischargedate is null OR person.dischargedate > '20080101') AND (person.datein is null OR person.datein <= '20080101')  AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.deaddate <= '20080101') "]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='14118']]></parameterDescription>
		<defaultValueExpression><![CDATA[" AND person.pcucodeperson='14118' "]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
1,
CONCAT(village.villname,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,
village.villno,
Sum(if(d.t159='1',1,0)) AS r1,
Sum(if(d.t159='2',1,0)) AS r2,
Sum(if(d.t159='3',1,0)) AS r3,
Sum(1) AS p
FROM
person
LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
LEFT JOIN village ON village.villcode = house.villcode
LEFT JOIN visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
INNER JOIN visithomehealthindividual AS d ON visit.pcucode = d.pcucode AND visit.visitno = d.visitno
WHERE SUBSTRING(house.villcode,7,2)<>'00'
  $P!{pcucode}
GROUP BY house.villcode]]>
	</queryString>
	<field name="1" class="java.lang.Long"/>
	<field name="villname" class="java.lang.String"/>
	<field name="villno" class="java.lang.Integer"/>
	<field name="r1" class="java.math.BigDecimal"/>
	<field name="r2" class="java.math.BigDecimal"/>
	<field name="r3" class="java.math.BigDecimal"/>
	<field name="p" class="java.math.BigDecimal"/>
	<variable name="sum_r1" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{r1}]]></variableExpression>
	</variable>
	<variable name="sum_r2" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{r2}]]></variableExpression>
	</variable>
	<variable name="sum_r3" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{r3}]]></variableExpression>
	</variable>
	<variable name="sum_p" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{p}]]></variableExpression>
	</variable>
	<variable name="r1rate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  (($F{r1}.doubleValue()) /($F{p}.doubleValue()))*100 )]]></variableExpression>
	</variable>
	<variable name="r2rate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  (($F{r2}.doubleValue()) /($F{p}.doubleValue()))*100 )]]></variableExpression>
	</variable>
	<variable name="r3rate" class="java.lang.Double">
		<variableExpression><![CDATA[new Double(  (($F{r3}.doubleValue()) /($F{p}.doubleValue()))*100 )]]></variableExpression>
	</variable>
	<variable name="SUM_p_1" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{p}]]></variableExpression>
	</variable>
	<variable name="SUM_r1_1" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{r1}]]></variableExpression>
	</variable>
