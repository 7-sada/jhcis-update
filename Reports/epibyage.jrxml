<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="epibyage" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="78"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="startDate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="endDate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01838"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 < 12 AND e.vaccinecode="BCG", 1,0)) AS m11_BCG,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 < 12 AND e.vaccinecode="HBV3", 1,0)) AS m11_HBV3,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 < 12 AND e.vaccinecode="DTP3", 1,0)) AS m11_DTP3,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 < 12 AND e.vaccinecode="OPV3", 1,0)) AS m11_OPV3,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 < 12 AND e.vaccinecode="MEAS", 1,0)) AS m11_MEAS,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 < 12 AND e.vaccinecode="MMR", 1,0)) AS m11_MMR,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 12 AND 17 AND e.vaccinecode="BCG", 1,0)) AS m1217_BCG,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 12 AND 17 AND e.vaccinecode="HBV3", 1,0)) AS m1217_HBV3,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 12 AND 17 AND e.vaccinecode="DTP3", 1,0)) AS m1217_DTP3,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 12 AND 17 AND e.vaccinecode="OPV3", 1,0)) AS m1217_OPV3,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 12 AND 17 AND e.vaccinecode="MEAS", 1,0)) AS m1217_MEAS,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 12 AND 17 AND e.vaccinecode="MMR", 1,0)) AS m1217_MMR,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 18 AND 23 AND e.vaccinecode="DTP4", 1,0)) AS m1823_DTP4,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 18 AND 23 AND e.vaccinecode="OPV4", 1,0)) AS m1823_OPV4,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 18 AND 23 AND e.vaccinecode="JE2", 1,0)) AS m1823_JE2,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 24 AND 29 AND e.vaccinecode="DTP4", 1,0)) AS m2429_DTP4,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 24 AND 29 AND e.vaccinecode="OPV4", 1,0)) AS m2429_OPV4,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 30 AND 47 AND e.vaccinecode="JE3", 1,0)) AS m3047_JE3,

SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 48 AND 60 AND e.vaccinecode="DTP5", 1,0)) AS m4860_DTP5,
SUM(IF(DATEDIFF(v.visitdate,p.birth)  /30 BETWEEN 48 AND 60 AND e.vaccinecode="OPV5", 1,0)) AS m4860_OPV5
FROM
person AS p
Inner Join visit AS v ON p.pid = v.pid AND p.pcucodeperson = v.pcucodeperson
Inner Join visitepi AS e ON v.visitno = e.visitno AND v.pcucodeperson = e.pcucodeperson
WHERE v.visitdate BETWEEN $P{startDate} AND  $P{endDate}
AND e.pcucodeperson LIKE $P{pcucode}
;]]>
	</queryString>
