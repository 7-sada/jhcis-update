<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="child1year_vac_loss" pageWidth="835" pageHeight="595" orientation="Landscape" columnWidth="775" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-12-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="villno" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select p.pid,CONVERT(concat(ifnull(titlename,ifnull(p.prename,'ไม่ระบุ')),' ' ,fname,' ' ,lname) using utf8)  as name
,birth,DATE_FORMAT(p.birth,'%Y-%m-%d') as bb
,ROUND(DATEDIFF(CAST($P{pdate} AS DATE),p.birth) /30) AS age_ym
,p.mumoi,v.pcucode

,(select ROUND(DATEDIFF(CAST(v1.dateepi AS DATE),p.birth)/30) as v1m from visitepi v1 where v.pid=v1.pid and v.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='BCG'   group by v1.pid, v1.pcucodeperson ) as bcg
,(select DATE_FORMAT(v1.dateepi,'%d-%m-%y') from visitepi v1 where v.pid = v1.pid and v.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='BCG' group by v1.pid and v1.pcucodeperson) as bcg11
,(select hosservice from visitepi v1 where v.pid = v1.pid and v.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='BCG' group by v1.pid and v1.pcucodeperson) as bcg111

,(select ROUND(DATEDIFF(CAST(v2.dateepi AS DATE),p.birth)/30) as v2m from visitepi v2 where v.pid=v2.pid and v.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='HBV1'  group by v2.pid,v2.pcucodeperson ) as hbv1
,(select DATE_FORMAT(v2.dateepi,'%d-%m-%y') from visitepi v2 where v.pid = v2.pid and v.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='HBV1' group by v2.pid and v2.pcucodeperson) as hbv11
,(select hosservice from visitepi v2 where v.pid = v2.pid and v.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='HBV1' group by v2.pid and v2.pcucodeperson) as hbv111

,(select ROUND(DATEDIFF(CAST(v3.dateepi AS DATE),p.birth)/30) as v3m from visitepi v3 where v.pid=v3.pid and v.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='HBV2'  group by v3.pid,v3.pcucodeperson ) as hbv2
,(select DATE_FORMAT(v3.dateepi,'%d-%m-%y') from visitepi v3 where v.pid = v3.pid and v.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='HBV2' group by v3.pid and v3.pcucodeperson) as hbv21
,(select hosservice from visitepi v3 where v.pid = v3.pid and v.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='HBV2' group by v3.pid and v3.pcucodeperson) as hbv211

,(select ROUND(DATEDIFF(CAST(v4.dateepi AS DATE),p.birth)/30) as v4m from visitepi v4 where v.pid=v4.pid and v.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='DTP1'  group by v4.pid,v4.pcucodeperson ) as dtp1
,(select DATE_FORMAT(v4.dateepi,'%d-%m-%y') from visitepi v4 where v.pid = v4.pid and v.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='DTP1' group by v4.pid and v4.pcucodeperson) as dtp11
,(select hosservice from visitepi v4 where v.pid = v4.pid and v.pcucodeperson=v4.pcucodeperson and v4.vaccinecode='DTP1' group by v4.pid and v4.pcucodeperson) as dtp111

,(select ROUND(DATEDIFF(CAST(v5.dateepi AS DATE),p.birth)/30) as v5m from visitepi v5 where v.pid=v5.pid and v.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='OPV1'  group by v5.pid,v5.pcucodeperson ) as opv1
,(select DATE_FORMAT(v5.dateepi,'%d-%m-%y') from visitepi v5 where v.pid = v5.pid and v.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='OPV1' group by v5.pid and v5.pcucodeperson) as opv11
,(select hosservice from visitepi v5 where v.pid = v5.pid and v.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='OPV1' group by v5.pid and v5.pcucodeperson) as opv111

,(select ROUND(DATEDIFF(CAST(v6.dateepi AS DATE),p.birth)/30) as v6m from visitepi v6 where v.pid=v6.pid and v.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='DTP2'  group by v6.pid,v6.pcucodeperson ) as dtp2
,(select DATE_FORMAT(v6.dateepi,'%d-%m-%y') from visitepi v6 where v.pid = v6.pid and v.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='DTP2' group by v6.pid and v6.pcucodeperson) as dtp21
,(select hosservice from visitepi v6 where v.pid = v6.pid and v.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='DTP2' group by v6.pid and v6.pcucodeperson) as dtp211

,(select ROUND(DATEDIFF(CAST(v7.dateepi AS DATE),p.birth)/30) as v7m from visitepi v7 where v.pid=v7.pid and v.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='OPV2'  group by v7.pid,v7.pcucodeperson ) as opv2
,(select DATE_FORMAT(v7.dateepi,'%d-%m-%y') from visitepi v7 where v.pid = v7.pid and v.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='OPV2' group by v7.pid and v7.pcucodeperson) as opv21
,(select hosservice from visitepi v7 where v.pid = v7.pid and v.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='OPV2' group by v7.pid and v7.pcucodeperson) as opv211

,(select ROUND(DATEDIFF(CAST(v8.dateepi AS DATE),p.birth)/30) as v8m from visitepi v8 where v.pid=v8.pid and v.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='HBV3'  group by v8.pid,v8.pcucodeperson ) as hbv3
,(select DATE_FORMAT(v8.dateepi,'%d-%m-%y') from visitepi v8 where v.pid = v8.pid and v.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='HBV3' group by v8.pid and v8.pcucodeperson) as hbv31
,(select hosservice from visitepi v8 where v.pid = v8.pid and v.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='HBV3' group by v8.pid and v8.pcucodeperson) as hbv311

,(select ROUND(DATEDIFF(CAST(v9.dateepi AS DATE),p.birth)/30) as v9m from visitepi v9 where v.pid=v9.pid and v.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='DTP3'  group by v9.pid,v9.pcucodeperson ) as dtp3
,(select DATE_FORMAT(v9.dateepi,'%d-%m-%y') from visitepi v9 where v.pid = v9.pid and v.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='DTP3' group by v9.pid and v9.pcucodeperson) as dtp31
,(select hosservice from visitepi v9 where v.pid = v9.pid and v.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='DTP3' group by v9.pid and v9.pcucodeperson) as dtp311

,(select ROUND(DATEDIFF(CAST(v10.dateepi AS DATE),p.birth)/30) as v10m from visitepi v10  where v.pid=v10.pid and v.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='OPV3'  group by v10.pid,v10.pcucodeperson ) as opv3
,(select DATE_FORMAT(v10.dateepi,'%d-%m-%y') from visitepi v10 where v.pid = v10.pid and v.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='OPV3' group by v10.pid and v10.pcucodeperson) as opv31
,(select hosservice from visitepi v10 where v.pid = v10.pid and v.pcucodeperson=v10.pcucodeperson and v10.vaccinecode='OPV3' group by v10.pid and v10.pcucodeperson) as opv311

,(select ROUND(DATEDIFF(CAST(v11.dateepi AS DATE),p.birth)/30) as v11m from visitepi v11 where v.pid=v11.pid and v.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='MEAS'  group by v11.pid,v11.pcucodeperson ) as meas
,(select DATE_FORMAT(v11.dateepi,'%d-%m-%y') from visitepi v11 where v.pid = v11.pid and v.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='MEAS' group by v11.pid and v11.pcucodeperson) as meas1
,(select hosservice from visitepi v11 where v.pid = v11.pid and v.pcucodeperson=v11.pcucodeperson and v11.vaccinecode='MEAS' group by v11.pid and v11.pcucodeperson) as meas11

,(select ROUND(DATEDIFF(CAST(v12.dateepi AS DATE),p.birth)/30) as v12m from visitepi v12 where v.pid=v12.pid and v.pcucodeperson=v12.pcucodeperson and v12.vaccinecode like 'MMR%'  group by v12.pid,v12.pcucodeperson ) as mmr
,(select DATE_FORMAT(v12.dateepi,'%d-%m-%y') from visitepi v12 where v.pid = v12.pid and v.pcucodeperson=v12.pcucodeperson and v12.vaccinecode like 'MMR%' group by v12.pid and v12.pcucodeperson) as mmr1
,(select hosservice from visitepi v12 where v.pid = v12.pid and v.pcucodeperson=v12.pcucodeperson and v12.vaccinecode like 'MMR%' group by v12.pid and v12.pcucodeperson) as mmr11

,(select ROUND(DATEDIFF(CAST(v13.dateepi AS DATE),p.birth)/30) as v13m from visitepi v13 where v.pid=v13.pid and v.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='DHVB1'  group by v13.pid,v13.pcucodeperson ) as dhb1
,(select DATE_FORMAT(v13.dateepi,'%d-%m-%y') from visitepi v13 where v.pid = v13.pid and v.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='DHB1' group by v13.pid and v13.pcucodeperson) as dhb11
,(select hosservice from visitepi v13 where v.pid = v13.pid and v.pcucodeperson=v13.pcucodeperson and v13.vaccinecode='DHB1' group by v13.pid and v13.pcucodeperson) as dhb111

,(select ROUND(DATEDIFF(CAST(v14.dateepi AS DATE),p.birth)/30) as v14m from visitepi v14 where v.pid=v14.pid and v.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='DHB2'  group by v14.pid,v14.pcucodeperson ) as dhb2
,(select DATE_FORMAT(v14.dateepi,'%d-%m-%y') from visitepi v14 where v.pid = v14.pid and v.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='DHB2' group by v14.pid and v14.pcucodeperson) as dhb22
,(select hosservice from visitepi v14 where v.pid = v14.pid and v.pcucodeperson=v14.pcucodeperson and v14.vaccinecode='DHB2' group by v14.pid and v14.pcucodeperson) as dhb222

,(select ROUND(DATEDIFF(CAST(v15.dateepi AS DATE),p.birth)/30) as v15m from visitepi v15 where v.pid=v15.pid and v.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='DHB3'  group by v15.pid,v15.pcucodeperson ) as dhb3
,(select DATE_FORMAT(v15.dateepi,'%d-%m-%y') from visitepi v15 where v.pid = v15.pid and v.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='DHB3' group by v15.pid and v15.pcucodeperson) as dhb33
,(select hosservice from visitepi v15 where v.pid = v15.pid and v.pcucodeperson=v15.pcucodeperson and v15.vaccinecode='DHB3' group by v15.pid and v15.pcucodeperson) as dhb333

,(select ROUND(DATEDIFF(CAST(v16.dateepi AS DATE),p.birth)/30) as v16m from visitepi v16 where v.pid=v16.pid and v.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='DTP4'  group by v16.pid,v16.pcucodeperson ) as dtp4
,(select DATE_FORMAT(v16.dateepi,'%d-%m-%y') from visitepi v16 where v.pid = v16.pid and v.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='DTP4' group by v16.pid and v16.pcucodeperson) as dtp44
,(select hosservice from visitepi v16 where v.pid = v16.pid and v.pcucodeperson=v16.pcucodeperson and v16.vaccinecode='DTP4' group by v16.pid and v16.pcucodeperson) as dtp444

,(select ROUND(DATEDIFF(CAST(v17.dateepi AS DATE),p.birth)/30) as v17m from visitepi v17 where v.pid=v17.pid and v.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='OPV4'  group by v17.pid,v17.pcucodeperson ) as opv4
,(select DATE_FORMAT(v17.dateepi,'%d-%m-%y') from visitepi v17 where v.pid = v17.pid and v.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='OPV4' group by v17.pid and v17.pcucodeperson) as opv44
,(select hosservice from visitepi v17 where v.pid = v17.pid and v.pcucodeperson=v17.pcucodeperson and v17.vaccinecode='OPV4' group by v17.pid and v17.pcucodeperson) as opv444


,(select ROUND(DATEDIFF(CAST(v18.dateepi AS DATE),p.birth)/30) as v18m from visitepi v18 where v.pid=v18.pid and v.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='JE1'  group by v18.pid,v18.pcucodeperson ) as je1
,(select DATE_FORMAT(v18.dateepi,'%d-%m-%y') from visitepi v18 where v.pid = v18.pid and v.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='JE1' group by v18.pid and v18.pcucodeperson) as je11
,(select hosservice from visitepi v18 where v.pid = v18.pid and v.pcucodeperson=v18.pcucodeperson and v18.vaccinecode='JE1' group by v18.pid and v18.pcucodeperson) as je111

,(select ROUND(DATEDIFF(CAST(v19.dateepi AS DATE),p.birth)/30) as v19m from visitepi v19 where v.pid=v19.pid and v.pcucodeperson=v19.pcucodeperson and v19.vaccinecode='JE2'  group by v19.pid,v19.pcucodeperson ) as je2
,(select DATE_FORMAT(v19.dateepi,'%d-%m-%y') from visitepi v19 where v.pid = v19.pid and v.pcucodeperson=v19.pcucodeperson and v19.vaccinecode='JE2' group by v19.pid and v19.pcucodeperson) as je22
,(select hosservice from visitepi v19 where v.pid = v19.pid and v.pcucodeperson=v19.pcucodeperson and v19.vaccinecode='JE2' group by v19.pid and v19.pcucodeperson) as je222

,(select ROUND(DATEDIFF(CAST(v20.dateepi AS DATE),p.birth)/30) as v20m from visitepi v20 where v.pid=v20.pid and v.pcucodeperson=v20.pcucodeperson and v20.vaccinecode='JE3'  group by v20.pid,v20.pcucodeperson ) as je3
,(select DATE_FORMAT(v20.dateepi,'%d-%m-%y') from visitepi v20 where v.pid = v20.pid and v.pcucodeperson=v20.pcucodeperson and v20.vaccinecode='JE3' group by v20.pid and v20.pcucodeperson) as je33
,(select hosservice from visitepi v20 where v.pid = v20.pid and v.pcucodeperson=v20.pcucodeperson and v20.vaccinecode='JE3' group by v20.pid and v20.pcucodeperson) as je333

,(select ROUND(DATEDIFF(CAST(v21.dateepi AS DATE),p.birth)/30) as v21m from visitepi v21 where v.pid=v21.pid and v.pcucodeperson=v21.pcucodeperson and v21.vaccinecode='DTP5'  group by v21.pid,v21.pcucodeperson ) as dtp5
,(select DATE_FORMAT(v21.dateepi,'%d-%m-%y') from visitepi v21 where v.pid = v21.pid and v.pcucodeperson=v21.pcucodeperson and v21.vaccinecode='DTP5' group by v21.pid and v21.pcucodeperson) as dtp55
,(select hosservice from visitepi v21 where v.pid = v21.pid and v.pcucodeperson=v21.pcucodeperson and v21.vaccinecode='DTP5' group by v21.pid and v21.pcucodeperson) as dtp555

,(select ROUND(DATEDIFF(CAST(v22.dateepi AS DATE),p.birth)/30) as v22m from visitepi v22 where v.pid=v22.pid and v.pcucodeperson=v22.pcucodeperson and v22.vaccinecode='OPV5'  group by v22.pid,v22.pcucodeperson ) as opv5
,(select DATE_FORMAT(v22.dateepi,'%d-%m-%y') from visitepi v22 where v.pid = v22.pid and v.pcucodeperson=v22.pcucodeperson and v22.vaccinecode='OPV5' group by v22.pid and v22.pcucodeperson) as opv55
,(select hosservice from visitepi v22 where v.pid = v22.pid and v.pcucodeperson=v22.pcucodeperson and v22.vaccinecode='OPV5' group by v22.pid and v22.pcucodeperson) as opv555


,if(v.hosservice = v.pcucode,'ที่นี่','ที่อื่น' ) as servicehere
,if((hnomoi) = "" ,'ไม่ระบุบ้าน ?',hnomoi) AS hno_or_not
,p.hnomoi, village.villno,chospital.hosname,cprovince.provname,cdistrict.distname
,village.villname
from  visitepi v
          left join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson )
	  left join ctitle t on p.prename = t.titlecode
          left  join cdrug cd on (cd.drugcode = v.vaccinecode)
	  left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
          left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
          left join chospital ON (v.pcucode = chospital.hoscode)
	  left join cprovince ON (cprovince.provcode =chospital.provcode)
          left join cdistrict ON (cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode)
where   village.villno >= $P{villno}
	and DATEDIFF(CAST($P{pdate} AS DATE),p.birth) < 365
	$P!{pcucode}
group by v.pid,v.pcucodeperson
order by chospital.hoscode,village.villcode,p.birth DESC]]>
	</queryString>
