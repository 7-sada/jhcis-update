	</field>
	<field name="villcode" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="villname" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="dt" class="java.lang.String"/>
	<field name="dt1" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="dateepi" class="java.sql.Date">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
