	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date"/>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ AND `visitfp`.`pcucode`='07260' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
     cdrug.drugname,
     Sum(visitfp.unit) as unit,
     cdrugunitsell.unitsellname AS unitsell,
     CASE WHEN cdrug.drugtypesub=1 THEN 'ยาเม็ด' WHEN cdrug.drugtypesub=2 THEN 'ยาฉีด' WHEN cdrug.drugtypesub=3 THEN 'ยาฝัง' WHEN cdrug.drugtypesub=4 THEN 'ห่วง' ELSE 'อื่น ๆ' END as type,
 1
FROM
     cdrug INNER JOIN visitfp ON cdrug.drugcode = visitfp.fpcode
Left Outer Join cdrugunitsell ON cdrug.unitsell = cdrugunitsell.unitsellcode
WHERE cdrug.drugtypesub <> '0' AND cdrug.drugcode <> 'fp0000' $P!{pcucode} $P!{DateFp}
GROUP BY cdrug.drugname
ORDER BY cdrug.drugtypesub]]></queryString>

