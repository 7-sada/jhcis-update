	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND person.pcucodeperson =  '01032']]></parameterDescription>
		<defaultValueExpression ><![CDATA["  "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["รายชื่อ อสม."]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
CONCAT(h.pcucode,h.hcode) AS house,
CONCAT(ifnull(ctitle.titlename,person.prename),person.fname,' ',person.lname) AS voluname,
getAgeYearNum(person.birth,current_date) age,
person.rightno,
person.hnomoi,
DATE_FORMAT(persontype.dateelect,'%Y-%m-%d') AS dateelect,
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8),' ต.',getSubdist(LEFT(village.villcode,6))) AS village,
h.hno
FROM
`person`
Inner Join `persontype` ON `person`.`pcucodeperson` = `persontype`.`pcucodeperson` AND `person`.`pid` = `persontype`.`pid`
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join `house` ON `person`.`hcode` = `house`.`hcode` AND `person`.`pcucodeperson` = `house`.`pcucode`
Inner Join `village` ON `house`.`pcucode` = `village`.`pcucode` AND `house`.`villcode` = `village`.`villcode`
Inner Join `house` h ON `person`.`pid` = `h`.`pidvola` AND `person`.`pcucodeperson` = `h`.`pcucodepersonvola`
WHERE
`persontype`.`typecode` =  '09' 
$P!{pcucode}
ORDER BY
village.villcode ASC,
person.hnomoi ASC,h.hno]]></queryString>

