	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="fYear" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(2010)]]></defaultValueExpression>
	</parameter>
	<parameter name="bDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-10-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="eDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2010-09-30'"]]></defaultValueExpression>
	</parameter>
	<parameter name="odm" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(0)]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT _tmp_dmsurvey.pcucode,getOffice(_tmp_dmsurvey.pcucode) AS offname,DATE_FORMAT(visitdate,'%Y-%m-%d') AS visitdate
,0 AS pop
,COUNT(DISTINCT _tmp_dmsurvey.pcucodeperson,_tmp_dmsurvey.ppid) AS survey
,COUNT(DISTINCT _tmp_dmsurvey.pcucode,_tmp_dmsurvey.visitno,CASE WHEN _tmp_dmsurvey.vchro = '10' OR ((_tmp_dmsurvey.rcode IN ('01','02','09') AND _tmp_dmsurvey.fchronic= '10') OR (_tmp_dmsurvey.sugar > 100 AND _tmp_dmsurvey.npo = '0') OR (_tmp_dmsurvey.bmi > 25)) THEN 1 ELSE null END) AS predm
,COUNT(DISTINCT _tmp_dmsurvey.pcucodeperson,_tmp_dmsurvey.ppid,CASE WHEN _tmp_dmsurvey.vchro = '10' AND  _tmp_dmsurvey.chronicfirstdiag BETWEEN $P!{bDate} AND $P!{eDate} THEN 1 ELSE null END) AS fdm
,COUNT(DISTINCT _tmp_dmsurvey.pcucodeperson,_tmp_dmsurvey.ppid,CASE WHEN _tmp_dmsurvey.vchro = '10' AND  _tmp_dmsurvey.chronicfirstdiag < $P!{bDate}  THEN 1 ELSE null END) AS odm
,COUNT(DISTINCT _tmp_dmsurvey.pcucode,_tmp_dmsurvey.visitno,CASE WHEN _tmp_dmsurvey.counselingcode IS NOT NULL THEN 1 ELSE null END) AS edu
FROM
_tmp_dmsurvey
WHERE visitdate BETWEEN $P!{bDate} AND $P!{eDate}
GROUP BY 
_tmp_dmsurvey.pcucode,left(visitdate,7)

UNION
SELECT person.pcucodeperson,'' AS offname,DATE_FORMAT($P!{eDate},'%Y-%m-%d') AS visitdate
,COUNT(DISTINCT person.pcucodeperson,person.pid) AS pop
,0 AS survey
,0 AS preht
,0 AS fht
,0 AS oht
,0 AS edu
FROM
person
WHERE DATE_FORMAT(FROM_DAYS(TO_DAYS($P!{eDate})-TO_DAYS(`person`.`birth`)),'%Y')+0 >= 35
GROUP BY 
person.pcucodeperson

ORDER BY visitdate]]></queryString>

