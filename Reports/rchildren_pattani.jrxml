<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rchildren_pattani"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson =  '09083' "]]></defaultValueExpression>
	</parameter>
	<parameter name="visitdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.visitdate BETWEEN '20080101' AND '20090101' "]]></defaultValueExpression>
	</parameter>
	<parameter name="dateserv" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND persongrow.datesurvey BETWEEN '20080101' AND '20090101' "]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'20090101'"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
(SELECT Count(distinct person.pid) FROM person Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid WHERE DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}AND persondeath.pid IS NULL) AS p,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
Inner Join visitnutrition ON visit.pcucode = visitnutrition.pcucode AND visit.visitno = visitnutrition.visitno
WHERE DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(visit.visitdate) = (SELECT MAX(visitdate) FROM visit WHERE person.pcucodeperson = visit.pcucodeperson AND visit.pid = person.pid $P!{visitdate})) AS weight,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
Inner Join visitnutrition ON visit.pcucode = visitnutrition.pcucode AND visit.visitno = visitnutrition.visitno
WHERE visitnutrition.nlevel = 1 AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(visit.visitdate) = (SELECT MAX(visitdate) FROM visit WHERE person.pcucodeperson = visit.pcucodeperson AND visit.pid = person.pid $P!{visitdate})) AS mlowerweight,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
Inner Join visitnutrition ON visit.pcucode = visitnutrition.pcucode AND visit.visitno = visitnutrition.visitno
WHERE visitnutrition.nlevel = 2 AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(visit.visitdate) = (SELECT MAX(visitdate) FROM visit WHERE person.pcucodeperson = visit.pcucodeperson AND visit.pid = person.pid $P!{visitdate})) AS lowerweight,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
Inner Join visitnutrition ON visit.pcucode = visitnutrition.pcucode AND visit.visitno = visitnutrition.visitno
WHERE visitnutrition.nlevel = 3 AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(visit.visitdate) = (SELECT MAX(visitdate) FROM visit WHERE person.pcucodeperson = visit.pcucodeperson AND visit.pid = person.pid $P!{visitdate})) AS normalweight,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
Inner Join visitnutrition ON visit.pcucode = visitnutrition.pcucode AND visit.visitno = visitnutrition.visitno
WHERE visitnutrition.nlevel = 4 AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(visit.visitdate) = (SELECT MAX(visitdate) FROM visit WHERE person.pcucodeperson = visit.pcucodeperson AND visit.pid = person.pid $P!{visitdate})) AS overweight,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join visit ON person.pcucodeperson = visit.pcucodeperson AND person.pid = visit.pid
Inner Join visitnutrition ON visit.pcucode = visitnutrition.pcucode AND visit.visitno = visitnutrition.visitno
WHERE visitnutrition.nlevel = 5 AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(visit.visitdate) = (SELECT MAX(visitdate) FROM visit WHERE person.pcucodeperson = visit.pcucodeperson AND visit.pid = person.pid $P!{visitdate})) AS moverweight,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join persongrow ON person.pcucodeperson = persongrow.pcucodeperson AND person.pid = persongrow.pid
Inner Join cgrow ON cgrow.growcode = persongrow.growcode
WHERE DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(persongrow.datesurvey) = (SELECT MAX(datesurvey) FROM persongrow WHERE person.pcucodeperson = persongrow.pcucodeperson AND persongrow.pid = person.pid $P!{dateserv})) AS glow,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join persongrow ON person.pcucodeperson = persongrow.pcucodeperson AND person.pid = persongrow.pid
Inner Join cgrow ON cgrow.growcode = persongrow.growcode
WHERE persongrow.agemonthcan >= cgrow.growstd AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(persongrow.datesurvey) = (SELECT MAX(datesurvey) FROM persongrow WHERE person.pcucodeperson = persongrow.pcucodeperson AND persongrow.pid = person.pid $P!{dateserv})) AS normalglow,
(SELECT Count(distinct person.pid)
FROM
person
Left Outer Join persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid = person.pid
Inner Join persongrow ON person.pcucodeperson = persongrow.pcucodeperson AND person.pid = persongrow.pid
Inner Join cgrow ON cgrow.growcode = persongrow.growcode
WHERE persongrow.agemonthcan < cgrow.growstd AND DATEDIFF($P!{edate},birth) < 2190 $P!{pcucode}
AND persondeath.pid IS NULL 
AND zero2null(persongrow.datesurvey) = (SELECT MAX(datesurvey) FROM persongrow WHERE person.pcucodeperson = persongrow.pcucodeperson AND persongrow.pid = person.pid $P!{dateserv})) AS lowerglow]]></queryString>

	<field name="p" class="java.lang.Long"/>
	<field name="weight" class="java.lang.Long"/>
	<field name="mlowerweight" class="java.lang.Long"/>
	<field name="lowerweight" class="java.lang.Long"/>
	<field name="normalweight" class="java.lang.Long"/>
	<field name="overweight" class="java.lang.Long"/>
