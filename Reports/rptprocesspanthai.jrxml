<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptprocesspanthai" pageWidth="842" pageHeight="595" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-12-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT person.idcard
,concat(ifnull(ctitle.titlename,ifnull(person.prename,'ไม่ระบุ') ),person.fname,' ' ,person.lname) as pname
,DATE_FORMAT(visitdate,'%Y-%m-%d') as visitdate
,office.offid
,v.pcucode
,if(v.pcucode = office.offid,"หน่วยบริการ" ,"ที่อื่น " ) as pcu
,drugname
,CONVERT(concat(ifnull(c.titlename,ifnull(u.prename,'ไม่ระบุ' ) ),u.fname,' ',u.lname ) using utf8)  as uname
,count(visitdrug.drugcode) as ctime
,DATE_FORMAT(visitdrug.dateupdate,'%Y-%m-%d') as dateupdate
,curdate() as cdate
FROM person left join ctitle on person.prename = ctitle.titlecode
	left join visit  v on person.pid = v.pid  and person.pcucodeperson = v.pcucodeperson
	left join visitdrug on v.visitno = visitdrug.visitno and v.pcucode = visitdrug.pcucode
	left join cdrug on visitdrug.drugcode = cdrug.drugcode
	left join `user` u on visitdrug.doctor1 = u.username
	left join ctitle c on c.titlecode = u.prename
	left join office on v.pcucode = office.offid
WHERE    cdrug.drugtype='02'
	and  cdrug.drugtypesub='4'
 	and visitdate between $P{sdate} and $P{edate}
        $P!{pcucode}
GROUP BY v.visitno,v.pcucodeperson
ORDER BY v.visitdate]]>
	</queryString>
	<field name="idcard" class="java.lang.String"/>
	<field name="pname" class="java.lang.String"/>
	<field name="visitdate" class="java.lang.String"/>
	<field name="offid" class="java.lang.String"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="pcu" class="java.lang.String"/>
	<field name="drugname" class="java.lang.String"/>
	<field name="uname" class="java.lang.String"/>
	<field name="ctime" class="java.lang.Long"/>
	<field name="dateupdate" class="java.lang.String"/>
	<field name="cdate" class="java.sql.Date"/>
