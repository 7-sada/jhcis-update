	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-07-22"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-07-30"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select visit.visitdate datecare
,sum(case when (select count(concat( v1.pid,v1.pcucodeperson,v1.pregno)) as dc from visitancmothercare v1 where visit.pid= v1.pid and visit.pcucodeperson = v1.pcucodeperson  group by v1.pid,v1.pcucodeperson,v1.pregno having dc >=2) then 1 else 0 end) as mc2
,sum(case when (select count(concat( vb.pcucodeperson,vb.pid)) as db from visitbabycare vb where visit.pid= vb.pid and visit.pcucodeperson = vb.pcucodeperson  group by vb.pcucodeperson,vb.pid  having db =2) then 1 else 0 end) as bc2
,hosname
from    visit left join visitancmothercare   ON  visit.visitno = visitancmothercare.visitno and visit.pcucode = visitancmothercare.pcucode  
              left join visitbabycare ON visit.visitno = visitbabycare.visitNo and visit.pcucode = visitbabycare.pcucode
	      left join chospital ON visit.pcucode = chospital.hoscode

where visit.visitdate between $P{sdate} and $P{edate} $P!{pcucode}
         and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
group by visit.pcucode]]></queryString>

	<field name="datecare" class="java.sql.Date"/>
	<field name="mc2" class="java.math.BigDecimal"/>
	<field name="bc2" class="java.math.BigDecimal"/>
	<field name="hosname" class="java.lang.String"/>

