	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4274"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(visitepi.dateepi,"%Y-%m-%d")AS dateepi,
     visitepi.`vaccinecode` AS visitepi_vaccinecode,
     visitepiappoint.`vaccinecode` AS visitepiappoint_vaccinecode,
     DATE_FORMAT(visitepiappoint.`dateappoint`,"%Y-%m-%d")AS visitepiappoint_dateappoint,
     DATE_FORMAT(person.`birth`,"%Y-%m-%d")AS person_birth,
     cdrug.`drugname` AS cdrug_drugname,
     cdrug_A.`drugname` AS cdrug_A_drugname,
CONVERT(CONCAT(  DATE_FORMAT(dateepi,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(dateepi,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " - ",
	CASE SIGN(DATE_FORMAT(dateepi ,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(dateepi,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(dateepi,"%m") -  (DATE_FORMAT(dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(dateepi,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " - ",
	CASE SIGN(DATE_FORMAT(dateepi,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN( DATE_FORMAT(birth,"%d") - DATE_FORMAT(dateepi,"%d") )
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(birth),"%d") + DATE_FORMAT(dateepi, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(dateepi,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(dateepi,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_ymd
FROM
     `visitepi` visitepi INNER JOIN `person` person ON visitepi.`pcucodeperson` = person.`pcucodeperson`
     AND visitepi.`pid` = person.`pid`
     LEFT OUTER JOIN `visitepiappoint` visitepiappoint ON visitepi.`pcucodeperson` = visitepiappoint.`pcucodeperson`
     AND visitepiappoint.`pid` = visitepi.`pid`
     AND visitepiappoint.`visitno` = visitepi.`visitno`
     LEFT OUTER JOIN `cdrug` cdrug ON visitepi.`vaccinecode` = cdrug.`drugcode`
     LEFT OUTER JOIN `cdrug` cdrug_A ON visitepiappoint.`vaccinecode` = cdrug_A.`drugcode`
WHERE
     visitepi.pcucodeperson = '$P!{p_pcucode}'
     and visitepi.pid = '$P!{p_pid}'
ORDER BY
     visitepi.dateepi ASC]]></queryString>

	<field name="dateepi" class="java.util.Date"/>
	<field name="visitepi_vaccinecode" class="java.lang.String"/>
	<field name="visitepiappoint_vaccinecode" class="java.lang.String"/>
	<field name="visitepiappoint_dateappoint" class="java.util.Date"/>
	<field name="person_birth" class="java.util.Date"/>
	<field name="cdrug_drugname" class="java.lang.String"/>
	<field name="cdrug_A_drugname" class="java.lang.String"/>
	<field name="age_ymd" class="java.lang.String"/>

