	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["03320"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["10114"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pregno" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(visitanc.datecheck,"%Y-%m-%d")AS visitdate,
     visitanc.`datecheck` AS visitanc_datecheck,
     visitanc.`dateappointcheck` AS visitanc_dateappointcheck,
     truncate(visitanc.`weight`,2)AS visitanc_weight,
     visitanc.`height` AS visitanc_height,
     visitanc.`pregage` AS visitanc_pregage,
     visitanc.`caries` AS visitanc_caries,
     visitanc.`gumfail` AS visitanc_gumfail,
     visitanc.`tartar` AS visitanc_tartar,
     visitanc.`toothcheck` AS visitanc_toothcheck,
     visitanc.`thalasbabycheck` AS visitanc_thalasbabycheck,
     visitanc.`ttno35` AS visitanc_ttno35,
     CASE visitanc.`sugar` WHEN '0'THEN 'ปกติ'WHEN '1'THEN 'ระดับ1'WHEN '2'THEN 'ระดับ2'WHEN '3'THEN 'ระดับ3'WHEN '4'THEN 'ระดับ4'WHEN '5'THEN 'ระดับ5'WHEN '6'THEN 'ระดับ6'ELSE "-"END AS visitanc_sugar,
     visitanc.`albumin` AS visitanc_albumin,
     visitanc.`breastcheck` AS visitanc_breastcheck,
     CASE visitanc.`headache` WHEN '0'THEN 'ไม่พบ'WHEN '1'THEN 'พบ'END AS visitanc_headache,
     visitanc.`ancsell` AS visitanc_ancsell,
     visitanc.`anccost` AS visitanc_anccost,
     visitanc.`ancres` AS visitanc_ancres,
     visitanc.`dateupdate` AS visitanc_dateupdate,
     visitanc.`bmi` AS visitanc_bmi,
     visitanc.`ancno` AS visitanc_ancno,
     visitanc.`flag18fileexpo` AS visitanc_flag18fileexpo,
     visitanc.`hosservice` AS visitanc_hosservice,
     visitanc.`heartbabycount` AS visitanc_heartbabycount,
     CASE visitanc.`heartbaby` WHEN '0'THEN 'ไม่ได้ยิน'WHEN '1'THEN 'ได้ยินน้อย'WHEN '2'THEN 'ได้ยินปกต'END AS visitanc_heartbaby,
     CASE visitanc.`pilot` WHEN '1'THEN 'HF'WHEN 'HE'THEN ''WHEN 'HPE'THEN ''END AS visitanc_pilot,
     CASE visitanc.`positionbaby` WHEN '1'THEN 'LOA'WHEN '2'THEN 'ROA'WHEN '3'THEN 'OPP'WHEN '4'THEN 'Transverse'WHEN '5'THEN 'Breech'WHEN '6'THEN 'Foot'WHEN '9'THEN 'ไม่ทราบ'END AS visitanc_positionbaby,
     CASE visitanc.`fundus` WHEN '1'THEN ' SP'WHEN '2'THEN '1/3 > SP'WHEN '3'THEN '2/3 >SP'WHEN '4'THEN 'สะดือ'WHEN '5'THEN '1/4 >สะดือ'WHEN '6'THEN '2/4 >สะดือ'WHEN '7'THEN '3/4 >สะดือ'END AS visitanc_fundus,
     CASE visitanc.`heartattach` WHEN '0'THEN 'ไม่พบ'WHEN '1'THEN 'พบ'END AS visitanc_heartattach,
     CASE visitanc.`urinary` WHEN '0'THEN 'ผิดปกติ'WHEN '1'THEN 'ไม่ผิดปกติ'END AS visitanc_urinary,
     CASE visitanc.`cramp` WHEN '0'THEN 'ไม่พบ'WHEN '1'THEN 'พบ'END AS visitanc_cramp,
     CASE visitanc.`utblood` WHEN '0'THEN 'ไม่พบ'WHEN '1'THEN 'พบ'END AS visitanc_utblood,
     CASE visitanc.`edima` WHEN '0'THEN 'ไม่พบ'WHEN '1'THEN 'พบ'END AS visitanc_edima,
     CASE visitanc.`utmugo` WHEN '0'THEN 'ไม่โต'WHEN '1'THEN 'โต'END AS visitanc_utmugo,
     CASE visitanc.`dancebaby` WHEN '0'THEN 'ไม่ดิ้น'WHEN '1'THEN '่ดิ้น'END AS visitanc_dancebaby,
     CASE visitanc.`tyroid` WHEN '0'THEN 'ไม่โต'WHEN '1'THEN 'โต'END AS visitanc_tyroid,
     CASE visitanc.`sickening` WHEN '0'THEN 'ไม่พบ'WHEN '1'THEN 'พบ'END AS visitanc_sickening,
     visit.`pressure` AS visit_pressure,
     floor(datediff(visit.visitdate,lmp)/7) AS pregwks,
     datediff(visit.visitdate,lmp)%7 AS pregdays
FROM
     `visit` visit INNER JOIN `visitanc` visitanc ON visit.`pcucodeperson` = visitanc.`pcucodeperson`
     AND visit.`pid` = visitanc.`pid`
     AND visitanc.`visitno` = visit.`visitno`
     INNER JOIN `visitancpregnancy` visitancpregnancy ON visitanc.`pcucodeperson` = visitancpregnancy.`pcucodeperson`
     AND visitancpregnancy.`pregno` = visitanc.`pregno`
     AND visitancpregnancy.`pid` = visitanc.`pid`
WHERE
     visitanc.pcucodeperson = '$P!{p_pcucode}'
     and visitanc.pid = '$P!{p_pid}'
     and visitanc.pregno = $P!{p_pregno}
ORDER BY
     visitanc.datecheck ASC]]></queryString>

