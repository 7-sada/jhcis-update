	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4274"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(visit.visitdate,"%Y-%m-%d")AS visitdate,
     visitnutrition.`weight` AS visitnutrition_weight,
     visitnutrition.`tall` AS visitnutrition_tall,
     visitnutrition.`headcycle` AS visitnutrition_headcycle,
     visitnutrition.`toothnew` AS visitnutrition_toothnew,
     visitnutrition.`toothcorrupt` AS visitnutrition_toothcorrupt,
     visitnutrition.`navel` AS visitnutrition_navel,
     visitnutrition.`dateappoint` AS visitnutrition_dateappoint,
     visitnutrition.`remark` AS visitnutrition_remark,
     CASE visitnutrition.`nlevel` 
	WHEN '1' THEN 'นน.ต่ำกว่าเกณฑ์' 
	WHEN '2' THEN 'นน.ค่อนข้างต่ำ'
	WHEN '3' THEN 'ปกติ'
	WHEN '4' THEN 'นน.ค่อนข้างสูง'
	WHEN '5' THEN 'นน.สูงกว่าเกณฑ์'
     END  	AS visitnutrition_nlevel,
CONVERT(CONCAT(  DATE_FORMAT(visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " - ",
	CASE SIGN(DATE_FORMAT(visitdate ,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visitdate,"%m") -  (DATE_FORMAT(visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " - ",
	CASE SIGN(DATE_FORMAT(visitdate,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN( DATE_FORMAT(birth,"%d") - DATE_FORMAT(visitdate,"%d") )
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(birth),"%d") + DATE_FORMAT(visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_ymd
FROM
     `person` person INNER JOIN `visit` visit ON person.`pcucodeperson` = visit.`pcucodeperson`
     AND person.`pid` = visit.`pid`
     INNER JOIN `visitnutrition` visitnutrition ON visit.`pcucode` = visitnutrition.`pcucode`
     AND visit.`visitno` = visitnutrition.`visitno`
WHERE
     visit.pcucodeperson = '$P!{p_pcucode}'
     and visit.pid = '$P!{p_pid}'
ORDER BY
     visit.visitdate ASC]]></queryString>

	<field name="visitdate" class="java.util.Date"/>
	<field name="visitnutrition_weight" class="java.math.BigDecimal"/>
	<field name="visitnutrition_tall" class="java.math.BigDecimal"/>
