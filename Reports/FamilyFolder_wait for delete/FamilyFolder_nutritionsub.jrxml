	<field name="visitnutrition_navel" class="java.lang.String"/>
	<field name="visitnutrition_dateappoint" class="java.sql.Date"/>
	<field name="visitnutrition_remark" class="java.lang.String"/>
	<field name="visitnutrition_nlevel" class="java.lang.String"/>
	<field name="age_ymd" class="java.lang.String"/>

