	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4717"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["D:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     date_format(visitbabycare.`datecare`,'%Y-%m-%d')AS datecare,
     visitbabycare.`locatecare` AS visitbabycare_locatecare,
     CASE visitbabycare.`navel` WHEN '0' THEN 'ไม่ปกติ' WHEN '1' THEN 'ปกติ' END  AS visitbabycare_navel,
     CASE visitbabycare.`skin` WHEN '0' THEN 'ไม่ปกติ' WHEN '1' THEN 'ปกติ' END  AS visitbabycare_skin,
     CASE visitbabycare.`urine` WHEN '0' THEN 'ไม่ปกติ' WHEN '1' THEN 'ปกติ' END AS visitbabycare_urine,
     CASE visitbabycare.`feci` WHEN '0' THEN 'ไม่ปกติ' WHEN '1' THEN 'ปกติ' END  AS visitbabycare_feci,
     CASE visitbabycare.`babyhealth` WHEN '0' THEN 'ไม่สมบูรณ์' WHEN '1' THEN 'สมบูรณ์' END AS visitbabycare_babyhealth,
     date_format(visitbabycare.`dateappointcare`,'%Y-%m-%d') AS visitbabycare_dateappointcare,
     visitbabycare.`hosservice` AS visitbabycare_hosservice,
     visitnutrition.`weight` AS visitnutrition_weight,
     visitnutrition.`tall` AS visitnutrition_tall
FROM
     `visitbabycare` visitbabycare LEFT  OUTER JOIN `visitnutrition` visitnutrition ON visitnutrition.`pcucode` = visitbabycare.`pcucode`
     AND visitnutrition.`visitno` = visitbabycare.`visitNo`
WHERE
     visitbabycare.pcucodeperson = '$P!{p_pcucode}'
 AND visitbabycare.pid = '$P!{p_pid}'
ORDER BY
       visitbabycare.`datecare` ASC]]></queryString>

