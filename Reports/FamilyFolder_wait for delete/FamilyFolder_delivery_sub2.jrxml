	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["11"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["D:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     date_format(visitancmothercare.`datecare`,'%Y-%m-%d')AS datecare,
     visit.`pressure` AS pressure,
     visit.`pulse` AS pulse,
     visitancmothercare.`pregno` AS pregno,
     visitancmothercare.`locatecare` AS locatecare,
     date_format(visitancmothercare.`dateappointcare`,'%Y-%m-%d')AS dateappointcare,
     CASE  visitancmothercare.`funduslevel` WHEN '1' THEN 'ปกติ' WHEN '0' THEN 'ผิดปกติ' END AS funduslevel,
     CASE visitancmothercare.`wabad` WHEN '1' THEN 'มี' WHEN '0' THEN 'ไม่มี(หมด)' END AS wabad,
     CASE visitancmothercare.`breast`  WHEN '1' THEN 'ปกติ' WHEN '0' THEN 'บอด' END AS breast,
     CASE visitancmothercare.`milk` WHEN '1' THEN 'ไหล' WHEN '0' THEN 'ไม่ไหล' END  AS milk,
     CASE men  WHEN '1' THEN 'ปกติ' WHEN '0' THEN 'ผิดปกติ' END AS men,
     CASE visitancmothercare.`alb` WHEN '0' THEN 'ปกติ' WHEN '1' THEN 'ระดับ 1' WHEN '2' THEN 'ระดับ 2' WHEN '3' THEN 'ระดับ 3"' WHEN '4' THEN 'ระดับ 4' END  AS alb,
     CASE visitancmothercare.`sugar` WHEN '0' THEN 'ปกติ' WHEN '1' THEN 'ระดับ 1' WHEN '2' THEN 'ระดับ 2' WHEN '3' THEN 'ระดับ 3"' WHEN '4' THEN 'ระดับ 4' END AS sugar,
     CASE visitancmothercare.`tear` WHEN '1' THEN 'ปกติ' WHEN '2' THEN 'แผลมีเลือดซึม' WHEN '3' THEN 'แผลเป็นหนอง' WHEN '4' THEN 'ผิดปกติ อื่นๆ' END AS tear,
     CASE visitancmothercare.`resultcheck`  WHEN '1' THEN 'ปกติ' WHEN '0' THEN 'ผิดปกติ' END AS resultcheck,
     visitancmothercare.`hosservice` AS hosservice
FROM
     `visit` visit RIGHT OUTER JOIN `visitancmothercare` visitancmothercare ON visit.`pcucodeperson` = visitancmothercare.`pcucodeperson`
     AND visit.`visitno` = visitancmothercare.`visitno`
     AND visit.`pid` = visitancmothercare.`pid`
WHERE
     visitancmothercare.pcucodeperson = '$P!{p_pcucode}'
 AND visitancmothercare.pid = '$P!{p_pid}'
ORDER BY
     visitancmothercare.`pregno` ASC,
     visitancmothercare.`datecare` ASC]]></queryString>

