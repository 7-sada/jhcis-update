		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["220"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     personunable1type.`pcucodeperson` AS personunable1type_pcucodeperson,
     personunable1type.`pid` AS personunable1type_pid,
     personunable1type.`typecode` AS personunable1type_typecode,
     CASE personunable1type.`unablelevel` 
			WHEN '1' THEN 'ช่วยเหลือตัวเองได้' 
			WHEN '2' THEN 'ควรให้ความช่วยเหลือ' 
			WHEN '3' THEN 'ต้องช่วยเหลือโดยด่วน'
			WHEN '9' THEN 'หายจากความพิการ' END  AS personunable1type_unablelevel,
     DATE_FORMAT(personunable1type.`datefound`,"%Y-%m-%d") AS personunable1type_datefound,
     cpersonincomplete.`incompletename` AS cpersonincomplete_incompletename,
     cpersonincomplete.`incompletetype` AS cpersonincomplete_incompletetype
FROM
     `cpersonincomplete` cpersonincomplete INNER JOIN `personunable1type` personunable1type 
ON cpersonincomplete.`incompletecode` = personunable1type.`typecode`
WHERE
    personunable1type.pcucodeperson = '$P!{p_pcucode}'
     and personunable1type.pid = '$P!{p_pid}']]></queryString>

	<field name="personunable1type_pcucodeperson" class="java.lang.String"/>
	<field name="personunable1type_pid" class="java.lang.Integer"/>
	<field name="personunable1type_typecode" class="java.lang.String"/>
	<field name="personunable1type_unablelevel" class="java.lang.String"/>
	<field name="personunable1type_datefound" class="java.util.Date"/>
	<field name="cpersonincomplete_incompletename" class="java.lang.String"/>
	<field name="cpersonincomplete_incompletetype" class="java.lang.String"/>

