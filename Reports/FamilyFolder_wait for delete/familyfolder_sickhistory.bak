	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["01024"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["1301"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["d:\\myireport\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
   `person`.`pid`,concat(pcucodeperson,pid) as ppid,
   concat(ifnull(`person`.`prename`,''),ifnull(`person`.`fname`,''),'  ',ifnull(`person`.`lname`,'')) as pati,
   ifnull(idcard,'...ไม่ระบุฯ') as idc,
   birth,`person`.`birth`,date_format(`person`.`birth`,'%Y-%m-%d') as birt,pid,
   concat(pcucodeperson,'-',pid,'/',substring(curdate(),1,4)+543) as hnyear,hnomoi,mumoi,subdistname,subdistname,distname,provname
  ,case when person.rightcode is not null  then cright.`rightname`  else 'ไม่ระบุสิทธิ' end AS cright_rightname
  ,CONVERT(CONCAT(  DATE_FORMAT(CURRENT_DATE,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(CURRENT_DATE,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " - ",
	CASE SIGN(DATE_FORMAT(CURRENT_DATE ,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(CURRENT_DATE,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(CURRENT_DATE,"%m") -  (DATE_FORMAT(CURRENT_DATE,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(CURRENT_DATE,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(CURRENT_DATE,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " - ",
	CASE SIGN(DATE_FORMAT(CURRENT_DATE,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN( DATE_FORMAT(birth,"%d") - DATE_FORMAT(CURRENT_DATE,"%d") )
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(birth),"%d") + DATE_FORMAT(CURRENT_DATE, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(CURRENT_DATE,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(CURRENT_DATE,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_ymd
FROM
`person`
Left Outer Join `cprovince` ON  `cprovince`.`provcode` = `person`.`provcodemoi` 
Left Outer Join `cdistrict` ON `cdistrict`.`provcode` = `person`.`provcodemoi` AND 
                                          `cdistrict`.`distcode` = `person`.`distcodemoi`
Left Outer Join `csubdistrict` ON `csubdistrict`.`provcode` = `person`.`provcodemoi` AND 
                                               `csubdistrict`.`distcode` = `person`.`distcodemoi` AND 
                                               `csubdistrict`.`subdistcode` = `person`.`subdistcodemoi`
left outer join office on 1=1
left JOIN `cright` cright ON person.`rightcode` = cright.`rightcode`
where
	person.pcucodeperson = '$P!{p_pcucode}'
        and person.pid =  '$P!{p_pid}'
        and office.offid =  '$P!{p_pcucode}']]></queryString>

