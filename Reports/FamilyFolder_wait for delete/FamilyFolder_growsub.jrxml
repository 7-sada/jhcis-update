<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FamilyFolder_growsub"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="595"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["4525"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(datesurvey,"%Y-%m-%d")AS datesurvey,
     CONVERT(CONCAT(DATE_FORMAT(datesurvey,"%Y")-DATE_FORMAT(birth,"%Y")-(DATE_FORMAT(datesurvey,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d"))," - ",CASE SIGN(DATE_FORMAT(datesurvey,"%m")-DATE_FORMAT(birth,"%m"))WHEN 0 THEN(11-DATE_FORMAT(birth,"%m")+DATE_FORMAT(datesurvey,"%m")-(DATE_FORMAT(birth,"00-00-%d")<DATE_FORMAT(birth,"00-00-%d")))WHEN -1 THEN(12-DATE_FORMAT(birth,"%m")+DATE_FORMAT(datesurvey,"%m")-(DATE_FORMAT(datesurvey,"00-00-%d")<DATE_FORMAT(birth,"00-00-%d")))WHEN 1 THEN(DATE_FORMAT(datesurvey,"%m")-DATE_FORMAT(birth,"%m")-(DATE_FORMAT(datesurvey,"00-00-%d")<DATE_FORMAT(birth,"00-00-%d")))END," - ",CASE SIGN(DATE_FORMAT(datesurvey,"%d")-DATE_FORMAT(birth,"%d"))WHEN 0 THEN(DATE_FORMAT(birth,"%d")-DATE_FORMAT(datesurvey,"%d"))WHEN -1 THEN(DATE_FORMAT(LAST_DAY(birth),"%d")+DATE_FORMAT(datesurvey,"%d")-DATE_FORMAT(birth,"%d"))WHEN 1 THEN(DATE_FORMAT(datesurvey,"%d")-DATE_FORMAT(birth,"%d")-(DATE_FORMAT(datesurvey,"%d")<DATE_FORMAT(birth,"%d")))END)USING utf8)AS age_ymd,
     persongrow.`growcode` AS persongrow_growcode,
     persongrow.`agemonthcan` AS persongrow_agemonthcan,
     persongrow.`datesurvey` AS persongrow_datesurvey,
     persongrow.`abnormal` AS persongrow_abnormal,
     cgrow.`growname` AS cgrow_growname,
     cgrow.`growstd` AS cgrow_growstd,
     CASE WHEN growstd=persongrow.`agemonthcan`  THEN  'พํฒนาการปกติ'
	  WHEN cgrow.`growstd`>persongrow.`agemonthcan`  THEN  'พํฒนาเร็วกว่าปกติ'
          WHEN cgrow.`growstd`<persongrow.`agemonthcan`  THEN  'พํฒนาช้ากว่าปกติ'
     END AS result
FROM
     `person` person INNER JOIN `persongrow` persongrow ON person.`pcucodeperson` = persongrow.`pcucodeperson`
     AND person.`pid` = persongrow.`pid`
     INNER JOIN `cgrow` cgrow ON persongrow.`growcode` = cgrow.`growcode`
WHERE
     persongrow.pcucodeperson = '$P!{p_pcucode}'
 AND persongrow.pid = '$P!{p_pid}'
ORDER BY
     persongrow.datesurvey ASC]]></queryString>

	<field name="datesurvey" class="java.util.Date"/>
	<field name="age_ymd" class="java.lang.String"/>
	<field name="persongrow_growcode" class="java.lang.String"/>
	<field name="persongrow_agemonthcan" class="java.lang.Double"/>
	<field name="persongrow_datesurvey" class="java.sql.Date"/>
	<field name="persongrow_abnormal" class="java.lang.String"/>
	<field name="cgrow_growname" class="java.lang.String"/>
	<field name="cgrow_growstd" class="java.math.BigDecimal"/>
	<field name="result" class="java.lang.String"/>

