	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["3897"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
      cdisease.`diseasename` AS cdisease_diseasename,
      personchronicfamily.`pcucodeperson` AS personchronicfamily_pcucodeperson,
     personchronicfamily.`pid` AS personchronicfamily_pid,
     personchronicfamily.`relationcode` AS personchronicfamily_relationcode,
     personchronicfamily.`chroniccode` AS personchronicfamily_chroniccode,
     cfamilyrelation.`famrelname` AS cfamilyrelation_famrelname
FROM
     `cdisease` cdisease INNER JOIN `personchronicfamily` personchronicfamily ON cdisease.`diseasecode` = personchronicfamily.`chroniccode`
     INNER JOIN `cfamilyrelation` cfamilyrelation ON personchronicfamily.`relationcode` = cfamilyrelation.`famrelcode`
WHERE
     personchronicfamily.pcucodeperson = '$P!{p_pcucode}'  and personchronicfamily.pid = '$P!{p_pid}']]></queryString>

