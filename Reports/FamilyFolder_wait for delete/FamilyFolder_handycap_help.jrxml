<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="FamilyFolder_handycap_help"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="481"
		 pageHeight="842"
		 columnWidth="481"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["220"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     DATE_FORMAT(zero2null(personunable4help.`datehelp`),"%Y-%m-%d")AS personunable4help_datehelp,
     personunable4help.`pcucodeperson` AS personunable4help_pcucodeperson,
     personunable4help.`pid` AS personunable4help_pid,
     personunable4help.`helpcode` AS personunable4help_helpcode,
     CASE personunable4help.`provider` 
	WHEN '61' THEN 'กระทรวงการพัฒนาสังคม'  
	WHEN '62' THEN 'กระทรวงแรงงาน'  
	WHEN '67' THEN 'อบจ.'  
	WHEN '68' THEN 'อบต.'  
	WHEN '69' THEN 'กาชาด'  ELSE "-"
     END AS personunable4help_provider,
     cpersonhelp.`helpname` AS cpersonhelp_helpname
FROM
     `cpersonhelp` cpersonhelp INNER JOIN `personunable4help` personunable4help ON cpersonhelp.`helpcode` = personunable4help.`helpcode`
WHERE
     personunable4help.pcucodeperson = '$P!{p_pcucode}'
     and personunable4help.pid = '$P!{p_pid}']]></queryString>

	<field name="personunable4help_datehelp" class="java.util.Date"/>
	<field name="personunable4help_pcucodeperson" class="java.lang.String"/>
	<field name="personunable4help_pid" class="java.lang.Integer"/>
	<field name="personunable4help_helpcode" class="java.lang.String"/>
	<field name="personunable4help_provider" class="java.lang.String"/>
	<field name="cpersonhelp_helpname" class="java.lang.String"/>

