	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["06096"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["1436"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     person.`pid`,
     concat(person.pcucodeperson,person.pid)as ppid,
     concat(ifnull(ctitle.`titlename`,''),ifnull(`person`.`fname`,''),'  ',ifnull(`person`.`lname`,''))as name,
     ifnull(person.idcard,'...ไม่ระบุฯ')as idc,
     person.`birth`,
     concat(person.pcucodeperson,'-',person.pid,'/',substring(curdate(),1,4)+543)as hnyear,
     hnomoi,
     mumoi,
     subdistname,
     subdistname,
     distname,
     provname,
     DATE_FORMAT(visit.visitdate,"%Y-%m-%d")AS visit_visitdate,
     visithomehealthindividual.`homehealthdetail` AS visithomehealthindividual_homehealthdetail,
     visithomehealthindividual.`patientsign` AS visithomehealthindividual_patientsign,
     visithomehealthindividual.`homehealthresult` AS visithomehealthindividual_homehealthresult,
     visithomehealthindividual.`homehealthplan` AS visithomehealthindividual_homehealthplan,
     DATE_FORMAT(visithomehealthindividual.`dateappoint`,"%Y-%m-%d")AS dateappoint,
     visithomehealthindividual.`homehealthtype` AS visithomehealthindividual_homehealthtype,
     user.`fullname` AS user_fullname,
     ctitle.`titlename` AS ctitle_titlename
FROM `person` person
     LEFT OUTER JOIN  `cprovince` cprovince ON cprovince.`provcode` = person.`provcodemoi`
     LEFT OUTER JOIN `cdistrict` cdistrict ON person.`provcodemoi` = cdistrict.`provcode`
     AND cdistrict.`distcode` = person.`distcodemoi`
     LEFT OUTER JOIN `csubdistrict` csubdistrict ON person.`provcodemoi` = csubdistrict.`provcode`
     AND csubdistrict.`subdistcode` = person.`subdistcodemoi`
     AND csubdistrict.`distcode` = person.`distcodemoi`
     INNER JOIN `visit` visit ON person.`pcucodeperson` = visit.`pcucodeperson`
     AND person.`pid` = visit.`pid`
     LEFT OUTER JOIN `ctitle` ctitle ON person.`prename` = ctitle.`titlecode`
     INNER JOIN `visithomehealthindividual` visithomehealthindividual ON visit.`pcucode` = visithomehealthindividual.`pcucode`
     AND visit.`visitno` = visithomehealthindividual.`visitno`
     LEFT OUTER JOIN `user` user ON visithomehealthindividual.`pcucode` = user.`pcucode`
     AND user.`username` = visithomehealthindividual.`user`
WHERE
     person.pcucodeperson = '$P!{p_pcucode}'
     and person.pid = '$P!{p_pid}']]></queryString>

