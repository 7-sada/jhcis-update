<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptvisitanc"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="103"
		 bottomMargin="76"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-03-29"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select 
sum(case when(select count(v1.pid) as cpid  from visitanc v1  where p.pid = v1.pid and p.pcucodeperson = v1.pcucodeperson  group by v1.pid,v1.pcucodeperson having cpid=1) then 1 else 0 end) as ancnew
,sum(case when(select count(v1.pid) as cpid  from visitanc v1  where p.pid = v1.pid and p.pcucodeperson = v1.pcucodeperson and ( if(v1.pregage is null, (round(DATEDIFF(dateappointcheck,lmp) /7)<=12) ,(v1.pregage <='12')) ) group by v1.pid,v1.pcucodeperson having cpid=1) then 1 else 0 end) as anc12w
,sum(case when vancd.deliverresult='ท' then 1 else 0 end) ancresultt
,sum(case when(select count(vl.pid) as lpid from visitlabblood vl  where p.pid = vl.pid and p.pcucodeperson = vl.pcucodeperson and (vl.hct != '' OR vl.hct is not null)and datecheck in(select MIN(datecheck) from visitlabblood where visitlabblood.visitno = vl.visitno and visitlabblood.pcucode = vl.pcucode)  group by vl.pid,vl.pcucodeperson having lpid=1 ) then 1 else 0 end) as anchctnew

,sum(case when (vlb.hct < 33 OR vlb.hbag=11)  then 1 else 0 end) hcthb
,sum(case when(select count(vl1.pid) as lpid from visitlabblood vl1  where p.pid = vl1.pid and p.pcucodeperson = vl1.pcucodeperson  and ( if(visitanc.pregage is null, (round(DATEDIFF(dateappointcheck,lmp) /7)<=12) ,(visitanc.pregage <='32')) )  and (vl1.hct != '' OR vl1.hct is not null) group by vl1.pid,vl1.pcucodeperson having lpid=2) then 1 else 0 end) as anc32hct2
,sum(case when (vlb.hct < 33 OR vlb.hbag=11) and ( if(visitanc.pregage is null, (round(DATEDIFF(dateappointcheck,lmp) /7)<=12) ,(visitanc.pregage <='32')) )  then 1 else 0 end) anc32hcthb
,visitdate
,hosname
from person p  left join visit ON p.pid = visit.pid  and  p.pcucodeperson = visit.pcucodeperson
               left join visitanc On visit.visitno=visitanc.visitno and visit.pcucode = visitanc.pcucode 
               left join visitancdeliver vancd On visit.visitno = vancd.visitno and visit.pcucode  = vancd.pcucode 
               left join visitlabblood vlb On visitanc.visitno = vlb.visitno and visitanc.pcucode = vlb.pcucode 
               left join visitancpregnancy ancp On p.pid = ancp.pid and p.pcucodeperson = ancp.pcucodeperson
               left join chospital ON visit.pcucode = chospital.hoscode     
where visit.visitdate between $P{sdate} and  $P{edate} $P!{pcucode} 
      and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
group by visitanc.pcucode]]></queryString>

	<field name="ancnew" class="java.math.BigDecimal"/>
	<field name="anc12w" class="java.math.BigDecimal"/>
	<field name="ancresultt" class="java.math.BigDecimal"/>
	<field name="anchctnew" class="java.math.BigDecimal"/>
	<field name="hcthb" class="java.math.BigDecimal"/>
	<field name="anc32hct2" class="java.math.BigDecimal"/>
	<field name="anc32hcthb" class="java.math.BigDecimal"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="hosname" class="java.lang.String"/>

