	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\ireport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucodeperson" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["08727"]]></defaultValueExpression>
	</parameter>
	<parameter name="pid" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["345"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT person.pid, idcard, prename, fname, lname, IF(sex='1','ชาย','หญิง') AS sex, IFNULL(statusname,'...ไม่ระบุฯ') AS marystatus,
 IFNULL(occupaname,'ไม่ระบุ') AS occupa, IFNULL(nationname,'ไม่ระบุ') AS nation, IFNULL(religionname,'ไม่ระบุ') AS religion,
 person.income, getAgeYearNum(birth,curdate()) AS agey, getAgeMonthNum(birth,curdate()) AS agem,
 getAgeDayNum(birth,curdate()) AS aged, person.allergic
FROM person LEFT OUTER JOIN cnation ON cnation.nationcode = person.nation
 LEFT OUTER JOIN coccupa ON coccupa.occupacode = person.occupa
 LEFT OUTER JOIN cstatus ON cstatus.statuscode = person.marystatus
 LEFT OUTER JOIN creligion ON creligion.religioncode = person.religion
WHERE person.pid=$P{pid} AND pcucodeperson=$P{pcucodeperson}]]></queryString>

