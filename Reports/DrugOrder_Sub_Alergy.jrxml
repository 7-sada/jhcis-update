<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DrugOrder_Sub_Alergy" pageWidth="415" pageHeight="510" columnWidth="404" leftMargin="4" rightMargin="7" topMargin="2" bottomMargin="2" uuid="6c31d7ce-ce0c-4eda-a7d2-d53cebf32b80">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["06654"]]></defaultValueExpression>
	</parameter>
	<parameter name="pid" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["6"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT IF(h.drugcode IS NULL,NULL,@i:=@i+1) AS rowno
,h.allergic ,h.pcucodeperson ,h.pid ,h.drugcode ,h.drugname
FROM
(	select if(p1.allergic IS NULL OR TRIM(p1.allergic)= '','..ไม่ระบุฯ',p1.allergic) allergic,p2.pcucodeperson,p2.pid,p2.drugcode
,IF(p2.drugcode IS NULL,NULL,concat(if(d.drugname is null or trim(d.drugname)='','',trim(d.drugname)),'-'
,CASE WHEN levelalergic='1' THEN '1:ไม่ร้ายแรง' WHEN levelalergic='2' THEN '2:ร้ายแรงเสียชีวิต' WHEN levelalergic='3' THEN '3:ร้ายแรงอันตรายถึงชีวิต'
WHEN levelalergic='4' THEN '4:ต้องรักษาใน รพ.' WHEN levelalergic='5' THEN '5:ทำให้ต้องรักษานานขึ้น' WHEN levelalergic='6' THEN '6:ร้ายแรงถึงพิการ'
WHEN levelalergic='7' THEN '7:ร้ายแรงผิดปกติแต่เกิด' WHEN levelalergic='8' THEN '8:ร้ายแรง อื่นๆ' ELSE '..ไม่ระบุความรุนแรง' END)) drugname
	from person p1
left join personalergic p2 on p1.pcucodeperson=p2.pcucodeperson AND p1.pid=p2.pid
left join cdrug d on p2.drugcode = d.drugcode
	where p1.pcucodeperson = $P{pcucode} and p1.pid = $P{pid}
	ORDER BY if(levelalergic in('2','3'),0,if(levelalergic='1',9,levelalergic))
) AS h ,(SELECT @i:=0) AS foo]]>
	</queryString>
	<field name="allergic" class="java.lang.String"/>
	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="drugcode" class="java.lang.String"/>
	<field name="drugname" class="java.lang.String"/>
	<field name="rowno" class="java.lang.Number"/>
