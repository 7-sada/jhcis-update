     visit.`timestart` AS visit_timestart,
     visit.`timeend` AS visit_timeend,

     ifnull(visit.`vitalcheck`,'..ไม่ระบุฯ') as vtc,
     Concat(ifnull(ct2.titlename,ifnull(`user`.`prename`,'...')),`user`.`fname`,'  ',if(`user`.`lname` is null or trim(`user`.`lname`)='','..',`user`.`lname`)) fullname,
     if(refer='00' or refer is null,'',concat('Case refer: ',referdesc)) as referc,
     ch2.hosname as hmm,ch3.hosname as hss, realprice
#,ifnull(doctor1,doctor2) as doctordrug12
,ifnull(concat(u.fname,' ',u.lname),doctor1) as doctordrug12
,IFNULL(sugarnumdigit,'...') sg
,concat('คำวินิจฉัยฯ:',IF(visit.`diagnote` is null OR TRIM(`diagnote`)='','-',TRIM(`diagnote`))) as diagnote
,person.birth
,DATE_FORMAT(person.birth,'%Y-%m-%d') as birththai
,IF(pa.pid IS NULL,NULL,'!!! มีการแพ้ยาฯ โปรดระมัดระวังเรื่องการจ่ายยาฯ') alg
,ifnull(symptomsco,'') symptomsco
,concat('โรคประจำตัว: ',ifnull(person.persondisease,'..ไม่ระบุ..')) persondisease
,concat('การสูบบุหรี่:',ifnull(spp.ppname,'..')) ppname
FROM
     `person` person
left join ctitle ct1 on person.prename = ct1.titlecode
     INNER JOIN `visit` visit ON person.`pid` = visit.`pid` and person.pcucodeperson = visit.pcucodeperson
     left outer JOIN `visitdrug` visitdrug ON visit.`visitno` = visitdrug.`visitno` and visit.pcucode = visitdrug.pcucode
     left join `user` u ON visitdrug.doctor1 = u.`username` and `visitdrug`.`pcucode` = u.`pcucode`
     left outer JOIN `cdrug` cdrug ON visitdrug.`drugcode` = cdrug.`drugcode`
     left join cdrugunitsell on unitsell = unitsellcode
     iNNER JOIN `chospital` chospital ON visit.`pcucode` = chospital.`hoscode`
     left outer JOIN `csubdistrict` csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left outer JOIN `cdistrict` cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
