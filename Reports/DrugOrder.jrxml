     left outer JOIN `cprovince` cw ON cw.provcode = pc.provcode

     left outer JOIN `user` ON visit.username = `user`.`username` and `visit`.`pcucode` = `user`.`pcucode`
     left join cpatientrefer on visit.refer = cpatientrefer.refercode
     left join chospital ch2 on visit.hosmain = ch2.hoscode
     left join chospital ch3 on visit.hossub = ch3.hoscode
