	<queryString>
		<![CDATA[SELECT
person.pcucodeperson,person.pid,
     concat(ifnull(ct1.titlename,ifnull(person.`prename`,'...')),person.`fname`,'  ',person.`lname`)AS name,
     concat(chospital.`hosname`,' ต.',ifnull(csubdistricth.`subdistname`,'-'),' อ.',ifnull(cdistricth.`distname`,'-'),
                                ' จ.',ifnull(cprovinceh.`provname`,'-')) AS hostname,
     concat(ifnull(pc.`hno`,'-'),' ม.',ifnull(convert(pc.`mu` using utf8),'-'),
                                 ' ต.',ifnull(csd.`subdistname`,'-'),
                                 ' อ.',ifnull(cd.`distname`,'-'),' จ.',ifnull(cw.`provname`,'-')) AS addr,
     visit.`visitno` AS visit_visitno,
if(visit.`incup`='2','ใบสั่งยา (...นอก CUP)','ใบสั่งยา') AS incup,
     visit.`pcucode` AS visit_pcucode,
     visit.`money1` AS visit_money1,
     convert(ifnull(visit.`money2`,0.0) using utf8) AS visit_money2,
     person.`idcard` AS person_idcard,
