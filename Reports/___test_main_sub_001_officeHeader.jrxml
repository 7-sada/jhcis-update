	<subDataset name="New Dataset 1" uuid="91313d4d-2075-4c5a-a442-a5a538d2adda">
		<parameter name="visitno" class="java.lang.String"/>
		<queryString>
			<![CDATA[select fname,lname,pressure,ab.labcode,lc.labname,ab.labresultdigit
,v.pcucode
from person p
join visit v on p.pcucodeperson=v.pcucodeperson and p.pid=v.pid
inner join visitlabchcyhembmsse ab on v.pcucode=ab.pcucode and v.visitno=ab.visitno
inner join clabchcyhembmsse lc on ab.labcode=lc.labcode
where v.visitno=$P{visitno}]]>
		</queryString>
		<field name="fname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pressure" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="labcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="labname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="labresultdigit" class="java.lang.Double">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pcucode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Project_Java\\_DesktopApp\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="hoscode" class="java.lang.String"/>
	<parameter name="visitno" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select 1]]>
	</queryString>
	<field name="1" class="java.lang.Long"/>
	<title>
		<band height="66" splitType="Stretch">
			<subreport>
				<reportElement x="0" y="0" width="555" height="66" uuid="c182dda3-5325-45d0-91a8-a254372a3b68"/>
				<subreportParameter name="SUBREPORT_DIR"/>
				<subreportParameter name="pcucode">
					<subreportParameterExpression><![CDATA[$P{hoscode}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<subreportExpression><![CDATA[$P{SUBREPORT_DIR} + "OfficeAddress.jasper"]]></subreportExpression>
