	<parameter name="sdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="edate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="startdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2008-10-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="enddate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2008-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01838"]]></defaultValueExpression>
	</parameter>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode_per" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT v.villcode, v.villname, h.hno, CONCAT(IFNULL(ctitle.titlename,IFNULL(p.prename,'...')),p.fname,'  ',p.lname) AS fullname,
p.birth,
getageymd(p.birth, $P{startdate}) AS age_ymd

FROM
village AS v
Inner Join house AS h ON v.villcode = h.villcode AND v.pcucode = h.pcucode
Inner Join person AS p ON h.hcode = p.hcode AND h.pcucodeperson = p.pcucodeperson
left join ctitle on ctitle.titlecode=p.prename
WHERE
substring(v.villcode,7,2) <>  '00'
AND DATEDIFF($P{startdate},p.birth)  /30 BETWEEN 0 AND 72
AND p.birth < $P{enddate}
$P{pcucode}
AND (p.typelive IN('0','1','3') OR p.typelive IS NULL)
ORDER BY
v.villcode, h.hno ASC]]>
	</queryString>
