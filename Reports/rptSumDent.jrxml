	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\EditPrename\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="round" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(1)]]></defaultValueExpression>
	</parameter>
	<parameter name="byear" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["and visit.pcucode ='01032'"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT DATE_FORMAT(visitdate,'%Y-%m') as visitdate
,DATE_FORMAT(visitdate,'%Y-%m-%d') as vd
,count(distinct visit.pid,visit.pcucodeperson) cperson
,sum(case when (select count(distinct v89.visitno,v89.pcucodeperson ) from visit  v89   where visit.visitno= v89.visitno and visit.pcucode = v89.pcucode and v89.rightcode ='89'   )  then 1 else 0 end) as cperson89
,chospital.hosname,h.hosname cupname
,$P{byear}+543 as cyear
,$P{byear}+542 as bbyear

FROM  visit  
	left join chospital on visit.pcucode = chospital.hoscode
        left join village on visit.pcucode = village.pcucode
        left join chospital h on village.cup = h.hoscode
WHERE case when $P{round} != 1 then 
      visit.visitdate between CONCAT($P{byear} ,"-04-01")  and CONCAT($P{byear},"-09-30")
      else		
      visit.visitdate between CONCAT(($P{byear})-1 ,"-10-01")  and CONCAT($P{byear},"-03-31") end
	$P!{pcucode}
GROUP BY visit.pcucode,DATE_FORMAT(visitdate,'%Y-%m')]]></queryString>

	<field name="visitdate" class="java.lang.String"/>
	<field name="vd" class="java.util.Date"/>
	<field name="cperson" class="java.lang.Long"/>
	<field name="cperson89" class="java.math.BigDecimal"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="cupname" class="java.lang.String"/>
	<field name="cyear" class="java.lang.Long"/>
	<field name="bbyear" class="java.lang.Long"/>

