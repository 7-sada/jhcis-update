<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="chronic_lab" pageWidth="212" pageHeight="141" orientation="Landscape" columnWidth="212" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="a98c8f46-22b4-419d-908a-927c30e3bef9">
	<property name="ireport.zoom" value="3.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="SEQ" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT concat(ctitle.titlename,p.fname)as 'name',p.lname,getAgeYearNum(p.birth,v.visitdate)as age,
DATE_FORMAT(v.visitdate,'%Y-%m-%d')as visitdate,v.visitno,v.pid
,max(case when vc.labcode= 'CH99' then vc.labresultdigit Else null end) as HbA1C
,max(case when vc.labcode= 'CH07' then vc.labresultdigit Else null end) as Chol
,max(case when vc.labcode= 'CH09' then vc.labresultdigit Else null end) as Cr
,max(case when vc.labcode= 'CH25' then vc.labresultdigit Else null end)as TG
,max(case when vc.labcode= 'CH04' then vc.labresultdigit Else null end) as BUN
,max(case when vc.labcode= 'CH14' then vc.labresultdigit Else null end) as HDL
,max(case when vc.labcode= 'CH17' then vc.labresultdigit Else null end) as LDL
,max(case when vc.labcode= 'CH22' then vc.labresultdigit Else null end) as Na
,max(case when vc.labcode= 'CH19' then vc.labresultdigit Else null end) as K
,max(case when vc.labcode= 'CH05' then vc.labresultdigit Else null end) as Cl
,max(case when vc.labcode= 'CH28' then vc.labresultdigit Else null end) as CO2
,max(case when vc.labcode= 'CHeGFR' then vc.labresultdigit Else null end) as eGFR
,max(case when vc.labcode='MS01020201'then vc.labresultdigit Else null end) as MAU
,vs.sugarnumdigit as FBS,max(case when  vc.labcode='MS01020202'and vc.labresultdigit = '0' then '-ve'when  vc.labcode='MS01020202' and vc.labresultdigit is not null and vc.labresultdigit = '1' then 'trace' when  vc.labcode='MS01020202' and vc.labresultdigit is not null and vc.labresultdigit ='2' then vc.labresulttext Else null end) as 'Urine Protien'
from visit as v
     INNER JOIN person p on v.pcucodeperson=p.pcucodeperson and v.pid=p.pid
     INNER JOIN ctitle on p.prename=ctitle.titlecode
     left JOIN visitlabchcyhembmsse as vc on v. pcucode=vc.pcucode and v.visitno=vc.visitno
     left JOIN visitlabsugarblood as vs on v.pcucode=vs.pcucode and v.visitno=vs.visitno
     left JOIN visitlabsugarurine as vp on v.pcucode=vp.pcucode and v.visitno=vp.visitNo
WHERE v.visitno=$P{SEQ}

GROUP BY v.visitno]]>
	</queryString>
