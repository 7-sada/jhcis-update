	<queryString><![CDATA[SELECT
     1,
     vhouse_count.`villname`,
     vhouse_count.`villno`,
     vhouse_count.`subdistcode` AS vhouse_count_subdistcode,
     vhouse_count.`subdistname` AS vhouse_count_subdistname,
     if(vpop_count.pop=0,null,vpop_count.pop)pop,
     if(vhouse_count.house=0,null,vhouse_count.house)house,
     if(vhouse_count.w1=0,null,vhouse_count.w1)w1,
     if(vhouse_count.w2=0,null,vhouse_count.w2)w2,
     if(vhouse_count.w3=0,null,vhouse_count.w3)w3,
     if(vhouse_count.w4=0,null,vhouse_count.w4)w4,
     if(vhouse_count.waterdrinkeno=0,null,vhouse_count.waterdrinkeno)waterdrinkeno,
     if(vhouse_count.toilet=0,null,vhouse_count.toilet)toilet,
     if(vhouse_count.pets=0,null,vhouse_count.pets)pets,
     if(vhouse_count.petsdung=0,null,vhouse_count.petsdung)petsdung,
     if(vhouse_count.garbageware=0,null,vhouse_count.garbageware)garbageware,
     if(vhouse_count.g1=0,null,vhouse_count.g1)g1,
     if(vhouse_count.g2=0,null,vhouse_count.g2)g2,
     if(vhouse_count.g3=0,null,vhouse_count.g3)g3,
     if(vhouse_count.g4=0,null,vhouse_count.g4)g4,
     if(vhouse_count.housesanitation=0,null,vhouse_count.housesanitation)housesanitation,
     if(vhouse_count.waterassuage=0,null,vhouse_count.waterassuage)waterassuage,
     if(vhouse_count.foodsanitation=0,null,vhouse_count.foodsanitation)foodsanitation,
     if(vhouse_count.controlinsetdisease=0,null,vhouse_count.controlinsetdisease)controlinsetdisease
FROM
     `vpop_count` vpop_count INNER JOIN `vhouse_count` vhouse_count ON vpop_count.`villcode` = vhouse_count.`villcode`]]></queryString>

