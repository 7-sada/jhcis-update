	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="vn" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["71149"]]></defaultValueExpression>
	</parameter>
	<parameter name="HCC" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["01871"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
`person`.`pid`,
Concat(`person`.`prename`,`person`.`fname`,'  ',`person`.`lname`) as pati,
`visit`.`visitdate`,date_format(`visit`.`visitdate`,'%Y-%m-%d') as vsd,
Concat('ÓĖóÓĖ▓: ',`cdrug`.`drugname`) as drugn,
Concat(CAST(`visitdrug`.`unit` As Char), ' ', IFNULL(`cdrug`.`unitsell`,'ÓĖ½ÓĖÖÓ╣łÓĖ¦ÓĖó')) as unt,
Concat('ÓĖ¦ÓĖ┤ÓĖśÓĖĄÓ╣āÓĖŖÓ╣ē: ',`visitdrug`.`dose`) as used,
Concat(`chospital`.`hosname`,' ÓĖł.',`cprovince`.`provname`) as hos,
concat('ÓĖäÓĖ│Ó╣ĆÓĖĢÓĖĘÓĖŁÓĖÖ: ',IFNULL(cdrug.drugcaution,'-')) as caution,
concat('ÓĖ¬ÓĖŻÓĖŻÓĖ×ÓĖäÓĖĖÓĖō: ',IFNULL(cdrug.drugproperties,'-')) as drugproperties,
cdrug.drugcode, cdrug.dateexpire as dateexpire	
FROM
`visit`
Inner Join `person` ON `person`.`pid` = `visit`.`pid` and person.pcucodeperson = visit.pcucodeperson
Inner Join `visitdrug` ON `visit`.`visitno` = `visitdrug`.`visitno` and visit.pcucode = visitdrug.pcucode 
Inner Join `cdrug` ON `visitdrug`.`drugcode` = `cdrug`.`drugcode` ,`office`
Inner Join `chospital` ON `office`.`offid` = `chospital`.`hoscode`
Inner Join `cprovince` ON `chospital`.`provcode` = `cprovince`.`provcode`

where
	visit.visitno = '$P!{vn}' and visit.pcucode = '$P!{HCC}'
        and visitdrug.dose is not null  
        and trim(visitdrug.dose)<>""
	and cdrug.drugtype in('01','10')
        and chospital.hoscode = '$P!{HCC}']]></queryString>

	<field name="pid" class="java.lang.Integer"/>
	<field name="pati" class="java.lang.String"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="vsd" class="java.lang.String"/>
	<field name="drugn" class="java.lang.String"/>
	<field name="unt" class="java.lang.String"/>
	<field name="used" class="java.lang.String"/>
	<field name="hos" class="java.lang.String"/>
	<field name="caution" class="java.lang.String"/>
	<field name="drugproperties" class="java.lang.String"/>
	<field name="drugcode" class="java.lang.String"/>
	<field name="dateexpire" class="java.util.Date"/>

