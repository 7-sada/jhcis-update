					</textElement>
				<text><![CDATA[ได้รับการตรวจน้ำตาลฯ ในเดือน]]></text>
				</staticText>
				<staticText>
					<reportElement
						mode="Opaque"
						x="466"
						y="193"
						width="36"
						height="26"
						forecolor="#000000"
						backcolor="#FFFFFF"
						key="staticText-26"/>
					<box topBorder="Thin" topBorderColor="#0000FF" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#3333FF" bottomBorder="Thin" bottomBorderColor="#3333FF"/>
