					</textElement>
				<textFieldExpression   class="java.util.Date"><![CDATA[$F{visitdate}.valueOf( $P{pdate})]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="81"
						width="768"
						height="86"
						forecolor="#FF0033"
						key="textField-11"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Top" lineSpacing="1_1_2">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["หมายเหตุ : \n1.เฉพาะคนในเขตฯ ที่อาศัยอยู่จริง (TypeLive = 1 หรือ 3)  2.อายุเต็ม " +$P{age}+ " ปีบริบูรณ์ นับถึงวันที่ 31 ธันวาคม ของปีที่รายงาน    \n3.ผลการตรวจฯ ให้ใช้ครั้งล่าสุดของการตรวจวัน(น้ำหนัก/ส่วนสูง) ภายในวันที่  ที่รายงาน  (เช่น นาย ก ได้รับตรวจวัดฯ 2 ครั้งคือ 3พค.52 และ 10มิย.52)  ถ้าออกรายงานถึง 31 พค.52 ก็ให้ใช้ผลการตรวจวัดเมื่อวันที่ 3 พค.52 (ไม่ใช่ 10 มิย. 52 ))  4.ผลระดับน้ำตาลฯ ใช้กับเฉพาะกรณี งดน้ำและอาหาร ก่อนตรวจฯ เท่านั้น โดย <=110:ปกติ /  >110 และ <126 :เสี่ยง /  >=126 :สูง 5. สะสม หมายถึงปีงบประมาณ"]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement
						mode="Opaque"
						x="310"
						y="193"
						width="40"
						height="26"
						forecolor="#000000"
						backcolor="#FFFFFF"
						key="staticText-34"/>
