	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-25"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(35)]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["c:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT chospital.hosname,csubdistrict.subdistname,cdistrict.distname,cprovince.provname
,village.villname,village.villcode
,v.visitdate,v.pcucode
,sum(case when person.sex='1'  and vsb.foodsuspend='0' and vsb.sugarnumdigit !='' and v.visitdate between CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30') then 1 else 0 end)   as whms
,sum(case when person.sex='2'  and vsb.foodsuspend='0' and vsb.sugarnumdigit !='' and v.visitdate between CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30') then 1 else 0 end) as whfms

,sum(case when person.sex='1'  and vsb.foodsuspend='0' and vsb.sugarnumdigit !='' and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end)   as whm
,sum(case when person.sex='2'  and vsb.foodsuspend='0' and vsb.sugarnumdigit !='' and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as whfm

,sum(case when person.sex='1' and vsb.foodsuspend='0' and vsb.sugarnumdigit <=110 and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as am
,sum(case when person.sex='2' and vsb.foodsuspend='0' and vsb.sugarnumdigit <=110 and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as afm

,sum(case when person.sex='1' and vsb.foodsuspend='0' and (vsb.sugarnumdigit >110 and vsb.sugarnumdigit <126 ) and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as bm
,sum(case when person.sex='2' and vsb.foodsuspend='0' and (vsb.sugarnumdigit >110 and vsb.sugarnumdigit <126 ) and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as bfm

,sum(case when person.sex='1' and vsb.foodsuspend='0' and vsb.sugarnumdigit >=126 and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as cm
,sum(case when person.sex='2' and vsb.foodsuspend='0' and vsb.sugarnumdigit >=126 and v.visitdate between $P{sdate} and $P{edate} then 1 else 0 end) as cfm

FROM visitlabsugarblood vsb 
           left join visit v on vsb.visitno = v.visitno and vsb.pcucode = v.pcucode
           left join person on v.pid = person.pid  and  v.pcucodeperson =  person.pcucodeperson 
	   left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode 
	   left join village on house.villcode = village.villcode and house.pcucode = village.pcucode

	   left join chospital on v.pcucode = chospital.hoscode
           left join csubdistrict on csubdistrict.subdistcode = chospital.subdistcode and csubdistrict.distcode = chospital.distcode and csubdistrict.provcode = chospital.provcode
           left join cdistrict on cdistrict.distcode = chospital.distcode and cdistrict.provcode = chospital.provcode
           left join cprovince on  cprovince.provcode = chospital.provcode

WHERE DATEDIFF(concat(YEAR($P{pdate}),'-12','-31'),person.birth)/365 >= $P{age}
     and (person.typelive ='1' or person.typelive ='3' or person.typelive is null or person.typelive='0' )
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
     and person.pid NOT IN (SELECT persondeath.pid FROM persondeath WHERE persondeath.pcucodeperson=person.pcucodeperson and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{edate})) 
     and substring(village.villcode,7,2) !='00'
     and vsb.foodsuspend='0'
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
     $P!{pcucode}
GROUP BY v.pcucode,village.villcode]]></queryString>

