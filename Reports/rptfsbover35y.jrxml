	<field name="whm" class="java.math.BigDecimal"/>
	<field name="whfm" class="java.math.BigDecimal"/>
	<field name="am" class="java.math.BigDecimal"/>
	<field name="afm" class="java.math.BigDecimal"/>
	<field name="bm" class="java.math.BigDecimal"/>
	<field name="bfm" class="java.math.BigDecimal"/>
	<field name="cm" class="java.math.BigDecimal"/>
	<field name="cfm" class="java.math.BigDecimal"/>

