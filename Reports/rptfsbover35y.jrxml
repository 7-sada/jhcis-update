				<text><![CDATA[วันที่พิมพ์รายงาน :]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" pattern="d MMMMM yyyy" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
