<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptNCDMellitus"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select count(person.pid) countperson
,if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30") ,date_format($P{sdate},'%Y')+543 , date_format($P{sdate},'%Y')+544 ) as cyear
,date_format($P{sdate},'%Y') +543 as bgyear

,(select count(personchronic.pid)  from personchronic inner join cdisease on personchronic.chroniccode = cdisease.diseasecode where cdisease.codechronic = '10' and datefirstdiag between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as chronic10
,(select count(personchronic.pid)  from personchronic inner join cdisease on personchronic.chroniccode = cdisease.diseasecode 
		where cdisease.codechronic = '10' 
		and datefirstdiag between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as chronic10sum

,(select count(ncdpersonscreenall.pid) from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") )  as ncdscreen
,(select count(ncdpersonscreenall.pid) from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") ))  as ncdscreensum

,(select sum(case when screen_q1='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as screenq1
,(select sum(case when screen_q1='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as screenq1sum

,(select sum(case when screen_q2='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as screenq2
,(select sum(case when screen_q2='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as screenq2sum

,(select sum(case when screen_q3='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as screenq3
,(select sum(case when screen_q3='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as screenq3sum

,(select sum(case when screen_q4='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as screenq4
,(select sum(case when screen_q4='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as screenq4sum

,(select sum(case when screen_q5='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as screenq5
,(select sum(case when screen_q5='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as screenq5sum

,(select sum(case when screen_q6='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as screenq6
,(select sum(case when screen_q6='1' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as screenq6sum

,(select sum(case when bsl between '100' and '125'  then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as bsl1
,(select sum(case when bsl between '100' and '125'  then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as bsl1sum

,(select sum(case when bsl > '125'  then 1 else 0 end)  from ncdpersonscreenall where screen_date between CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as bsl2
,(select sum(case when bsl > '125'  then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as bsl2sum

,(select sum(case when bsl != '' then 1 else 0 end)  from ncdpersonscreenall where screen_date between  CONCAT(date_format($P{sdate},'%Y-%m'),"-01")  and  CONCAT(date_format($P{sdate},'%Y-%m'),"-31") ) as bsl
,(select sum(case when bsl != '' then 1 else 0 end)  from ncdpersonscreenall where screen_date between if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") 
	, CONCAT(date_format($P{sdate},'%Y'),"-10-01") )
      and 
	if(date_format($P{sdate},'%Y-%m') between CONCAT(date_format($P{sdate},'%Y')-1,"-10-01") and CONCAT(date_format($P{sdate},'%Y'),"-09-30")
	 ,CONCAT(date_format($P{sdate},'%Y'),"-09-30") 
	, CONCAT(date_format($P{sdate},'%Y')+1,"-09-30") )) as bslsum
,hosname,provname
,date_format($P{sdate},'%Y-%m') as ym
,curdate() as currentdate
FROM person inner join house on  person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	inner join chospital on house.pcucode = chospital.hoscode
	inner join cprovince on chospital.provcode = cprovince.provcode

WHERE round(datediff(curdate(),birth) /360) > 34 and right(house.villcode,2) !='00'
$P!{pcucode}
GROUP BY house.pcucode]]></queryString>

