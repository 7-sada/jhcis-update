						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ ผู้ป่วยโรคเบาหวานที่เคยได้รับการวินิจฉัยจากแพทย์ (ผู้ป่วยเก่า ณ 30 กย )]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="50"
						width="319"
						height="25"
						key="staticText-34"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ ประชากรที่มีอายุ 35 ปีขึ้นไปที่ต้องได้รับการคัดกรอง (ข้อ 1 ลบข้อ 2)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="75"
						width="319"
						height="25"
						key="staticText-35"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[4.1 ผู้ที่ได้รับการคัดกรองด้วยวาจา (Verbal Screening)
     ปัจจัยเสี่ยงที่พบจากการคัดกรองด้วยวาจา (เพื่อทราบปัจจัยเสี่ยงของพื้นที่)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="100"
						width="319"
						height="25"
						key="staticText-36"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.1.1 มีบิดา มารดา พีน้องหรือคนใดคนหนึ่งเป็นโรคเบาหวาน]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="125"
						width="319"
						height="25"
						key="staticText-37"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.1.2 มีภาวะอ้วนโดย BMI มากกว่าหรือเท่ากับ 25]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="150"
						width="319"
						height="25"
						key="staticText-38"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.1.3 มีภาวะความดันโลหิตสูง]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="175"
						width="319"
						height="25"
						key="staticText-39"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.1.4 มีภาวะไขมันในเลือดผิดปกติ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="200"
						width="319"
						height="25"
						key="staticText-40"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.1.5 มีประวัติเป็นเบาหวานขณะตั้งครรภ์หรือมีประวัติคลอดบุตรที่มี 
         น้ำหนักตัวแรกคลอด มากกว่าหรือเท่ากับ 4 กิโลกรัม]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="225"
						width="319"
						height="25"
						key="staticText-41"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.1.6 มีประวัติหรือเคยมีประวัติน้ำตาลในเลือดสูง]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="250"
						width="319"
						height="25"
						key="staticText-42"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[4.2 จากข้อ 4.1 ผู้ที่ได้รับการคัดกรองด้วยวาจา พบปัจจัยเสี่ยง 1 ใน 6 ข้อ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="275"
						width="319"
						height="25"
						key="staticText-43"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[4.3 จากข้อ 4.2 ผู้ที่ได้รับการตรวจเลือด (Blood Screening)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="300"
						width="319"
						height="25"
						key="staticText-44"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.3.1 จากข้อ 4.3 พบผู้มีภาวะเบาหวาน (น้ำตาล 100-125 mg%) ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="325"
						width="319"
						height="25"
						key="staticText-45"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[   4.3.2 จากข้อ 4.3 พบผู้สงสัยเป็นโรคเบาหวาน (น้ำตาล >= 126 mg%)]]></text>
				</staticText>
