	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-08-10"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="villno" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT house.pcucode,cdrug.drugcode
, CONVERT(cdrug.drugname USING utf8) drugname
,visitepiappoint.dateappoint
,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),' ',person.fname) using utf8)  AS pf,person.lname
,person.hnomoi,village.villno
,CONVERT(village.villname using utf8) as villname
,village.villcode,chospital.hosname,cprovince.provname,cdistrict.distname
,tb.subdistname
FROM   visitepiappoint
        left JOIN person ON  visitepiappoint.pid = person.pid and visitepiappoint.pcucodeperson = person.pcucodeperson
        left join ctitle on person.prename = ctitle.titlecode    
	left JOIN cdrug ON visitepiappoint.vaccinecode = cdrug.drugcode 
        left JOIN house ON person.hcode = house.hcode and person.pcucodeperson = house.pcucode
        left JOIN village ON house.villcode = village.villcode and person.pcucodeperson = village.pcucode
        left JOIN chospital ON (village.pcucode = chospital.hoscode)
        left JOIN cprovince ON (cprovince.provcode =chospital.provcode)
        left JOIN cdistrict ON (cdistrict.provcode = chospital.provcode and cdistrict.distcode = chospital.distcode)
	 left join csubdistrict tb on tb.provcode = left(village.villcode,2) and tb.distcode = substring(village.villcode,3,2) and tb.subdistcode = substring(village.villcode,5,2)
WHERE visitepiappoint.dateappoint = $P{pdate} 
    
	and (birth IS NOT NULL OR birth NOT LIKE '0000%')
ORDER BY visitepiappoint.vaccinecode,village.villcode]]></queryString>

