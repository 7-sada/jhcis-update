	<subDataset name="DataAdult" uuid="56b84a1c-dc0f-4e5c-b8c7-8a8a378ea556">
		<parameter name="edate" class="java.lang.String"/>
		<parameter name="sdate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select aa.pid,aa.dt,aa.tt,aa.dateepi,
concat(ifnull(titlename,ifnull(p1.prename,'...')) ," ", fname," ", lname) as fullname,
getAgeYearNum(p1.birth,now()) as Age,p1.mumoi,h.villcode,
(case when right(h.villcode,2) = '00' then p4.villname
else concat("หมู่ที่่ ", p1.mumoi ," ", p4.villname)
end ) as fullvill,p4.villname
from person p1
join
(select B.pid,Group_concat(B.dt) as dt,group_concat(B.tt) as tt ,max(B.dateepi) as dateepi,B.pcucodeperson
from
(select A.*
from
(select p.pid,v.vaccinecode as dt,null as tt ,v.dateepi,p.pcucodeperson
from person p
join visitepi v on (p.pid = v.pid and p.pcucodeperson = v.pcucodeperson)
where v.dateepi between $P!{sdate} and $P!{edate}
and v.vaccinecode like '%dt%'
and getAgeYearNum(p.birth,v.dateepi) > 15
union all
select p.pid,null as dt,v.vaccinecode as tt ,v.dateepi,p.pcucodeperson
from person p
join visitepi v on p.pid = v.pid
where v.dateepi between $P!{sdate} and $P!{edate}
and v.vaccinecode like '%TT%'
and getAgeYearNum(p.birth,v.dateepi) > 15)A
group by A.dt,A.dateepi,A.pid
order by A.pid)B
group by B.pid)aa on (p1.pid = aa.pid and p1.pcucodeperson = aa.pcucodeperson)
join ctitle p2 on p1.prename = p2.titlecode
left join house h on (p1.hcode = h.hcode and p1.pcucodeperson = h.pcucode)
left join village p4 on (h.villcode = p4.villcode and h.pcucode = p4.pcucode)
order by h.villcode,pid]]>
		</queryString>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dt" class="java.lang.String"/>
		<field name="tt" class="java.lang.String"/>
		<field name="dateepi" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fullname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="Age" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="mumoi" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="villcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fullvill" class="java.lang.String"/>
		<field name="villname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<group name="mumoi">
			<groupExpression><![CDATA[$F{villcode}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="header_1" class="java.lang.String"/>
