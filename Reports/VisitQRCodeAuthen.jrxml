	<queryString>
		<![CDATA[select p.pid,visitno,visitdate
,IF(claimcode_nhso IS NULL OR claimcode_nhso = '','ไม่มีการ Authen',claimcode_nhso) as claimcode
,IF(TIME(datetime_claim) IS NULL ,'ไม่มีการ Authen',TIME(datetime_claim)) as claimtime
,hiciauthen_nhso as claimtype
,p.idcard cid
from visit join person p on visit.pcucodeperson=p.pcucodeperson and visit.pid=p.pid where visitno = $P{visitno}]]>
	</queryString>
