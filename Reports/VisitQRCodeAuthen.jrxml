($F{claimtype}.equals( "PG0130001" )?"ฟอกเลือดด้วยเครื่องไตเทียม":
($F{claimtype}.equals( "PG0150001" )?"ดูแลอาการป่วยเบี้ยงต้น":"" )))))]]></textFieldExpression>
