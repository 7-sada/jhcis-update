<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="top_disease_sex"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="510"
		 pageHeight="842"
		 columnWidth="510"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_startDate" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDate" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.visitdate BETWEEN '2009-10-01' AND '2009-10-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_endDate" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_reportOffice" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["หน่วยงาน :: ........................"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlSex" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.sex='1' "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sex" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlVillage" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlPcu" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDiag" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT cdisease.diseasecode AS diseasecode,
     cdisease.diseasename AS diseasename,
     count(visitdiag.visitno ) AS visitcount
FROM
     visit visit INNER JOIN visitdiag visitdiag ON visit.pcucode = visitdiag.pcucode
     AND visit.visitno = visitdiag.visitno
     INNER JOIN person person ON visit.pcucodeperson = person.pcucodeperson
     AND person.pid = visit.pid
     INNER JOIN house house ON person.pcucodeperson = house.pcucode
     AND house.hcode = person.hcode
     INNER JOIN village village ON house.pcucode = village.pcucode
     AND village.villcode = house.villcode
     INNER JOIN cdisease cdisease ON visitdiag.diagcode = cdisease.diseasecode
WHERE 1=1 $P!{p_sqlDate} $P!{p_sqlSex} $P!{p_sqlVillage} $P!{p_sqlPcu} $P!{p_sqlDiag}
GROUP BY cdisease.diseasecode
ORDER BY count(visitdiag.visitno ) DESC]]></queryString>

	<field name="diseasecode" class="java.lang.String"/>
	<field name="diseasename" class="java.lang.String"/>
	<field name="visitcount" class="java.lang.Long"/>

	<variable name="reportOffice" class="java.lang.String" resetType="Report" calculation="Nothing">
