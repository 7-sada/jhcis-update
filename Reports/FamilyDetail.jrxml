<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="FamilyDetail" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="8a5b7249-96ba-4fad-9c07-8b74d3f85a09">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucodeperson" class="java.lang.String">
		<defaultValueExpression><![CDATA[new String("04864")]]></defaultValueExpression>
	</parameter>
	<parameter name="hcode" class="java.lang.String">
		<defaultValueExpression><![CDATA[new String("266")]]></defaultValueExpression>
	</parameter>
	<parameter name="reportdate" class="java.lang.String">
		<defaultValueExpression><![CDATA[new String("2019-10-28")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT P.pcucodeperson,house.hno,P.familyno,P.idcard,P.birth,P.allergic,P.privatedoc,
  P.income,P.rightcode,P.officework,
  P.`datein`,DATE_FORMAT(P.`datein`,'%Y-%m-%d') AS dateinvalue,
  P.`birth`,DATE_FORMAT(P.`birth`,'%Y-%m-%d') AS birthvalue,
  CAST(CONCAT(P.bloodgroup,'',P.bloodrh) AS CHAR) AS bloodgroup,
  CAST((CASE P.sex WHEN '1' THEN 'ชาย' WHEN '2' THEN 'หญิง' ELSE 'ไม่ระบุ' END) AS char) AS sex,
  IF(P.fname IS NULL AND P.lname IS NULL, '', CAST(CONCAT(ifnull(t.titlename,'..'),P.fname,'  ',P.lname) AS char)) AS fullname,
  CAST( CONCAT( getAgeYearNum(P.birth, $P{reportdate}),'-',getAgeMonthNum(P.birth, $P{reportdate}),'-',getAgeDayNum(P.birth, $P{reportdate}) ) AS char) AS ageymd,
  (SELECT CAST(CONCAT(ifnull(t.titlename,REF_P.prename),REF_P.fname,'  ',REF_P.lname) AS char) FROM person REF_P left JOIN ctitle t on REF_P.prename=t.titlecode WHERE REF_P.pcucodeperson=$P{pcucodeperson} AND REF_P.hcode=$P{hcode} AND REF_P.familyposition='1' LIMIT 1) AS familyleader,
  (SELECT IF(cfamilyposition.famposname IS NOT NULL,cfamilyposition.famposname,'ไม่ระบุ') AS famposname FROM cfamilyposition WHERE cfamilyposition.famposcode=P.familyposition LIMIT 1) AS familyposition,
  (SELECT IF(cstatus.statusname IS NOT NULL,cstatus.statusname,'ไม่ระบุ') AS statusname FROM cstatus WHERE cstatus.statuscode=P.marystatus LIMIT 1) AS marystatus,
  (SELECT IF(ceducation.educationname IS NOT NULL,ceducation.educationname,'ไม่ระบุ') AS educationname FROM ceducation WHERE ceducation.educationcode=P.educate LIMIT 1) AS educate,
  (SELECT IF(coccupa.occupaname IS NOT NULL,coccupa.occupaname,'ไม่ระบุ') AS occupaname FROM coccupa WHERE coccupa.occupacode=P.occupa LIMIT 1) AS occupa,
  (SELECT IF(creligion.religionname IS NOT NULL,creligion.religionname,'ไม่ระบุ') AS religionname FROM creligion WHERE creligion.religioncode=P.religion LIMIT 1) AS religion,

  /*  อสม  */
  (SELECT IF(ref_p.fname='' OR ref_p.fname IS NULL, 'ไม่ระบุ', CAST(CONCAT(ifnull(t.titlename,ref_p.prename),ref_p.fname,'  ',ref_p.lname) AS char))
  FROM house ref_h
    INNER JOIN person ref_p ON (ref_h.pcucodepersonvola=ref_p.pcucodeperson AND ref_h.pidvola=ref_p.pid)
    left outer join ctitle t on ref_p.prename=t.titlecode
  WHERE ref_h.pcucode=$P{pcucodeperson} AND ref_h.hcode=$P{hcode}) AS villagehealthvolunteer,

  /*  กสค */
  (SELECT IF(ref_p.fname='' OR ref_p.fname IS NULL, 'ไม่ระบุ', CAST(CONCAT('- -',ref_p.prename,' -',ref_p.fname,'  ',ref_p.lname) AS char))
  FROM house ref_h
    INNER JOIN person ref_p ON (ref_h.pcucodepersonvola=ref_p.pcucodeperson AND ref_h.pidvola=ref_p.pid)
  WHERE ref_h.pcucode=$P{pcucodeperson} AND ref_h.hcode=$P{hcode}) AS familyhealthleader,

  /*  ตำแหน่งในชุมชน */
  (SELECT ref_cpt.persontypename
  FROM persontype ref_pt
    INNER JOIN cpersontype ref_cpt ON (ref_pt.typecode=ref_cpt.persontypecode)
  WHERE ref_pt.pcucodeperson=P.pcucodeperson AND ref_pt.pid=P.pid) AS communityposition,

  (CASE PB.ciga WHEN '0' THEN 'ไม่สูบ' WHEN '1' THEN 'สูบนานๆครั้ง' WHEN '2' THEN 'สูบประจำ' ELSE 'ไม่ระบุ' END) AS cigar,
  (CASE PB.wisky WHEN '0' THEN 'ไม่ดื่ม' WHEN '1' THEN 'ดื่มนานๆครั้ง' WHEN '2' THEN 'ดื่ม1-2 ครั้ง/เดือน' ELSE 'ไม่ระบุ' END) AS whisky,
  (CASE PB.exercise WHEN '0' THEN 'ไม่ทำ' WHEN '1' THEN '< 3 วัน/สัปดาห์' WHEN '2' THEN '3-5 วัน/สัปดาห์' ELSE 'ไม่ระบุ' END) AS exercise,

  IF(P.mumoi IS NOT NULL,P.mumoi,'-') AS mumoi,
  IF(P.roadmoi IS NOT NULL,P.roadmoi,'-') AS roadmoi,
  (SELECT IF(village.villname IS NOT NULL,SUBSTRING(village.villname,7,2),'-') AS villname FROM village WHERE village.villcode=CAST( CONCAT(P.provcodemoi,P.distcodemoi,P.subdistcodemoi,P.mumoi) AS CHAR) ) AS village,
  (SELECT IF(csubdistrict.subdistname IS NOT NULL,csubdistrict.subdistname,'-') AS subdistname FROM csubdistrict WHERE csubdistrict.provcode=P.provcodemoi AND csubdistrict.distcode=P.distcodemoi AND csubdistrict.subdistcode=P.subdistcodemoi) AS subdistrict,
  (SELECT IF(cdistrict.distname IS NOT NULL,cdistrict.distname,'-') AS distname FROM cdistrict WHERE cdistrict.provcode=P.provcodemoi AND cdistrict.distcode=P.distcodemoi) AS district,
  (SELECT IF(cprovince.provname IS NOT NULL,cprovince.provname,'-') AS provname FROM cprovince WHERE cprovince.provcode=P.provcodemoi) AS province

FROM person P
INNER JOIN house ON (P.pcucodeperson=house.pcucode AND P.hcode=house.hcode)
LEFT outer JOIN personbehavior PB ON (PB.pcucodeperson=P.pcucodeperson AND PB.pid=P.pid)
left outer join ctitle t on P.prename=t.titlecode
WHERE P.pcucodeperson=$P{pcucodeperson} AND P.hcode=$P{hcode}
ORDER BY P.pcucodeperson ASC,  P.hcode ASC, P.familyno ASC, P.familyposition ASC]]>
	</queryString>
