<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ciga_2_List_Mu_Sex" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="257f05eb-33f6-4102-8d7c-016bcb47d735">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA["  "]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="where_person" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND (person.dischargedate is null OR person.dischargedate > current_date) AND (person.datein is null OR person.datein <= current_date)  AND CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.deaddate <= current_date) "]]></defaultValueExpression>
	</parameter>
	<parameter name="where_age" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND getagemonth(person.birth,current_date) between 9 and 15 "]]></defaultValueExpression>
	</parameter>
	<parameter name="header" class="java.lang.String" isForPrompting="false"/>
	<parameter name="period" class="java.lang.String" isForPrompting="false"/>
	<parameter name="typelive" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="enddate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["current_date()"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT d.*,vl.villname ,vl.villcode village ,ifnull(vl.villno,'..') villno
FROM village vl JOIN
(SELECT c.* FROM
	(SELECT a1.*,MAX(dateserv) maxD FROM
	    (SELECT  h.villcode, p.sex
                      ,if(sex='1','ชาย',if(sex='2','หญิง','..')) sx
                      ,f.pcucodeperson
                      ,f.pid,IFNULL(ct.titlename,'..') pname
                      ,fname,lname,h.hno,f.dateserv, f.ppspecial
                      ,p.birth birthF
                      ,DATE_FORMAT(p.birth,'%Y-%m-%d') AS birth
                      ,getAgeYearNum(p.birth,CURDATE()) age
                      ,p.rightcode rightc
	     FROM f43specialpp f JOIN person p
               ON f.pcucodeperson=p.pcucodeperson AND f.pid=p.pid
	     JOIN house h ON p.pcucodeperson=h.pcucode AND p.hcode=h.hcode
               LEFT JOIN ctitle ct ON p.prename=ct.titlecode
		 WHERE UCase(left(ppspecial,3)) IN('1B5') AND RIGHT(villcode,2)<>'00'
		 ORDER BY villcode, p.pid,f.dateserv DESC
		) AS a1
		GROUP BY a1.pid
	) AS c
  WHERE getAgeYearNum(birth,maxD) >14
    AND (UCASE(LEFT(c.ppspecial,4)) in('1B50','1B53')
         OR UCASE(LEFT(c.ppspecial,5)) in('1B540','1B541','1B550','1B551','1B560','1B561'))
) AS d
ON vl.villcode=d.villcode
WHERE RIGHT(vl.villcode,2)<>'00'
ORDER BY vl.villcode,d.sex]]>
	</queryString>
