	<detail>
		<band height="20" splitType="Stretch">
			<textField pattern="" isBlankWhenNull="false">
				<reportElement uuid="20943a0b-bacc-4fc0-8b84-ec9f769ea2cf" key="txtPname-1" x="31" y="0" width="34" height="18" forecolor="#000000" backcolor="#FFFFFF"/>
