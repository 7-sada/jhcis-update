	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[C:\\jhcis\\reports\\]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["current_date"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRep" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[ AND person.pcucodeperson='14118']]></parameterDescription>
		<defaultValueExpression><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<parameter name="TypeLive" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[ลักษณะการอยู่อาศัย ตามทะเบียนราษฎร์,อยู่จริง]]></parameterDescription>
		<defaultValueExpression><![CDATA["AND person.typelive = 3"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="offAddress2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="grTypeLive" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
CONCAT(`village`.`villname`,' หมู่ที่ ',convert(village.villno using utf8)) AS villname,`village`.`villcode`,
Count(`person`.`pid`),
if(`cright`.`rightname` is null,'ไม่ระบุฯ',`cright`.`rightname`) AS rightname,
if(`crightgroup`.`rightgroupname` is null,'ไม่ระบุฯ',`crightgroup`.`rightgroupname`)  AS rightgroupname
FROM
`person`
Left Outer Join `house` ON `person`.`hcode` = `house`.`hcode` AND `house`.`pcucode` = `person`.`pcucodeperson`
Left Outer Join `village` ON `house`.`villcode` = `village`.`villcode` AND `village`.`pcucode` = `house`.`pcucode`
Left Outer Join `cright` ON `person`.`rightcode` = `cright`.`rightcode`
Left Outer Join `crightgroup` ON `cright`.`rightgroup` = `crightgroup`.`rightgroupcode`
Left Outer Join persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
WHERE right(`house`.`villcode`,2)  >  '00'  AND  `persondeath`.`pid` IS NULL
 $P!{pcucode}
AND (`person`.`dateexpire` >= $P!{ReportDate} OR `person`.`dateexpire` is null)
AND (`cright`.`rightgroup` <>  'x' AND `person`.`rightcode` <> 'xx' AND `person`.`rightcode` IS NOT NULL )
$P!{TypeLive}
GROUP BY
`village`.`villcode`,
`person`.`rightcode`
ORDER BY `village`.`villcode`,`cright`.`rightgroup]]>
	</queryString>
	<field name="villname" class="java.lang.String"/>
	<field name="villcode" class="java.lang.String"/>
	<field name="Count(`person`.`pid`)" class="java.lang.Double"/>
	<field name="rightname" class="java.lang.String"/>
	<field name="rightgroupname" class="java.lang.String"/>
	<variable name="SumRight" class="java.lang.Double" resetType="Group" resetGroup="villname" calculation="Sum">
		<variableExpression><![CDATA[$F{Count(`person`.`pid`)}]]></variableExpression>
	</variable>
	<variable name="SumRightTotal" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{Count(`person`.`pid`)}]]></variableExpression>
	</variable>
	<variable name="GRP_RIGTHGRP" class="java.lang.Integer" resetType="Group" resetGroup="villname" incrementType="Group" incrementGroup="rightgroupname" calculation="Count">
		<variableExpression><![CDATA[($V{rightgroupname_COUNT})]]></variableExpression>
	</variable>
