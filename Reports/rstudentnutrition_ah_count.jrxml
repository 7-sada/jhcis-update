	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band height="103" splitType="Stretch">
			<staticText>
				<reportElement uuid="f70a90df-68eb-49f4-9d03-f494e09b4f26" key="staticText-1" x="0" y="2" width="338" height="18"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<text><![CDATA[รายงานการติดตามภาวะโภชนาการเด็กนักเรียน : อายุ(เดือน) / ส่วนสูง(ซม.) -->]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="07f4ec66-6faf-4069-98fb-feb23653c254" key="staticText-2" x="0" y="42" width="782" height="14"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  1.โปรแกรมคำนวณภาวะโภชนาการโดยคิดจากการชั่ง นน.(หรือวัดส่วนสูง) ครั้งล่าสุดของแต่ละเทอมฯ (เทอม 1->พค.-ตค. ของปีการศึกษา / เทอม 2 พย.ของปีการศึกษานั้น - เมย. ของปีถัดไป) ]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="dda1f04f-df99-4a4b-8841-54939f762788" key="staticText-3" x="0" y="56" width="782" height="14"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  2.หากยอดรวมของจำนวนโภชนาการไม่ปกติ + ตามเกณฑ์ ไม่เท่ากับจำนวนนักเรียนที่วัดส่วนสูง แสดงว่ามีนักเรียนบางคนที่ไม่ระบุวันเกิด(จึงแปรผลโภชนาการไม่ได้ ?)]]></text>
			</staticText>
			<textField isBlankWhenNull="false">
				<reportElement uuid="961a6bea-db4a-4b52-b99a-35f893778782" key="textField" x="0" y="22" width="782" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA["สถานพยาบาล (สถานีอนามัย) "+$P{offAddress}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="false">
				<reportElement uuid="e652f46c-bdab-4395-ad5a-4ed15cec7111" key="textField" x="338" y="2" width="441" height="18"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$P{team}+": "+$P{dTerm}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement uuid="defbac1c-4965-4c25-acd0-715fbd582e59" key="staticText-3" x="2" y="70" width="782" height="16" forecolor="#FF0000"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  1. แสดงการคำนวณโภชนาการเฉพาะนักเรียนชั้น อนุบาล 1 - ม. 3 (เพื่อให้สอดคล้องกับรายงานจำนวนนักเรียน(ที่แสดงจำนวนฯ ถึงชั้น ม. 3))]]></text>
			</staticText>
			<textField>
				<reportElement uuid="4c416698-7d0e-401d-83f3-9c1e6ecaf024" x="49" y="86" width="730" height="16"/>
				<textElement/>
				<textFieldExpression><![CDATA["2. "+$P{dTerm}]]></textFieldExpression>
			</textField>
