<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptmothercare" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="2dff741b-c390-40a1-9a2d-4fff8b4d3659">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="238"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-10-26"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT b.id
,date_format(visitancdeliver.datedeliver,'%Y-%m-%d') as datedeliver
,CONVERT(concat(ifnull(tm.titlename,ifnull(person.prename,'ไม่ระบุ') ),person.fname,' ',person.lname) using utf8) as mothername
,visitancdeliver.pcucodeperson,visitancdeliver.pid,visitancdeliver.pregno
,DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(person.birth,'%Y-%m-%d') as age
,if(house.hno != '' ,CONVERT(concat(house.hno,' ม.',villno) USING utf8), CONVERT(concat('- ม.',villno) USING utf8) ) as address
,CONVERT(concat(ifnull(tc.titlename,ifnull(person.prename,'ไม่ระบุ') ),pchild.fname,' ',pchild.lname) using utf8) childname
,house.pcucode
,(select datecare from visitancmothercare v
	where v.pcucodeperson=visitancdeliver.pcucodeperson AND v.pid=visitancdeliver.pid AND v.pregno = visitancdeliver.pregno AND DATEDIFF(v.datecare,visitancdeliver.datedeliver) < 8 LIMIT 0,1) as m1
,(select datecare from visitancmothercare v
  where v.pcucodeperson=visitancdeliver.pcucodeperson AND v.pid=visitancdeliver.pid AND v.pregno = visitancdeliver.pregno
    AND DATEDIFF(v.datecare,visitancdeliver.datedeliver) > 7
    AND DATEDIFF(v.datecare,visitancdeliver.datedeliver) < 16 order by v.datecare ASC limit 0,1) as m2
,(select datecare from visitancmothercare v
  where v.pcucodeperson=visitancdeliver.pcucodeperson AND v.pid=visitancdeliver.pid AND v.pregno = visitancdeliver.pregno
    AND DATEDIFF(v.datecare,visitancdeliver.datedeliver) > 15
    AND DATEDIFF(v.datecare,visitancdeliver.datedeliver) < 43 order by v.datecare ASC limit 0,1) as m3
,current_date() as currdate
FROM  visitancdeliver
LEFT join visitancmothercare v on visitancdeliver.pcucodeperson= v.pcucodeperson
                              AND visitancdeliver.pid  = v.pid
                              AND visitancdeliver.pregno = v.pregno
left join visitancdeliverchild vchild on visitancdeliver.pcucodeperson = vchild.pcucodeperson
                                     AND visitancdeliver.pid = vchild.pid
                                     AND visitancdeliver.pregno = vchild.pregno
left join person   on visitancdeliver.pid = person.pid
                  and visitancdeliver.pcucodeperson = person.pcucodeperson
left join ctitle tm on person.prename = tm.titlecode
left join person pchild  on pchild.pid = vchild.pidchild
                        and pchild.pcucodeperson = vchild.pcucodechild
left join ctitle tc on pchild.prename = tc.titlecode
left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
join _laborno_for_anvdeliver_rep b on visitancdeliver.pcucodeperson=b.pcucodeperson and visitancdeliver.pid=b.pid and visitancdeliver.pregno=b.pregno
WHERE visitancdeliver.datedeliver between $P{sdate} and $P{edate}
GROUP BY  v.pcucodeperson ,v.pid ,v.pregno ,vchild.pidchild
order by b.id]]>
	</queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="datedeliver" class="java.lang.String"/>
	<field name="mothername" class="java.lang.String"/>
	<field name="pregno" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="pid" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="pcucodeperson" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="age" class="java.lang.Double"/>
	<field name="address" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="childname" class="java.lang.String"/>
	<field name="pcucode" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="m1" class="java.sql.Date"/>
	<field name="m2" class="java.sql.Date"/>
	<field name="m3" class="java.sql.Date"/>
	<field name="currdate" class="java.sql.Date"/>
