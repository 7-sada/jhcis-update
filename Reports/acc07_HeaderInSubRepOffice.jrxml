	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["15009"]]></defaultValueExpression>
	</parameter>
	<parameter name="datespec" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2012-04-04"]]></defaultValueExpression>
	</parameter>
	<parameter name="repn" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["... ..."]]></defaultValueExpression>
	</parameter>
	<parameter name="datespecThai" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["วันนี้วันของกรู"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT person.pid, concat( ifnull(titlename,ifnull(person.prename,'...')) ," ", fname," ", lname) fname,
DATE_FORMAT(birth,"%Y-%m-%d") as d_birth , birth,
CONVERT(CONCAT(getAgeYearNum(person.birth,CAST($P{datespec} AS DATE)),' ปี ',     
getAgeMonthNum(person.birth,CAST($P{datespec} AS DATE)),' เดือน ',     
getAgeDayNum(person.birth,CAST($P{datespec} AS DATE)),' วัน ') USING utf8) AS age_ymd,if(deliverresult='ท',
CONVERT(CONCAT(visitanc.pregno,'(แท้ง)') USING utf8),convert(visitancpregnancy.pregno USING utf8)) as abort, 
lmp,
DATE_ADD(lmp, INTERVAL 40 week ) as edc , round(DATEDIFF(cast($P{datespec} as date),lmp) /7) as pregage,  
hnomoi,mumoi,villname,v.villcode  
FROM person  left join ctitle on person.prename = titlecode  
left join visitanc on (person.pid = visitanc.pid  and person.pcucodeperson = visitanc.pcucodeperson)  
left join visitancpregnancy on (visitancpregnancy.pid = person.pid and 
                                visitancpregnancy.pcucodeperson = person.pcucodeperson ) 
left join visitancdeliver on visitancpregnancy.pcucodeperson = visitancdeliver.pcucodeperson AND 
                             visitancpregnancy.pid = visitancdeliver.pid AND 
                             visitancpregnancy.pregno = visitancdeliver.pregno
join house h on person.pcucodeperson = h.pcucode and person.hcode = h.hcode
join village v on h.pcucode = v.pcucode and h.villcode = v.villcode   
WHERE person.pcucodeperson =$P{pcucode}  and (DATEDIFF($P{datespec},lmp) between 0 and 280)  
                                     and Right(v.villcode,2)<> '00' and 1=1  
                                     and person.pid NOT IN (SELECT persondeath.pid 
                                                            FROM persondeath 
                                                            WHERE person.pid = persondeath.pid and 
                                                                  person.pcucodeperson = persondeath.pcucodeperson and 
(persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{datespec}))   GROUP BY person.pid]]></queryString>

	<field name="pid" class="java.lang.Integer"/>
	<field name="fname" class="java.lang.String"/>
	<field name="d_birth" class="java.lang.String"/>
	<field name="birth" class="java.sql.Date"/>
