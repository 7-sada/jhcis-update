	<field name="hosmain" class="java.lang.String"/>
	<variable name="SUM_money2_1" class="java.lang.Double" resetType="Group" resetGroup="hosmain" calculation="Sum">
		<variableExpression><![CDATA[$F{money2}]]></variableExpression>
	</variable>
	<variable name="SUM_money2_2" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{money2}]]></variableExpression>
	</variable>
	<variable name="SUM_money1_1" class="java.lang.Double" resetType="Group" resetGroup="hosmain" calculation="Sum">
