<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DrugOrder_subreport2_FP" pageWidth="226" pageHeight="170" orientation="Landscape" columnWidth="226" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="e755beed-e3a3-4752-a3df-ef2ac154508c">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="visitno" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
     concat(cdrug.`drugname`,'  ',CONVERT(ifnull(unit,'0') USING  utf8),' ',ifnull(cs.unitsellname,'หน่วย')) AS dfp
FROM
`visitfp` visitfp
INNER JOIN `cdrug` cdrug ON visitfp.`fpcode` = cdrug.`drugcode`
join cdrugunitsell cs on (cdrug.unitsell = cs.unitsellcode)

WHERE
     visitfp.`visitno` = $P{visitno} and visitfp.pcucode = $P{pcucode}]]>
	</queryString>
	<field name="dfp" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
