, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-05') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt535
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-06') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt536
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-07') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt537
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-08') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt538
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-09') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt539
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-10') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt5310
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-11') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt5311
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-12') and getAgeyearNum(birth,visitdate) >59), count(distinct visit.pcucode,visit.visitno),0) as cpmt5312
#==
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-01') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt531
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-02') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt532
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-03') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt533
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-04') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt534
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-05') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt535
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-06') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt536
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-07') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt537
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-08') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt538
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate}),'-09') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt539
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-10') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt5310
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-11') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt5311
, if((date_format(visitdate,'%Y-%m') = concat(YEAR($P{edate})-1,'-12') and getAgeyearNum(birth,visitdate) >59), count(concat(visitdrugdental.pcucode,visitdrugdental.visitno)),0) as ctmt5312

,curdate() as cdate,chospital.hosname
,hc.hosname as cupname
from  person
	inner join visit on person.pid = visit.pid and person.pcucodeperson  = visit.pcucodeperson
inner join visitdrugdental on visit.pcucode = visitdrugdental.pcucode and visit.visitno = visitdrugdental.visitno
	inner join chospital on visit.pcucode = chospital.hoscode
	inner join house on person.hcode= house.hcode and person.pcucodeperson = house.pcucode
	inner join village on house.villcode = village.villcode and house.pcucode = village.pcucode
	inner join chospital hc on village.cup = hc.hoscode
where  visitdate between $P{sdate} and  $P{edate} $P!{pcucode}
	and concat(visit.pcucode,visit.visitno) in (select concat(visitdrugdental.pcucode,visitdrugdental.visitno) from visitdrugdental)
group by ymt ,date_format(visit.visitdate,'%Y-%m')]]>
	</queryString>
