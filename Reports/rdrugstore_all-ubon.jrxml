	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="where" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[cdrugremain.pcucode =  '01068' AND]]></parameterDescription>
		<defaultValueExpression><![CDATA[" WHERE  cdrug.drugflag = '1' "]]></defaultValueExpression>
	</parameter>
	<parameter name="rName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["แบบ รบ 301 (สรุปรวม)"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
CASE
 WHEN cdrug.drugtype =  '01'  THEN 'ยาฯ'
 WHEN cdrug.drugtype =  '02'   THEN 'หัตถการ'
 WHEN cdrug.drugtype =  '03'   THEN 'วัสดุการแพทย์'
 WHEN cdrug.drugtype =  '04'  THEN 'เวชภัณฑ์คุมกำเนิด'
 WHEN cdrug.drugtype =  '05'   THEN 'วัคซีน'
 WHEN cdrug.drugtype =  '06'   THEN 'ค่าบริการฯ'
 WHEN cdrug.drugtype =  '07'   THEN 'ค่าตรวจทางห้องปฏิบัติการฯ'
 WHEN cdrug.drugtype =  '08'  THEN 'ทันตกรรม'
 WHEN cdrug.drugtype =  '10'  THEN 'ยาสมุนไพร'
 WHEN cdrug.drugtype =  '11'  THEN 'เวชภัณฑ์ที่ไม่ใช่ยา'
 ELSE 'ไม่ระบุประเภทฯ'
END AS drugtype,
cdrug.drugcode,
CASE
 WHEN cdrug.drugcode IN ('DT','DT1','DT2','DTS1','DTS2','DTS3','DTS4','DTANC1','DTANC2','DTANC3','DTANC4','DTANC5') OR cdrug.drugcode =  'V120' THEN 'DT'
 WHEN cdrug.drugcode IN ('DTP','DTP1','DTP2','DTP3','DTP4','DTP5') OR cdrug.drugcode =  'V121' THEN 'DTP'
 WHEN cdrug.drugcode IN ('HBV','HBV1','HBV2','HBV3') OR cdrug.drugcode =  'V122' THEN 'HB'
 WHEN cdrug.drugcode IN ('JE','JE1','JE2','JE3') OR cdrug.drugcode =  'V123' THEN 'JE'
 WHEN cdrug.drugcode IN ('MMR','MMR2') OR cdrug.drugcode =  'V124' THEN 'MMR'
 WHEN cdrug.drugcode IN ('OPV','OPV1','OPV2','OPV3','OPV4','OPV5','OPVs1','OPVs2','OPVs3','OPVC') OR cdrug.drugcode =  'V125' THEN 'OPV'
 WHEN cdrug.drugcode IN ('TT','TT1','TT2','TT3','TT4','TT5') OR cdrug.drugcode =  'V126' THEN 'TT'
 WHEN cdrug.drugcode IN ('DHB','DHB1','DHB2','DHB3') OR cdrug.drugcode =  'V127' THEN 'DTP+HB'
 WHEN cdrug.drugcode IN ('MEAS') OR cdrug.drugcode =  'V128' THEN 'MEAS'
 WHEN cdrug.drugcode IN ('RB','RB1','RB2','RB3','RB4','RB5','RB12','RB22','RB32','RB42','RB52') THEN 'RB'
 ELSE cdrug.drugname END AS drug,
cdrugunitsell.unitsellname AS unitusage,
CASE
WHEN vdrugusedbf.dserv is null and vdrugstoretoloanbf.dserv is null and cdrugremain.remain is null then 0
WHEN vdrugusedbf.dserv is null and vdrugstoretoloanbf.dserv is null and cdrugremain.remain is not null then cdrugremain.remain
WHEN vdrugusedbf.dserv is null and vdrugstoretoloanbf.dserv is not null and cdrugremain.remain is null then 0-vdrugstoretoloanbf.dserv
WHEN vdrugusedbf.dserv is null and vdrugstoretoloanbf.dserv is not null and cdrugremain.remain is not null then cdrugremain.remain-vdrugstoretoloanbf.dserv
WHEN vdrugusedbf.dserv is not null and vdrugstoretoloanbf.dserv is null and cdrugremain.remain is null then 0-vdrugusedbf.dserv
WHEN vdrugusedbf.dserv is not null and vdrugstoretoloanbf.dserv is null and cdrugremain.remain is not null then cdrugremain.remain-vdrugusedbf.dserv
WHEN vdrugusedbf.dserv is not null and vdrugstoretoloanbf.dserv is not null and cdrugremain.remain is null then  0-(vdrugusedbf.dserv+vdrugstoretoloanbf.dserv)
WHEN vdrugusedbf.dserv is not null and vdrugstoretoloanbf.dserv is not null and cdrugremain.remain is not null then cdrugremain.remain-(vdrugusedbf.dserv+vdrugstoretoloanbf.dserv)
ELSE 0
END AS remain,
if(vdrugcostmxdate.dcost is null,cdrug.cost,vdrugcostmxdate.dcost) as costrem,
Sum(if(vdrugstockall.dr0 is null,0,vdrugstockall.dr0)) as dr0,
Sum(if(vdrugstockall.dr1 is null,0,vdrugstockall.dr1)) as dr1,
Sum(if(vdrugstockall.dr2 is null,0,vdrugstockall.dr2))as dr2,
Sum(if(vdrugstockall.dr3 is null,0,vdrugstockall.dr3)) as dr3,
Sum(if(vdrugstockall.drcost is null,0,vdrugstockall.drcost)) as drcost,
Sum(if(vdrugstockall.dserv is null,0,vdrugstockall.dserv)) as dsrev,
Sum(if(vdrugstockall.dl1 is null,0,vdrugstockall.dl1)) as dl1,
Sum(if(vdrugstockall.dl2 is null,0,vdrugstockall.dl2)) as dl2,
Sum(if(vdrugstockall.dl3 is null,0,vdrugstockall.dl3)) as dl3,
Sum(if(vdrugstockall.dl9 is null,0,vdrugstockall.dl9)) as dl9,
Sum(if(vdrugstockall.ducost is null,0,vdrugstockall.ducost)) as ducost,
if(vdrugreceivebf.amount is null,0,vdrugreceivebf.amount) drbf,
if(vdrugreceivebf.drcost is null,0,vdrugreceivebf.drcost)  drcostbf
FROM
cdrug
Inner Join cdrugremain ON cdrug.drugcode = cdrugremain.drugcode
Left Join vdrugusedbf ON cdrugremain.drugcode = vdrugusedbf.drugcode
Left Join vdrugstockall ON cdrugremain.drugcode = vdrugstockall.cdrug
Left Join vdrugcostmxdate ON vdrugcostmxdate.cdrug = vdrugstockall.cdrug
Left Join vdrugreceivebf ON vdrugreceivebf.cdrug = cdrug.drugcode
Left Join vdrugstoretoloanbf ON vdrugstoretoloanbf.drugcode = cdrug.drugcode
Left Outer Join cdrugunitsell ON cdrug.unitsell = cdrugunitsell.unitsellcode
$P!{where}
GROUP BY
drug
ORDER BY drugtype,drugname]]>
	</queryString>
	<field name="drugtype" class="java.lang.String"/>
	<field name="drugcode" class="java.lang.String"/>
	<field name="drug" class="java.lang.String"/>
	<field name="unitusage" class="java.lang.String"/>
	<field name="remain" class="java.lang.Double"/>
	<field name="costrem" class="java.lang.Double"/>
	<field name="dr0" class="java.lang.Double"/>
	<field name="dr1" class="java.lang.Double"/>
	<field name="dr2" class="java.lang.Double"/>
	<field name="dr3" class="java.lang.Double"/>
	<field name="drcost" class="java.lang.Double"/>
	<field name="dsrev" class="java.lang.Double"/>
	<field name="dl1" class="java.lang.Double"/>
	<field name="dl2" class="java.lang.Double"/>
	<field name="dl3" class="java.lang.Double"/>
	<field name="dl9" class="java.lang.Double"/>
	<field name="ducost" class="java.lang.Double"/>
	<field name="drbf" class="java.lang.Double"/>
	<field name="drcostbf" class="java.lang.Double"/>
	<variable name="sum_drcost" class="java.lang.Double" resetType="Group" resetGroup="drugtype" calculation="Sum">
		<variableExpression><![CDATA[$F{drcost}]]></variableExpression>
	</variable>
	<variable name="sum_ducost" class="java.lang.Double" resetType="Group" resetGroup="drugtype" calculation="Sum">
		<variableExpression><![CDATA[$F{ducost}]]></variableExpression>
	</variable>
	<variable name="sum_all_drcost" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{drcost}]]></variableExpression>
	</variable>
	<variable name="sum_all_ducost" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{ducost}]]></variableExpression>
	</variable>
	<variable name="sum_remain" class="java.lang.Double">
		<variableExpression><![CDATA[new java.lang.Double( $F{remain}.doubleValue()+($F{dr0}.doubleValue()+$F{dr1}.doubleValue()+$F{dr2}.doubleValue()+$F{dr3}.doubleValue())-($F{dsrev}.doubleValue()+$F{dl1}.doubleValue()+$F{dl2}.doubleValue()+$F{dl3}.doubleValue()+$F{dl9}.doubleValue()))]]></variableExpression>
	</variable>
	<variable name="sum_cost_remain" class="java.lang.Double" resetType="None">
		<variableExpression><![CDATA[new java.lang.Double( ((($F{remain}.doubleValue()+$F{drbf}.doubleValue())*$F{costrem}.doubleValue())+$F{drcost}.doubleValue()) -($F{ducost}.doubleValue()) )]]></variableExpression>
	</variable>
	<variable name="sum_cost_remain_1" class="java.lang.Double" resetType="Group" resetGroup="drugtype" calculation="Sum">
		<variableExpression><![CDATA[$V{sum_cost_remain}]]></variableExpression>
	</variable>
	<variable name="sum_cost_remain_2" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{sum_cost_remain}]]></variableExpression>
	</variable>
	<variable name="sum_cost_bf" class="java.lang.Double">
		<variableExpression><![CDATA[new java.lang.Double( ($F{remain}.doubleValue()+$F{drbf}.doubleValue())*$F{costrem}.doubleValue() )]]></variableExpression>
	</variable>
	<variable name="sum_cost_bf_1" class="java.lang.Double" resetType="Group" resetGroup="drugtype" calculation="Sum">
		<variableExpression><![CDATA[$V{sum_cost_bf}]]></variableExpression>
	</variable>
