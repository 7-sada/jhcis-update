<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ncd_list_organ" pageWidth="150" pageHeight="113" orientation="Landscape" columnWidth="150" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="p_reportOffice" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["หน่วยงาน :........................................"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_startDate" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_endDate" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlOffice" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlPid" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND ncd_person_ncd_hist.pid='1' "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_flag" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND ncd_person_ncd_hist.dm_flag='1' "]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     sum(CASE WHEN org_code='01' THEN 1 ELSE 0 END)AS org_01,
     sum(CASE WHEN org_code='02' THEN 1 ELSE 0 END)AS org_02,
     sum(CASE WHEN org_code='03' THEN 1 ELSE 0 END)AS org_03,
     sum(CASE WHEN org_code='04' THEN 1 ELSE 0 END)AS org_04,
     sum(CASE WHEN org_code='05' THEN 1 ELSE 0 END)AS org_05,
     sum(CASE WHEN org_code='99' THEN 1 ELSE 0 END)AS org_99
FROM
     `ncd_person_ncd_hist` ncd_person_ncd_hist INNER JOIN `ncd_person_ncd_hist_detail` ncd_person_ncd_hist_detail ON ncd_person_ncd_hist.`pcucode` = ncd_person_ncd_hist_detail.`pcucode`
     AND ncd_person_ncd_hist.`pid` = ncd_person_ncd_hist_detail.`pid`
WHERE
     1 = 1 $P!{p_sqlOffice} $P!{p_sqlPid} $P!{p_flag}]]>
	</queryString>
	<field name="org_01" class="java.math.BigDecimal"/>
	<field name="org_02" class="java.math.BigDecimal"/>
	<field name="org_03" class="java.math.BigDecimal"/>
	<field name="org_04" class="java.math.BigDecimal"/>
	<field name="org_05" class="java.math.BigDecimal"/>
	<field name="org_99" class="java.math.BigDecimal"/>
	<background>
