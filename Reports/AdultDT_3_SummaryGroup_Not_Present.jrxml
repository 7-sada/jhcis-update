	<subDataset name="DataAdult" uuid="56b84a1c-dc0f-4e5c-b8c7-8a8a378ea556">
		<parameter name="sdate" class="java.lang.String"/>
		<parameter name="edate" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT p1.pcucodeperson,
p1.pid, concat(ifnull(titlename,ifnull(p1.prename,'...')) ," ", fname," ", lname) as fullname
#,getAgeYearNum(p1.birth,CAST('2018-01-26' AS DATE)) as Age
,getAgeYearNum(p1.birth,p3.dateepi) as Age
,p1.mumoi,h.villcode,
v.villname,p3.vaccinecode as dt,
(case when p3.vaccinecode = 'DT1' then 'Y'
when p3.vaccinecode = 'DT2' then 'Y'
when p3.vaccinecode = 'DT3' then 'Y'
when p3.vaccinecode = 'DT4' then 'Y'
when p3.vaccinecode = 'DT5' then 'Y'
when p3.vaccinecode = 'dT' then 'Y'
else null end) as dt1,
p3.dateepi
from person p1
join ctitle p2 on p1.prename = p2.titlecode
join visitepi p3 on p1.pid = p3.pid
left join house h on p1.hcode = h.hcode and p1.pcucodeperson = h.pcucode
left join village v ON h.villcode = v.villcode and h.pcucode = v.pcucode
where
#p3.dateepi between '2016-01-01' and '2018-01-31'
p3.dateepi between $P!{sdate} and $P!{edate}
and p3.vaccinecode like '%dt%'
#and getAgeYearNum(p1.birth,CAST('2018-01-26' AS DATE)) >= 15
and getAgeYearNum(p1.birth,p3.dateepi) >= 15
order by v.villcode]]>
		</queryString>
		<field name="pcucodeperson" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fullname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="Age" class="java.lang.Long"/>
		<field name="mumoi" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="villcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="villname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dt" class="java.lang.String"/>
		<field name="dt1" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dateepi" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<group name="mumoi">
			<groupExpression><![CDATA[$F{villcode}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="header_1" class="java.lang.String"/>
	<parameter name="header_2" class="java.lang.String"/>
	<parameter name="sdate" class="java.lang.String"/>
	<parameter name="edate" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT p1.pcucodeperson,
p1.pid, concat(ifnull(titlename,ifnull(p1.prename,'...')) ," ", fname," ", lname) as fullname
#,getAgeYearNum(p1.birth,CAST('2018-01-26' AS DATE)) as Age
,getAgeYearNum(p1.birth,p3.dateepi) as Age
,p1.mumoi,h.villcode,
v.villname,p3.vaccinecode as dt,
(case when p3.vaccinecode = 'DT1' then 'Y'
when p3.vaccinecode = 'DT2' then 'Y'
when p3.vaccinecode = 'DT3' then 'Y'
when p3.vaccinecode = 'DT4' then 'Y'
when p3.vaccinecode = 'DT5' then 'Y'
when p3.vaccinecode = 'dT' then 'Y'
else null end) as dt1,
p3.dateepi
,villname
from person p1
join ctitle p2 on p1.prename = p2.titlecode
join visitepi p3 on p1.pid = p3.pid
left join house h on p1.hcode = h.hcode and p1.pcucodeperson = h.pcucode
left join village v ON h.villcode = v.villcode and h.pcucode = v.pcucode
where
#p3.dateepi between '2016-01-01' and '2018-01-31'
p3.dateepi between $P!{sdate} and $P!{edate}
and p3.vaccinecode like '%dt%'
#and getAgeYearNum(p1.birth,CAST('2018-01-26' AS DATE)) >= 15
and getAgeYearNum(p1.birth,p3.dateepi) >= 15
order by v.villcode]]>
	</queryString>
