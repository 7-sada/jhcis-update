<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="epiappoint" language="groovy" pageWidth="374" pageHeight="219" columnWidth="374" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="HN" class="java.lang.Integer">
		<parameterDescription><![CDATA[เลขที่ HN]]></parameterDescription>
		<defaultValueExpression><![CDATA[4]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ctitle.titlename, person.fname,person.lname,person.pid, drugname

,date_format(dateappoint,'%Y-%m-%d') dateappoint    ,hosname

,curdate()


FROM visitepiappoint v
  left join person on v.pcucodeperson = person.pcucodeperson and v.pid = person.pid
  left join ctitle on person.prename = ctitle.titlecode
  left join cdrug on v.vaccinecode = cdrug.drugcode
  left join chospital on v.pcucodeperson = chospital.hoscode
where 1=1 and v.pid = $P{HN}
order by v.vaccinecode]]>
	</queryString>
	<field name="titlename" class="java.lang.String"/>
	<field name="fname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="drugname" class="java.lang.String"/>
	<field name="dateappoint" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="curdate()" class="java.sql.Date"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band height="40" splitType="Stretch">
			<textField>
				<reportElement x="136" y="20" width="228" height="20"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{titlename}+$F{fname}+' '+$F{lname}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="36" y="20" width="100" height="20"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{pid}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="1" y="20" width="35" height="20"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="12"/>
				</textElement>
				<text><![CDATA[HN :]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="17" y="0" width="347" height="20"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="12" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["บัตรนัดฉีดยา        "+$F{hosname}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="27" splitType="Stretch">
			<textField>
				<reportElement x="1" y="0" width="166" height="27"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{drugname}]]></textFieldExpression>
			</textField>
			<textField pattern="d MMMMM yyyy">
				<reportElement x="167" y="0" width="113" height="27"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{curdate()}.valueOf( $F{dateappoint} )]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="280" y="0" width="84" height="27"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement/>
				<text><![CDATA[]]></text>
