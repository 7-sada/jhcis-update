					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[มาให้ตรงนัด]]></text>
			</staticText>
		</band>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
