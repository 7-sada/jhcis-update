<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rVillageAgegroup"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="header_1" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header_2" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="edate" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
house.villcode, village.villno, 
IF( (village.villname IS NOT NULL AND village.villname<>''), village.villname, CONCAT('ไม่ระบุ (',village.villcode,')') ) AS villname, 

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 0 AND 150) AND person.sex='1', 1, 0)) AS TotalG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 0 AND 150) AND person.sex='2', 1, 0)) AS TotalL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 0 AND 150), 1, 0)) AS TotalA,

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) < 1) AND person.sex='1', 1, 0)) AS AG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) < 1) AND person.sex='2', 1, 0)) AS AL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) < 1), 1, 0)) AS AA, 

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 1 AND 4) AND person.sex='1', 1, 0)) AS BG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 1 AND 4) AND person.sex='2', 1, 0)) AS BL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 1 AND 4), 1, 0)) AS BA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 5 AND 9) AND person.sex='1', 1, 0)) AS CG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 5 AND 9) AND person.sex='2', 1, 0)) AS CL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 5 AND 9), 1, 0)) AS CA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 10 AND 14) AND person.sex='1', 1, 0)) AS DG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 10 AND 14) AND person.sex='2', 1, 0)) AS DL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 10 AND 14), 1, 0)) AS DA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 15 AND 19) AND person.sex='1', 1, 0)) AS EG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 15 AND 19) AND person.sex='2', 1, 0)) AS EL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 15 AND 19), 1, 0)) AS EA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 20 AND 24) AND person.sex='1', 1, 0)) AS FG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 20 AND 24) AND person.sex='2', 1, 0)) AS FL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 20 AND 24), 1, 0)) AS FA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 25 AND 29) AND person.sex='1', 1, 0)) AS GG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 25 AND 29) AND person.sex='2', 1, 0)) AS GL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 25 AND 29), 1, 0)) AS GA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 30 AND 34) AND person.sex='1', 1, 0)) AS HG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 30 AND 34) AND person.sex='2', 1, 0)) AS HL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 30 AND 34), 1, 0)) AS HA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 35 AND 39) AND person.sex='1', 1, 0)) AS IG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 35 AND 39) AND person.sex='2', 1, 0)) AS IL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 35 AND 39), 1, 0)) AS IA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 40 AND 44) AND person.sex='1', 1, 0)) AS JG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 40 AND 44) AND person.sex='2', 1, 0)) AS JL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 40 AND 44), 1, 0)) AS JA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 45 AND 49) AND person.sex='1', 1, 0)) AS KG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 45 AND 49) AND person.sex='2', 1, 0)) AS KL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 45 AND 49), 1, 0)) AS KA,

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 50 AND 54) AND person.sex='1', 1, 0)) AS LG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 50 AND 54) AND person.sex='2', 1, 0)) AS LL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 50 AND 54), 1, 0)) AS LA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 55 AND 59) AND person.sex='1', 1, 0)) AS MG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 55 AND 59) AND person.sex='2', 1, 0)) AS ML,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 55 AND 59), 1, 0)) AS MA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 60 AND 64) AND person.sex='1', 1, 0)) AS NG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 60 AND 64) AND person.sex='2', 1, 0)) AS NL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 60 AND 64), 1, 0)) AS NA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 65 AND 69) AND person.sex='1', 1, 0)) AS OG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 65 AND 69) AND person.sex='2', 1, 0)) AS OL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 65 AND 69), 1, 0)) AS OA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 70 AND 74) AND person.sex='1', 1, 0)) AS PG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 70 AND 74) AND person.sex='2', 1, 0)) AS PL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 70 AND 74), 1, 0)) AS PA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 74 AND 79) AND person.sex='1', 1, 0)) AS QG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 74 AND 79) AND person.sex='2', 1, 0)) AS QL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 74 AND 79), 1, 0)) AS QA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 80 AND 84) AND person.sex='1', 1, 0)) AS RG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 80 AND 84) AND person.sex='2', 1, 0)) AS RL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) BETWEEN 80 AND 84), 1, 0)) AS RA,  

SUM(IF( (getAgeYearNum(person.birth, CURDATE()) > 84) AND person.sex='1', 1, 0)) AS SG,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) > 84) AND person.sex='2', 1, 0)) AS SL,
SUM(IF( (getAgeYearNum(person.birth, CURDATE()) > 84), 1, 0)) AS SA

FROM house 
  INNER JOIN person ON (house.pcucode=person.pcucodeperson AND house.hcode=person.hcode)  
  LEFT JOIN village ON (house.pcucode=village.pcucode AND house.villcode=village.villcode)   
WHERE SUBSTRING(house.villcode,7,2)<>'00' 
  AND house.pcucode='01898'
GROUP BY house.villcode, village.villno  
ORDER BY village.villno ASC 	
LIMIT 10;]]></queryString>

