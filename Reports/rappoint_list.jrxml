<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rappoint_list" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="ce52541c-7e6e-4dcb-bebc-cb271222de84">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="DateRepStart" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="appointDate" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[WHERE appointdate BETWEEN ('2010-11-01') AND ('2010-11-24')]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="bDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'2007-01-10'"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND `visitdiag`.`pcucode` =  '01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT distinct
     visit.pcucode,visit.visitno,visit.pid,
     concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname)as name,
     house.hno,
     village.villno,
     village.villname,
     DATE_FORMAT(person.birth,'%Y-%m-%d') as birth,
     DATE_FORMAT(visitdiagappoint.appodate,'%Y-%m-%d') as appointdate,
DATE_FORMAT(visitdiagappoint.appodate,'%Y-%m-%d') as appdate,
      concat(
(
year(visitdiagappoint.appodate)-year(person.birth)-(right(visitdiagappoint.appodate,14)<right(person.birth,14))
) ,' - ',(
if (right(visitdiagappoint.appodate,14)<right(person.birth,14),
(12+month(visitdiagappoint.appodate)-month(person.birth)),
month(visitdiagappoint.appodate)-month(person.birth)
))
) as age
FROM
village
Inner Join house ON village.villcode = house.villcode AND house.pcucode = village.pcucode
Inner Join person ON house.hcode = person.hcode AND person.pcucodeperson = house.pcucode
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join visit ON person.pid = visit.pid AND visit.pcucodeperson = person.pcucodeperson
Inner Join visitdiag ON visit.visitno = visitdiag.visitno AND visitdiag.pcucode = visit.pcucode
Inner Join visitdiagappoint ON visitdiag.pcucode = visitdiagappoint.pcucode AND visitdiag.visitno = visitdiagappoint.visitno AND visitdiag.diagcode = visitdiagappoint.diagcode
$P!{appointDate} $P!{pcucode}
GROUP BY visit.pcucode,visit.pid,visitdiagappoint.appodate
ORDER BY visitdiagappoint.appodate,house.villcode,house.hno,visit.visitno]]>
	</queryString>
	<field name="pcucode" class="java.lang.String"/>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="name" class="java.lang.String"/>
	<field name="hno" class="java.lang.String"/>
	<field name="villno" class="java.lang.Integer"/>
	<field name="villname" class="java.lang.String"/>
	<field name="birth" class="java.util.Date"/>
	<field name="appointdate" class="java.util.Date"/>
	<field name="appdate" class="java.lang.String"/>
	<field name="age" class="java.lang.String"/>
