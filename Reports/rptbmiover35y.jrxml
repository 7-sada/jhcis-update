					<box topBorder="Thin" topBorderColor="#0033FF" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#3333FF" bottomBorder="Thin" bottomBorderColor="#3333FF"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
