	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-12-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2011-02-11"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" isForPrompting="false" class="java.lang.Integer">
		<defaultValueExpression ><![CDATA[new Integer(15)]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["c:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT chospital.hosname,csubdistrict.subdistname
,village.villname,village.villcode
,v.visitdate,v.pcucode
,sum(case when person.sex='1' and v.weight !='' and (v.height !='' and v.height >0) and (v.visitdate between CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30'))  then 1 else 0 end) as whms
,sum(case when person.sex='2' and v.weight !='' and (v.height !='' and v.height >0) and (v.visitdate between CONCAT(DATE_FORMAT($P{edate},'%Y')-1 ,'-10','-01') and CONCAT(DATE_FORMAT($P{edate},'%Y') ,'-09','-30')) then 1 else 0 end) as whfms
,sum(case when person.sex='1' and v.weight !='' and (v.height !='' and v.height >0) and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end) as whm
,sum(case when person.sex='2' and v.weight !='' and (v.height !='' and v.height >0) and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end) as whfm
,sum(case when(person.sex='1' and v.weight !='' and (v.height !='' and v.height >0)  and (v.weight/((v.height/100)*(v.height/100))) < 18.5000 )and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as am
,sum(case when(person.sex='2' and v.weight !='' and (v.height !='' and v.height >0)  and (v.weight/((v.height/100)*(v.height/100))) < 18.5000 )and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as afm
,sum(case when person.sex='1' and v.weight !='' and (v.height !='' and v.height >0)  and ( (v.weight/((v.height/100)*(v.height/100)))  >=18.5000  and  (v.weight/((v.height/100)*(v.height/100)))  <25 )and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as bm
,sum(case when person.sex='2' and v.weight !='' and (v.height !='' and v.height >0)  and ( (v.weight/((v.height/100)*(v.height/100)))  >=18.5000  and  (v.weight/((v.height/100)*(v.height/100)))  <25  ) and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as bfm
,sum(case when person.sex='1' and v.weight !='' and (v.height !='' and v.height >0)  and ( (v.weight/((v.height/100)*(v.height/100)))  >=25   and  (v.weight/((v.height/100)*(v.height/100)))  <30 )and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as cm
,sum(case when person.sex='2' and v.weight !='' and (v.height !='' and v.height >0)  and ( (v.weight/((v.height/100)*(v.height/100)))  >=25   and  (v.weight/((v.height/100)*(v.height/100)))  <30 ) and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as cfm
,sum(case when person.sex='1' and v.weight !='' and (v.height !='' and v.height >0)  and ((v.weight/((v.height/100)*(v.height/100))) >= 30.0000) and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as dm
,sum(case when person.sex='2' and v.weight !='' and (v.height !='' and v.height >0)  and ((v.weight/((v.height/100)*(v.height/100))) >= 30.0000) and (v.visitdate between $P{sdate} and $P{edate}) then 1 else 0 end ) as dfm
FROM visit v 
     left join person on person.pid = v.pid and person.pcucodeperson = v.pcucodeperson
     left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
     left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
     left join chospital on v.pcucode = chospital.hoscode
     left join csubdistrict on csubdistrict.subdistcode = chospital.subdistcode and csubdistrict.distcode = chospital.distcode and csubdistrict.provcode = chospital.provcode   
WHERE substring(village.villcode,7,2) !='00'	
and (birth IS NOT NULL OR birth NOT LIKE '0000%')
      $P!{pcucode}
     and DATEDIFF(concat(YEAR($P{edate}),'-12','-31'),person.birth)/365 >= $P{age}
     and CONCAT(person.pid,person.pcucodeperson) NOT IN (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath WHERE persondeath.pcucodeperson = person.pcucodeperson and (persondeath.deaddate IS NULL OR persondeath.deaddate<=$P{edate})) 
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
     and (person.typelive ='1' or person.typelive ='3' or person.typelive is null or person.typelive='0' )

GROUP BY v.pcucode,village.villcode]]></queryString>

