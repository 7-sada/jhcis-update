	<queryString><![CDATA[SELECT
     drug_to_draw.`drugname` AS drug_to_draw_drugname,
     drug_to_draw.`pack` AS drug_to_draw_pack,
     drug_to_draw.`sunit` AS drug_to_draw_sunit,
     drug_to_draw.remain - sunit AS amountdrugstore,
     drug_to_draw.`requisitionamount` AS drug_to_draw_requisitionamount,
     drug_to_draw.`remark` AS drug_to_draw_remark,
     drug_to_draw.`cost` AS drug_to_draw_cost,
     drug_to_draw.`amount` AS drug_to_draw_amount,
     drug_to_draw.`avg` AS drug_to_draw_avg
FROM
     `drug_to_draw` drug_to_draw]]></queryString>

