	SUM(CASE WHEN diagcode LIKE 'F7%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='1' THEN 1 ELSE 0 END) AS E4G,
	SUM(CASE WHEN diagcode LIKE 'F7%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='2' THEN 1 ELSE 0 END) AS E4L,
