	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='1' THEN 1 ELSE 0 END) AS K3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='2' THEN 1 ELSE 0 END) AS K3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='1' THEN 1 ELSE 0 END) AS L3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='2' THEN 1 ELSE 0 END) AS L3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='1' THEN 1 ELSE 0 END) AS M3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='2' THEN 1 ELSE 0 END) AS M3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='1' THEN 1 ELSE 0 END) AS N3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='2' THEN 1 ELSE 0 END) AS N3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='1' THEN 1 ELSE 0 END) AS O3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='2' THEN 1 ELSE 0 END) AS O3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='1' THEN 1 ELSE 0 END) AS P3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='2' THEN 1 ELSE 0 END) AS P3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='1' THEN 1 ELSE 0 END) AS Q3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='2' THEN 1 ELSE 0 END) AS Q3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='1' THEN 1 ELSE 0 END) AS R3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='2' THEN 1 ELSE 0 END) AS R3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='1' THEN 1 ELSE 0 END) AS S3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='2' THEN 1 ELSE 0 END) AS S3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND person.sex='1' THEN 1 ELSE 0 END) AS SUM3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND person.sex='2' THEN 1 ELSE 0 END) AS SUM3L,

