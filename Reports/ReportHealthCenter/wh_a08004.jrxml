FROM persondeath pd WHERE person.pid = pd.pid AND person.pcucodeperson = pd.pcucodeperson ) THEN 1 ELSE 0 END) AS R62L,
	SUM(CASE WHEN (diagcode BETWEEN 'X60' AND 'X84' ) AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='1' AND CONCAT(person.pid,person.pcucodeperson) NOT IN (SELECT CONCAT(pd.pid,pd.pcucodeperson) 
FROM persondeath pd WHERE person.pid = pd.pid AND person.pcucodeperson = pd.pcucodeperson ) THEN 1 ELSE 0 END) AS S62G,
	SUM(CASE WHEN (diagcode BETWEEN 'X60' AND 'X84' ) AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='2' AND CONCAT(person.pid,person.pcucodeperson) NOT IN (SELECT CONCAT(pd.pid,pd.pcucodeperson) 
FROM persondeath pd WHERE person.pid = pd.pid AND person.pcucodeperson = pd.pcucodeperson ) THEN 1 ELSE 0 END) AS S62L,
	SUM(CASE WHEN (diagcode BETWEEN 'X60' AND 'X84' ) AND person.sex='1' AND CONCAT(person.pid,person.pcucodeperson) NOT IN (SELECT CONCAT(pd.pid,pd.pcucodeperson) 
FROM persondeath pd WHERE person.pid = pd.pid AND person.pcucodeperson = pd.pcucodeperson )  THEN 1 ELSE 0 END) AS SUM62G,
	SUM(CASE WHEN (diagcode BETWEEN 'X60' AND 'X84' ) AND person.sex='2' AND CONCAT(person.pid,person.pcucodeperson) NOT IN (SELECT CONCAT(pd.pid,pd.pcucodeperson) 
FROM persondeath pd WHERE person.pid = pd.pid AND person.pcucodeperson = pd.pcucodeperson ) THEN 1 ELSE 0 END) AS SUM62L

FROM
	visit
	INNER JOIN person ON visit.pid=person.pid AND visit.pcucode=person.pcucodeperson
	INNER JOIN visitdiag ON visit.visitno=visitdiag.visitno AND visit.pcucode=visitdiag.pcucode
WHERE
	visit.visitdate BETWEEN '$P!{BEGINDATE}' AND '$P!{ENDDATE}'
	$P!{PCUCODE}]]></queryString>

