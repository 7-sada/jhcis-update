	SUM(CASE WHEN diagcode LIKE 'F7%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='2' THEN 1 ELSE 0 END) AS A4L,
