<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="wh_a08004"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="1160"
		 pageHeight="595"
		 columnWidth="1100"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15000' " ]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="PCUCODEPERSON" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
	visit.pcucode AS pcucode,
	getOffice(visit.pcucode) AS pcuname,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='1' THEN 1 ELSE 0 END) AS A1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='2' THEN 1 ELSE 0 END) AS A1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='1' THEN 1 ELSE 0 END) AS B1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='2' THEN 1 ELSE 0 END) AS B1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='1' THEN 1 ELSE 0 END) AS C1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='2' THEN 1 ELSE 0 END) AS C1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='1' THEN 1 ELSE 0 END) AS D1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='2' THEN 1 ELSE 0 END) AS D1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='1' THEN 1 ELSE 0 END) AS E1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='2' THEN 1 ELSE 0 END) AS E1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='1' THEN 1 ELSE 0 END) AS F1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='2' THEN 1 ELSE 0 END) AS F1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='1' THEN 1 ELSE 0 END) AS G1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='2' THEN 1 ELSE 0 END) AS G1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='1' THEN 1 ELSE 0 END) AS H1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='2' THEN 1 ELSE 0 END) AS H1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='1' THEN 1 ELSE 0 END) AS K1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='2' THEN 1 ELSE 0 END) AS K1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='1' THEN 1 ELSE 0 END) AS L1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='2' THEN 1 ELSE 0 END) AS L1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='1' THEN 1 ELSE 0 END) AS M1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='2' THEN 1 ELSE 0 END) AS M1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='1' THEN 1 ELSE 0 END) AS N1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='2' THEN 1 ELSE 0 END) AS N1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='1' THEN 1 ELSE 0 END) AS O1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='2' THEN 1 ELSE 0 END) AS O1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='1' THEN 1 ELSE 0 END) AS P1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='2' THEN 1 ELSE 0 END) AS P1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='1' THEN 1 ELSE 0 END) AS Q1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='2' THEN 1 ELSE 0 END) AS Q1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='1' THEN 1 ELSE 0 END) AS R1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='2' THEN 1 ELSE 0 END) AS R1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='1' THEN 1 ELSE 0 END) AS S1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='2' THEN 1 ELSE 0 END) AS S1L,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND person.sex='1' THEN 1 ELSE 0 END) AS SUM1G,
	SUM(CASE WHEN diagcode LIKE 'I2%' AND person.sex='2' THEN 1 ELSE 0 END) AS SUM1L,

	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='1' THEN 1 ELSE 0 END) AS A2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='2' THEN 1 ELSE 0 END) AS A2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='1' THEN 1 ELSE 0 END) AS B2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='2' THEN 1 ELSE 0 END) AS B2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='1' THEN 1 ELSE 0 END) AS C2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='2' THEN 1 ELSE 0 END) AS C2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='1' THEN 1 ELSE 0 END) AS D2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='2' THEN 1 ELSE 0 END) AS D2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='1' THEN 1 ELSE 0 END) AS E2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='2' THEN 1 ELSE 0 END) AS E2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='1' THEN 1 ELSE 0 END) AS F2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='2' THEN 1 ELSE 0 END) AS F2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='1' THEN 1 ELSE 0 END) AS G2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='2' THEN 1 ELSE 0 END) AS G2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='1' THEN 1 ELSE 0 END) AS H2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='2' THEN 1 ELSE 0 END) AS H2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='1' THEN 1 ELSE 0 END) AS K2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='2' THEN 1 ELSE 0 END) AS K2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='1' THEN 1 ELSE 0 END) AS L2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='2' THEN 1 ELSE 0 END) AS L2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='1' THEN 1 ELSE 0 END) AS M2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='2' THEN 1 ELSE 0 END) AS M2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='1' THEN 1 ELSE 0 END) AS N2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='2' THEN 1 ELSE 0 END) AS N2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='1' THEN 1 ELSE 0 END) AS O2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='2' THEN 1 ELSE 0 END) AS O2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='1' THEN 1 ELSE 0 END) AS P2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='2' THEN 1 ELSE 0 END) AS P2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='1' THEN 1 ELSE 0 END) AS Q2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='2' THEN 1 ELSE 0 END) AS Q2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='1' THEN 1 ELSE 0 END) AS R2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='2' THEN 1 ELSE 0 END) AS R2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='1' THEN 1 ELSE 0 END) AS S2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='2' THEN 1 ELSE 0 END) AS S2L,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND person.sex='1' THEN 1 ELSE 0 END) AS SUM2G,
	SUM(CASE WHEN ( diagcode BETWEEN  'F40' AND 'F48' ) AND person.sex='2' THEN 1 ELSE 0 END) AS SUM2L,

	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='1' THEN 1 ELSE 0 END) AS A3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) AND person.sex='2' THEN 1 ELSE 0 END) AS A3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='1' THEN 1 ELSE 0 END) AS B3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='2' THEN 1 ELSE 0 END) AS B3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='1' THEN 1 ELSE 0 END) AS C3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='2' THEN 1 ELSE 0 END) AS C3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='1' THEN 1 ELSE 0 END) AS D3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='2' THEN 1 ELSE 0 END) AS D3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='1' THEN 1 ELSE 0 END) AS E3G,
