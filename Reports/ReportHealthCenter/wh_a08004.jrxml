	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='2' THEN 1 ELSE 0 END) AS F3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='1' THEN 1 ELSE 0 END) AS G3G,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='2' THEN 1 ELSE 0 END) AS G3L,
	SUM(CASE WHEN diagcode LIKE 'F3%' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='1' THEN 1 ELSE 0 END) AS H3G,
