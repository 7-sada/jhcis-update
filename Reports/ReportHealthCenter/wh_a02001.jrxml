	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 
	person.pcucodeperson AS pcucode,
	chospital.hoscode AS pcuname,
	house.villcode AS villno,
	getVill(house.villcode) AS village,
	getDisGr103(persondeath.deadcause) AS GR103,
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 < 1 AND person.sex = '1' THEN 1 ELSE null END) AS 'AM0000',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 < 1 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0000',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 1 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0001',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 1 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0001',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 2 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0002',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 2 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0002',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 3 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0003',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 3 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0003',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 4 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0004',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 = 4 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0004',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 5 AND 9 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0509',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 5 AND 9 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0509',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 10 AND 14 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM1014',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 10 AND 14 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL1014',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 15 AND 19 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM1519',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 15 AND 19 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL1519',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 20 AND 24 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM2024',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 20 AND 24 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL2024',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 25 AND 29 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM2529',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 25 AND 29 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL2529',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 30 AND 34 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM3034',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 30 AND 34 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL3034',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 35 AND 39 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM3539',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 35 AND 39 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL3539',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 40 AND 44 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM4044',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 40 AND 44 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL4044',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 45 AND 49 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM4549',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 45 AND 49 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL4549',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 50 AND 54 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM5054',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 50 AND 54 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL5054',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 55 AND 59 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM5559',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 55 AND 59 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL5559',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 60 AND 64 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM6064',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 60 AND 64 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL6064',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 65 AND 69 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM6569',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 65 AND 69 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL6569',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 70 AND 74 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM7074',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 70 AND 74 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL7074',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 > 74 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM7500',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(persondeath.deaddate)-TO_DAYS(person.birth)),'%Y')+0 > 74 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL7500' ,
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN person.birth IS NULL OR person.birth = '0000-00-00' AND person.sex = '1' THEN 1 ELSE null END) AS  'AM',
	COUNT(DISTINCT persondeath.pid,persondeath.pcucodeperson,CASE WHEN person.birth IS NULL OR person.birth = '0000-00-00' AND person.sex = '2' THEN 1 ELSE null END) AS  'AL'
FROM
	person 
	LEFT JOIN persondeath ON person.pcucodeperson = persondeath.pcucodeperson AND person.pid = persondeath.pid
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	INNER JOIN chospital ON chospital.hoscode=person.pcucodeperson
WHERE 
	SUBSTRING(house.villcode,7,2)<>'00' AND getDisGr103(persondeath.deadcause) IS NOT NULL 
	AND persondeath.deaddate BETWEEN  '$P!{BEGINDATE}' AND '$P!{ENDDATE}' 
 	$P!{PCUCODE} 
GROUP BY 
	getDisGr103(persondeath.deadcause),house.villcode,person.pcucodeperson
ORDER BY 
	person.pcucodeperson,house.villcode,getDisGr103(persondeath.deadcause)]]></queryString>

