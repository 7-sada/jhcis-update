	<queryString><![CDATA[SELECT house.villcode,villname,visit.pcucode
,sum(case when visitnutrition.nlevel = '1' and sex ='1' then 1 else 0 end) as mlevel1
,sum(case when visitnutrition.nlevel = '1' and sex ='2' then 1 else 0 end) as fmlevel1
,sum(case when visitnutrition.nlevel = '2' and sex ='1' then 1 else 0 end) as mlevel2
,sum(case when visitnutrition.nlevel = '2' and sex ='2' then 1 else 0 end) as fmlevel2
,sum(case when visitnutrition.nlevel = '3' and sex ='1' then 1 else 0 end) as mlevel3
,sum(case when visitnutrition.nlevel = '3' and sex ='2' then 1 else 0 end) as fmlevel3
,sum(case when visitnutrition.nlevel = '4' and sex ='1' then 1 else 0 end) as mlevel4
,sum(case when visitnutrition.nlevel = '4' and sex ='2' then 1 else 0 end) as fmlevel4
,sum(case when visitnutrition.nlevel = '5' and sex ='1' then 1 else 0 end) as mlevel5
,sum(case when visitnutrition.nlevel = '5' and sex ='2' then 1 else 0 end) as fmlevel5

,sum(case when visitnutrition.nlevel2 = '1' and sex ='1' then 1 else 0 end) as mlevel21
,sum(case when visitnutrition.nlevel2 = '1' and sex ='2' then 1 else 0 end) as fmlevel21
,sum(case when visitnutrition.nlevel2 = '2' and sex ='1' then 1 else 0 end) as mlevel22
,sum(case when visitnutrition.nlevel2 = '2' and sex ='2' then 1 else 0 end) as fmlevel22
,sum(case when visitnutrition.nlevel2 = '3' and sex ='1' then 1 else 0 end) as mlevel23
,sum(case when visitnutrition.nlevel2 = '3' and sex ='2' then 1 else 0 end) as fmlevel23

,sum(case when sex='1'  then 1 else 0 end) as mpop05
,sum(case when sex='2'  then 1 else 0 end) as fmpop05
,hosname
from person left join house on person.hcode=house.hcode and person.pcucodeperson = house.pcucode
	left join visit on person.pid = visit.pid and person.pcucodeperson = visit.pcucodeperson
	left join visitnutrition on visit.visitno = visitnutrition.visitno and visit.pcucode = visitnutrition.pcucode
	left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
	left join chospital on visit.pcucode=chospital.hoscode
where  DATE_FORMAT(current_date,'%Y-%m-%d')  - DATE_FORMAT(birth,'%Y-%m-%d') < 6
$P!{PCUCODE}
group by house.villcode]]></queryString>

