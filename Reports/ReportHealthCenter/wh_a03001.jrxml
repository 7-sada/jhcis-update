	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15000' " ]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="PCUCODEPERSON" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
	personchronic.pcucodeperson AS pcucode,
	getOffice(personchronic.pcucodeperson) AS pcuname,
	getPopNum(personchronic.pcucodeperson) AS popnum,
	cdiseasechronic.groupcode AS chroniccode,
	cdiseasechronic.groupname AS chronicname,
	SUM(CASE WHEN cdiseasechronic.groupcode AND personchronic.datefirstdiag BETWEEN $P!{DATEREPSTART} AND $P!{DATEREPEND} THEN 1 ELSE 0 END ) AS SUMNEW,
	SUM(CASE WHEN cdiseasechronic.groupcode THEN 1 ELSE 0 END ) AS SUMALL

FROM
	personchronic
	INNER JOIN person ON personchronic.pid=person.pid AND personchronic.pcucodeperson=person.pcucodeperson
	INNER JOIN cdisease ON personchronic.chroniccode=cdisease.mapdisease 
	INNER JOIN cdiseasechronic ON cdisease.codechronic =cdiseasechronic.groupcode

WHERE 
	personchronic.datefirstdiag <= '$P!{ENDDATE}'
	$P!{PCUCODE}

GROUP BY
	cdiseasechronic.groupcode

ORDER BY
	cdiseasechronic.groupcode ASC]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pcuname" class="java.lang.String"/>
	<field name="popnum" class="java.lang.Integer"/>
	<field name="chroniccode" class="java.lang.String"/>
	<field name="chronicname" class="java.lang.String"/>
	<field name="SUMNEW" class="java.math.BigDecimal"/>
	<field name="SUMALL" class="java.math.BigDecimal"/>

	<variable name="SUMNEW" class="java.math.BigDecimal" resetType="Group" resetGroup="pcucode" calculation="Sum">
		<variableExpression><![CDATA[$F{SUMNEW}]]></variableExpression>
	</variable>
	<variable name="SUMALL" class="java.math.BigDecimal" resetType="Group" resetGroup="pcucode" calculation="Sum">
		<variableExpression><![CDATA[$F{SUMALL}]]></variableExpression>
	</variable>

