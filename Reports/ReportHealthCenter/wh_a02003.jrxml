		<variableExpression><![CDATA[new Double ($F{AG}.doubleValue()+$F{BG}.doubleValue()+$F{CG}.doubleValue()+$F{DG}.doubleValue()+$F{EG}.doubleValue()+$F{FG}.doubleValue()+$F{GG}.doubleValue()+$F{HG}.doubleValue()+$F{IG}.doubleValue()+$F{JG}.doubleValue()+$F{KG}.doubleValue()+$F{LG}.doubleValue()+$F{MG}.doubleValue()+$F{NG}.doubleValue()+$F{OG}.doubleValue()+$F{PG}.doubleValue()+$F{QG}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="SUML" class="java.lang.Double" resetType="Report" calculation="Nothing">
