	<variable name="SUMA" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new Double ($F{AA}.doubleValue()+$F{BA}.doubleValue()+$F{CA}.doubleValue()+$F{DA}.doubleValue()+$F{EA}.doubleValue()+$F{FA}.doubleValue()+$F{GA}.doubleValue()+$F{HA}.doubleValue()+$F{IA}.doubleValue()+$F{JA}.doubleValue()+$F{KA}.doubleValue()+$F{LA}.doubleValue()+$F{MA}.doubleValue()+$F{NA}.doubleValue()+$F{OA}.doubleValue()+$F{PA}.doubleValue()+$F{QA}.doubleValue())]]></variableExpression>
	</variable>
