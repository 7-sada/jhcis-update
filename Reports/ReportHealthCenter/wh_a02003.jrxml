	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="PCUCODEPERSON" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
	persondeath.pcucodeperson AS pcucode,
	getOffice(persondeath.pcucodeperson) AS pcuname,
	getPopNum(persondeath.pcucodeperson) AS popnum, 
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'A00' AND 'B99' OR persondeath.deadcause  BETWEEN 'A00' AND 'B99')   THEN 1 ELSE 0 END) AS AA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'A00' AND 'B99' OR persondeath.deadcause  BETWEEN 'A00' AND 'B99') AND person.sex='1' THEN 1 ELSE 0 END) AS AG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'A00' AND 'B99' OR persondeath.deadcause  BETWEEN 'A00' AND 'B99') AND person.sex='2' THEN 1 ELSE 0 END) AS AL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'C00' AND 'D49' OR persondeath.deadcause  BETWEEN 'C00' AND 'D49')  THEN 1 ELSE 0 END) AS BA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'C00' AND 'D49' OR persondeath.deadcause  BETWEEN 'C00' AND 'D49') AND person.sex='1' THEN 1 ELSE 0 END) AS BG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'C00' AND 'D49' OR persondeath.deadcause  BETWEEN 'C00' AND 'D49') AND person.sex='2' THEN 1 ELSE 0 END) AS BL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'D50' AND 'D89' OR persondeath.deadcause  BETWEEN 'D50' AND 'D89')  THEN 1 ELSE 0 END) AS CA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'D50' AND 'D89' OR persondeath.deadcause  BETWEEN 'D50' AND 'D89') AND person.sex='1' THEN 1 ELSE 0 END) AS CG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'D50' AND 'D89' OR persondeath.deadcause  BETWEEN 'D50' AND 'D89') AND person.sex='2' THEN 1 ELSE 0 END) AS CL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'E00' AND 'E88' OR persondeath.deadcause  BETWEEN 'E00' AND 'E88')  THEN 1 ELSE 0 END) AS DA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'E00' AND 'E88' OR persondeath.deadcause  BETWEEN 'E00' AND 'E88') AND person.sex='1' THEN 1 ELSE 0 END) AS DG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'E00' AND 'E88' OR persondeath.deadcause  BETWEEN 'E00' AND 'E88') AND person.sex='2' THEN 1 ELSE 0 END) AS DL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'F01' AND 'F99' OR persondeath.deadcause  BETWEEN 'F01' AND 'F99')  THEN 1 ELSE 0 END) AS EA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'F01' AND 'F99' OR persondeath.deadcause  BETWEEN 'F01' AND 'F99') AND person.sex='1' THEN 1 ELSE 0 END) AS EG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'F01' AND 'F99' OR persondeath.deadcause  BETWEEN 'F01' AND 'F99') AND person.sex='2' THEN 1 ELSE 0 END) AS EL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'G00' AND 'G98' OR persondeath.deadcause  BETWEEN 'G00' AND 'G98')  THEN 1 ELSE 0 END) AS FA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'G00' AND 'G98' OR persondeath.deadcause  BETWEEN 'G00' AND 'G98') AND person.sex='1' THEN 1 ELSE 0 END) AS FG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'G00' AND 'G98' OR persondeath.deadcause  BETWEEN 'G00' AND 'G98') AND person.sex='2' THEN 1 ELSE 0 END) AS FL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'I00' AND 'I99' OR persondeath.deadcause  BETWEEN 'I00' AND 'I99')  THEN 1 ELSE 0 END) AS GA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'I00' AND 'I99' OR persondeath.deadcause  BETWEEN 'I00' AND 'I99') AND person.sex='1' THEN 1 ELSE 0 END) AS GG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'I00' AND 'I99' OR persondeath.deadcause  BETWEEN 'I00' AND 'I99') AND person.sex='2' THEN 1 ELSE 0 END) AS GL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'J00' AND 'J98' OR persondeath.deadcause  BETWEEN 'J00' AND 'J98')  THEN 1 ELSE 0 END) AS HA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'J00' AND 'J98' OR persondeath.deadcause  BETWEEN 'J00' AND 'J98') AND person.sex='1' THEN 1 ELSE 0 END) AS HG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'J00' AND 'J98' OR persondeath.deadcause  BETWEEN 'J00' AND 'J98') AND person.sex='2' THEN 1 ELSE 0 END) AS HL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'K00' AND 'K92' OR persondeath.deadcause  BETWEEN 'K00' AND 'K92')  THEN 1 ELSE 0 END) AS IA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'K00' AND 'K92' OR persondeath.deadcause  BETWEEN 'K00' AND 'K92') AND person.sex='1' THEN 1 ELSE 0 END) AS IG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'K00' AND 'K92' OR persondeath.deadcause  BETWEEN 'K00' AND 'K92') AND person.sex='2' THEN 1 ELSE 0 END) AS IL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'L00' AND 'L98' OR persondeath.deadcause  BETWEEN 'L00' AND 'L98')  THEN 1 ELSE 0 END) AS JA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'L00' AND 'L98' OR persondeath.deadcause  BETWEEN 'L00' AND 'L98') AND person.sex='1' THEN 1 ELSE 0 END) AS JG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'L00' AND 'L98' OR persondeath.deadcause  BETWEEN 'L00' AND 'L98') AND person.sex='2' THEN 1 ELSE 0 END) AS JL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'M00' AND 'M99' OR persondeath.deadcause  BETWEEN 'M00' AND 'M99')  THEN 1 ELSE 0 END) AS KA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'M00' AND 'M99' OR persondeath.deadcause  BETWEEN 'M00' AND 'M99') AND person.sex='1' THEN 1 ELSE 0 END) AS KG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'M00' AND 'M99' OR persondeath.deadcause  BETWEEN 'M00' AND 'M99') AND person.sex='2' THEN 1 ELSE 0 END) AS KL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'N00' AND 'N99' OR persondeath.deadcause  BETWEEN 'N00' AND 'N99')  THEN 1 ELSE 0 END) AS LA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'N00' AND 'N99' OR persondeath.deadcause  BETWEEN 'N00' AND 'N99') AND person.sex='1' THEN 1 ELSE 0 END) AS LG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'N00' AND 'N99' OR persondeath.deadcause  BETWEEN 'N00' AND 'N99') AND person.sex='2' THEN 1 ELSE 0 END) AS LL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'P00' AND 'P96' OR persondeath.deadcause  BETWEEN 'P00' AND 'P96')  THEN 1 ELSE 0 END) AS MA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'P00' AND 'P96' OR persondeath.deadcause  BETWEEN 'P00' AND 'P96') AND person.sex='1' THEN 1 ELSE 0 END) AS MG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'P00' AND 'P96' OR persondeath.deadcause  BETWEEN 'P00' AND 'P96') AND person.sex='2' THEN 1 ELSE 0 END) AS ML,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'Q00' AND 'Q99' OR persondeath.deadcause  BETWEEN 'Q00' AND 'Q99')  THEN 1 ELSE 0 END) AS NA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'Q00' AND 'Q99' OR persondeath.deadcause  BETWEEN 'Q00' AND 'Q99') AND person.sex='1' THEN 1 ELSE 0 END) AS NG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'Q00' AND 'Q99' OR persondeath.deadcause  BETWEEN 'Q00' AND 'Q99') AND person.sex='2' THEN 1 ELSE 0 END) AS NL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'R00' AND 'R99' OR persondeath.deadcause  BETWEEN 'R00' AND 'R99')  THEN 1 ELSE 0 END) AS OA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'R00' AND 'R99' OR persondeath.deadcause  BETWEEN 'R00' AND 'R99') AND person.sex='1' THEN 1 ELSE 0 END) AS OG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'R00' AND 'R99' OR persondeath.deadcause  BETWEEN 'R00' AND 'R99') AND person.sex='2' THEN 1 ELSE 0 END) AS OL,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'V01' AND 'Y89' OR persondeath.deadcause  BETWEEN 'V01' AND 'Y89')  THEN 1 ELSE 0 END) AS PA,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'V01' AND 'Y89' OR persondeath.deadcause  BETWEEN 'V01' AND 'Y89') AND person.sex='1' THEN 1 ELSE 0 END) AS PG,
	SUM(CASE WHEN (persondeath.cdeatha BETWEEN 'V01' AND 'Y89' OR persondeath.deadcause  BETWEEN 'V01' AND 'Y89') AND person.sex='2' THEN 1 ELSE 0 END) AS PL,
	SUM(CASE WHEN (persondeath.cdeatha ='' OR persondeath.cdeatha IS NULL OR persondeath.deadcause ='' OR persondeath.deadcause IS NULL)  THEN 1 ELSE 0 END) AS QA,
	SUM(CASE WHEN (persondeath.cdeatha ='' OR persondeath.cdeatha IS NULL OR persondeath.deadcause ='' OR persondeath.deadcause IS NULL) AND person.sex='1' THEN 1 ELSE 0 END) AS QG,
	SUM(CASE WHEN (persondeath.cdeatha ='' OR persondeath.cdeatha IS NULL OR persondeath.deadcause ='' OR persondeath.deadcause IS NULL) AND person.sex='2' THEN 1 ELSE 0 END) AS QL
FROM
	persondeath
	INNER JOIN person ON persondeath.pcucodeperson=person.pcucodeperson AND persondeath.pid=person.pid 
WHERE 
	persondeath.deaddate BETWEEN '$P!{BEGINDATE}' AND '$P!{ENDDATE}'
	$P!{PCUCODE}]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pcuname" class="java.lang.String"/>
	<field name="popnum" class="java.lang.Integer"/>
	<field name="AA" class="java.math.BigDecimal"/>
