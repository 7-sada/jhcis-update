	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15000' " ]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="PCUCODEPERSON" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
	person.pcucodeperson AS pcucode,
	chospital.hosname AS pcuname,
	house.villcode,
	getVill(house.villcode) AS village,
	cdisease504.group504code,
	cdisease504.group504icd10interval,
	cdisease504.group504name,
	COUNT(DISTINCT visit.pid,visit.pcucode, CASE WHEN  visit.visitdate BETWEEN  '$P!{BEGINDATE}' AND '$P!{ENDDATE}' THEN 1 ELSE null END) AS 'PT',
	COUNT(DISTINCT visit.visitno,visit.pcucode, CASE WHEN   visit.visitdate BETWEEN  '$P!{BEGINDATE}' AND '$P!{ENDDATE}' THEN 1 ELSE null END) AS 'VISIT',
	0 AS 'SUM_VISIT',
	0 AS 'POP'  
FROM
	person
	LEFT JOIN visit ON person.pid = visit.pid AND person.pcucodeperson = visit.pcucodeperson
	LEFT JOIN visitdiag ON visit.pcucode = visitdiag.pcucode AND visit.visitno = visitdiag.visitno
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	LEFT JOIN cdisease ON visitdiag.diagcode = cdisease.diseasecode
	LEFT JOIN cdisease504 ON cdisease.code504 = cdisease504.group504code
	INNER JOIN chospital ON chospital.hoscode=person.pcucodeperson
WHERE 
	SUBSTRING(house.villcode,7,2)<>'00'   AND cdisease504.group504code IS NOT NULL 
 	$P!{PCUCODE}
GROUP BY 
	house.villcode,person.pcucodeperson,cdisease504.group504code

UNION
 
SELECT 
	person.pcucodeperson AS pcucode,
	chospital.hosname AS pucname,
	house.villcode,
	getVill(house.villcode) AS village,
	'' AS group504code,
	'' AS group504icd10interval,
	'' AS group504name,
	0 AS 'PT',
	0 as 'VISIT',
	0 AS 'SUM_VISIT',
	COUNT(DISTINCT person.pid,person.pcucodeperson)  AS 'POP'
FROM
	person
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	LEFT JOIN persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
	INNER JOIN chospital ON chospital.hoscode=person.pcucodeperson
WHERE 
	SUBSTRING(house.villcode,7,2)<>'00'  
	AND ((person.datein is null AND person.dischargedate > current_date) or ( person.dischargedate is null  AND person.datein < current_date) or (person.datein is null AND  person.dischargedate is null ))
	AND (person.birth <= current_date) 
	AND (persondeath.pid IS NULL OR persondeath.deaddate >= current_date) 
  	$P!{PCUCODEPERSON}
GROUP BY 
	house.villcode,person.pcucodeperson 

UNION
 
SELECT
	person.pcucodeperson AS pcucode,
	chospital.hosname AS pcuname,
	house.villcode,
	getVill(house.villcode) AS village,
	cdisease504.group504code,
	cdisease504.group504icd10interval,
	cdisease504.group504name,
	0 AS 'PT',
	0 AS 'VISIT',
	COUNT(DISTINCT visit.visitno,visit.pcucode,CASE WHEN visit.visitdate BETWEEN  $P!{BEGINDATE} AND $P!{ENDDATE} AND cdisease504.group504code IS NOT NULL THEN 1 ELSE null END) AS 'SUM_VISIT',
	0 AS 'POP'  
FROM
	person
	LEFT JOIN visit ON person.pid = visit.pid AND person.pcucodeperson = visit.pcucodeperson
	LEFT JOIN visitdiag ON visit.pcucode = visitdiag.pcucode AND visit.visitno = visitdiag.visitno
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	LEFT JOIN cdisease ON visitdiag.diagcode = cdisease.diseasecode
	LEFT JOIN cdisease504 ON cdisease.code504 = cdisease504.group504code
	INNER JOIN chospital ON chospital.hoscode=person.pcucodeperson
WHERE SUBSTRING(house.villcode,7,2)<>'00'
AND visit.visitdate BETWEEN  '$P!{BEGINDATE}' AND '$P!{ENDDATE}' 
 $P!{PCUCODE}
GROUP BY house.villcode,person.pcucodeperson
ORDER BY pcucode,villcode,group504code]]></queryString>

