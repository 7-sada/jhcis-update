	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="BUDGETYEARNO" isForPrompting="true" class="java.lang.String">
		<parameterDescription><![CDATA[ปีงบประมาณ (ค.ศ. 4 หลัก เช่น 2011)]]></parameterDescription>
		<defaultValueExpression ><![CDATA["2011"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
	NS.pcucode AS pcucode,
	getOffice(NS.pcucode) AS pcuname,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdchronic.pcucode = NS.pcucode) AS POPNUM,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.bps < 140
		AND ncdservice.bpd < 90
		AND ncdchronic.pcucode = NS.pcucode) AS No1,

	(SELECT COUNT(*) FROM (
	SELECT 
		DISTINCT ncdchronic.cid,ncdchronic.pcucode AS pcucode
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.bps < 140
		AND ncdservice.bpd < 90
	GROUP BY 
		ncdchronic.cid
	HAVING
		COUNT(*) > 1) NO2  WHERE NO2.pcucode = NS.pcucode) AS No2,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdlab.labstdcode = '3250101' OR ncdlab.labstdcode = '3250201' OR ncdlab.labstdcode = '3250301'
				OR ncdlab.labstdcode = '3250401' OR ncdlab.labstdcode = '3220303' OR ncdlab.labstdcode = '3220201'
				OR ncdlab.labstdcode = '3220501' OR ncdlab.labstdcode = '3210301' OR ncdlab.labstdcode = '3010401'
				OR ncdlab.labstdcode = '3010101' OR ncdlab.labstdcode = '3100101')
		AND ncdchronic.pcucode =  NS.pcucode) AS No3,


	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdchronic.chronic LIKE 'I119%'
		AND ncdchronic.pcucode = NS.pcucode) AS No4,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdchronic.chronic BETWEEN 'I610' AND 'I619' OR ncdchronic.chronic BETWEEN 'G440' AND 'G449')
		AND ncdchronic.pcucode = NS.pcucode) AS No5,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdchronic.chronic = 'I120'
		AND ncdchronic.pcucode = NS.pcucode) AS No6,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.giveupsmoking = '1'
		AND ncdchronic.pcucode = NS.pcucode) AS No7,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '01'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdservice.smokingyr <> '' OR ncdservice.smokingyr <> NULL)
		AND ncdchronic.pcucode = NS.pcucode) AS No7_Total

FROM 
	ncdservice NS
WHERE
	NS.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)

GROUP BY
	NS.pcucode]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pcuname" class="java.lang.String"/>
