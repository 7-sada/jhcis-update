	<queryString><![CDATA[select house.villcode,villname
,(select  count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) 
 	from visitanc anc where visitanc.pcucodeperson=anc.pcucodeperson and visitanc.pid=anc.pid and visitanc.pregno = anc.pregno group by house.villcode) as anctotal
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) )  from visitanc anc1 where visitanc.pid = anc1.pid and visitanc.pcucodeperson = anc1.pcucodeperson 
		and visitanc.pregno = anc1.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15 
		group by house.villcode) as anc15
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc2  where visitanc.pid = anc2.pid and visitanc.pcucodeperson = anc2.pcucodeperson
	 and visitanc.pregno = anc2.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 
	group by house.villcode) as anc1519
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc3  where visitanc.pid = anc3.pid and visitanc.pcucodeperson = anc3.pcucodeperson
	 and visitanc.pregno = anc3.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 20 and 24 
	group by house.villcode) as anc2024
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc4  where visitanc.pid = anc4.pid and visitanc.pcucodeperson = anc4.pcucodeperson
	 and visitanc.pregno = anc4.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 25 and 29 
	group by house.villcode) as anc2529
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc5  where visitanc.pid = anc5.pid and visitanc.pcucodeperson = anc5.pcucodeperson
	 and visitanc.pregno = anc5.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 30 and 34 
	group by house.villcode) as anc3034
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc6  where visitanc.pid = anc6.pid and visitanc.pcucodeperson = anc6.pcucodeperson
	 and visitanc.pregno = anc6.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 35 and 39 
	group by house.villcode) as anc3539
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc7  where visitanc.pid = anc7.pid and visitanc.pcucodeperson = anc7.pcucodeperson
	 and visitanc.pregno = anc7.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 40 and 44 
	group by house.villcode)  as anc4044
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc8  where visitanc.pid = anc8.pid and visitanc.pcucodeperson = anc8.pcucodeperson
	 and visitanc.pregno = anc8.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 
	group by house.villcode)as anc4549
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc9  where visitanc.pid = anc9.pid and visitanc.pcucodeperson = anc9.pcucodeperson
	 and visitanc.pregno = anc9.pregno and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) >=50
	group by house.villcode) as anc50
,(select count(distinct concat(visitanc.pcucodeperson,visitanc.pid,visitanc.pregno) ) from visitanc anc10  where visitanc.pid = anc10.pid 
	and visitanc.pcucodeperson = anc10.pcucodeperson and person.birth is null group by house.villcode) as ancunk
,sum(case  when ancno ='1' and visitanc.pregage between '1' and '27' then 1 
       	when ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp

,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
     	when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp15 
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
    	when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp1519 
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 20 and 24 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 20 and 24 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 20 and 24 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 20 and 24 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp2024
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 25 and 29 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 25 and 29 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 25 and 29 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 25 and 29 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp2529
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 30 and 34 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 30 and 34 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 30 and 34 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 30 and 34 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp3034
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 35 and 39 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 35 and 39 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 35 and 39 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 35 and 39 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp3539
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 40 and 44 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
      	when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 40 and 44 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 40 and 44 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 40 and 44 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp4044
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp4559
,sum(case  when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) >=50 and  ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when  (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) >=50 and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) >=50 and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) >=50 and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccomp50 

,sum(case  when birth is null and ancno ='1' and visitanc.pregage between '1' and '27' then 1 
        when birth is null and  ancno ='2' and visitanc.pregage between '28' and '31' then 1 
	when birth is null and  ancno ='3' and visitanc.pregage between '32' and '35' then 1 
	when birth is null and  ancno ='4' and visitanc.pregage between '36' and '39' then 1 
		else 0 end) as anccompunkage 

,(select count(DISTINCT concat( vmc.pcucodeperson,vmc.pid))  mc    from visitancmothercare  vmc 
   where visitancmothercare.pid = vmc.pid and visitancmothercare.pcucodeperson = vmc.pcucodeperson and visitancmothercare.pregno = vmc.pregno
     group by house.villcode having mc =4 ) as mothccomp
,(select count(DISTINCT concat( vmc1.pcucodeperson,vmc1.pid))  mc1    from visitancmothercare  vmc1 
   where visitancmothercare.pid = vmc1.pid and visitancmothercare.pcucodeperson = vmc1.pcucodeperson and visitancmothercare.pregno = vmc1.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15
     group by house.villcode having mc1 =4 ) as mothccomp15
,(select count(DISTINCT concat( vmc2.pcucodeperson,vmc2.pid))  mc2    from visitancmothercare  vmc2 
   where visitancmothercare.pid = vmc2.pid and visitancmothercare.pcucodeperson = vmc2.pcucodeperson and visitancmothercare.pregno = vmc2.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 
     group by house.villcode having mc2 =4 ) as mothccomp1519
,(select count(DISTINCT concat( vmc3.pcucodeperson,vmc3.pid))  mc3    from visitancmothercare  vmc3 
   where visitancmothercare.pid = vmc3.pid and visitancmothercare.pcucodeperson = vmc3.pcucodeperson and visitancmothercare.pregno = vmc3.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 20 and 24 
