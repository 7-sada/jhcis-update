,(select count(DISTINCT concat( vmc5.pcucodeperson,vmc5.pid))  mc5    from visitancmothercare  vmc5 
   where visitancmothercare.pid = vmc5.pid and visitancmothercare.pcucodeperson = vmc5.pcucodeperson and visitancmothercare.pregno = vmc5.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 30 and 34 
     group by house.villcode having mc5 =4 ) as mothccomp3034
,(select count(DISTINCT concat( vmc6.pcucodeperson,vmc6.pid))  mc6    from visitancmothercare  vmc6 
   where visitancmothercare.pid = vmc6.pid and visitancmothercare.pcucodeperson = vmc6.pcucodeperson and visitancmothercare.pregno = vmc6.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 35 and 39 
     group by house.villcode having mc6 =4 ) as mothccomp3539
,(select count(DISTINCT concat( vmc7.pcucodeperson,vmc7.pid))  mc7    from visitancmothercare  vmc7
   where visitancmothercare.pid = vmc7.pid and visitancmothercare.pcucodeperson = vmc7.pcucodeperson and visitancmothercare.pregno = vmc7.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 40 and 44 
     group by house.villcode having mc7 =4 ) as mothccomp4044
,(select count(DISTINCT concat( vmc8.pcucodeperson,vmc8.pid))  mc8    from visitancmothercare  vmc8
   where visitancmothercare.pid = vmc8.pid and visitancmothercare.pcucodeperson = vmc8.pcucodeperson and visitancmothercare.pregno = vmc8.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 
     group by house.villcode having mc8 =4 ) as mothccomp4549
,(select count(DISTINCT concat( vmc9.pcucodeperson,vmc9.pid))  mc9    from visitancmothercare  vmc9 
   where visitancmothercare.pid = vmc9.pid and visitancmothercare.pcucodeperson = vmc9.pcucodeperson and visitancmothercare.pregno = vmc9.pregno 
                   and (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d'))  >=50 
     group by house.villcode having mc9 =4 ) as mothccomp50
,(select count(DISTINCT concat( vmc10.pcucodeperson,vmc10.pid))  mc10 from visitancmothercare  vmc10 
   where visitancmothercare.pid = vmc10.pid and visitancmothercare.pcucodeperson = vmc10.pcucodeperson and visitancmothercare.pregno = vmc10.pregno 
                   and birth is null     group by house.villcode having mc10 =4 ) as mothccompunkage

,case when  visitanc.pregage <12 then 1 else 0 end ancb12w
,case when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) <15 and visitanc.pregage <12 then 1 else 0 end ancb12w15
,case when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 15 and 19 and visitanc.pregage <12 then 1 else 0 end ancb12w1519
