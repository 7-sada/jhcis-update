,sum(case when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) between 45 and 49 and visitancmothercare.resultcheck != '1' then 1 else 0 end) as mothresultcheck4549
,sum(case when (DATE_FORMAT(current_date,'%Y-%m-%d') - DATE_FORMAT(birth,'%Y-%m-%d')) >=50 and visitancmothercare.resultcheck != '1' then 1 else 0 end) as mothresultcheck50
,sum(case when birth is null and visitancmothercare.resultcheck != '1' then 1 else 0 end) as mothresultcheckunkage

,(select count(concat(bc.pcucodeperson,bc.pid) ) cbc    from visitbabycare bc    where visitbabycare.pid = bc.pid and visitbabycare.pcucodeperson = bc.pcucodeperson    group by house.villcode having cbc=2) as babycare2
,sum(case when  visitbabycare.babyhealth != 1 then 1 else 0 end) as babynohealth

from visitanc left join person on visitanc.pid = person.pid and person.pcucodeperson =  visitanc.pcucodeperson 
   	left join visitancmothercare on visitanc.pid = visitancmothercare.pid and visitanc.pcucodeperson = visitancmothercare.pcucodeperson and visitanc.pregno = visitancmothercare.pregno
	left join visitancdeliver on visitanc.pid = visitancdeliver.pid and visitanc.pcucodeperson = visitancdeliver.pcucodeperson and visitanc.pregno = visitancdeliver.pregno
      	left join visitbabycare on person.pid = visitbabycare.pid and person.pcucodeperson = visitbabycare.pcucodeperson
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
where 1=1 and visitanc.datecheck between '$P!{BEGINDATE}' and '$P!{ENDDATE}'

group by house.villcode
order by house.villcode]]></queryString>

