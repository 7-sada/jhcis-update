	<parameter name="villcode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="mpop05" isForPrompting="false" class="java.math.BigDecimal"/>
	<parameter name="fmpop05" isForPrompting="false" class="java.math.BigDecimal"/>
	<queryString><![CDATA[select 
(select count(distinct pg1.pcucodeperson,pg1.pid) from persongrow pg1 where persongrow.pcucodeperson = pg1.pcucodeperson and person.pid = pg1.pid and person.sex='1' ) as mgrow
,(select count(distinct pg2.pcucodeperson,pg2.pid) from persongrow pg2 where persongrow.pcucodeperson = pg2.pcucodeperson and person.pid = pg2.pid and person.sex='2' ) as fmgrow
,(select count(distinct pg1.pcucodeperson,pg1.pid) from persongrow pg1 where persongrow.pcucodeperson = pg1.pcucodeperson and person.pid = pg1.pid and person.sex='1' ) *100 as mgrowp
,(select count(distinct pg2.pcucodeperson,pg2.pid) from persongrow pg2 where persongrow.pcucodeperson = pg2.pcucodeperson and person.pid = pg2.pid and person.sex='2' ) *100 as fmgrowp
,(select count(distinct pg3.pcucodeperson,pg3.pid) from persongrow pg3 where  person.pcucodeperson = pg3.pcucodeperson and person.pid= pg3.pid and   sex='1' and pg3.agemonthcan= cgrow.growstd  ) as mgrowstd
,(select count(distinct pg4.pcucodeperson,pg4.pid) from persongrow pg4 where  person.pcucodeperson = pg4.pcucodeperson and person.pid= pg4.pid and   sex='2' and pg4.agemonthcan= cgrow.growstd  ) as fmgrowstd
,(select count(distinct pg3.pcucodeperson,pg3.pid) from persongrow pg3 where  person.pcucodeperson = pg3.pcucodeperson and person.pid= pg3.pid and   sex='1' and pg3.agemonthcan= cgrow.growstd  ) *100 as mgrowstdp
,(select count(distinct pg4.pcucodeperson,pg4.pid) from persongrow pg4 where  person.pcucodeperson = pg4.pcucodeperson and person.pid= pg4.pid and   sex='2' and pg4.agemonthcan= cgrow.growstd  ) *100 as  fmgrowstdp


from persongrow left join person on persongrow.pcucodeperson = person.pcucodeperson and persongrow.pid = person.pid
	left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join cgrow on persongrow.growcode = cgrow.growcode
where DATE_FORMAT(current_date,'%Y-%m-%d')  - DATE_FORMAT(birth,'%Y-%m-%d') < 6
      and house.villcode = $P{villcode}
group by house.villcode]]></queryString>

	<field name="mgrow" class="java.lang.Long"/>
	<field name="fmgrow" class="java.lang.Long"/>
	<field name="mgrowp" class="java.lang.Long"/>
	<field name="fmgrowp" class="java.lang.Long"/>
	<field name="mgrowstd" class="java.lang.Long"/>
	<field name="fmgrowstd" class="java.lang.Long"/>
	<field name="mgrowstdp" class="java.lang.Long"/>
	<field name="fmgrowstdp" class="java.lang.Long"/>

