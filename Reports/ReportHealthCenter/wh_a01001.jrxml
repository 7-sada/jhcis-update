	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 
	person.pcucodeperson AS pcucode,
	chospital.hosname AS pcuname,
	house.villcode AS villno,
	getvill(house.villcode) AS village,
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 < 1 AND person.sex = '1' THEN 1 ELSE null END) AS 'AM0000',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 < 1 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0000',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 1 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0001',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 1 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0001',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 2 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0002',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 2 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0002',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 3 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0003',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 3 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0003',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 4 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0004',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 4 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0004',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 5 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0005',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 = 5 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0005',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 6 AND 14 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM0614',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 6 AND 14 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL0614',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 15 AND 20 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM1520',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 15 AND 20 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL1520',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 21 AND 29 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM2129',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 21 AND 29 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL2129',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 30 AND 39 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM3039',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 30 AND 39 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL3039',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 40 AND 49 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM4049',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 40 AND 49 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL4049',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 50 AND 59 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM5059',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 BETWEEN 50 AND 59 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL5059',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 >= 60 AND person.sex = '1' THEN 1 ELSE null END) AS  'AM6000',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN DATE_FORMAT(FROM_DAYS(TO_DAYS(CURRENT_DATE)-TO_DAYS(person.birth)),'%Y')+0 >= 60 AND person.sex = '2' THEN 1 ELSE null END) AS  'AL6000',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN person.birth IS NULL OR person.birth = '0000-00-00' AND person.sex = '1' THEN 1 ELSE null END) AS  'AM',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN person.birth IS NULL OR person.birth = '0000-00-00' AND person.sex = '2' THEN 1 ELSE null END) AS  'AL',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN person.sex = '1' THEN 1 ELSE null END) AS  'M',
	COUNT(DISTINCT person.pid,person.pcucodeperson ,CASE WHEN person.sex = '2' THEN 1 ELSE null END) AS  'L',
	COUNT(DISTINCT person.pid,person.pcucodeperson) AS  'POP' 
FROM
	person
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	LEFT JOIN persondeath ON persondeath.pcucodeperson = person.pcucodeperson AND persondeath.pid=person.pid
	INNER JOIN chospital ON chospital.hoscode=person.pcucodeperson
WHERE 
	SUBSTRING(house.villcode,7,2)<>'00' 
 	AND  (persondeath.pid IS NULL OR persondeath.deaddate >= '$P!{ENDDATE}')
 	AND (person.datein < '$P!{ENDDATE}' OR person.datein IS NULL)
 	AND (person.birth < '$P!{ENDDATE}' OR person.birth IS NULL)
 	$P!{PCUCODE}
GROUP BY 
	person.pcucodeperson  ,house.villcode  
ORDER BY 
	person.pcucodeperson,house.villcode]]></queryString>

