<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="wh_a030011"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15000' " ]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="PCUCODEPERSON" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
	personchronic.pcucodeperson AS pcucode,
	getOffice(personchronic.pcucodeperson) AS pcuname,
	getPopNum(personchronic.pcucodeperson) AS popnum,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'E10%' OR personchronic.chroniccode LIKE 'E11%' OR personchronic.chroniccode LIKE 'E12%' OR personchronic.chroniccode LIKE 'E13%' OR personchronic.chroniccode LIKE 'E14%') AND person.sex='1' THEN 1 ELSE 0 END) AS A1G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'E10%' OR personchronic.chroniccode LIKE 'E11%' OR personchronic.chroniccode LIKE 'E12%' OR personchronic.chroniccode LIKE 'E13%' OR personchronic.chroniccode LIKE 'E14%') AND person.sex='2' THEN 1 ELSE 0 END) AS A1L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'E10%' OR personchronic.chroniccode LIKE 'E11%' OR personchronic.chroniccode LIKE 'E12%' OR personchronic.chroniccode LIKE 'E13%' OR personchronic.chroniccode LIKE 'E14%') THEN 1 ELSE 0 END) AS A1A,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I10%' OR personchronic.chroniccode LIKE 'I11%' OR personchronic.chroniccode LIKE 'I12%' OR personchronic.chroniccode LIKE 'I13%' OR personchronic.chroniccode LIKE 'I14%' OR personchronic.chroniccode LIKE 'I15%') AND person.sex='1' THEN 1 ELSE 0 END) AS A2G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I10%' OR personchronic.chroniccode LIKE 'I11%' OR personchronic.chroniccode LIKE 'I12%' OR personchronic.chroniccode LIKE 'I13%' OR personchronic.chroniccode LIKE 'I14%' OR personchronic.chroniccode LIKE 'I15%') AND person.sex='2' THEN 1 ELSE 0 END) AS A2L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I10%' OR personchronic.chroniccode LIKE 'I11%' OR personchronic.chroniccode LIKE 'I12%' OR personchronic.chroniccode LIKE 'I13%' OR personchronic.chroniccode LIKE 'I14%' OR personchronic.chroniccode LIKE 'I15%') THEN 1 ELSE 0 END) AS A2A,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I6%') AND person.sex='1' THEN 1 ELSE 0 END) AS A3G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I6%') AND person.sex='2' THEN 1 ELSE 0 END) AS A3L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I6%') THEN 1 ELSE 0 END) AS A3A,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I20%' OR personchronic.chroniccode LIKE 'I21%' OR personchronic.chroniccode LIKE 'I22%' OR personchronic.chroniccode LIKE 'I23%' OR personchronic.chroniccode LIKE 'I24%' OR personchronic.chroniccode LIKE 'I25%') AND person.sex='1' THEN 1 ELSE 0 END) AS A4G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I20%' OR personchronic.chroniccode LIKE 'I21%' OR personchronic.chroniccode LIKE 'I22%' OR personchronic.chroniccode LIKE 'I23%' OR personchronic.chroniccode LIKE 'I24%' OR personchronic.chroniccode LIKE 'I25%') AND person.sex='2' THEN 1 ELSE 0 END) AS A4L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'I20%' OR personchronic.chroniccode LIKE 'I21%' OR personchronic.chroniccode LIKE 'I22%' OR personchronic.chroniccode LIKE 'I23%' OR personchronic.chroniccode LIKE 'I24%' OR personchronic.chroniccode LIKE 'I25%') THEN 1 ELSE 0 END) AS A4A,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J43%' OR personchronic.chroniccode LIKE 'J44%') AND person.sex='1' THEN 1 ELSE 0 END) AS A5G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J43%' OR personchronic.chroniccode LIKE 'J44%') AND person.sex='2' THEN 1 ELSE 0 END) AS A5L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J43%' OR personchronic.chroniccode LIKE 'J44%') THEN 1 ELSE 0 END) AS A5A,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J45%' OR personchronic.chroniccode LIKE 'J46%') AND person.sex='1' THEN 1 ELSE 0 END) AS A6G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J45%' OR personchronic.chroniccode LIKE 'J46%') AND person.sex='2' THEN 1 ELSE 0 END) AS A6L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J45%' OR personchronic.chroniccode LIKE 'J46%') THEN 1 ELSE 0 END) AS A6A
	
FROM
	personchronic
	INNER JOIN person ON personchronic.pid=person.pid AND personchronic.pcucodeperson=person.pcucodeperson
WHERE
	personchronic.datefirstdiag BETWEEN '$P!{BEGINDATE}' AND '$P!{ENDDATE}'
	$P!{PCUCODE}]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pcuname" class="java.lang.String"/>
	<field name="popnum" class="java.lang.Integer"/>
	<field name="A1G" class="java.math.BigDecimal"/>
	<field name="A1L" class="java.math.BigDecimal"/>
	<field name="A1A" class="java.math.BigDecimal"/>
	<field name="A2G" class="java.math.BigDecimal"/>
	<field name="A2L" class="java.math.BigDecimal"/>
	<field name="A2A" class="java.math.BigDecimal"/>
	<field name="A3G" class="java.math.BigDecimal"/>
	<field name="A3L" class="java.math.BigDecimal"/>
	<field name="A3A" class="java.math.BigDecimal"/>
	<field name="A4G" class="java.math.BigDecimal"/>
	<field name="A4L" class="java.math.BigDecimal"/>
	<field name="A4A" class="java.math.BigDecimal"/>
	<field name="A5G" class="java.math.BigDecimal"/>
	<field name="A5L" class="java.math.BigDecimal"/>
	<field name="A5A" class="java.math.BigDecimal"/>
	<field name="A6G" class="java.math.BigDecimal"/>
	<field name="A6L" class="java.math.BigDecimal"/>
	<field name="A6A" class="java.math.BigDecimal"/>

	<variable name="SUMA" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new Double ($F{A1A}.doubleValue()+$F{A2A}.doubleValue()+$F{A3A}.doubleValue()+$F{A4A}.doubleValue()+$F{A5A}.doubleValue()+$F{A6A}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="SUMG" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new Double ($F{A1G}.doubleValue()+$F{A2G}.doubleValue()+$F{A3G}.doubleValue()+$F{A4G}.doubleValue()+$F{A5G}.doubleValue()+$F{A6G}.doubleValue())]]></variableExpression>
	</variable>
	<variable name="SUML" class="java.lang.Double" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new Double ($F{A1L}.doubleValue()+$F{A2L}.doubleValue()+$F{A3L}.doubleValue()+$F{A4L}.doubleValue()+$F{A5L}.doubleValue()+$F{A6L}.doubleValue())]]></variableExpression>
	</variable>

