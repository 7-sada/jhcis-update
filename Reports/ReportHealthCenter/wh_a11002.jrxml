	<field name="7fp4y" class="java.math.BigDecimal"/>
	<field name="71epi5ydtp5" class="java.math.BigDecimal"/>
	<field name="72epi5yopv5" class="java.math.BigDecimal"/>
	<field name="8stdc1" class="java.math.BigDecimal"/>
	<field name="81stdc1dtp1" class="java.math.BigDecimal"/>
	<field name="82stdc1dts1" class="java.math.BigDecimal"/>
	<field name="83stdc1dts2" class="java.math.BigDecimal"/>
	<field name="84stdc1opv1" class="java.math.BigDecimal"/>
	<field name="85stdc1opv2" class="java.math.BigDecimal"/>
	<field name="86stdc1bcg" class="java.math.BigDecimal"/>
	<field name="9stdc6" class="java.math.BigDecimal"/>
	<field name="91stdc1dts4" class="java.math.BigDecimal"/>


