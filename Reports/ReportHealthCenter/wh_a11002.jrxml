	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT house.villcode ,villname,visit.pcucode,hosname
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) < 1  then 1 else 0 end) as child1
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) < 1 and visitepi.vaccinecode ='BCG'   then 1 else 0 end) as 11fp1ybcg
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) < 1 and visitepi.vaccinecode ='HBV3'  then 1 else 0 end) as 12fp1yhbv3
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) < 1 and visitepi.vaccinecode ='DTP3'  then 1 else 0 end) as 13fp1ydtp3
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  )< 1 and visitepi.vaccinecode ='OPV3'  then 1 else 0 end) as 14fp1yopv3 
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) < 1 and (visitepi.vaccinecode ='MMR' OR visitepi.vaccinecode ='MEAS' ) then 1 else 0 end) as 15fp1ymmr
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) < 1 and visitepi.vaccinecode ='DHB3'  then 1 else 0 end) as 16fp1ydhb3 
,count(distinct visitancpregnancy.pid,visitancpregnancy.pcucodeperson) as 2anc
,count(distinct visitanc.pid,visitanc.pcucodeperson, case when  (visitanc.ttno35 ='DTANC2' OR visitanc.ttno35='DTANC3' OR visitanc.ttno35 ='DTANC4') then 1 else 0 end) as  21ancdtanc
,count(distinct visitanc.pid,visitanc.pcucodeperson, case when  (visitanc.ttno35 ='tt_in_Scop') then 1 else 0 end) as  22ancttinscop
,count(distinct visitepi.pid,visitepi.pcucodeperson, case when  (visitepi.vaccinecode ='TT2' OR visitepi.vaccinecode ='TT3' OR visitepi.vaccinecode ='TT4') then 1 else 0 end) as  3vactt

,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) = 1  then 1 else 0 end) as 4child1y
,sum(case when (DATE_FORMAT('2010-04-01',"%Y") -  DATE_FORMAT(birth,"%Y")  ) = 1 and visitepi.vaccinecode ='JE1'   then 1 else 0 end) as 41fp1yje1

,sum(case when DATEDIFF(DATE_FORMAT('2010-04-01',"%Y-%m-%d") ,  DATE_FORMAT(birth,"%Y-%m-%d")  ) = 547  then 1 else 0 end) as 5fp18m 
,sum(case when DATEDIFF(DATE_FORMAT('2010-04-01',"%Y-%m-%d") ,  DATE_FORMAT(birth,"%Y-%m-%d")  ) = 547 and visitepi.vaccinecode ='DTP4' then 1 else 0 end) as 51epi18mdtp4 
,sum(case when DATEDIFF(DATE_FORMAT('2010-04-01',"%Y-%m-%d") ,  DATE_FORMAT(birth,"%Y-%m-%d")  ) = 547  and visitepi.vaccinecode ='OPV3'  then 1 else 0 end) as 52epi18mopv3 
,sum(case when DATEDIFF(DATE_FORMAT('2010-04-01',"%Y-%m-%d") ,  DATE_FORMAT(birth,"%Y-%m-%d")  ) = 547  and visitepi.vaccinecode ='JE3'  then 1 else 0 end) as 53epi18mje3

,sum(case when DATEDIFF(DATE_FORMAT('2010-04-01',"%Y-%m-%d") ,  DATE_FORMAT(birth,"%Y-%m-%d")  ) = 912  then 1 else 0 end) as 6epi30m 
,sum(case when DATEDIFF(DATE_FORMAT('2010-04-01',"%Y-%m-%d") ,  DATE_FORMAT(birth,"%Y-%m-%d")  ) = 912  and visitepi.vaccinecode ='JE3'  then 1 else 0 end) as 61epi30mje3

,sum(case when (DATE_FORMAT('2010-04-01',"%Y-%m-%d") - DATE_FORMAT(birth,"%Y-%m-%d")  ) = 4  then 1 else 0 end) as 7fp4y 
,sum(case when (DATE_FORMAT('2010-04-01',"%Y-%m-%d") - DATE_FORMAT(birth,"%Y-%m-%d")  ) = 4 and visitepi.vaccinecode ='DTP5' then 1 else 0 end) as 71epi5ydtp5 
,sum(case when (DATE_FORMAT('2010-04-01',"%Y-%m-%d") - DATE_FORMAT(birth,"%Y-%m-%d")  ) = 4  and visitepi.vaccinecode ='OPV5'  then 1 else 0 end) as 72epi5yopv5 

,sum(case when ps.classeducate='4' then 1 else 0 end) as 8stdc1
,sum(case when ps.classeducate='4'  and visitepi.vaccinecode ='DTP1'   then 1 else 0 end) as 81stdc1dtp1
,sum(case when ps.classeducate='4'  and visitepi.vaccinecode ='DTS1'   then 1 else 0 end) as 82stdc1dts1
,sum(case when ps.classeducate='4'  and visitepi.vaccinecode ='DTS2'   then 1 else 0 end) as 83stdc1dts2
,sum(case when ps.classeducate='4'  and visitepi.vaccinecode ='OPV1'   then 1 else 0 end) as 84stdc1opv1
,sum(case when ps.classeducate='4'  and visitepi.vaccinecode ='OPV2'   then 1 else 0 end) as 85stdc1opv2
,sum(case when ps.classeducate='4'  and visitepi.vaccinecode ='BCG'   then 1 else 0 end) as 86stdc1bcg
,sum(case when ps.classeducate='9' then 1 else 0 end) as 9stdc6
,sum(case when ps.classeducate='9'  and visitepi.vaccinecode ='DTS4'   then 1 else 0 end) as 91stdc1dts4

FROM  person 
           LEFT JOIN visit ON person.pid= visit.pid and person.pcucodeperson = visit.pcucodeperson
           LEFT JOIN visitepi ON person.pid= visitepi.pid and person.pcucodeperson = visitepi.pcucodeperson  
           LEFT JOIN visitanc on person.pid= visitanc.pid and person.pcucodeperson = visitanc.pcucodeperson   
   	   LEFT JOIN visitancdeliver vd ON person.pid = vd.pid and person.pcucodeperson = vd.pcucodeperson
	   LEFT JOIN visitancpregnancy  ON person.pid = visitancpregnancy.pid and person.pcucodeperson = visitancpregnancy.pcucodeperson
           LEFT JOIN personstudent ps ON person.pid= ps.pid and person.pcucodeperson = ps.pcucodeperson
           LEFT JOIN house ON person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	   LEFT JOIN village On house.villcode = village.villcode and house.pcucode = village.pcucode
           LEFT join chospital on visit.pcucode = chospital.hoscode

WHERE 1=1 
     and visit.visitdate between '$P!{BEGINDATE}' and '$P!{ENDDATE}'
     and Right(house.villcode,2)!='00'
     and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
$P!{PCUCODE}
GROUP BY visit.pcucode,house.villcode
ORDER By visit.pcucode,house.villcode]]></queryString>

	<field name="villcode" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="child1" class="java.math.BigDecimal"/>
