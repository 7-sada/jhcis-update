	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-12-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT 
	person.pcucodeperson AS pcucode,
	chospital.hosname AS pcuname,
	house.villcode AS villno,
	getVill(house.villcode) AS village,
	CONCAT(cdisease506.group506code,' : ',cdisease506.group506name) AS name506,
	COUNT(DISTINCT visit.pid,visit.pcucode, CASE WHEN (cdisease.code506  IS NOT NULL ) THEN 1 ELSE null END) AS PT,
	0 AS POP 
FROM 
	person
	LEFT JOIN visit ON person.pid = visit.pid AND person.pcucodeperson = visit.pcucode
	LEFT JOIN visitdiag ON visit.pcucode = visitdiag.pcucode AND visit.visitno = visitdiag.visitno
	LEFT JOIN cdisease ON visitdiag.diagcode = cdisease.diseasecode
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	LEFT JOIN cdisease506 ON cdisease.code506 = cdisease506.group506code 
	INNER JOIN chospital ON chospital.hoscode = person.pcucodeperson
WHERE 
	SUBSTRING(house.villcode,7,2)<>'00' AND cdisease506.group506code IS NOT NULL 
	AND visit.visitdate BETWEEN  '$P!{BEGINDATE}' AND '$P!{ENDDATE}'  
	$P!{PCUCODE} 
GROUP BY 
	cdisease.code506,
	house.villcode,
	person.pcucodeperson

UNION 

SELECT 
	person.pcucodeperson AS pcucode,
  chospital.hosname AS pcuname,
	house.villcode AS villno,
	getVill(house.villcode) AS village,
	'' AS name506,
	0 AS PT,
	COUNT(DISTINCT person.pid,person.pcucodeperson)  AS POP
FROM
	person
	LEFT JOIN house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
	LEFT JOIN persondeath ON person.pid = persondeath.pid AND person.pcucodeperson = persondeath.pcucodeperson
	INNER JOIN chospital ON chospital.hoscode = person.pcucodeperson
WHERE 
	SUBSTRING(house.villcode,7,2)<>'00'  
	AND ((person.datein IS NULL AND person.dischargedate > CURRENT_DATE) OR ( person.dischargedate IS NULL  
	AND person.datein < CURRENT_DATE) OR (person.datein IS NULL AND  person.dischargedate IS NULL))
	AND (person.birth <= CURRENT_DATE) AND (persondeath.pid IS NULL 
	OR persondeath.deaddate >= CURRENT_DATE)
GROUP BY 
	house.villcode,
	person.pcucodeperson

ORDER BY 
	pcucode,
	villno,
	name506]]></queryString>

