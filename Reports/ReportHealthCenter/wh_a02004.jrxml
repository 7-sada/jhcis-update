	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2009-12-31'"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15000' " ]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="PCUCODEPERSON" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND person.pcucodeperson = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
	persondeath.pcucodeperson AS pcucode,
	getOffice(persondeath.pcucodeperson) AS pcuname,
	deadcause,
	diseasenamethai,
	getPopNum(persondeath.pcucodeperson) AS popnum,
	COUNT(*),
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) < 1 ) AND person.sex='1' THEN 1 ELSE 0 END) AS AG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) < 1 ) AND person.sex='2' THEN 1 ELSE 0 END) AS AL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 1 ) AND person.sex='1' THEN 1 ELSE 0 END) AS BG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 1 ) AND person.sex='2' THEN 1 ELSE 0 END) AS BL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 2 ) AND person.sex='1' THEN 1 ELSE 0 END) AS CG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 2 ) AND person.sex='2' THEN 1 ELSE 0 END) AS CL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 3 ) AND person.sex='1' THEN 1 ELSE 0 END) AS DG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 3 ) AND person.sex='2' THEN 1 ELSE 0 END) AS DL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 4 ) AND person.sex='1' THEN 1 ELSE 0 END) AS EG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) = 4 ) AND person.sex='2' THEN 1 ELSE 0 END) AS EL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='1' THEN 1 ELSE 0 END) AS FG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 5 AND 9 ) AND person.sex='2' THEN 1 ELSE 0 END) AS FL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='1' THEN 1 ELSE 0 END) AS GG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 10 AND 14 ) AND person.sex='2' THEN 1 ELSE 0 END) AS GL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='1' THEN 1 ELSE 0 END) AS HG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 15 AND 19 ) AND person.sex='2' THEN 1 ELSE 0 END) AS HL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='1' THEN 1 ELSE 0 END) AS IG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 20 AND 24 ) AND person.sex='2' THEN 1 ELSE 0 END) AS IL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='1' THEN 1 ELSE 0 END) AS JG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 25 AND 29 ) AND person.sex='2' THEN 1 ELSE 0 END) AS JL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='1' THEN 1 ELSE 0 END) AS KG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 30 AND 34 ) AND person.sex='2' THEN 1 ELSE 0 END) AS KL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='1' THEN 1 ELSE 0 END) AS LG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 35 AND 39 ) AND person.sex='2' THEN 1 ELSE 0 END) AS LL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='1' THEN 1 ELSE 0 END) AS MG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 40 AND 44 ) AND person.sex='2' THEN 1 ELSE 0 END) AS ML,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='1' THEN 1 ELSE 0 END) AS NG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 45 AND 49 ) AND person.sex='2' THEN 1 ELSE 0 END) AS NL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='1' THEN 1 ELSE 0 END) AS OG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 50 AND 54 ) AND person.sex='2' THEN 1 ELSE 0 END) AS OL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='1' THEN 1 ELSE 0 END) AS PG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 55 AND 59 ) AND person.sex='2' THEN 1 ELSE 0 END) AS PL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='1' THEN 1 ELSE 0 END) AS QG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 60 AND 64 ) AND person.sex='2' THEN 1 ELSE 0 END) AS QL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='1' THEN 1 ELSE 0 END) AS RG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 65 AND 69 ) AND person.sex='2' THEN 1 ELSE 0 END) AS RL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='1' THEN 1 ELSE 0 END) AS SG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) BETWEEN 70 AND 74 ) AND person.sex='2' THEN 1 ELSE 0 END) AS SL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='1' THEN 1 ELSE 0 END) AS TG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( DATE_FORMAT(persondeath.deaddate,'%Y') - YEAR(person.birth) >= 75 ) AND person.sex='2' THEN 1 ELSE 0 END) AS TL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='1' THEN 1 ELSE 0 END) AS UG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND ( person.birth = '' OR  person.birth IS NULL ) AND person.sex='2' THEN 1 ELSE 0 END) AS UL,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND person.sex='1' THEN 1 ELSE 0 END) AS SUMG,
	SUM(CASE WHEN persondeath.deadcause=deadcause AND person.sex='2' THEN 1 ELSE 0 END) AS SUML
FROM 
	persondeath 
	INNER JOIN person ON persondeath.pcucodeperson=person.pcucodeperson AND persondeath.pid=person.pid
	INNER JOIN cdisease ON persondeath.deadcause=cdisease.diseasecode
WHERE 
	(persondeath.cdeatha <>'' OR persondeath.cdeatha IS NOT NULL )
	AND (persondeath.deaddate <> '' OR persondeath.deaddate IS NOT NULL)
	AND persondeath.deaddate BETWEEN '$P!{BEGINDATE}' AND '$P!{ENDDATE}'
	$P!{PCUCODE}
GROUP BY 
	cdeatha
ORDER BY 
	COUNT(*) DESC  LIMIT 10]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pcuname" class="java.lang.String"/>
	<field name="deadcause" class="java.lang.String"/>
	<field name="diseasenamethai" class="java.lang.String"/>
