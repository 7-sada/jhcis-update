	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2010-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2010-06-29'"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["ชื่อหน่วยบริการ"]]></defaultValueExpression>
	</parameter>
	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15000' " ]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select village.villcode as areaname,visit.pcucode,hosname,villname
,sum(case when (diagcode LIKE 'I20%' OR diagcode LIKE 'I21%' OR diagcode LIKE 'I22%' OR diagcode LIKE 'I23%' OR diagcode LIKE 'I24%' OR diagcode LIKE 'I25%' OR diagcode LIKE 'I26%' OR diagcode LIKE 'I27%' OR diagcode LIKE 'I28%' OR diagcode LIKE 'F29%') then 1 else 0 end) as F20_F529
,sum(case when (diagcode LIKE 'F40%' OR diagcode LIKE 'F41%' OR diagcode LIKE 'F42%' OR diagcode LIKE 'F43%' OR diagcode LIKE 'F44%' OR diagcode LIKE 'F45%' OR diagcode LIKE 'F46%' OR diagcode LIKE 'F47%' OR diagcode LIKE 'F48%' OR diagcode LIKE 'F49%') then 1 else 0 end) as F40_F49
,sum(case when (diagcode LIKE 'F30%' OR diagcode LIKE 'F31%' OR diagcode LIKE 'F32%' OR diagcode LIKE 'F33%' OR diagcode LIKE 'F34%' OR diagcode LIKE 'F35%' OR diagcode LIKE 'F36%' OR diagcode LIKE 'F37%' OR diagcode LIKE 'F38%' OR diagcode LIKE 'F39%') then 1 else 0 end) as F30_F39
,sum(case when (diagcode LIKE 'F70%' OR diagcode LIKE 'F71%' OR diagcode LIKE 'F72%' OR diagcode LIKE 'F73%' OR diagcode LIKE 'F74%' OR diagcode LIKE 'F75%' OR diagcode LIKE 'F76%' OR diagcode LIKE 'F77%' OR diagcode LIKE 'F78%' OR diagcode LIKE 'F79%')  then 1 else 0 end) as F70_F79
,sum(case when (diagcode LIKE 'F40%' OR diagcode LIKE 'F41%' ) then 1 else 0 end) as F40_F41
,sum(case when (diagcode LIKE 'X60%' OR diagcode LIKE 'F61%' OR diagcode LIKE 'F62%' OR diagcode LIKE 'F63%' OR diagcode LIKE 'F64%' OR diagcode LIKE 'F65%' OR diagcode LIKE 'F66%' OR diagcode LIKE 'F67%' OR diagcode LIKE 'F68%' OR diagcode LIKE 'F69%'  
                 OR diagcode LIKE 'F70%' OR diagcode LIKE 'F71%' OR diagcode LIKE 'F72%' OR diagcode LIKE 'F73%' OR diagcode LIKE 'F74%' OR diagcode LIKE 'F75%' OR diagcode LIKE 'F76%' OR diagcode LIKE 'F77%' OR diagcode LIKE 'F78%' OR diagcode LIKE 'F79%' 
                 OR diagcode LIKE 'X80%' OR diagcode LIKE 'X81%' OR diagcode LIKE 'X83%' OR diagcode LIKE 'X83%' OR diagcode LIKE 'X84%' ) then 1 else 0 end) as X60_X84
,sum(case when (diagcode LIKE 'X60%' OR diagcode LIKE 'F61%' OR diagcode LIKE 'F62%' OR diagcode LIKE 'F63%' OR diagcode LIKE 'F64%' OR diagcode LIKE 'F65%' OR diagcode LIKE 'F66%' OR diagcode LIKE 'F67%' OR diagcode LIKE 'F68%' OR diagcode LIKE 'F69%'  
                 OR diagcode LIKE 'F70%' OR diagcode LIKE 'F71%' OR diagcode LIKE 'F72%' OR diagcode LIKE 'F73%' OR diagcode LIKE 'F74%' OR diagcode LIKE 'F75%' OR diagcode LIKE 'F76%' OR diagcode LIKE 'F77%' OR diagcode LIKE 'F78%' OR diagcode LIKE 'F79%' 
                 OR diagcode LIKE 'X80%' OR diagcode LIKE 'X81%' OR diagcode LIKE 'X83%' OR diagcode LIKE 'X83%' OR diagcode LIKE 'X84%' ) then 1 else 0 end ) as dX60_dX84
,sum(case when (diagcode LIKE 'X60%' OR diagcode LIKE 'F61%' OR diagcode LIKE 'F62%' OR diagcode LIKE 'F63%' OR diagcode LIKE 'F64%' OR diagcode LIKE 'F65%' OR diagcode LIKE 'F66%' OR diagcode LIKE 'F67%' OR diagcode LIKE 'F68%' OR diagcode LIKE 'F69%'  
                 OR diagcode LIKE 'F70%' OR diagcode LIKE 'F71%' OR diagcode LIKE 'F72%' OR diagcode LIKE 'F73%' OR diagcode LIKE 'F74%' OR diagcode LIKE 'F75%' OR diagcode LIKE 'F76%' OR diagcode LIKE 'F77%' OR diagcode LIKE 'F78%' OR diagcode LIKE 'F79%' 
                 OR diagcode LIKE 'X80%' OR diagcode LIKE 'X81%' OR diagcode LIKE 'X83%' OR diagcode LIKE 'X83%' OR diagcode LIKE 'X84%'  
 		and concat(person.pid,person.pcucodeperson) not in (select concat(pd.pid,pd.pcucodeperson) 
		from persondeath pd where person.pid = pd.pid and person.pcucodeperson = pd.pcucodeperson 
		and pd.deaddate >= '$P!{ENDDATE}' ) ) then 1 else 0 end ) as ndX60_ndX84
,count(distinct person.pid,person.pcucodeperson , case when (person.datein is null and person.dischargedate > now()) OR (person.datein is null and person.dischargedate is null)
                         and (person.birth <= now()) then 1 else 0 end ) as pop
from person left join visit on person.pid = visit.pid and person.pcucodeperson = visit.pcucodeperson
            left join visitdiag on visit.visitno = visitdiag.visitno and visit.pcucode = visitdiag.pcucode
            left join house on person.hcode = house.hcode and visit.pcucode = house.pcucode
            left join village on house.villcode = village.villcode
            left join persondeath on person.pid = persondeath.pid and person.pcucodeperson = persondeath.pcucodeperson
	    left join chospital on visit.pcucode = chospital.hoscode
where visit.visitdate between '$P!{BEGINDATE}' and '$P!{ENDDATE}'
$P!{PCUCODE}
group by visit.pcucode,village.villcode
order by house.villcode]]></queryString>

