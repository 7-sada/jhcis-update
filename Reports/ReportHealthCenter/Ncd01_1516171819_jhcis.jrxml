	<parameter name="BUDGETYEARNO" isForPrompting="true" class="java.lang.String">
		<parameterDescription><![CDATA[ปีงบประมาณ (ค.ศ. 4 หลัก เช่น 2011)]]></parameterDescription>
		<defaultValueExpression ><![CDATA["2011"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATECONCAT" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[$P{BUDGETYEARNO}+"0930"]]></defaultValueExpression>
	</parameter>
	<parameter name="STARTDATECONCAT" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[((Integer.valueOf($P{BUDGETYEARNO})).intValue()-1)+"1001"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
	NS.pcucode AS pcucode,
	getOffice(NS.pcucode) AS pcuname,
	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN $P!{STARTDATECONCAT} AND $P!{ENDDATECONCAT}
		AND ncdchronic.pcucode = NS.pcucode) AS POPNUM,

(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN $P!{STARTDATECONCAT} AND $P!{ENDDATECONCAT}
		AND (ncdservice.examfoot <> '' OR ncdservice.examfoot <> NULL)
		AND ncdchronic.pcucode = NS.pcucode) AS No15,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN $P!{STARTDATECONCAT} AND $P!{ENDDATECONCAT}
		AND ncdservice.giveupsmoking = '1'
		AND ncdchronic.pcucode = NS.pcucode) AS No16,


	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN $P!{STARTDATECONCAT} AND $P!{ENDDATECONCAT}
		AND (ncdservice.exameyel BETWEEN '2' AND '6' OR ncdservice.exameyer BETWEEN '2' AND '6')
		AND ncdchronic.pcucode = NS.pcucode) AS No17,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN $P!{STARTDATECONCAT} AND $P!{ENDDATECONCAT}
		AND ncdlab.labstdcode = '3411602'
		AND ncdchronic.pcucode = NS.pcucode) AS No18
FROM 
	ncdservice NS
WHERE
	NS.date_serv BETWEEN $P!{STARTDATECONCAT} AND $P!{ENDDATECONCAT}

GROUP BY
	NS.pcucode

ORDER BY
	NS.pcucode]]></queryString>

