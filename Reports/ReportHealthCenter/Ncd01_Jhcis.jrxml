<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="Ncd01_jhcis"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="BUDGETYEARNO" isForPrompting="true" class="java.lang.String">
		<parameterDescription><![CDATA[ปีงบประมาณ (ค.ศ. 4 หลัก เช่น 2011)]]></parameterDescription>
		<defaultValueExpression ><![CDATA["2011"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT 
	NS.pcucode AS pcucode,
	getOffice(NS.pcucode) AS pcuname,
	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdchronic.pcucode = NS.pcucode) AS POPNUM,

	(SELECT 
		COUNT(*)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode='3220303'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.lab_result BETWEEN 70 AND 130
		AND ncdlab.pcucode = NS.pcucode) AS No1,

	(SELECT 
		COUNT(*)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode='3220303'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.pcucode = NS.pcucode) AS No1_Total,
	
	(SELECT 
		COUNT(*)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode='3240101'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.pcucode = NS.pcucode) AS No2,

	(SELECT 
		COUNT(*)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode='3240101'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.lab_result < 7
		AND ncdlab.pcucode = NS.pcucode) AS No3,
	
	(SELECT 
		COUNT(DISTINCT ncdlab.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode ='3250101'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.cid IN (SELECT cid FROM ncdlab WHERE ncdlab.labstdcode ='3250201'	AND ncdlab.pcucode = NS.pcucode)
		AND ncdlab.cid IN (SELECT cid FROM ncdlab WHERE ncdlab.labstdcode ='3250301'	AND ncdlab.pcucode = NS.pcucode)
		AND ncdlab.cid IN (SELECT cid FROM ncdlab WHERE ncdlab.labstdcode ='3250401'	AND ncdlab.pcucode = NS.pcucode)
		AND ncdlab.pcucode = NS.pcucode) AS No5,

	(SELECT 
		COUNT(*)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode='3250401'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.lab_result < 100
		AND ncdlab.pcucode = NS.pcucode) AS No6,

	(SELECT 
		COUNT(*)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdlab.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdlab.labstdcode='3250401'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.pcucode = NS.pcucode) AS No6_Total,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.bps <= 130
		AND ncdservice.bpd <= 80
		AND ncdchronic.pcucode = NS.pcucode) AS No7,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.labstdcode ='3411602'
		AND ncdchronic.pcucode = NS.pcucode) AS No8,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN visitdrug 	ON visitdrug.pcucode = ncdservice.pcucode AND visitdrug.visitno = ncdservice.seq
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
		INNER JOIN cdrug ON visitdrug.drugcode = cdrug.drugcode
		INNER JOIN  _tmpdbregister cdrugstd ON cdrug.tcode = cdrugstd.tcode
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.labstdcode ='3411602'
		AND (cdrug.drugtype='01' OR cdrug.drugtype='01')
		AND cdrugstd.stdcode LIKE '1006190000035211203%'
		AND ncdchronic.pcucode = NS.pcucode) AS No9,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdservice.exameyel <> '' OR ncdservice.exameyel <> NULL)
		AND (ncdservice.exameyer <> '' OR ncdservice.exameyer <> NULL)
		AND ncdchronic.pcucode = NS.pcucode) AS No10,
	
	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN visitdrug 	ON visitdrug.pcucode = ncdservice.pcucode AND visitdrug.visitno = ncdservice.seq
		INNER JOIN cdrug ON visitdrug.drugcode = cdrug.drugcode
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND cdrug.drugtype='02' 
		AND cdrug.drugcode = '8931' 
		AND ncdchronic.pcucode = NS.pcucode) AS No11,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdservice.examfoot <> '' OR ncdservice.examfoot <> NULL)
		AND ncdchronic.pcucode = NS.pcucode) AS No12,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.examfoot ='4'
		AND ncdchronic.pcucode = NS.pcucode) AS No13,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.examfoot ='5'
		AND ncdchronic.pcucode = NS.pcucode) AS No14,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdservice.examfoot <> '' OR ncdservice.examfoot <> NULL)
		AND ncdchronic.pcucode = NS.pcucode) AS No15,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.giveupsmoking = '1'
		AND ncdchronic.pcucode = NS.pcucode) AS No16,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdservice.smokingyr = '1'
		AND ncdchronic.pcucode = NS.pcucode) AS No16_Total,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND (ncdservice.exameyel BETWEEN '2' AND '6' OR ncdservice.exameyer BETWEEN '2' AND '6')
		AND ncdchronic.pcucode = NS.pcucode) AS No17,

	(SELECT 
		COUNT(DISTINCT ncdchronic.cid)
	FROM 
		ncdchronic
		INNER JOIN ncdlab ON ncdlab.cid = ncdchronic.cid
		INNER JOIN ncdservice ON ncdservice.cid = ncdchronic.cid
		INNER JOIN cdisease ON cdisease.mapdisease = ncdchronic.chronic
	WHERE 
		cdisease.codechronic = '10'
		AND ncdservice.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)
		AND ncdlab.labstdcode = '3411602'
		AND ncdchronic.pcucode = NS.pcucode) AS No18
	
FROM 
	ncdservice NS
WHERE
	NS.date_serv BETWEEN CONCAT(($P!{BUDGETYEARNO}*1)-1,1001) AND CONCAT($P!{BUDGETYEARNO},0930)

GROUP BY
	NS.pcucode]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="pcuname" class="java.lang.String"/>
	<field name="POPNUM" class="java.lang.Long"/>
	<field name="No1" class="java.lang.Long"/>
	<field name="No1_Total" class="java.lang.Long"/>
	<field name="No2" class="java.lang.Long"/>
	<field name="No3" class="java.lang.Long"/>
	<field name="No5" class="java.lang.Long"/>
	<field name="No6" class="java.lang.Long"/>
	<field name="No6_Total" class="java.lang.Long"/>
	<field name="No7" class="java.lang.Long"/>
	<field name="No8" class="java.lang.Long"/>
	<field name="No9" class="java.lang.Long"/>
	<field name="No10" class="java.lang.Long"/>
	<field name="No11" class="java.lang.Long"/>
	<field name="No12" class="java.lang.Long"/>
	<field name="No13" class="java.lang.Long"/>
	<field name="No14" class="java.lang.Long"/>
	<field name="No15" class="java.lang.Long"/>
	<field name="No16" class="java.lang.Long"/>
	<field name="No16_Total" class="java.lang.Long"/>
	<field name="No17" class="java.lang.Long"/>
	<field name="No18" class="java.lang.Long"/>

	<variable name="YEARTHAI" class="java.lang.Integer" resetType="None" calculation="Nothing">
		<variableExpression><![CDATA[new Integer((Integer.valueOf($P{BUDGETYEARNO})).intValue()+543)]]></variableExpression>
	</variable>

		<group  name="PCUCODE" isStartNewPage="true" >
			<groupExpression><![CDATA[$F{pcucode}]]></groupExpression>
			<groupHeader>
			<band height="30"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" isBlankWhenNull="true" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="535"
						height="30"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" leftPadding="3" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["สถานที่ให้บริการ : "+$F{pcucode}+" - "+$F{pcuname}]]></textFieldExpression>
				</textField>
			</band>
			</groupHeader>
			<groupFooter>
			<band height="0"  isSplitAllowed="true" >
			</band>
			</groupFooter>
		</group>
		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="60"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="352"
						y="30"
						width="76"
						height="30"
						forecolor="#000000"
						backcolor="#FFFFFF"
						key="txtReportdate-1"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ข้อมูล ณ วันที่]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" pattern="" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="428"
						y="30"
						width="107"
						height="30"
						key="reportDate-1"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[(new java.text.SimpleDateFormat("d MMMMM yyyy",new Locale("th", "TH"))).format(new Date())]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="535"
						height="30"
						key="textField-39"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["ตัวชี้วัด/ข้อมูล โรคเบาหวาน  ตามตัวชี้วัด สปสช. ปีงบประมาณ "+$V{YEARTHAI}.toString()]]></textFieldExpression>
				</textField>
			</band>
		</pageHeader>
		<columnHeader>
			<band height="75"  isSplitAllowed="true" >
				<staticText>
					<reportElement
						x="0"
						y="0"
						width="40"
						height="75"
						key="staticText-1"/>
					<box topBorder="Thin" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isBold="true" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ลำดับ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="385"
						y="25"
						width="75"
						height="50"
						key="staticText-3"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isBold="true" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[จำนวน]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="460"
						y="25"
						width="75"
						height="50"
						key="staticText-4"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isBold="true" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[อัตราต่อจำนวนผูป่วย]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="40"
						y="0"
						width="345"
						height="75"
						key="staticText-5"/>
					<box topBorder="Thin" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="12" isBold="true" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ตัวชี้วัด/ข้อมูล]]></text>
				</staticText>
				<textField isStretchWithOverflow="false" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
