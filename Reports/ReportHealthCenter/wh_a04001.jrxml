	<parameter name="PCUCODE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="OFFICEADDRESS" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["ชื่อหน่วยบริการ"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select  village.villcode,villname,house.pcucode
,sum(case when (person.rightcode ='89'  ) then 1 else 0 end)  as pucs
,sum(case when (person.rightcode between '60' and '88' OR person.rightcode between '90' and '98') then 1 else 0 end)  as pwel
,sum(case when (person.rightcode ='01' OR person.rightcode ='01'  OR person.rightcode ='03'  ) then 1 else 0 end) as psss
,sum(case when (person.rightcode ='25'  ) then 1 else 0 end) as pssi
,sum(case when (person.rightcode ='00' ) then 1 else 0 end) as pofc
,sum(case when (person.rightcode ='04' ) then 1 else 0 end) as psof
,sum(case when (person.rightcode ='24' ) then 1 else 0 end) as psbf
,sum(case when (person.rightcode ='9A' ) then 1 else 0 end) as pfrg
,sum(case when (person.rightcode ='05' ) then 1 else 0 end) as pbfc
,sum(case when (person.rightcode ='51' OR person.rightcode='52' ) then 1 else 0 end) as pnrd
,sum(case when (person.rightcode ='11' ) then 1 else 0 end) as pvof
,sum(case when (person.rightcode ='12' ) then 1 else 0 end) as pvss
,sum(case when (person.rightcode ='13' ) then 1 else 0 end) as pvbf
,sum(case when (person.rightcode ='14' ) then 1 else 0 end) as pvso
,sum(case when (person.rightcode ='19' ) then 1 else 0 end) as pvsb
,sum(case when (person.rightcode ='16' ) then 1 else 0 end) as ppvt
,sum(case when (person.rightcode ='17' ) then 1 else 0 end) as ppss
,sum(case when (person.rightcode ='18' ) then 1 else 0 end) as ppof
,sum(case when (person.rightcode ='08' ) then 1 else 0 end) as ppbf
,sum(case when (person.rightcode ='10' ) then 1 else 0 end) as ppso
,sum(case when (person.rightcode ='20' ) then 1 else 0 end) as pvpt
,sum(case when (person.rightcode ='21' ) then 1 else 0 end) as pvps
,sum(case when (person.rightcode ='22' ) then 1 else 0 end) as pvpo
,sum(case when (person.rightcode ='xx' ) then 1 else 0 end) as punk
,count(distinct person.pid,person.pcucodeperson , case when (person.datein is null and person.dischargedate > now()) OR (person.datein is null and person.dischargedate is null)
                         and (person.birth <= now()) then 1 else 0 end ) as pop

from person left join visit on person.pid= visit.pid and person.pcucodeperson = visit.pcucodeperson
	left join cright on person.rightcode = cright.rightcode
        left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
        left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
        left join persondeath on person.pid = persondeath.pid and person.pcucodeperson = persondeath.pcucodeperson
where 1=1 
$P!{PCUCODE}
and right(village.villcode,2) != '00'
AND visit.visitdate BETWEEN  '$P!{BEGINDATE}' AND '$P!{ENDDATE}'
group by village.villcode
order by visit.pcucode,village.villcode]]></queryString>

