	SUM(CASE WHEN (personchronic.chroniccode LIKE 'E10%' OR personchronic.chroniccode LIKE 'E11%' OR personchronic.chroniccode LIKE 'E12%' OR personchronic.chroniccode LIKE 'E13%' OR personchronic.chroniccode LIKE 'E14%') AND person.sex='2' AND ( DATE_FORMAT(CURDATE(),'%Y') - YEAR(person.birth) BETWEEN 0 AND 4 ) THEN 1 ELSE 0 END) AS A1L,
