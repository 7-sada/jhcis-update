	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J45%' OR personchronic.chroniccode LIKE 'J46%') AND person.sex='2' AND (person.birth = '' OR  person.birth IS NULL ) THEN 1 ELSE 0 END) AS Q6L,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J45%' OR personchronic.chroniccode LIKE 'J46%') AND person.sex='1'  THEN 1 ELSE 0 END) AS SUM6G,
	SUM(CASE WHEN (personchronic.chroniccode LIKE 'J45%' OR personchronic.chroniccode LIKE 'J46%') AND person.sex='2'  THEN 1 ELSE 0 END) AS SUM6L
	
FROM
	personchronic
	INNER JOIN person ON personchronic.pid=person.pid AND personchronic.pcucodeperson=person.pcucodeperson
WHERE
	personchronic.datefirstdiag BETWEEN '$P!{BEGINDATE}' AND '$P!{ENDDATE}'
	$P!{PCUCODE}]]></queryString>

