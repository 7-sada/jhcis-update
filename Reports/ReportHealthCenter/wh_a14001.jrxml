	<parameter name="DATEREPSTART" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DATEREPEND" isForPrompting="false" class="java.lang.String"/>
	<parameter name="BEGINDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select  village.villcode,villname,house.pcucode,hosname
,sum(case when (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 and  ( marystatus='2' or marystatus='7' )  then 1 else 0 end ) as 11femael1544
,sum(case when (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') )) not  between 5475 and 16060 and  ( marystatus='2' or marystatus='7' )  then 1 else 0 end ) as 11femaelother
,sum(case when   marystatus in('2','7' )  then 1 else 0 end ) as 11femaeltotal
,sum(case when women.fptype='1' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 11tab1544y
,sum(case when women.fptype='1' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 11tabother
,sum(women.fptype ='1' ) as 11tab
,sum(case when women.fptype='2' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 12tab1544y
,sum(case when women.fptype='2' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 12tabother
,sum(women.fptype ='2'  ) as 12inj
,sum(case when women.fptype='4' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 13tab1544y
,sum(case when women.fptype='4' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 13tabother
,sum(women.fptype ='4' ) as 13drug
,sum(case when women.fptype='3' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 14tab1544y
,sum(case when women.fptype='3' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 14tabother
,sum(women.fptype ='3' ) as 14drug
,sum(case when women.fptype='5' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 15tab1544y
,sum(case when women.fptype='5' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 15tabother
,sum(women.fptype ='5' ) as 15drug
,sum(case when women.fptype='6' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 16tab1544y
,sum(case when women.fptype='6' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 16tabother
,sum(women.fptype ='6' ) as 16drug
,sum(case when women.fptype='7' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 17tab1544y
,sum(case when women.fptype='7' and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 17tabother
,sum( women.fptype ='7'  ) as 17drug
,sum(case when women.reasonnofp in('1','3','9') and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as 18tab1544y
,sum(case when women.reasonnofp in('1','3','9') and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  not between 5475 and 16060 then 1 else 0 end) as 18tabother
,sum( women.reasonnofp in('1','3','9'))  as 18drug
,sum(case when (person.marystatus='2' or person.marystatus='7') and (DATEDIFF(DATE_FORMAT(current_date(),'%Y-%m-%d') ,DATE_FORMAT(birth,'%Y-%m-%d') ))  between 5475 and 16060 then 1 else 0 end) as female1544
from  person    left join visitfp ON person.pcucodeperson = visitfp.pcucodeperson    AND person.pid = visitfp.pid 
        left join house on person.hcode = house.hcode and person.pcucodeperson = house.pcucode
        left join village on house.villcode = village.villcode and house.pcucode= village.pcucode
        left join women on person.pid = women.pid and person.pcucodeperson = women.pcucodeperson
	left join chospital on visitfp.pcucode = chospital.hoscode
where sex='2'
and visitfp.datefp between '$P!{BEGINDATE}' and '$P!{ENDDATE}' 
group by house.pcucode,house.villcode]]></queryString>

