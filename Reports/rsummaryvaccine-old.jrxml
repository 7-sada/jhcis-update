		<variableExpression><![CDATA[$F{bcg}]]></variableExpression>
	</variable>
	<variable name="SUM_bcg_2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{bcg}]]></variableExpression>
