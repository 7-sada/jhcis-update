<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rsummaryvaccine" pageWidth="595" pageHeight="841" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="47" bottomMargin="46" uuid="bdf95ccb-72c7-408f-8152-abaa92108796">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="357"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2009-12-09"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-07-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  h.hosname,t.subdistname,d.distname,p.provname
     ,vepi.dateepi
     ,count(vepi.vaccinecode) as total
     ,sum(case when vepi.vaccinecode='BCG' then 1 else null end ) as bcg
     ,sum(case when vepi.vaccinecode='BCGS1' then 1 else null end ) as bcgs1
     ,sum(case when vepi.vaccinecode='DTP1' then 1 else null end ) as dtp1
     ,sum(case when vepi.vaccinecode='DTP2' then 1 else null end ) as dtp2
     ,sum(case when vepi.vaccinecode='DTP3' then 1 else null end ) as dtp3
     ,sum(case when vepi.vaccinecode='DTP4' then 1 else null end ) as dtp4
     ,sum(case when vepi.vaccinecode='DTP5' then 1 else null end ) as dtp5
     ,sum(case when vepi.vaccinecode='HBV1' then 1 else null end ) as hbv1
     ,sum(case when vepi.vaccinecode='HBV2' then 1 else null end ) as hbv2
     ,sum(case when vepi.vaccinecode='HBV3' then 1 else null end ) as hbv3
     ,sum(case when vepi.vaccinecode='JE1' then 1 else null end ) as je1
     ,sum(case when vepi.vaccinecode='JE2' then 1 else null end ) as je2
     ,sum(case when vepi.vaccinecode='JE3' then 1 else null end ) as je3
     ,sum(case when vepi.vaccinecode='MEAS' then 1 else null end ) as m
     ,sum(case when (vepi.vaccinecode='MMR1' OR vepi.vaccinecode='MMR') then 1 else null end ) as mmr1
     ,sum(case when vepi.vaccinecode='MMR2' then 1 else null end ) as mmr2
     ,sum(case when vepi.vaccinecode='OPV1' then 1 else null end ) as opv1
     ,sum(case when vepi.vaccinecode='OPV2' then 1 else null end ) as opv2
     ,sum(case when vepi.vaccinecode='OPV3' then 1 else null end ) as opv3
     ,sum(case when vepi.vaccinecode='OPV4' then 1 else null end ) as opv4
     ,sum(case when vepi.vaccinecode='OPV5' then 1 else null end ) as opv5
     ,sum(case when vepi.vaccinecode='OPVs1' then 1 else null end ) as opvs1
     ,sum(case when vepi.vaccinecode='OPVs2' then 1 else null end ) as opvs2
     ,sum(case when vepi.vaccinecode='OPVs3' then 1 else null end ) as opvs3
     ,sum(case when vepi.vaccinecode='OPVC' then 1 else null end ) as opvc
     ,sum(case when (vepi.vaccinecode='TT1' OR vepi.vaccinecode='dT1' ) then 1 else null end ) as tt1
     ,sum(case when (vepi.vaccinecode='TT2' OR vepi.vaccinecode='dT2' ) then 1 else null end ) as tt2
     ,sum(case when (vepi.vaccinecode='TT3' OR vepi.vaccinecode='dT3' ) then 1 else null end ) as tt3
     ,sum(case when (vepi.vaccinecode='TT4' OR vepi.vaccinecode='dT4' ) then 1 else null end ) as tt4
     ,sum(case when (vepi.vaccinecode='TT5' OR vepi.vaccinecode='dT5' ) then 1 else null end ) as tt5
     ,sum(case when (vepi.vaccinecode='dTS1' OR vepi.vaccinecode='DTS1' )then 1 else null end ) as dts1
     ,sum(case when (vepi.vaccinecode='dTS2' OR vepi.vaccinecode='DTS2' ) then 1 else null end ) as dts2
     ,sum(case when (vepi.vaccinecode='dTS3' OR vepi.vaccinecode='DTS3' ) then 1 else null end ) as dts3
     ,sum(case when (vepi.vaccinecode='dTS4' OR vepi.vaccinecode='DTS4' ) then 1 else null end ) as dts4
     ,sum(case when vepi.vaccinecode ='DTANC1' then 1 else null end ) as dtanc1
     ,sum(case when vepi.vaccinecode ='DTANC2' then 1 else null end ) as dtanc2
     ,sum(case when vepi.vaccinecode ='DTANC3' then 1 else null end ) as dtanc3
     ,sum(case when vepi.vaccinecode ='DTANC4' then 1 else null end ) as dtanc4
     ,sum(case when vepi.vaccinecode ='DTANC5' then 1 else null end ) as dtanc5
     ,sum(case when (vepi.vaccinecode='DHB1') then 1 else null end ) as dtphb1
     ,sum(case when (vepi.vaccinecode='DHB2') then 1 else null end ) as dtphb2
     ,sum(case when (vepi.vaccinecode='DHB3') then 1 else null end ) as dtphb3
,sum(case when (vepi.vaccinecode='RB1') then 1 else null end ) as rb1
,sum(case when (vepi.vaccinecode='RB2') then 1 else null end ) as rb2
,sum(case when (vepi.vaccinecode='RB3') then 1 else null end ) as rb3
,sum(case when (vepi.vaccinecode='RB4') then 1 else null end ) as rb4
,sum(case when (vepi.vaccinecode='RB5') then 1 else null end ) as rb5
,sum(case when (vepi.vaccinecode='FLU') then 1 else null end ) as flu
,sum(case when (vepi.vaccinecode='IPV-P') then 1 else null end ) as ipv
from visit v
        left join visitepi vepi  on v.visitno = vepi.visitno and v.pcucode = vepi.pcucode
	left join visitanc on v.visitno = visitanc.visitno and v.pcucode = visitanc.pcucode
        left join chospital h on v.pcucode = h.hoscode
        left join csubdistrict t on t.subdistcode = h.subdistcode and t.distcode = h.distcode and t.provcode = h.provcode
        left join cdistrict d on d.distcode = h.distcode and d.provcode = h.provcode
        left join cprovince p on p.provcode = h.provcode
where v.visitdate between $P{sdate} and $P{edate}
     $P!{pcucode}
     and (v.flagservice <'04' OR v.flagservice is null OR length(trim(v.flagservice))=0 )
group by v.pcucode]]>
	</queryString>
