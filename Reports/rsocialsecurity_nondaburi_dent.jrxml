<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rsocialsecurity_nondaburi_dent"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="20"
		 rightMargin="20"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\JHCIS\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND (`visit`.`visitdate` between  '2010-06-20' AND '2010-06-30')"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ AND visit.pcucode='01856' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="zdiag" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ AND visitdiag.diagcode  NOT REGEXP '^[Zz]' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT (if(chospital.hosname is null,'ไม่ระบุโรงพยาบาลหลัก',chospital.hosname)) AS hosname,
visit.visitno,person.idcard,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname) AS vname ,person.pid,
DATE_FORMAT(`visit`.`visitdate`,'%Y-%m-%d') as vdate,
if(person.sex='1','ช',(if(person.sex='2','ญ',null))) AS sex,getAgeYearNum(person.birth,current_date) AS age,cdisease.diseasename,visitdiag.diagcode,visitdiag.causeill,user.noofoccupation,visit.refertohos,visit.rightno,
if(visit.money2 is null or visit.money2 = 0 or visit.money2 = '' ,visit.money1,visit.money2) money2,
 SUM(distinct if(cdrug.drugtype = '02' AND cdrug.drugcode <>  '897', visitdrug.unit*visitdrug.realprice, null ) ) AS surgery,
 SUM(distinct if(cdrug.drugtype = '06' OR cdrug.drugcode = '897' , visitdrug.unit*visitdrug.realprice, null ) ) AS service,
 SUM(distinct if(cdrug.drugtype = '07' , visitdrug.unit*visitdrug.realprice, null ) ) AS lab,
 SUM(distinct if(cdrug.drugtype = '08' , visitdrug.unit*visitdrug.realprice, null ) ) AS dental,
if(CONCAT("'",visitdiag.pcucode,visitdiag.visitno,"'") is null,"''",CONCAT("'",visitdiag.pcucode,visitdiag.visitno,"'")) person
FROM person INNER JOIN visit ON visit.pid = person.pid AND visit.pcucodeperson=person.pcucodeperson
Left Outer Join ctitle ON person.prename = ctitle.titlecode
 LEFT OUTER JOIN visitdiag ON visit.visitno = visitdiag.visitno AND visit.pcucode=visitdiag.pcucode
 LEFT OUTER JOIN cdisease ON visitdiag.diagcode = cdisease.diseasecode
 LEFT OUTER JOIN visitdrug ON visit.visitno = visitdrug.visitno AND visit.pcucode = visitdrug.pcucode
 LEFT OUTER JOIN cdrug ON visitdrug.drugcode = cdrug.drugcode
 LEFT JOIN chospital ON visit.hosmain = chospital.hoscode
 LEFT JOIN user ON visit.username = user.username AND user.pcucode = visit.pcucode
 Left Outer Join cright ON visit.rightcode = cright.rightcode
WHERE cright.rightgroup ='2' AND visit.flagservice <> '99' 
$P!{pcucode} 
$P!{zdiag} 
$P!{ReportDate}
GROUP BY visit.visitno,visit.visitdate,person.pid,visit.money2,visit.rightno,visit.hosmain,visit.refertohos,user.noofoccupation
ORDER BY visit.hosmain,`visit`.`visitdate`]]></queryString>

