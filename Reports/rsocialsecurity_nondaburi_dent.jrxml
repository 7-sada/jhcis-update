		<variableExpression><![CDATA[new java.lang.Double(($F{money2}==null?0.00:$F{money2}.doubleValue())-(($F{surgery}==null?0.00:$F{surgery}.doubleValue())+($F{service}==null?0.00:$F{service}.doubleValue())+($F{lab}==null?0.00:$F{lab}.doubleValue())+($F{dental}==null?0.00:$F{dental}.doubleValue())))]]></variableExpression>
	</variable>
