<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rexpenseopd_subreport_total2"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="535"
		 pageHeight="802"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="visitno" isForPrompting="false" class="java.lang.Integer"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String"/>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="edate" isForPrompting="false" class="java.lang.String"/>
	<parameter name="rightgroup" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[select
sum(case when (cdr.drugtype ='11') then (dr.unit*dr.realprice) else 0 end) as dservice
,sum(case when (cdr.drugtype ='02' and left(cdr.drugcode,1)='2') then (dr.unit*dr.realprice) else 0 end) as denservice
,sum(case when (cdr.drugtype ='07') then (dr.unit*dr.realprice) else 0 end) as labservice
,sum(case when (cdr.drugtype ='02' and left(cdr.drugcode,1) !='2') then (dr.unit*dr.realprice) else 0 end) as cmservice
,sum(case when (cdr.drugtype ='01' or cdr.drugtype='10') then (dr.unit*dr.realprice) else 0 end) as drugservice
from  visitdrug dr 
      left JOIN cdrug cdr on dr.drugcode = cdr.drugcode
      left join visit v on dr.visitno = v.visitno and dr.pcucode = v.pcucode 
      left join cright on cright.rightcode = v.rightcode
where v.visitdate between $P{sdate} and $P{edate}
      and cright.rightgroup  = $P{rightgroup}
group by v.pcucode]]></queryString>

	<field name="dservice" class="java.math.BigDecimal"/>
	<field name="denservice" class="java.math.BigDecimal"/>
	<field name="labservice" class="java.math.BigDecimal"/>
	<field name="cmservice" class="java.math.BigDecimal"/>
	<field name="drugservice" class="java.math.BigDecimal"/>

		<background>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</background>
		<title>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</title>
		<pageHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</pageHeader>
		<columnHeader>
			<band height="0"  isSplitAllowed="true" >
			</band>
		</columnHeader>
		<detail>
			<band height="18"  isSplitAllowed="true" >
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="0"
						y="0"
						width="39"
						height="15"
						forecolor="#FF0033"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#FF0033" bottomBorder="None" bottomBorderColor="#FF0033"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{dservice}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="39"
						y="0"
						width="38"
						height="15"
						forecolor="#FF0033"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#FF0033" bottomBorder="None" bottomBorderColor="#FF0033"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{denservice}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="77"
						y="0"
						width="43"
						height="15"
						forecolor="#FF0033"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#FF0033" bottomBorder="None" bottomBorderColor="#FF0033"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{labservice}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="120"
						y="0"
						width="43"
						height="15"
						forecolor="#FF0033"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#FF0033" bottomBorder="None" bottomBorderColor="#FF0033"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{cmservice}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="163"
						y="0"
						width="43"
						height="15"
						forecolor="#FF0033"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#FF0033" bottomBorder="None" bottomBorderColor="#FF0033"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{drugservice}]]></textFieldExpression>
				</textField>
				<textField isStretchWithOverflow="false" pattern="#,##0.00" isBlankWhenNull="false" evaluationTime="Now" hyperlinkType="None"  hyperlinkTarget="Self" >
					<reportElement
						x="206"
						y="0"
						width="43"
						height="15"
						forecolor="#FF0033"
						backcolor="#FFFFFF"
						key="textField"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#FF0033" bottomBorder="None" bottomBorderColor="#FF0033"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="Helvetica-Bold" size="8" isBold="true"/>
					</textElement>
				<textFieldExpression   class="java.math.BigDecimal"><![CDATA[$F{dservice}.add( $F{denservice} ).add($F{labservice} ).add( $F{cmservice} ).add( $F{drugservice} )]]></textFieldExpression>
				</textField>
			</band>
		</detail>
		<columnFooter>
			<band height="0"  isSplitAllowed="true" >
