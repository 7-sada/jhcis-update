		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
CONCAT(d.drugcode,' : ',cdrug.drugname) AS drugname,
CONCAT(sum(d.lotamount),' x ',d.packamount) AS amount,
cdrugunitsell.unitsellname,
d.lotno,
DATE_FORMAT(d.dateexpire,'%Y-%m-%d') AS expiredate
FROM
drugrepositorytakendetail d
Inner Join cdrug ON d.drugcode = cdrug.drugcode
Left Outer Join cdrugunitsell ON d.lotunit = cdrugunitsell.unitsellcode
$P!{where}
GROUP BY d.drugcode,d.packamount,d.dateexpire
ORDER BY
d.dateexpire ASC,
d.drugcode,cdrug.drugname]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="amount" class="java.lang.String"/>
	<field name="unitsellname" class="java.lang.String"/>
	<field name="lotno" class="java.lang.String"/>
	<field name="expiredate" class="java.util.Date"/>

