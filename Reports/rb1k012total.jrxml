				</textElement>
				<text><![CDATA[ทะเบียนผู้รับบริการอนามัยมารดา]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="d9a932a6-f140-4cf7-9067-b8dbb576bbad" key="staticText-3" x="0" y="28" width="40" height="21"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
