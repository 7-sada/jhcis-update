	<subDataset name="data1" uuid="8a2a0653-9bd6-48b4-a757-603f2fdc3cd3">
		<parameter name="sdate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select va.dateappoint,
date_format(va.dateappoint,'%d') as dd1,
(case when date_format(va.dateappoint,'%m') = '01' then 'มค.'
when date_format(va.dateappoint,'%m') = '02' then 'กพ.'
when date_format(va.dateappoint,'%m') = '03' then 'มีค.'
when date_format(va.dateappoint,'%m') = '04' then 'เมย.'
when date_format(va.dateappoint,'%m') = '05' then 'พค.'
when date_format(va.dateappoint,'%m') = '06' then 'มิย.'
when date_format(va.dateappoint,'%m') = '07' then 'กค.'
when date_format(va.dateappoint,'%m') = '08' then 'สค.'
when date_format(va.dateappoint,'%m') = '09' then 'กย.'
when date_format(va.dateappoint,'%m') = '10' then 'ตค.'
when date_format(va.dateappoint,'%m') = '11' then 'พย.'
when date_format(va.dateappoint,'%m') = '12' then 'ธค.'
else 'n/a' end) as mm1,
date_format(date_add(va.dateappoint,interval 543 year),'%y') as yy1,
va.vaccinecode,
if(va.vaccinecode = 'COVID19-1', "นัดรับวัคซีนเข็มที่ 1" , "นัดรับวัคซีนเข็มที่ 2"  )
 as reason ,
 va.pid,ct.titlename,p.fname,p.lname,
ifnull(pa.hno,p.hnomoi) as hno,ifnull(ifnull(pa.road,p.roadmoi),'-') as road,
ifnull(pa.mu,p.mumoi) as moo,
ifnull(cd.subdistname,cd1.subdistname) as subdistname,
ifnull(cs.distname,cs1.distname) as distname,
ifnull(cp.provname,cp1.provname) as provname,
ifnull(pa.postcode,p.postcodemoi) as postcode,
ifnull(p.telephoneperson,p.mobile) as tel
from visitepiappoint va
left join personaddresscontact pa on (va.pid = pa.pid and va.pcucodeperson = pa.pcucodeperson)
left join csubdistrict cd on (pa.subdistcode = cd.subdistcode and pa.distcode = cd.distcode
and pa.provcode = cd.provcode)
left join cdistrict cs on (pa.distcode = cs.distcode and pa.provcode = cs.distcode)
left join cprovince cp on (pa.provcode = cp.provcode)
left join person p on (va.pid = p.pid and va.pcucodeperson = p.pcucodeperson)
left join csubdistrict cd1 on (p.subdistcodemoi = cd1.subdistcode and p.distcodemoi = cd1.distcode
and p.provcodemoi = cd1.provcode)
left join cdistrict cs1 on (p.distcodemoi = cs1.distcode and p.provcodemoi = cs1.provcode)
left join cprovince cp1 on (p.provcodemoi = cp1.provcode)
left join ctitle ct on (p.prename = ct.titlecode)
where va.vaccinecode in ('COVID19-1','COVID19-2')
and va.dateappoint >= $P{sdate}
order by va.dateappoint,va.pid,va.vaccinecode]]>
		</queryString>
		<field name="dateappoint" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dd1" class="java.lang.String"/>
		<field name="mm1" class="java.lang.String"/>
		<field name="yy1" class="java.lang.String"/>
		<field name="vaccinecode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="reason" class="java.lang.String">
			<fieldDescription><![CDATA[คำอธิบายสาเหตุที่ไม่สามารถรับผู้ป่วยไว้ได้ฯ สำหรับแฟ้ม REFER_RESULT]]></fieldDescription>
		</field>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="titlename" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="hno" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="road" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="moo" class="java.lang.String">
			<fieldDescription><![CDATA[หมู่บ้าน(..น่าจะตามทะเบียนบ้านของเจ้าของสิทธิ)]]></fieldDescription>
		</field>
		<field name="subdistname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="distname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="provname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="postcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="tel" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="sdate" class="java.lang.String"/>
	<parameter name="showDate1" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select 1 as dum]]>
	</queryString>
	<field name="dum" class="java.lang.Long"/>
