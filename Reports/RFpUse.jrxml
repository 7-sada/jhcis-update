	<parameter name="bFpDate" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[begin date for query]]></parameterDescription>
		<defaultValueExpression ><![CDATA["2006-12-31"]]></defaultValueExpression>
