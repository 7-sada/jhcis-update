	<parameter name="DateFp" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[$P{DateFp}]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" datefp BETWEEN ('2006-01-01') AND ('2006-01-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="eFpDate" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[end date for query]]></parameterDescription>
		<defaultValueExpression ><![CDATA["2006-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
