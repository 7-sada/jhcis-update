	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date"/>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date"/>
	<queryString><![CDATA[SELECT
`cdrug`.`drugname`,
Sum(`visitfp`.`pregtestunit`)
FROM
`visitfp`
Right Outer Join `cdrug` ON (`cdrug`.`drugcode` = `visitfp`.`pregtest` AND $P!{DateFp}  )
WHERE `cdrug`.`drugtype` = '04' AND `cdrug`.`drugtypesub` = '0' 
GROUP BY
`cdrug`.`drugname`]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="Sum(`visitfp`.`pregtestunit`)" class="java.lang.Double"/>

