					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA[$F{diseasenamethai}.isEmpty()?$F{diseasename}:$F{diseasenamethai}+"("+$F{diseasecode}+")"]]></textFieldExpression>
