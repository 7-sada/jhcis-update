	<columnHeader>
		<band height="110" splitType="Stretch">
			<staticText>
				<reportElement uuid="1489941e-2be0-4abe-abc2-a923edb7f69d" key="staticText-1" x="0" y="4" width="320" height="18"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<text><![CDATA[รายงานการติดตามภาวะโภชนาการเด็กนักเรียน : อายุ(เดือน) / นน.(กก.) -->]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="2f830751-a8ee-4b5e-84b5-77299742953d" key="staticText-2" x="0" y="44" width="782" height="16"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  1.โปรแกรมคำนวณภาวะโภชนาการโดยคิดจากการชั่ง นน.(หรือวัดส่วนสูง) ครั้งล่าสุดของแต่ละเทอมฯ (เทอม 1->พค.-ตค. ของปีการศึกษา / เทอม 2 พย.ของปีการศึกษานั้น - เมย. ของปีถัดไป) ]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="cb196523-d4d8-4c47-b64a-78329ffe560c" key="staticText-3" x="0" y="60" width="782" height="16"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  2.หากยอดรวมของจำนวนโภชนาการไม่ปกติ + นน.ปกติ ไม่เท่ากับจำนวนนักเรียนที่ชั่งน้ำหนัก แสดงว่ามีนักเรียนบางคนที่ไม่ระบุวันเกิด(จึงแปรผลโภชนาการไม่ได้ ?)]]></text>
			</staticText>
			<textField isBlankWhenNull="false">
				<reportElement uuid="4243ae66-aea0-40cc-bcb3-6eaa9196464a" key="textField" x="127" y="23" width="655" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$P{offAddress}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="false">
				<reportElement uuid="25dd3b23-d771-4968-9146-eb21b86944a7" key="textField" x="320" y="4" width="462" height="18"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$P{team}+": "+$P{dTerm}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement uuid="3f44f0cd-d39f-4fd6-8952-6a7d92ec92a2" key="staticText-41" x="0" y="23" width="127" height="20"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle"/>
				<text><![CDATA[สถานพยาบาล (สถานีอนามัย)]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="9344454b-bf75-49a2-93f3-4dce411b922a" key="staticText-3" x="1" y="77" width="782" height="16" forecolor="#FF0000"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<text><![CDATA[หมายเหตุ :  1. แสดงการคำนวณโภชนาการเฉพาะนักเรียนชั้นอนุบาล 1 - ม. 3 (เพื่อให้สอดคล้องกับรายงานจำนวนนักเรียน(ที่แสดงจำนวนฯ ถึงชั้น ม. 3))]]></text>
			</staticText>
			<textField>
				<reportElement uuid="b4a04f91-624f-4533-bd86-7adeacdf8cce" x="49" y="93" width="730" height="16"/>
				<textElement/>
				<textFieldExpression><![CDATA["2. "+$P{dTerm}]]></textFieldExpression>
			</textField>
		</band>
