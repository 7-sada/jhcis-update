	<queryString><![CDATA[SELECT
     sum(CASE WHEN ncd_person.sex='1' THEN ncd_person_ncd_screen.age_year ELSE 0 END)  AS mAge,
     sum(CASE WHEN ncd_person.sex='2' THEN ncd_person_ncd_screen.age_year ELSE 0 END)  AS wAge,
     sum(CASE WHEN ncd_person.sex='1' THEN 1 ELSE 0 END) AS m,
     sum(CASE WHEN ncd_person.sex='2' THEN 1 ELSE 0 END) AS w,
     sum(1) AS total
FROM
     `ncd_person_ncd_screen` ncd_person_ncd_screen
     INNER JOIN `ncd_person` ncd_person ON ncd_person_ncd_screen.`pcucode` = ncd_person.`pcucode`
     AND ncd_person_ncd_screen.`pid` = ncd_person.`pid`
WHERE 1=1 $P!{p_sqlOffice} $P!{p_sqlDate}]]></queryString>

	<field name="mAge" class="java.math.BigDecimal"/>
	<field name="wAge" class="java.math.BigDecimal"/>
	<field name="m" class="java.math.BigDecimal"/>
	<field name="w" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>

	<variable name="v_total" class="java.lang.Integer" resetType="Report" calculation="Nothing">
	</variable>
