	<parameter name="visitdate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="zdiag" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select diseasenamethai ,cd.diseasecode
from cdisease cd inner join visitdiag  on  cd.diseasecode = visitdiag.diagcode

where  visitdiag.visitno=$P{visitno} and visitdiag.pcucode=$P{pcucode}
 $P!{zdiag}]]>
	</queryString>
