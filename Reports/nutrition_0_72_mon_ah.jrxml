	<field name="agemonth" class="java.lang.Long"/>
	<field name="countpid" class="java.lang.Long"/>
	<variable name="nutri" class="java.lang.String">
		<variableExpression><![CDATA[SetupNu.UpdateNutritionStateAgeLessThen18AgeHeight($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})]]></variableExpression>
	</variable>
	<variable name="nt" class="java.lang.Integer">
		<variableExpression><![CDATA[SetupNu.nutAH()]]></variableExpression>
	</variable>
	<variable name="weight-lowest" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[( $V{nt}.equals(1)? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="weight-low" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[( $V{nt}.equals(2)? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="weight-normal" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[( $V{nt}.equals(3)? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="weight-over" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[( $V{nt}.equals(4)? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="weight-overest" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
