	<field name="birth" class="java.sql.Date"/>
	<field name="appointdate" class="java.sql.Date"/>
	<field name="diagcode" class="java.lang.String"/>
	<field name="disease" class="java.lang.String"/>
	<field name="age" class="java.lang.String"/>
	<field name="type" class="java.lang.String"/>

