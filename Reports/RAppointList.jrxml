	</parameter>
	<parameter name="AppointDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" WHERE appointdate BETWEEN ('2007-01-01') AND ('2007-12-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     concat(`person`.`prename`,`person`.`fname`,' ',`person`.`lname`)as name,
     house.`hno`,
     village.`villno`,
     village.`villname`,
     person.`birth`,
     visitdiag.`appointdate`,
     visitdiag.`diagcode`,
     concat(`cdisease`.`diseasename`,' (',`cdisease`.`diseasenamethai`,')')as disease,
     concat((year(current_date)-year(`person`.`birth`)-(right(current_date,5)<right(`person`.`birth`,14))),' /  ',(if(month(current_date)<month(`person`.`birth`)&&day(current_date)>=day(`person`.`birth`),(12+month(current_date))-month(`person`.`birth`),(if(month(current_date)<month(`person`.`birth`)&&day(current_date)<day(`person`.`birth`),(11+month(current_date))-month(`person`.`birth`),(if(day(current_date)<day(`person`.`birth`),(month(current_date)-1)-month(`person`.`birth`),month(current_date)-month(`person`.`birth`))))))),' / ',(if(day(current_date)<day(`person`.`birth`),(30+day(current_date))-day(`person`.`birth`),day(current_date)-day(`person`.`birth`))))as age,
CASE
when `visitdiag`.`appointtype`=1 then 'รับยาฯ...'
when `visitdiag`.`appointtype`=2 then 'ติดตามผลการรักษา(Follow Up)...'
else 'ไม่ระบุประเภทการนัด...' end AS `type`
FROM
      village INNER JOIN  house ON village.`villcode` = house.`villcode`
     INNER JOIN person ON house.`hcode` = person.`hcode`
     INNER JOIN `visit` visit ON person.`pid` = visit.`pid`
     INNER JOIN `visitdiag` visitdiag ON visit.`visitno` = visitdiag.`visitno`
     INNER JOIN `cdisease` cdisease ON visitdiag.`diagcode` = cdisease.`diseasecode`
$P!{AppointDate}
ORDER BY visitdiag.`appointdate`]]></queryString>

	<field name="name" class="java.lang.String"/>
