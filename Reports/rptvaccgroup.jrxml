<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptvaccgroup" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="vaccgroup" class="java.lang.String">
		<defaultValueExpression><![CDATA["3"]]></defaultValueExpression>
	</parameter>
	<parameter name="age" class="java.lang.String">
		<defaultValueExpression><![CDATA["10"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String">
		<defaultValueExpression><![CDATA["2011-01-02"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select vacctype,vaccinecode,files18epi,visitepi.dateepi,visitepi.pid,visitepi.pcucodeperson,visitepi.pcucode,visitepi.hosservice
,CONCAT(titlename,fname,' ',lname) as fname,getAgeYearNum(birth,(date_format($P{pdate},'%Y-%m-%d'))) as agey
,cgroupvaccine.groupvaccname
,year($P{pdate}) as yy
from cgroupvaccdetail
	left join cgroupvaccine on cgroupvaccine.groupvacccode = cgroupvaccdetail.groupcode
	left join cdrug on cdrug.files18epi = cgroupvaccdetail.vacccode
	left join visitepi on  visitepi.vaccinecode = cdrug.drugcode
	left join person v on visitepi.pcucodeperson = v.pcucodeperson and visitepi.pid = v.pid
	left join ctitle on v.prename = ctitle.titlecode
where cgroupvaccdetail.groupcode = $P{vaccgroup}
and getAgeYearNum(birth,(date_format($P{pdate},'%Y-%m-%d'))) < $P{age}
and date_format($P{pdate},'%Y-%m-%d') > birth
$P!{pcucode}]]>
	</queryString>
	<field name="vacctype" class="java.lang.String"/>
	<field name="vaccinecode" class="java.lang.String"/>
	<field name="files18epi" class="java.lang.String"/>
	<field name="dateepi" class="java.sql.Date"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="hosservice" class="java.lang.String"/>
	<field name="fname" class="java.lang.String"/>
	<field name="agey" class="java.lang.Integer"/>
	<field name="groupvaccname" class="java.lang.String"/>
	<field name="yy" class="java.lang.Long"/>
