SELECT  "14_1",
visit.visitno,
person.birth,
visit.incup as ivd,
IF( LEFT(visit.rightcode,1) IN('7','8') , 
CASE incup 
WHEN '1' THEN 'u1' 
WHEN '2' THEN 'u0' ELSE 'u1' END,
IF(visit.rightcode IN('00','02','03') , ELT(FIELD(visit.rightcode,'00','02','03'),'a','b','b') , 'n')) AS chk_UC,
DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) as age_years,
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  < 6 , '1',
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  between 6 and 14 , '2', 
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  > 14 , '3', '0')))  as ay , 
0.0 as weight
FROM
cdrug
Inner Join visitdrug ON cdrug.drugcode = visitdrug.drugcode
Inner Join visit ON visitdrug.pcucode = visit.pcucode AND visitdrug.visitno = visit.visitno
Inner Join person ON visit.pcucodeperson = person.pcucodeperson AND visit.pid = person.pid
WHERE 1=1
AND DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) < 15
AND cdrug.drugtype =  '08' AND cdrug.drugtypesub =  '1'
AND ((visit.flagservice = '03') OR (visit.flagservice IS NULL))
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND visit.pcucode = $P{pcucode}

UNION
SELECT  "14_2",
visit.visitno,
person.birth,
visit.incup as ivd,
IF( LEFT(visit.rightcode,1) IN('7','8') , 
CASE incup 
WHEN '1' THEN 'u1' 
WHEN '2' THEN 'u0' ELSE 'u1' END,
IF(visit.rightcode IN('00','02','03') , ELT(FIELD(visit.rightcode,'00','02','03'),'a','b','b') , 'n')) AS chk_UC,
DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) as age_years,
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  < 6 , '1',
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  between 6 and 14 , '2', 
IF(DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d'))  > 14 , '3', '0')))  as ay , 
0.0 as weight
FROM
visitdentalcheck
Inner Join visit ON visitdentalcheck.pcucode = visit.pcucode AND visitdentalcheck.visitno = visit.visitno
Inner Join person ON visit.pcucodeperson = person.pcucodeperson AND visit.pid = person.pid
WHERE 1=1
AND DATE_FORMAT(visitdate,'%Y')-DATE_FORMAT(birth,'%Y') - (DATE_FORMAT(visitdate,'00-%m-%d')<DATE_FORMAT(birth,'00-%m-%d')) < 15
AND ((visit.flagservice = '03') OR (visit.flagservice IS NULL))
AND visit.visitdate BETWEEN $P{startDate} AND $P{endDate}
AND visit.pcucode = $P{pcucode}]]></queryString>

	<field name="idx" class="java.lang.String"/>
	<field name="pc" class="java.lang.Integer"/>
	<field name="birth" class="java.lang.String"/>
	<field name="Ivd" class="java.lang.String"/>
	<field name="chk_UC" class="java.lang.String"/>
	<field name="age_years" class="java.lang.String"/>
	<field name="ay" class="java.lang.String"/>
	<field name="weight" class="java.math.BigDecimal"/>

	<variable name="va3" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "a" )  && $F{ay}.equals( "3" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="va1" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "a" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="va2" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "a" )  && $F{ay}.equals( "2" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vb1" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "b" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu11" class="java.lang.Integer" resetType="Report" incrementType="Report" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u1" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="vu01" class="java.lang.Integer" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[( $F{idx}.equals( "1" ) && $F{chk_UC}.equals( "u0" )  && $F{ay}.equals( "1" )? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
