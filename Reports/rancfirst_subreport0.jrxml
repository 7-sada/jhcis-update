<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rancfirst_subreport0"
		 columnCount="1"
		 printOrder="Horizontal"
		 orientation="Portrait"
		 pageWidth="300"
		 pageHeight="555"
		 columnWidth="300"
		 columnSpacing="0"
		 leftMargin="0"
		 rightMargin="0"
		 topMargin="0"
		 bottomMargin="0"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="visitno" isForPrompting="true" class="java.lang.Integer"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT d.drugname,v.unit
FROM visitdrug v INNER JOIN cdrug d ON d.drugcode = v.drugcode 
WHERE visitno =$P!{visitno} $P!{pcucode}]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="unit" class="java.lang.Integer"/>

