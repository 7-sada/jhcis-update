	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="appointDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND dateappoint BETWEEN ('2009-05-01') AND ('2009-12-31') "]]></defaultValueExpression>
	</parameter>
	<parameter name="bDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2007-01-10'"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[" AND `visithomehealthindividual`.`pcucode` =  '01856' "]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
`person`.`pid`,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname,' : ',ifnull(person.idcard,'-')) as name,
`village`.`villcode`,
`village`.`villno`,
CONCAT(village.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,
ADDDATE(`person`.`birth`, INTERVAL 543 YEAR) as birth,
concat((year(`visithomehealthindividual`.`dateappoint`)-year(`person`.`birth`)-(right(`visithomehealthindividual`.`dateappoint`,5)<right(`person`.`birth`,5))) ,' - ',(
	if (day(`visithomehealthindividual`.`dateappoint`) <day(`person`.`birth`),
		(if (right(`visithomehealthindividual`.`dateappoint`,5)<right(`person`.`birth`,5),(12+ month(`visithomehealthindividual`.`dateappoint`))-month(`person`.`birth`),month(`visithomehealthindividual`.`dateappoint`)-month(`person`.`birth`)))-1 ,
		(if (right(`visithomehealthindividual`.`dateappoint`,5)<right(`person`.`birth`,5),(12+ month(`visithomehealthindividual`.`dateappoint`))-month(`person`.`birth`),month(`visithomehealthindividual`.`dateappoint`)-month(`person`.`birth`))
		)
	) 
)) as age,
`house`.`hno`,
`visithomehealthindividual`.`patientsign`,
`visithomehealthindividual`.`homehealthplan`,
ADDDATE(`visithomehealthindividual`.`dateappoint`, INTERVAL 543 YEAR) as dateappoint
FROM
`village`
Inner Join `house` ON `village`.`villcode` = `house`.`villcode` AND `house`.`pcucode` = `village`.`pcucode`
Inner Join `person` ON `house`.`hcode` = `person`.`hcode` AND `person`.`pcucodeperson` = `house`.`pcucode`
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join `visit` ON `person`.`pid` = `visit`.`pid` AND `visit`.`pcucodeperson` = `person`.`pcucodeperson`
Inner Join `visithomehealthindividual` ON `visit`.`visitno` = `visithomehealthindividual`.`visitno` AND `visithomehealthindividual`.`pcucode` = `visit`.`pcucode`
Left Join `user` ON `visithomehealthindividual`.`user` = `user`.`username` AND `user`.`pcucode` = `visithomehealthindividual`.`pcucode`
WHERE
right(`village`.`villcode`,2) <>  '00' $P!{appointDate} $P!{pcucode}
ORDER BY `village`.`villcode`,`house`.`hno`,`visithomehealthindividual`.`dateappoint`]]></queryString>

