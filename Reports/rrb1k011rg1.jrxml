	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-01-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-03-15"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="pttype" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["c:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="zdiag" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["and Lcase(left(visitdiag.diagcode,1)) !='z'"]]></defaultValueExpression>
	</parameter>
	<parameter name="note1" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     DATE_FORMAT(visit.visitdate, '%Y-%m-%d') AS visit_visitdate
     ,visit.`pcucode` AS visit_pcucode
     ,visit.`visitno` AS visit_visitno
     ,visit.pid AS hn,visit.pcucodeperson
     ,CONVERT(concat(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ) ,person.`fname`,' ', person.`lname`) using utf8)  AS personname
     ,person.`birth` AS person_birth
     ,CONVERT(CONCAT(  DATE_FORMAT(visit.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(visit.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), "ป ",
	CASE SIGN(DATE_FORMAT(visit.visitdate,"%m")-DATE_FORMAT(birth,"%m"))
 	   WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visit.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	   WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(visit.visitdate,"%m") -  (DATE_FORMAT(visit.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	   WHEN 1 THEN(DATE_FORMAT(visit.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(visit.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  "ด ",
	CASE SIGN(DATE_FORMAT(visit.visitdate,"%d") - DATE_FORMAT(birth,"%d"))
 	   WHEN 0 THEN(DATE_FORMAT(visit.visitdate,"%d") - DATE_FORMAT(birth,"%d") )
	   WHEN -1 THEN (DATE_FORMAT(LAST_DAY(visit.visitdate),"%d") + DATE_FORMAT(visit.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))
 	   WHEN 1 THEN (DATE_FORMAT(visit.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(visit.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END , "ว " ) USING utf8) AS age_ymd
      ,CONVERT(case when person.subdistcodemoi is null  then 'นอกเขต'
            when person.hnomoi is null then concat(' ม.',  person.`mumoi` ,' ต.',  csubdistrict.`subdistname` )
            when person.mumoi is null then concat(person.`hnomoi`  ,' ต.',  csubdistrict.`subdistname` )
            else concat(person.`hnomoi` ,' ม.',  person.`mumoi` ,' ต.',  csubdistrict.`subdistname` ) end  USING utf8)  AS address
      ,cright.`rightname` AS cright_rightname
     ,if(person.idcard is null ,"-", person.idcard )as idcard ,visit.symptoms,chospitalm.hosname
     ,visit.`rightno` AS visit_rightno
     ,visit.money1,visit.money2,visit.money3
     ,if(visit.money1 > visit.money2 ,(visit.money1 - visit.money2),(visit.money2 - visit.money1) ) AS diff
     ,CONVERT(concat(chospital.`hosname`,' ต.',csubdistricth.`subdistname`,' อ.',cdistricth.`distname`,' จ.',cprovinceh.`provname`) using utf8 ) AS hostname
FROM `visit` visit
     left join  `person` person ON person.`pcucodeperson` = visit.`pcucodeperson`  AND person.`pid` = visit.`pid`
     left join ctitle on person.prename = ctitle.titlecode
     left JOIN `visitdrug` visitdrug ON visit.`pcucode` = visitdrug.`pcucode`     AND visit.`visitno` = visitdrug.`visitno`
     left JOIN `visitdiag` visitdiag ON visit.`pcucode` = visitdiag.`pcucode`     AND visit.`visitno` = visitdiag.`visitno`
     left JOIN `cright` cright ON visit.`rightcode` = cright.`rightcode`
     left JOIN `chospital` chospital ON visit.`pcucode` = chospital.`hoscode`
     left JOIN `csubdistrict` csubdistrict ON csubdistrict.subdistcode = person.subdistcodemoi and person.distcodemoi = csubdistrict.distcode and person.provcodemoi = csubdistrict.provcode
     left JOIN `cdistrict` cdistrict ON person.distcodemoi = cdistrict.distcode and person.provcodemoi = cdistrict.provcode
     left JOIN `cprovince` cprovince ON person.provcodemoi = cprovince.provcode
     left JOIN `csubdistrict` csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left JOIN `cdistrict` cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
     left JOIN `cprovince` cprovinceh ON chospital.provcode = cprovinceh.provcode
     left JOIN `chospital` chospitalm ON chospitalm.hoscode = visit.hossub
WHERE cright.rightgroup ="1"
     $P!{pcucode}
     and visit.visitdate between $P{sdate} and $P{edate}
     and (visit.flagservice <'04' OR visit.flagservice is null OR length(trim(visit.flagservice))=0 )
     $P!{zdiag}
GROUP BY visit.pcucode,visit.visitno
ORDER BY visit.visitdate]]>
	</queryString>
	<field name="visit_visitdate" class="java.lang.String"/>
	<field name="visit_pcucode" class="java.lang.String"/>
	<field name="visit_visitno" class="java.lang.Integer"/>
	<field name="hn" class="java.lang.Integer"/>
	<field name="pcucodeperson" class="java.lang.String"/>
	<field name="personname" class="java.lang.String"/>
	<field name="person_birth" class="java.sql.Date"/>
	<field name="age_ymd" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
	<field name="cright_rightname" class="java.lang.String"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="symptoms" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="visit_rightno" class="java.lang.String"/>
	<field name="money1" class="java.lang.Double"/>
	<field name="money2" class="java.lang.Double"/>
	<field name="money3" class="java.lang.Double"/>
	<field name="diff" class="java.lang.Double"/>
	<field name="hostname" class="java.lang.String"/>
