	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="header" isForPrompting="false" class="java.lang.String"/>
	<parameter name="pjoin" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT  DISTINCT
vcancer.pid,
vcancer.pcucodeperson,
vcancer.name,
vcancer.hnomoi,
vcancer.villno,
DATE_FORMAT(vcancer.birth,'%Y-%m-%d') birth,
vcancer.age,
DATE_FORMAT(vcancer.visitdate,'%Y-%m-%d') visitdate,
vcancer.cancer,
vcancer.rightname,
vcancer.hosname,
vcancer.visitno,
vcancer.rightno,
vcancer.idcard,
vcancer.villcode
FROM
vcancer
Left Outer Join vcancerbf ON vcancer.pcucodeperson = vcancerbf.pcucodeperson AND vcancer.pid = vcancerbf.pid
Left Outer Join personchronic p1 ON vcancer.pid = p1.pid AND vcancer.pcucodeperson = p1.pcucodeperson
$P!{pjoin}
WHERE
vcancerbf.pid IS NULL AND p2.pid IS NULL 
ORDER BY `hosname` ASC,`villcode` ASC,visitdate ASC,hnomoi ASC]]></queryString>

