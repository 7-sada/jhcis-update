	<subDataset name="New Dataset 1" uuid="c7636604-fcd7-4b2a-99f9-f477522fa9ac">
		<parameter name="pcucode" class="java.lang.String">
			<defaultValueExpression><![CDATA["77511"]]></defaultValueExpression>
		</parameter>
		<parameter name="pid" class="java.lang.String">
			<defaultValueExpression><![CDATA["96"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select A.labcode,A.labname,date_add(A.date1 , interval 543 year) as date1,A.value1,
date_add(A.date2 , interval 543 year) as date2,A.value2,
date_add(A.date3 , interval 543 year) as date3,A.value3
from
(
(select (case when vb.typetesting = 1 then 'DTX'
when vb.typetesting = 2 then 'FBS'
else 'n/a' end) as labcode,'' as labname,
(select v1.visitdate from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '1' order by v1.visitdate desc limit 1) as date1,
(select vb1.sugarnumdigit from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '1' order by v1.visitdate desc limit 1) as value1,
(select v1.visitdate from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '1' order by v1.visitdate desc limit 1 offset 1) as date2,
(select vb1.sugarnumdigit from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '1' order by v1.visitdate desc limit 1 offset 1) as value2,
(select v1.visitdate from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '1' order by v1.visitdate desc limit 1 offset 2) as date3,
(select vb1.sugarnumdigit from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '1' order by v1.visitdate desc limit 1 offset 2) as value3
from visitlabsugarblood vb
join visit v on (vb.pcucode = v.pcucode and vb.visitno = v.visitno)
where v.pid = $P{pid}
and vb.typetesting = '1'
group by v.pid)
union all
(select (case when vb.typetesting = '1' then 'DTX'
when vb.typetesting = '2' then 'FBS'
else 'n/a' end) as labcode, '' as labname,
(select v1.visitdate from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '2' order by v1.visitdate desc limit 1) as date1,
(select vb1.sugarnumdigit from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '2' order by v1.visitdate desc limit 1) as value1,
(select v1.visitdate from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '2' order by v1.visitdate desc limit 1 offset 1) as date2,
(select vb1.sugarnumdigit from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '2' order by v1.visitdate desc limit 1 offset 1) as value2,
(select v1.visitdate from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '2' order by v1.visitdate desc limit 1 offset 2) as date3,
(select vb1.sugarnumdigit from visitlabsugarblood vb1 join visit v1 on (vb1.pcucode = v1.pcucode and vb1.visitno = v1.visitno)
where v1.pid = v.pid and vb1.typetesting = '2' order by v1.visitdate desc limit 1 offset 2) as value3
from visitlabsugarblood vb
join visit v on (vb.pcucode = v.pcucode and vb.visitno = v.visitno)
where v.pid = $P{pid}
and vb.typetesting = '2'
group by v.pid)
union all
(select
v.labcode,cl.labname,
(select datecheck from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1) as date1,
(select labresultdigit from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1) as value1,
(select datecheck from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1 offset 1) as date2,
(select labresultdigit from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1 offset 1) as value2,
