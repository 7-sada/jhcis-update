(select datecheck from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1) as date1,
(select labresultdigit from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1) as value1,
(select datecheck from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1 offset 1) as date2,
(select labresultdigit from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1 offset 1) as value2,
(select datecheck from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1 offset 2) as date3,
(select labresultdigit from visitlabchcyhembmsse where labcode=v.labcode and pid=v.pid and pcucode=v.pcucode order by datecheck desc limit 1 offset 2) as value3
from visitlabchcyhembmsse  as v
join clabchcyhembmsse as cl on (v.labcode = cl.labcode)
where v.pcucodeperson =$P{pcucode}
and v.pid = $P{pid}
and v.labcode = 'HE01020000'
group by v.labcode)
union all
(select p1.labcode,'' as labname,p1.date1,
(case when p1.value1 = '1' then 'Opthalmoscope ปกติ'
when p1.value1 = '2' then 'Fundus camera ปกติ'
when p1.value1 = '3' then 'Opthalmoscope ผิดปกติ'
when p1.value1 = '4' then 'Fundus camera ผิดปกติ'
when p1.value1 = '9' then 'ไม่ตรวจ'
else null end) as value1,
p1.date2,
(case when p1.value2 = '1' then 'Opthalmoscope ปกติ'
when p1.value2 = '2' then 'Fundus camera ปกติ'
when p1.value2 = '3' then 'Opthalmoscope ผิดปกติ'
when p1.value2 = '4' then 'Fundus camera ผิดปกติ'
when p1.value2 = '9' then 'ไม่ตรวจ'
else null end) as value2,
p1.date3,
(case when p1.value3 = '1' then 'Opthalmoscope ปกติ'
when p1.value3 = '2' then 'Fundus camera ปกติ'
when p1.value3 = '3' then 'Opthalmoscope ผิดปกติ'
when p1.value3 = '4' then 'Fundus camera ผิดปกติ'
when p1.value3 = '9' then 'ไม่ตรวจ'
else null end) as value3
from
((select nd.pcucodeperson,nd.pid,'การตรวจตา' as labcode,
(select datefollow from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1) as date1,
(select eyeopthalmoscope from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1) as value1,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 1) as date2,
(select eyeopthalmoscope from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 1) as value2,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 2) as date3,
(select eyeopthalmoscope from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
 and (eyeopthalmoscope not in ('9','X'))
order by datefollow desc limit 1 offset 2) as value3
from ncdservice nd
where nd.pid = $P{pid}
group by nd.pid))p1)
union all
(select B.labcode,'' as labname,B.date1,
(case when B.value1 = '0' then 'ตรวจ-ผลปกติ'
when B.value1 = '1' then 'Low-Risk'
when B.value1 = '2' then 'Moderate-Risk'
when B.value1 = '3' then 'High-Risk'
when B.value1 = '4' then 'Foot-Ulcer'
when B.value1 = '5' then 'Amputation'
else null end) as value1, B.date2,
(case when B.value2 = '0' then 'ตรวจ-ผลปกติ'
when B.value2 = '1' then 'Low-Risk'
when B.value2 = '2' then 'Moderate-Risk'
when B.value2 = '3' then 'High-Risk'
when B.value2 = '4' then 'Foot-Ulcer'
when B.value2 = '5' then 'Amputation'
else null end) as value2, B.date3,
(case when B.value3 = '0' then 'ตรวจ-ผลปกติ'
when B.value3 = '1' then 'Low-Risk'
when B.value3 = '2' then 'Moderate-Risk'
when B.value3 = '3' then 'High-Risk'
when B.value3 = '4' then 'Foot-Ulcer'
when B.value3 = '5' then 'Amputation'
else null end) as value3
from(
(select nd.pcucodeperson,nd.pid,'การตรวจเท้า' as labcode,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1) as date1,
(select examfoot from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1) as value1,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 1) as date2,
(select examfoot from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 1) as value2,
(select datefollow from ncdservice
where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 2) as date3,
(select examfoot from ncdservice where pcucodeperson = nd.pcucodeperson and pid = nd.pid
order by datefollow desc limit 1 offset 2) as value3
from ncdservice nd
where nd.pid = $P{pid}
group by nd.pid))B)
)A
group by A.labcode]]>
		</queryString>
		<field name="labcode" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="labname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="date1" class="java.sql.Date"/>
		<field name="value1" class="java.lang.String"/>
		<field name="date2" class="java.sql.Date"/>
		<field name="value2" class="java.lang.String"/>
		<field name="date3" class="java.sql.Date"/>
		<field name="value3" class="java.lang.String"/>
	</subDataset>
	<parameter name="pcucode" class="java.lang.String">
		<defaultValueExpression><![CDATA["77511"]]></defaultValueExpression>
	</parameter>
	<parameter name="pid" class="java.lang.String">
		<defaultValueExpression><![CDATA["96"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select h.hosname,concat(t.titlename,' ',p.fname,' ',p.lname) as name1
from visit v
join chospital h on (v.pcucode = h.hoscode)
join person p on (v.pid = p.pid and v.pcucodeperson = p.pcucodeperson)
left join ctitle t on (p.prename = t.titlecode)
where p.pid = $P{pid}
and h.hoscode = $P{pcucode}
limit 1]]>
	</queryString>
	<field name="hosname" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="name1" class="java.lang.String"/>
