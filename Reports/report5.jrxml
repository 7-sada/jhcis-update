	<subDataset name="New Dataset 1" uuid="af796ff2-0cd5-474e-9f9d-149ac02570c6">
		<queryString language="SQL">
			<![CDATA[SELECT
     person.`fname` AS person_fname,
     person.`lname` AS person_lname,
     person.`birth` AS person_birth,
     person.`sex` AS person_sex,
     person.`idcard` AS person_idcard,
     person.`prename` AS person_prename,
     person.`pid` AS person_pid
FROM
     `person` person]]>
		</queryString>
