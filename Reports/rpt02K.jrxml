	<field name="dxtype01" class="java.lang.String"/>
	<field name="dxtype02" class="java.lang.String"/>
	<field name="dxtype05" class="java.lang.String"/>
	<field name="operate" class="java.lang.String"/>
	<field name="dr" class="java.lang.String"/>
	<field name="licenseno" class="java.lang.String"/>
	<field name="realdrug" class="java.math.BigDecimal"/>
	<field name="lab" class="java.math.BigDecimal"/>
	<field name="totaloperate" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
	<field name="cdate" class="java.sql.Date"/>
	<field name="hosname" class="java.lang.String"/>


