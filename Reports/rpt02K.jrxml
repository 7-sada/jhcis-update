	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["AND visit.visitdate between '2011-01-01' and '2011-03-30' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT DATE_FORMAT(visitdate,'%Y-%m-%d')as visitdate,visit.pid as HN
,CONCAT(substring(person.idcard,1,1),"-", substring(person.idcard,2,4),"-",substring(person.idcard,6,5),"-" ,substring(person.idcard,11,2),"-",substring(person.idcard,13,1)  )  as idcard

, ifnull(titlename,ifnull(person.prename,'ไม่ระบุ') ) prename,person.fname,person.lname,visit.visitno,visit.pcucode
,case when visitdiag.dxtype='01' then cdisease.diseasecode else "-" end as dxtype01
,case when visitdiag.dxtype='02' then cdisease.diseasecode else "-" end as dxtype02
,case when visitdiag.dxtype='05' then cdisease.diseasecode else "-" end as dxtype05

,case when visitdrug.drugcode in('1019999','1549999','1639999','1679999','1769999','1789999','1859999','1869999','2019999','2259999','2339999','2389999'
            ,'2449999','2459999','2509999','2829999','2899999','3019999','3020401','3029999','4019999','4419999','4559999','4819999'
            ,'5019999','5039999','5169999','5179999','5199999','5309999','5319999','5329999','6019999','6029999','6039999','6049999','6059999','6069999'
            ,'6499999','6549999','6819999','6909999','6949999','6979999','6989999','7029999','7049999','7279999','7289999','7989999','7999999','8149999'
            ,'8249999','8339999','8379999','8418888','8779999','8789999','9999999')  then visitdrug.drugcode else "-" end as operate
,case when u.officertype='01' then u.fullname else "-" end dr
,case when u.officertype='01' then u.licenseno else "-" end licenseno 
,sum(case when (cdrug.drugtype='01' or cdrug.drugtype='10' or cdrug.drugtype='03')  then (visitdrug.unit * visitdrug.realprice ) else 0 end ) as realdrug
,sum(case when (cdrug.drugtype='07')  then (visitdrug.unit * visitdrug.realprice ) else 0 end ) as lab
,sum(case when ( cdrug.drugtype ='02'  )  then (visitdrug.unit * visitdrug.realprice ) else 0 end ) as totaloperate
,sum(visitdrug.unit * visitdrug.realprice ) as total
,curdate() cdate
,hosname
FROM visit left join person on visit.pid = person.pid and visit.pcucodeperson = person.pcucodeperson
	left join ctitle on person.prename = ctitle.titlecode
  	left join visitdiag on visit.visitno = visitdiag.visitno and visit.pcucode = visitdiag.pcucode
       left join cdisease on visitdiag.diagcode = cdisease.diseasecode
	left join visitdrug on visit.visitno = visitdrug.visitno  and visit.pcucode = visitdrug.pcucode
	left join cdrug on visitdrug.drugcode = cdrug.drugcode
	left join  `user`  u on visit.username = u.username
	left join chospital on visit.pcucode = chospital.hoscode
WHERE 1=1 $P!{ReportDate} $P!{pcucode}
GROUP BY visit.pcucode,visit.visitno,visit.pcucodeperson
ORDER BY visit.pcucode,visit.visitdate]]></queryString>

	<field name="visitdate" class="java.lang.String"/>
	<field name="HN" class="java.lang.Integer"/>
	<field name="idcard" class="java.lang.String"/>
	<field name="prename" class="java.lang.String"/>
