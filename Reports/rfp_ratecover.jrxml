	<queryString><![CDATA[SELECT
     1,
     vsfemale.`villcode`,
     vsfemale.`villno`,
     vsfemale.`villname`,
     vsfemale.`countperson`,
     vsfp.`tab`,
     vsfp.`inj`,
     vsfp.`inte`,
     vsfp.`loops`,
     vsfp.`condom`,
     vsfp.`fpmale`,
     vsfp.`fpfemale`,
     vsfemale.`subdistcode`,
     vsfemale.`subdistname`
FROM
     `vsfemale` vsfemale INNER JOIN `vsfp` vsfp ON vsfemale.`villcode` = vsfp.`villcode`
ORDER BY
     villcode ASC]]></queryString>

