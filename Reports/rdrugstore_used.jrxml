<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rdrugstore_used"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="595"
		 pageHeight="842"
		 columnWidth="535"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateRepEnd" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="where" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[WHERE cdrugremain.pcucode =  '02332' AND cdrug.drugflag = '1' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
CASE
 WHEN cdrug.drugtype =  '01'  THEN 'ยาฯ' 
 WHEN cdrug.drugtype =  '02'   THEN 'หัตถการ' 
 WHEN cdrug.drugtype =  '03'   THEN 'วัสดุการแพทย์' 
 WHEN cdrug.drugtype =  '04'  THEN 'เวชภัณฑ์คุมกำเนิด' 
 WHEN cdrug.drugtype =  '05'   THEN 'วัคซีน' 
 WHEN cdrug.drugtype =  '06'   THEN 'ค่าบริการฯ' 
 WHEN cdrug.drugtype =  '07'   THEN 'ค่าตรวจทางห้องปฏิบัติการฯ' 
 WHEN cdrug.drugtype =  '08'  THEN 'ทันตกรรม' 
 WHEN cdrug.drugtype =  '10'  THEN 'ยาสมุนไพร'
 ELSE 'ไม่ระบุประเภทฯ' 
END AS drugtype,
cdrug.drugcode,
CASE
 WHEN cdrug.drugcode IN ('DT','DT1','DT2','DTS1','DTS2','DTS3','DTS4','DTANC1','DTANC2','DTANC3','DTANC4','DTANC5') OR cdrug.drugcode =  'V120' THEN 'DT' 
 WHEN cdrug.drugcode IN ('DTP','DTP1','DTP2','DTP3','DTP4','DTP5') OR cdrug.drugcode =  'V121' THEN 'DTP'  
 WHEN cdrug.drugcode IN ('HBV','HBV1','HBV2','HBV3') OR cdrug.drugcode =  'V122' THEN 'HB'  
 WHEN cdrug.drugcode IN ('JE','JE1','JE2','JE3') OR cdrug.drugcode =  'V123' THEN 'JE'  
 WHEN cdrug.drugcode IN ('MMR','MMR2') OR cdrug.drugcode =  'V124' THEN 'MMR'  
 WHEN cdrug.drugcode IN ('OPV','OPV1','OPV2','OPV3','OPV4','OPV5','OPVs1','OPVs2','OPVs3','OPVC') OR cdrug.drugcode =  'V125' THEN 'OPV'  
 WHEN cdrug.drugcode IN ('TT','TT1','TT2','TT3','TT4','TT5') OR cdrug.drugcode =  'V126' THEN 'TT'  
 WHEN cdrug.drugcode IN ('DHB','DHB1','DHB2','DHB3') OR cdrug.drugcode =  'V127' THEN 'DTP+HB'  
 WHEN cdrug.drugcode IN ('MEAS') OR cdrug.drugcode =  'V128' THEN 'MEAS' 
 WHEN cdrug.drugcode IN ('RB','RB1','RB2','RB3','RB4','RB5') THEN 'RB'
 ELSE cdrug.drugname END AS drug,
cdrug.unitsell unitusage,
CASE WHEN vdrugusedbf.dserv is null and cdrugremain.remain is null then 0
WHEN vdrugusedbf.dserv is null and cdrugremain.remain is not null then cdrugremain.remain
WHEN vdrugusedbf.dserv is not null and cdrugremain.remain is null then 0-vdrugusedbf.dserv
WHEN vdrugusedbf.dserv is not null and cdrugremain.remain is not null then cdrugremain.remain-vdrugusedbf.dserv
ELSE 0
END AS remain,
if(vdrugcostmxdate.dcost is null,if(cdrug.costcaldrugstore is null,cdrug.cost,cdrug.costcaldrugstore),vdrugcostmxdate.dcost) as costrem,
if(vdrugstockall.dr1 is null,0,Sum(vdrugstockall.dr1)) as dr1,
if(vdrugstockall.dr2 is null,0,Sum(vdrugstockall.dr2))as dr2,
if(vdrugstockall.dr3 is null,0,Sum(vdrugstockall.dr3)) as dr3,
if(vdrugstockall.drcost is null,0,Sum(vdrugstockall.drcost)) as drcost,
if(vdrugstockall.dserv is null,0,Sum(vdrugstockall.dserv)) as dsrev,
if(vdrugstockall.dl1 is null,0,Sum(vdrugstockall.dl1)) as dl1,
if(vdrugstockall.dl2 is null,0,Sum(vdrugstockall.dl2)) as dl2,
if(vdrugstockall.dl3 is null,0,Sum(vdrugstockall.dl3)) as dl3,
if(vdrugstockall.dl9 is null,0,Sum(vdrugstockall.dl9)) as dl9,
if(vdrugstockall.ducost is null,0,Sum(vdrugstockall.ducost)) as ducost,
if(vdrugreceivebf.amount is null,0,vdrugreceivebf.amount) drbf,
if(vdrugreceivebf.drcost is null,0,vdrugreceivebf.drcost)  drcostbf
FROM
cdrug
Inner Join cdrugremain ON cdrug.drugcode = cdrugremain.drugcode
Inner Join vdrugusedbf ON cdrugremain.drugcode = vdrugusedbf.drugcode
Inner Join vdrugstockall ON cdrugremain.drugcode = vdrugstockall.cdrug
Inner Join vdrugcostmxdate ON vdrugcostmxdate.cdrug = vdrugstockall.cdrug
Inner Join vdrugreceivebf ON vdrugreceivebf.cdrug = cdrug.drugcode
$P!{where} 
GROUP BY
drug
ORDER BY drugtype,drugname]]></queryString>

