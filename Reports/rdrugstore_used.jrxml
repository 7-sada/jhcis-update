	</variable>
	<variable name="sum_ducost" class="java.lang.Double" resetType="Group" resetGroup="drugtype" calculation="Sum">
		<variableExpression><![CDATA[$F{ducost}]]></variableExpression>
	</variable>
	<variable name="sum_all_drcost" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{drcost}]]></variableExpression>
	</variable>
	<variable name="sum_all_ducost" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{ducost}]]></variableExpression>
	</variable>
	<variable name="sum_remain" class="java.lang.Integer" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[new Integer($F{remain}.intValue()+($F{dr1}.intValue()+$F{dr2}.intValue()+$F{dr3}.intValue())-($F{dsrev}.intValue()+$F{dl1}.intValue()+$F{dl2}.intValue()+$F{dl3}.intValue()+$F{dl9}.intValue()))]]></variableExpression>
	</variable>
	<variable name="sum_cost_remain" class="java.lang.Double" resetType="None" calculation="Nothing">
		<variableExpression><![CDATA[new java.lang.Double( ((($F{remain}.doubleValue()+$F{drbf}.doubleValue())*$F{costrem}.doubleValue())+$F{drcost}.doubleValue()) -($F{ducost}.doubleValue()) )]]></variableExpression>
	</variable>
	<variable name="sum_cost_remain_1" class="java.lang.Double" resetType="Group" resetGroup="drugtype" calculation="Sum">
		<variableExpression><![CDATA[$V{sum_cost_remain}]]></variableExpression>
	</variable>
	<variable name="sum_cost_remain_2" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{sum_cost_remain}]]></variableExpression>
	</variable>

