	<field name="agemonth" class="java.lang.Long"/>
	<field name="countpid" class="java.lang.Long"/>
	<variable name="nutri" class="java.lang.String">
		<variableExpression><![CDATA[SetupNu.UpdateNutritionStateAgeLessThen18WeightHeight($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth})]]></variableExpression>
	</variable>
	<variable name="nt" class="java.lang.Integer">
		<variableExpression><![CDATA[SetupNu.nutWH()]]></variableExpression>
	</variable>
	<variable name="weight-lowest" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[( $V{nt}.equals(1)? new Integer(1) : new Integer(0) )]]></variableExpression>
	</variable>
	<variable name="weight-low" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
