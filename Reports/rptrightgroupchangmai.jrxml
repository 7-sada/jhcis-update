<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptrightgroupchangmai" pageWidth="842" pageHeight="595" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="52eda3ea-a393-4d25-925e-f2d4e9c1d78b">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-10-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  rightgroupcode,rightgroupname
,count(distinct visit.pcucodeperson,visit.pid) as tperson
,count(distinct visit.pcucode,visit.visitno) as ttime
,sum(case when drugtype in ('01','04','05','10','03') then (visitdrug.unit  * visitdrug.costprice) else 0 end) as tdrug
,sum(case when drugtype in ('11','91') then  ((visit.money3) -  (visitdrug.unit  * visitdrug.costprice) )  else 0 end) as tother
,sum(case when drugtype ='07'  then (visitdrug.unit  * visitdrug.costprice) else 0 end) as tlab
,sum(case when drugtype ='02'  then (visitdrug.unit  * visitdrug.costprice) else 0 end) as tproce
,sum(visit.money3) as totcost
,if((sum(visit.money2)) >(sum(visit.money3))   ,null,((sum(visit.money3)) - (sum(visit.money2)) ))  as thelp
,sum(visit.money2) as totrec
,chospital.hosname
,date_format($P{sdate},'%Y-%m-%d') as startdate
,date_format($P{edate},'%Y-%m-%d') as enddate
from visitdrug left join visit on visitdrug.visitno = visit.visitno and visitdrug.pcucode = visit.pcucode
               left join cdrug on visitdrug.drugcode = cdrug.drugcode
	       left join cright on visit.rightcode = cright.rightcode
	       left join crightgroup on cright.rightgroup = crightgroup.rightgroupcode
	       left join chospital on visit.pcucode = chospital.hoscode
where visit.visitdate between  $P{sdate} and $P{edate}
  $P!{pcucode}
group by rightgroupcode]]>
	</queryString>
	<field name="rightgroupcode" class="java.lang.String"/>
	<field name="rightgroupname" class="java.lang.String"/>
	<field name="tperson" class="java.lang.Long"/>
	<field name="ttime" class="java.lang.Long"/>
	<field name="tdrug" class="java.lang.Double"/>
	<field name="tother" class="java.lang.Double"/>
	<field name="tlab" class="java.lang.Double"/>
	<field name="tproce" class="java.lang.Double"/>
	<field name="totcost" class="java.lang.Double"/>
	<field name="thelp" class="java.lang.Double"/>
	<field name="totrec" class="java.lang.Double"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="startdate" class="java.util.Date"/>
	<field name="enddate" class="java.util.Date"/>
	<variable name="SUM_tperson_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{tperson}]]></variableExpression>
	</variable>
	<variable name="SUM_ttime_1" class="java.lang.Double" calculation="Sum">
