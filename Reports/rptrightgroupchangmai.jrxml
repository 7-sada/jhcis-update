	</variable>
	<variable name="SUM_tother_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{tother}]]></variableExpression>
	</variable>
	<variable name="SUM_tlab_1" class="java.lang.Double" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{tlab}]]></variableExpression>
	</variable>
	<variable name="SUM_tproce_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{tproce}]]></variableExpression>
	</variable>
	<variable name="SUM_totcost_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{totcost}]]></variableExpression>
	</variable>
	<variable name="SUM_totrec_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{totrec}]]></variableExpression>
	</variable>
