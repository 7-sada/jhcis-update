	<queryString>
		<![CDATA[SELECT
Sum( if(drugcode = '2372700' , 1, 0 ) ) AS per06,
Sum( if(drugcode = '2382770' , 1, 0 ) ) AS per05,
Sum( if(drugcode BETWEEN '23771A1' AND '23771C3' , 1, 0 ) ) AS per03,
Sum( if(drugcode = '2277310' , 1, 0 ) ) AS per04,
Sum( if(drugcode in ('2377030','2387030') , 1, 0 ) ) AS per01,
Sum( if(drugcode = '2387279' , 1, 0 ) ) AS per033,
Sum( if(drugcode = '2372700' , c_Vn, 0 ) ) AS time06,
Sum( if(drugcode = '2382770' , c_Vn, 0 ) ) AS time05,
Sum( if(drugcode BETWEEN '23771A1' AND '23771C3' , c_Vn, 0 ) ) AS time03,
Sum( if(drugcode = '2277310' , c_Vn, 0 ) ) AS time04,
Sum( if(drugcode in ('2377030','2387030') , c_Vn, 0 ) ) AS time01,
Sum( if(drugcode = '2387279' , c_Vn, 0 ) ) AS time033,
Sum( if(drugcode = '2372700' , s_Un, 0 ) ) AS sun06,
Sum( if(drugcode = '2382770' , s_Un, 0 ) ) AS sun05
FROM v_activity_gum_stat_6_12]]>
	</queryString>
