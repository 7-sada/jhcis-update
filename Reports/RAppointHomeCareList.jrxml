	<parameter name="DateRepStart" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="AppointDate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND dateappoint BETWEEN ('2007-01-01') AND ('2007-12-31') "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
`person`.`pid`,
     concat(`person`.`prename`,`person`.`fname`,' ',`person`.`lname`)as name,
`village`.`villcode`,
`village`.`villno`,
`village`.`villname`,
`person`.`birth`,
concat((year(current_date)-year(`person`.`birth`)-(right(current_date,5)<right(`person`.`birth`,14))) ,' / ',(if (right(current_date,5)<right(`person`.`birth`,14),(12+month(current_date))-month(`person`.`birth`),month(current_date)-month(`person`.`birth`)))) as age,
`house`.`hno`,
`visithomehealthindividual`.`patientsign`,
`visithomehealthindividual`.`homehealthdetail`,
`visithomehealthindividual`.`dateappoint`
FROM
`village`
Inner Join `house` ON `village`.`villcode` = `house`.`villcode`
Inner Join `person` ON `house`.`hcode` = `person`.`hcode`
Inner Join `visit` ON `person`.`pid` = `visit`.`pid`
Inner Join `visithomehealthindividual` ON `visit`.`visitno` = `visithomehealthindividual`.`Visitno`
Left Join `user` ON `visithomehealthindividual`.`user` = `user`.`username`
WHERE
right(`village`.`villcode`,2) <>  '00' $P!{AppointDate}
ORDER BY `visithomehealthindividual`.`dateappoint`]]></queryString>

