		<defaultValueExpression><![CDATA["D:\\JHCIS\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     a.`pcucode`,
     b.`pid`,
     titlenamelong ,
     b.prename,
     b.fname,
     b.lname,
     concat(titlenamelong,b.fname,' ',b.lname)as name,
     date_format(b.`birth`,'%Y-%m-%d') as birth,
     a.`age_year`,
     c.`cid`,
     c.`changwat`,
     c.`ampur`,
     c.`tambol`,
     c.`village`,
     concat(ifnull(hno,'-'),' (',right(h.villcode,2),')') house,
     a.`bsl`,
     a.`bmi`,
     a.`hbp_s1`,
     a.`hbp_d1`,
     a.`hbp_s2`,
     a.`hbp_d2`,
     a.`waist`,
     cprovince.`provname` AS provname,
     cdistrict.`distname` AS distname,
     csubdistrict.`subdistname` AS subdistname
,vl.villname
FROM
     `ncd_person_ncd_screen` a INNER JOIN `person` b ON a.`pcucode` = b.`pcucodeperson`
     AND a.`pid` = b.`pid`
     INNER JOIN `ncd_person` c ON a.`pcucode` = c.`pcucode`
     AND a.`pid` = c.`pid`
     JOIN house h ON b.pcucodeperson=h.pcucode AND b.hcode=h.hcode
     INNER JOIN `ncd_person_ncd` d ON a.`pcucode` = d.`pcucode`
     AND a.`pid` = d.`pid`
     LEFT OUTER JOIN `cprovince` cprovince ON c.`changwat` = cprovince.`provcode`
     LEFT OUTER JOIN ctitle ON  b.prename = ctitle.`titlecode`
     LEFT OUTER JOIN `cdistrict` cdistrict ON c.`ampur` = concat(cdistrict.`provcode`,cdistrict.`distcode`)
     LEFT OUTER JOIN `csubdistrict` csubdistrict ON c.`tambol` = concat(csubdistrict.`provcode`,csubdistrict.`distcode`,csubdistrict.`subdistcode`)
     JOIN village vl on c.pcucode=vl.pcucode and c.village=vl.villcode
WHERE
     1 = 1$P!{p_sqlOffice}$P!{p_sqlDate}
ORDER BY c.village, b.fname ASC, b.lname ASC]]>
	</queryString>
