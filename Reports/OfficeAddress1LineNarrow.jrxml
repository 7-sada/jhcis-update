<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="OfficeAddress1Line" pageWidth="288" pageHeight="802" columnWidth="288" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="e4f26095-0981-4b1c-bf54-e2c200e3f45b">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'01060'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     chospital.`hosname` AS chospital_hosname,
     chospital.`mu` AS chospital_mu,
     csubdistrict.`subdistname` AS csubdistrict_subdistname,
     cdistrict.`distname` AS cdistrict_distname,
     cprovince.`provname` AS cprovince_provname
FROM
     `chospital` chospital INNER JOIN `office` office ON chospital.`hoscode` = office.`offid`
     INNER JOIN `csubdistrict` csubdistrict ON chospital.`provcode` = csubdistrict.`provcode`
     AND chospital.`subdistcode` = csubdistrict.`subdistcode`
     AND chospital.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cdistrict` cdistrict ON csubdistrict.`provcode` = cdistrict.`provcode`
     AND cdistrict.`distcode` = csubdistrict.`distcode`
     INNER JOIN `cprovince` cprovince ON cdistrict.`provcode` = cprovince.`provcode`
WHERE offid=$P!{pcucode}]]>
	</queryString>
	<field name="chospital_hosname" class="java.lang.String"/>
	<field name="chospital_mu" class="java.lang.String"/>
	<field name="csubdistrict_subdistname" class="java.lang.String"/>
	<field name="cdistrict_distname" class="java.lang.String"/>
	<field name="cprovince_provname" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
