		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="27" splitType="Stretch">
			<staticText>
				<reportElement key="staticText" positionType="Float" x="0" y="1" width="60" height="13" forecolor="#000000" backcolor="#FFFFFF" uuid="a84da758-3bec-494b-90ae-817952976757"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font size="10"/>
				</textElement>
				<text><![CDATA[สถานบริการ:]]></text>
			</staticText>
			<textField isBlankWhenNull="false">
				<reportElement key="textField" x="61" y="1" width="227" height="13" uuid="f47f0580-f563-4580-b949-5858b3217398"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Top">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{chospital_hosname} + " หมู่ " + $F{chospital_mu}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="false">
				<reportElement key="textField" x="0" y="14" width="288" height="13" uuid="01e489f6-bce3-40af-ae0d-cf5816cbbb56"/>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement verticalAlignment="Top">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA["ต."+$F{csubdistrict_subdistname}+" อ."+$F{cdistrict_distname}+" จ."+$F{cprovince_provname}]]></textFieldExpression>
			</textField>
		</band>
