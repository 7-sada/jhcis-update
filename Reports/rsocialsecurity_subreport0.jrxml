	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="person" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA["'0116052452009-11-06'"]]></parameterDescription>
		<defaultValueExpression><![CDATA["'08731158535'"]]></defaultValueExpression>
	</parameter>
	<parameter name="zdiag" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND visitdiag.diagcode  NOT REGEXP '^[Zz]']]></parameterDescription>
		<defaultValueExpression><![CDATA["  "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="p" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[(($P{person}==null || $P{person}.equals("")) ?"''":" AND CONCAT(visitdiag.pcucode,visit.visitno,visit.visitdate) = "+$P{person})]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
cdisease.diseasenamethai,visitdiag.diagcode,visitdiag.causeill
FROM
visitdiag
Left Join cdisease ON visitdiag.diagcode = cdisease.diseasecode
Left Join `visit` ON `visit`.`visitno` = `visitdiag`.`visitno` AND `visitdiag`.`pcucode` = `visit`.`pcucode`
WHERE
 CONCAT(visitdiag.pcucode,visit.visitno) = $P!{person}
and !(left(diagcode,1)='Z' and diagcode not in ('Z48.0'))
#and (lcase(left(diagcode,1))<'z' or lcase(diagcode)='z48.0')
#$P!{zdiag}
#ORDER BY diagcode
]]>
	</queryString>
