<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rrb1k01appoint"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="727"
		 pageHeight="595"
		 columnWidth="667"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-03-26"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2009-01-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2008-11-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["08449"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select v.visitno,v.pcucode,
concat(p.prename,p.fname,' ',p.lname)as personname,
p.hnomoi,village.villname,DATE_FORMAT(p.birth, "%y-%m-%d") as birth,p.birth as bb,
 	CONVERT(CONCAT(  DATE_FORMAT(v.visitdate,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.visitdate,"00-%m-%d")<DATE_FORMAT(birth,"00-%m-%d")), " / ",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%m")-DATE_FORMAT(birth,"%m"))  
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
 	 WHEN 1 THEN(DATE_FORMAT(v.visitdate,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.visitdate,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " / ",  
	CASE SIGN(DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d"))  
 	 WHEN 0 THEN(12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.visitdate,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))  
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(birth),"%d") + DATE_FORMAT(v.visitdate, "%d")  -  DATE_FORMAT(birth, "%d"))  
 	 WHEN 1 THEN (DATE_FORMAT(v.visitdate,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.visitdate,"%d") < DATE_FORMAT(birth,"%d")))  END  ) USING utf8) AS age_ymd ,
	DATE_FORMAT(vd.appointdate,"%Y-%m-%d") as appointdate,  
 	CASE WHEN  vd.appointtype='1' then "รับยา" 
             WHEN vd.appointtype ='2' then "ฟังผลการรักษา" end  as appointtype,
h.hosname,d.distname,pr.provname
from visit v left outer join person p on v.pid= p.pid and v.pcucode = p.pcucodeperson
        left outer join village  on concat(p.provcodemoi,p.distcodemoi,p.subdistcodemoi,p.mumoi ) =village.villcode
	left outer join visitdiag vd on vd.visitno = v.visitno and vd.pcucode = v.pcucode
        left outer join chospital h on h.hoscode=v.pcucode
        left outer join cdistrict d on d.distcode = p.distcodemoi and d.provcode = p.provcodemoi
        left outer join cprovince  pr on pr.provcode = p.provcodemoi    
where v.pcucode =$P{pcucode} and v.visitdate between $P{sdate} and $P{edate}  and appointdate >= $P{pdate}
order by village.villcode,v.visitdate]]></queryString>

