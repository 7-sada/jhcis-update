	<queryString><![CDATA[SELECT
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '10' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_oct,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '11' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_nov,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '12' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_dec,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '1' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_jan,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '2' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_feb,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '3' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_mar,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '4' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_apr,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '5' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_may,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '6' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_jun,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '7' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_jul,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '8' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_aug,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NOT NULL AND vmonth = '9' THEN 1 ELSE 0 END) AS SIGNED INTEGER) o_sep,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '10' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_oct,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '11' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_nov,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '12' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_dec,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '1' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_jan,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '2' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_feb,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '3' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_mar,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '4' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_apr,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '5' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_may,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '6' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_jun,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '7' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_jul,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '8' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_aug,
CAST(SUM(CASE WHEN _tmp_chronic.p2 IS NULL AND vmonth = '9' THEN 1 ELSE 0 END) AS SIGNED INTEGER) n_sep,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '10' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_oct,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '11' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_nov,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '12' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_dec,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '1' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_jan,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '2' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_feb,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '3' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_mar,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '4' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_apr,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '5' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_may,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '6' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_jun,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '7' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_jul,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '8' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_aug,
CAST(SUM(CASE WHEN _tmp_chronic.p3 IS NOT NULL AND vmonth = '9' THEN 1 ELSE 0 END) AS SIGNED INTEGER) d_sep
FROM
_tmp_chronic]]></queryString>

