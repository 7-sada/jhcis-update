	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\Program Files\\JasperSoft\\iReport-2.0.0\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
     person.`prename`,
     person.`fname`,
     person.`lname`,
     person.`hnomoi`,
     cdrug.`drugname`,
     person.`mumoi`,
     village.`villname`,
     visitfp.`datefp`
FROM
     `person` person INNER JOIN `house` house ON person.`hcode` = house.`hcode`
     INNER JOIN `village` village ON house.`villcode` = village.`villcode`
     INNER JOIN `visitfp` visitfp ON person.`pid` = visitfp.`pid`
     INNER JOIN `cdrug` cdrug ON visitfp.`fpcode` = cdrug.`drugcode`
WHERE
     `visitfp`.`datedue` = $P{DateDue}
ORDER BY
     `person`.`mumoi` ASC]]></queryString>

