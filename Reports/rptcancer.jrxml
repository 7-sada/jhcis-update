<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptcancer"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-02"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-06-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\iReport-2.0.0\\"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select house.villcode,village.villname,house.pcucode,chospital.hosname
,sum(case when visitlabcancer.typecancer ='1' then 1 else 0 end) as canc1
,sum(case when visitlabcancer.typecancer ='1' and result='x'  then 1 else 0 end) as canc1rx
,sum(case when visitlabcancer.typecancer ='1' and result='0'  then 1 else 0 end) as canc1r0
,sum(case when visitlabcancer.typecancer ='1' and result='1'  then 1 else 0 end) as canc1r1
,sum(case when visitlabcancer.typecancer ='1' and result='2'  then 1 else 0 end) as canc1r2
,sum(case when visitlabcancer.typecancer ='1' and result='5'  then 1 else 0 end) as canc1r5
,sum(case when visitlabcancer.typecancer ='1' and result='6'  then 1 else 0 end) as canc1r6
,sum(case when visitlabcancer.typecancer ='1' and result='9'  then 1 else 0 end) as canc1r9

,sum(case when visitlabcancer.typecancer ='2' then 1 else 0 end) as canc2
,sum(case when visitlabcancer.typecancer ='2' and result='x'  then 1 else 0 end) as canc2rx
,sum(case when visitlabcancer.typecancer ='2' and result='0'  then 1 else 0 end) as canc2r0
,sum(case when visitlabcancer.typecancer ='2' and result='1'  then 1 else 0 end) as canc2r1
,sum(case when visitlabcancer.typecancer ='2' and result='2'  then 1 else 0 end) as canc2r2
,sum(case when visitlabcancer.typecancer ='2' and result='5'  then 1 else 0 end) as canc2r5
,sum(case when visitlabcancer.typecancer ='2' and result='6'  then 1 else 0 end) as canc2r6
,sum(case when visitlabcancer.typecancer ='2' and result='9'  then 1 else 0 end) as canc2r9

,sum(case when visitlabcancer.typecancer ='3' then 1 else 0 end) as canc3
,sum(case when visitlabcancer.typecancer ='3' and result='x'  then 1 else 0 end) as canc3rx
,sum(case when visitlabcancer.typecancer ='3' and result='0'  then 1 else 0 end) as canc3r0
,sum(case when visitlabcancer.typecancer ='3' and result='1'  then 1 else 0 end) as canc3r1
,sum(case when visitlabcancer.typecancer ='3' and result='2'  then 1 else 0 end) as canc3r2
,sum(case when visitlabcancer.typecancer ='3' and result='5'  then 1 else 0 end) as canc3r5
,sum(case when visitlabcancer.typecancer ='3' and result='6'  then 1 else 0 end) as canc3r6
,sum(case when visitlabcancer.typecancer ='3' and result='9'  then 1 else 0 end) as canc3r9


from visitlabcancer left join person on visitlabcancer.pid = person.pid and visitlabcancer.pcucodeperson = person.pcucodeperson
	left join house on  person.hcode = house.hcode and person.pcucodeperson = house.pcucode
	left join village on house.villcode = village.villcode and house.pcucode = village.pcucode
	left join chospital on house.pcucode = chospital.hoscode
where 1=1
	and visitlabcancer.datecheck between $P{sdate} and $P{edate}
	$P!{pcucode}
	and concat(visitlabcancer.pcucodeperson,visitlabcancer.pid) not in (select concat(p1.pcucodeperson,p1.pid) from persondeath p1 where visitlabcancer.pid = p1.pid and visitlabcancer.pcucodeperson = p1.pcucodeperson and deaddate <= $P{edate} )
group by house.pcucode,house.villcode 
order by house.pcucode,house.villcode]]></queryString>

