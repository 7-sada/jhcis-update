<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rptsumrightbymoney"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Portrait"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2012-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2012-01-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["AND visit.pcucode='00993'"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select date_format(visitdate,'%Y-%m-%d') as visitdate
,sum(case when crightgroup.rightgroupcode ='2' then visit.money2 else '' end) as rg2money2
,sum(case when crightgroup.rightgroupcode ='2' then visit.money3 else '' end) as rg2money3
,sum(case when crightgroup.rightgroupcode ='y' then visit.money2 else '' end) as rgymoney2
,sum(case when crightgroup.rightgroupcode ='y' then visit.money3 else '' end) as rgymoney3
,sum(case when crightgroup.rightgroupcode ='4' then visit.money2 else '' end) as rg4money2
,sum(case when crightgroup.rightgroupcode ='4' then visit.money3 else '' end) as rg4money3
,sum(case when crightgroup.rightgroupcode ='3' then visit.money2 else '' end) as rg3money2
,sum(case when crightgroup.rightgroupcode ='3' then visit.money3 else '' end) as rg3money3
,sum(case when crightgroup.rightgroupcode ='1' then visit.money2 else '' end) as rg1money2
,sum(case when crightgroup.rightgroupcode ='1' then visit.money3 else '' end) as rg1money3
,sum(case when crightgroup.rightgroupcode ='x' then visit.money2 else '' end) as rgxmoney2
,sum(case when crightgroup.rightgroupcode ='x' then visit.money3 else '' end) as rgxmoney3
,sum(money2) as tmoney2
,sum(money3) as tmoney3
,sum(money1) as tmonty1
,hosname,provname
from visit left join cright on visit.rightcode = cright.rightcode
	left join crightgroup on cright.rightgroup = crightgroup.rightgroupcode
	left join chospital on visit.pcucode = chospital.hoscode
	left join cprovince on chospital.provcode = cprovince.provcode
where visitdate between $P{sdate} and $P{edate} $P!{pcucode}
group by visitdate]]></queryString>

	<field name="visitdate" class="java.util.Date"/>
	<field name="rg2money2" class="java.lang.Double"/>
	<field name="rg2money3" class="java.lang.Double"/>
	<field name="rgymoney2" class="java.lang.Double"/>
	<field name="rgymoney3" class="java.lang.Double"/>
