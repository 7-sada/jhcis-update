						<font fontName="SansSerif" size="10"/>
					</textElement>
				<textFieldExpression   class="java.lang.String"><![CDATA["3. โรคเท้าช้างในระยะที่ปรากฏอาการเป็นที่รังเกียจแก่สังคม"]]></textFieldExpression>
				</textField>
