	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="DateRepStart" isForPrompting="true" class="java.util.Date"/>
	<parameter name="DateRepEnd" isForPrompting="true" class="java.util.Date"/>
	<parameter name="bdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2010-01-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["'2010-06-01'"]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
`cdrug`.`drugname`,
Sum(`drugstorereceivedetail`.`amount`) AS amount,
`drugstorereceivedetail`.`lotno`,
DATE_FORMAT(`drugstorereceivedetail`.`expiredate`,'%Y-%m-%d') AS expiredate
FROM
`drugstorereceivedetail`
Inner Join `cdrug` ON `drugstorereceivedetail`.`drugcode` = `cdrug`.`drugcode`
WHERE
`drugstorereceivedetail`.`expiredate` BETWEEN  $P!{bdate} AND $P!{edate}
GROUP BY
`cdrug`.`drugname`,
`drugstorereceivedetail`.`expiredate`,
`drugstorereceivedetail`.`lotno`,
`drugstorereceivedetail`.`drugcode`
ORDER BY
`drugstorereceivedetail`.`expiredate` ASC]]></queryString>

	<field name="drugname" class="java.lang.String"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="lotno" class="java.lang.String"/>
	<field name="expiredate" class="java.util.Date"/>

