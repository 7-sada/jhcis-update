<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="asu_1_Acute_Executive_Dx_Show" pageWidth="863" pageHeight="595" orientation="Landscape" columnWidth="823" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="73d96595-31b2-493f-a13a-a0c3807476c4">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="offAddress" class="java.lang.String"/>
	<parameter name="p_d1" class="java.lang.String"/>
	<parameter name="p_d2" class="java.lang.String"/>
	<parameter name="p_dBetween" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT q1.*,q2.d24,IFNULL(q2.dn,'.. ไม่ใช้ยาปฏิชีวนะ ..') dn
FROM
(SELECT IF(dxtype='01','โรคหลัก' ,CONCAT('มิใช่โรคหลัก( ',dxtype,')')) dxt
,v.pcucode ,v.visitno,v.pid HN
,DATE_FORMAT(visitdate, "%Y-%m-%d") as vd,v.visitdate
,d1.diagcode ICD10,diseasename
FROM visitdiag d1 JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
JOIN _tmp_asu_acute_uri d2 ON d1.diagcode=d2.icd10acui
JOIN cdisease cd ON d1.diagcode=cd.diseasecode
WHERE LCASE(LEFT(d2.icd10acui,1)) IN('a','k')
  AND dxtype='01'
  AND v.visitdate BETWEEN $P{p_d1} AND $P{p_d2}
ORDER BY dxtype,(v.visitdate),v.visitno) AS q1
LEFT JOIN
(SELECT v.pcucode,v.visitno,ifnull(drugcode24,'-') d24 ,drugname dn FROM visitdrug d1
JOIN visit v ON d1.pcucode=v.pcucode AND d1.visitno=v.visitno
JOIN cdrug d2 ON d1.drugcode=d2.drugcode
WHERE v.visitdate BETWEEN $P{p_d1} AND $P{p_d2}
  AND d2.antibio='1') AS q2
ON q1.pcucode=q2.pcucode AND q1.visitno=q2.visitno]]>
	</queryString>
	<field name="dxt" class="java.lang.String"/>
	<field name="pcucode" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="visitno" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="HN" class="java.lang.Integer"/>
	<field name="visitdate" class="java.sql.Date">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="vd" class="java.lang.String"/>
	<field name="ICD10" class="java.lang.String"/>
	<field name="diseasename" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="d24" class="java.lang.String"/>
	<field name="dn" class="java.lang.String"/>
	<variable name="sumTotA" class="java.lang.Long" calculation="Count">
		<variableExpression><![CDATA[$F{HN}]]></variableExpression>
	</variable>
