		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==5) ||
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==6)
		? Boolean.TRUE : Boolean.FALSE )
       		:
       		(
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==1) ||
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==2) ||
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==4) ||
