		<defaultValueExpression><![CDATA["2008-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="nformu" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND person.pcucodeperson='"+"01913"+"'"]]></defaultValueExpression>
	</parameter>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="awh" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["aw"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
CONCAT(IFNULL(ctitle.titlename,IFNULL(person.prename,'...')),person.fname,'  ',person.lname) AS fullname,
vchild_60mon_weight_0.hno,
visit.visitdate,
DATE_FORMAT(visit.visitdate,"%Y-%m-%d")AS svisitdate,
person.birth,
vchild_60mon_weight_0.agemonth,
person.sex,
vchild_60mon_weight_0.weight,
vchild_60mon_weight_0.tall,
vchild_60mon_weight_0.pid,
vchild_60mon_weight_0.villno,
vchild_60mon_weight_0.villcode,
vchild_60mon_weight_0.villname
FROM
person
Left Join vchild_60mon_weight_0 ON person.pcucodeperson = vchild_60mon_weight_0.pcucodeperson AND person.pid = vchild_60mon_weight_0.pid
Inner Join visit ON vchild_60mon_weight_0.pcucodeperson = visit.pcucodeperson AND vchild_60mon_weight_0.lastvn = visit.visitno AND vchild_60mon_weight_0.pid = visit.pid
left join ctitle on ctitle.titlecode=person.prename
/*Inner Join vnutrition_last_st2 ON visit.visitno = vnutrition_last_st2.lastvn*/
WHERE
visit.visitdate BETWEEN $P{startdate} AND $P{enddate} $P!{pcucode}
ORDER BY vchild_60mon_weight_0.villcode,visit.visitdate]]>
	</queryString>
	<field name="fullname" class="java.lang.String"/>
	<field name="hno" class="java.lang.String"/>
	<field name="visitdate" class="java.sql.Date"/>
	<field name="svisitdate" class="java.sql.Timestamp"/>
	<field name="birth" class="java.sql.Date"/>
	<field name="agemonth" class="java.lang.Long"/>
	<field name="sex" class="java.lang.String"/>
	<field name="weight" class="java.math.BigDecimal"/>
	<field name="tall" class="java.math.BigDecimal"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="villno" class="java.lang.Integer"/>
	<field name="villcode" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<variable name="vcount" class="java.lang.Integer" resetType="Group" resetGroup="villno" calculation="Sum">
		<variableExpression><![CDATA[(  $P{awh} == "aw" ?
	(
	( SetupNu.nutAW_($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})==1) ||
	( SetupNu.nutAW_($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})==2) ||
	( SetupNu.nutAW_($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})==4) ||
	( SetupNu.nutAW_($F{agemonth}.intValue(),$F{weight}.doubleValue(),$F{sex})==5)
	? new Integer(1) : new Integer(0) )
	:
    	(  $P{awh} == "wh" ?
       		(
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==1) ||
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==2) ||
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==4) ||
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==5) ||
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==6)
		? new Integer(1) : new Integer(0) )
       		:
       		(
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==1) ||
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==2) ||
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==4) ||
		( SetupNu.nutAH_($F{agemonth}.intValue(),$F{tall}.intValue(),$F{sex})==5)
		? new Integer(1) : new Integer(0) )
    	)
)]]></variableExpression>
	</variable>
