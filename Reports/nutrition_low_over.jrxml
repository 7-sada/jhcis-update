	? Boolean.TRUE : Boolean.FALSE )
	:
    	(  $P{awh} == "wh" ?
       		(
		( SetupNu.nutWH_($F{weight}.doubleValue(),$F{tall}.intValue(),$F{sex},$F{agemonth}.doubleValue())==1) ||
