	<parameter name="whereHosmain" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ WHERE vp.hosmain is null ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
vp.pcucode,
vp.hosmain,
DATE_FORMAT(vp.vdate,'%Y-%m-%d') vdate,
vp.pdm,
vp.fdm,
vp.odm,
vdmlapbp.f_hba1c,
vdmlapbp.o_hba1c,
vdmlapbp.f_lipid,
vdmlapbp.o_lipid,
vdmlapbp.hba1c7,
vdmlapbp.ldl,
vdmlapbp.bp,
vp.fdm_foot,
vp.odm_foot,
vp.fdm_eye,
vp.odm_eye
FROM
vpersondm vp
Left Outer Join vdmlapbp ON vp.pcucode = vdmlapbp.pcucode 
AND vp.hosmain = vdmlapbp.hosmain 
AND LEFT(vp.vdate,7) = LEFT(vdmlapbp.cdate,7)
$P!{whereHosmain}]]></queryString>

