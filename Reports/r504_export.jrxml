	<parameter name="sdate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["2010-03-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.pcucode = '15102' "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
visit.pcucode,
visit.visitno,
visit.visitdate,
person.pid,
person.prename,
person.fname,
person.lname,
person.sex,
cdisease.diseasecode,
cdisease.diseasename,
cdisease.code504,
cdisease504.group504name
FROM
visitdiag
Inner Join cdisease ON cdisease.diseasecode = visitdiag.diagcode
Inner Join visit ON visit.visitno = visitdiag.visitno AND visit.pcucode = visitdiag.pcucode
Inner Join person ON visit.pcucodeperson = person.pcucodeperson AND visit.pid = person.pid
Inner Join cdisease504 ON cdisease504.group504code = cdisease.code504
WHERE  1=1
AND visit.visitdate  BETWEEN '$P!{sdate}' AND  '$P!{edate}'
$P!{pcucode}
AND (cdisease.illornot <> '2' OR cdisease.illornot is null)   
AND (visit.flagservice < '04' OR visit.flagservice is null OR length(trim(visit.flagservice)) = 0)  
ORDER BY 
visit.pcucode,
cdisease.code504,
visit.visitdate]]></queryString>

