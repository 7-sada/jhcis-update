<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="runableperson_list" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" isFloatColumnFooter="true">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[AND person.pcucodeperson='01856']]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="offAddress" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pid" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[$F{pid}]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucodeperson" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[$F{pcucodeperson}]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT personunable.pid,personunable.pcucodeperson,CONCAT(village.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,village.villno,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname,' ',person.lname) AS pname,
concat((year(current_date())-year(person.birth)-(right(current_date(),5)<right(person.birth,5))),' - ',
(if (day(current_date()) <day(person.birth),
	(if (right(current_date(),5)<right(person.birth,5)
		,(12+ month(current_date()))-month(person.birth),month(current_date())-month(person.birth)))-1
		,(if (right(current_date(),5)<right(`person`.`birth`,5)
			,(12+ month(current_date()))-month(person.birth)
			,month(current_date())-month(person.birth)
		))
	)
) ,' - ',
(if (day(current_date()) < day(person.birth),(day(last_day(current_date()))+ day(current_date()))-day(person.birth),day(current_date())-day(person.birth)))) AS age,
person.hnomoi,
personunable.registerno,
DATE_FORMAT(personunable.dateregister,'%Y-%m-%d') as dateregister
FROM
person
Inner Join personunable ON person.pcucodeperson = personunable.pcucodeperson AND person.pid = personunable.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Inner Join house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
Inner Join village ON village.villcode = house.villcode AND village.pcucode = house.pcucode
WHERE (person.mumoi is not null AND right(`house`.`villcode`,2) != '00')  AND
CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath) $P!{pcucode}
ORDER BY village.villno,person.hnomoi]]>
	</queryString>
