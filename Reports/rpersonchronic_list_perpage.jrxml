				<textFieldExpression   class="java.lang.String"><![CDATA[$F{villname}+" = "+$V{dis_COUNT}+" คน (จำนวนคน นับทุกโรค "+$V{villname_COUNT}+" คน)"]]></textFieldExpression>
				</textField>
			</band>
