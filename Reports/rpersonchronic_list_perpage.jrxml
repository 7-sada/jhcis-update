<?xml version="1.0" encoding="UTF-8"  ?>
<!-- Created with iReport - A designer for JasperReports -->
<!DOCTYPE jasperReport PUBLIC "//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport
		 name="rpersonchronic_list_perpage"
		 columnCount="1"
		 printOrder="Vertical"
		 orientation="Landscape"
		 pageWidth="842"
		 pageHeight="595"
		 columnWidth="782"
		 columnSpacing="0"
		 leftMargin="30"
		 rightMargin="30"
		 topMargin="20"
		 bottomMargin="20"
		 whenNoDataType="NoPages"
		 isTitleNewPage="false"
		 isSummaryNewPage="false">
	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="offAddress" isForPrompting="false" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["C:\\jhcis\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[AND person.pcucodeperson='01856' ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[" "]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT village.villcode,
CONCAT(village.`villname`,' ต.',getSubdist(LEFT(village.villcode,6))) AS villname,person.pid,
concat(ifnull(ifnull(ctitle.titlename,person.prename),'-'),person.fname) AS fname,
person.lname,
if((personaddresscontact.hno Is Null OR personaddresscontact.mu Is Null OR personaddresscontact.subdistcode Is Null OR personaddresscontact.distcode Is Null OR personaddresscontact.provcode) ,CONCAT(person.hnomoi,' ม.',person.mumoi,' ต.',csubdistrict.subdistname,' อ.',cdistrict.distname,' จ.',cprovince.provname),CONCAT(personaddresscontact.hno,' ม.',personaddresscontact.mu,' ต.',csdc.subdistname,' อ.',cdc.distname,' จ.',cpc.provname)) AS address,
concat((year(current_date())-year(person.birth)-(right(current_date(),5)<right(person.birth,5))),' - ',
(if (day(current_date()) <day(person.birth),
	(if (right(current_date(),5)<right(person.birth,5)
		,(12+ month(current_date()))-month(person.birth),month(current_date())-month(person.birth)))-1 
		,(if (right(current_date(),5)<right(`person`.`birth`,5)
			,(12+ month(current_date()))-month(person.birth)
			,month(current_date())-month(person.birth)
		))
	)
) ,' - ',
(if (day(current_date()) < day(person.birth),(day(last_day(current_date()))+ day(current_date()))-day(person.birth),day(current_date())-day(person.birth)))) AS age,
personchronic.behaviorrisk,
cdisease.diseasenamethai,
CASE
when personchronic.typedischart=1 then 'หาย'
when personchronic.typedischart=2 then 'ตาย'
when personchronic.typedischart=3 then 'ยังรักษาอยู่ฯ'
when personchronic.typedischart=4 then 'ไม่ทราบ(ไม่มีข้อมูล)'
when personchronic.typedischart=5 then 'รอการจำหน่าย/เฝ้าระวัง'
when personchronic.typedischart=6 then 'ยังรักษาอยู่ฯ'
when personchronic.typedischart=7 then 'ครบการรักษาฯ'
when personchronic.typedischart=8 then 'โรคอยู่ในภาวะสงบฯ'
when personchronic.typedischart=9 then 'ปฏิเสธการรักษาฯ'
else null end AS typedischart,
chospital.hosname
FROM
personchronic
Left Outer Join person ON personchronic.pcucodeperson = person.pcucodeperson AND personchronic.pid = person.pid
Left Outer Join ctitle ON person.prename = ctitle.titlecode
Left Outer Join cdisease ON personchronic.chroniccode = cdisease.diseasecode
Left Outer Join personaddresscontact ON person.pcucodeperson = personaddresscontact.pcucodeperson AND person.pid = personaddresscontact.pid
Left Outer Join csubdistrict AS csdc ON personaddresscontact.subdistcode = csdc.subdistcode AND personaddresscontact.distcode = csdc.distcode AND personaddresscontact.provcode = csdc.provcode
Left Outer Join cdistrict AS cdc ON personaddresscontact.provcode = cdc.provcode AND personaddresscontact.distcode = cdc.distcode
Left Outer Join cprovince AS cpc ON personaddresscontact.provcode = cpc.provcode
Left Outer Join csubdistrict ON person.subdistcodemoi = csubdistrict.subdistcode AND person.distcodemoi = csubdistrict.distcode AND person.provcodemoi = csubdistrict.provcode
Left Outer Join cdistrict ON csubdistrict.distcode = cdistrict.distcode AND csubdistrict.provcode = cdistrict.provcode
Left Outer Join cprovince ON cdistrict.provcode = cprovince.provcode
Left Outer Join chospital ON personchronic.cup = chospital.hoscode
Left Outer Join house ON house.pcucode = person.pcucodeperson AND house.hcode = person.hcode
Inner Join village ON village.villcode = house.villcode AND village.pcucode = house.pcucode
WHERE 
 CONCAT(person.pid,person.pcucodeperson) not in (SELECT CONCAT(persondeath.pid,persondeath.pcucodeperson) FROM persondeath) $P!{pcucode} 
ORDER BY village.villcode,cdisease.diseasecode,address]]></queryString>

	<field name="villcode" class="java.lang.String"/>
	<field name="villname" class="java.lang.String"/>
	<field name="pid" class="java.lang.Integer"/>
	<field name="fname" class="java.lang.String"/>
	<field name="lname" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
	<field name="age" class="java.lang.String"/>
	<field name="behaviorrisk" class="java.lang.String"/>
	<field name="diseasenamethai" class="java.lang.String"/>
	<field name="typedischart" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>

	<variable name="dis_COUNT" class="java.lang.Integer" resetType="Group" resetGroup="villname" calculation="DistinctCount">
