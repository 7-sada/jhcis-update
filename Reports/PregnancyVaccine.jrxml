	<subDataset name="Pregnancy" uuid="c0f7e3f8-2515-4504-b4c4-061de8e73b88">
		<parameter name="edate" class="java.lang.String"/>
		<parameter name="sdate" class="java.lang.String"/>
		<queryString>
			<![CDATA[select aa.pid,concat(ifnull(titlename,ifnull(p1.prename,'...')) ," ", fname," ", lname) as fullname,
getAgeYearNum(p1.birth,now()) as Age,aa.dt,aa.flu,aa.weekPrag,aa.dateepi,aa.lmp
from person p1
join
(select A.pid,group_concat(A.dt) as dt ,group_concat(A.flu) as flu,max(A.weekPrag) as weekPrag,
max(A.dateepi) as dateepi,A.lmp,A.pcucodeperson
from
(select v.pid,v.vaccinecode as dt,null as flu,vd.datedeliver,v.pcucodeperson,
TRUNCATE(((datediff(v.dateepi,vp.lmp))/7),0) as weekPrag ,
v.dateepi,vp.lmp,vp.edc
from visitepi v
join visitancpregnancy vp on (v.pid = vp.pid and v.pcucodeperson = vp.pcucodeperson)
left join visitancdeliver vd on (vp.pid = vd.pid and vp.pregno = vd.pregno)
where v.vaccinecode like '%dt%'
and v.dateepi between $P!{sdate} and $P!{edate}
and v.dateepi between vp.lmp and IFNULL(vd.datedeliver,vp.edc)
union all
select v.pid,null as dt,v.vaccinecode as flu,vd.datedeliver,v.pcucodeperson,
TRUNCATE(((datediff(v.dateepi,vp.lmp))/7),0) as weekPrag ,
v.dateepi,vp.lmp,vp.edc
from visitepi v
join visitancpregnancy vp on (v.pid = vp.pid and v.pcucodeperson = vp.pcucodeperson)
left join visitancdeliver vd on vp.pid = vd.pid and vp.pregno = vd.pregno
where v.vaccinecode like '%flu%'
and v.dateepi between $P!{sdate} and $P!{edate}
and v.dateepi between vp.lmp and IFNULL(vd.datedeliver,vp.edc)
)A
group by A.pid
order by A.dateepi,A.pid)aa
on (p1.pid = aa.pid and p1.pcucodeperson = aa.pcucodeperson)
join ctitle p2 on p1.prename = p2.titlecode]]>
		</queryString>
		<field name="pid" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="fullname" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="Age" class="java.lang.Integer">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="dt" class="java.lang.String"/>
		<field name="flu" class="java.lang.String"/>
		<field name="weekPrag" class="java.math.BigDecimal"/>
		<field name="dateepi" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="lmp" class="java.sql.Date">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
	</subDataset>
