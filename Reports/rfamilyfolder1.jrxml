	<parameter name="edate" isForPrompting="false" class="java.lang.String"/>
	<queryString><![CDATA[SELECT
house.villcode, 

SUM( IF( (person.sex='1' AND getAgeYearNum(person.birth, CURDATE()) < 1), 1, 0) ) AS AG,
SUM( IF( (person.sex='2' AND getAgeYearNum(person.birth, CURDATE()) < 1), 1, 0) ) AS AL, 
SUM( IF( getAgeYearNum(person.birth, CURDATE()) < 1, 1, 0) ) AS AA

FROM house 
	INNER JOIN person ON (house.pcucode=person.pcucodeperson AND house.hcode=person.hcode)  
WHERE 1=1  
GROUP BY house.villcode  
ORDER BY house.villcode ASC 	
LIMIT 10;		]]></queryString>

	<field name="villcode" class="java.lang.String"/>
	<field name="AG" class="java.math.BigDecimal"/>
	<field name="AL" class="java.math.BigDecimal"/>
	<field name="AA" class="java.math.BigDecimal"/>

