	<parameter name="whereHosmain" isForPrompting="false" class="java.lang.String">
		<parameterDescription><![CDATA[ WHERE vp.hosmain is null ]]></parameterDescription>
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT
vp.`pcucode`,
vp.`hosmain`,
DATE_FORMAT(vp.`vdate`,'%Y-%m-%d') vdate,
sum(vp.`preht`) pht,
sum(vp.`oht`) oht,
sum(vp.`fht`) fht,
sum(vp.`f_lipid`) f_lipid,
sum(vp.`o_lipid`) o_lipid,
sum(vp.`f_urinep`) f_urinep,
sum(vp.`o_urinep`) o_urinep,
sum(vp.`f_fbs`) f_fbs,
sum(vp.`o_fbs`) o_fbs,
sum(vp.`bp`) bp,
sum(vp.`ldl`) ldl,
sum(vp.`urinep`) urinep
FROM
`vht` vp
$P!{whereHosmain}
GROUP BY vp.`pcucode`,
vp.`hosmain`,
LEFT(vp.`vdate`,7)]]></queryString>

	<field name="pcucode" class="java.lang.String"/>
	<field name="hosmain" class="java.lang.String"/>
	<field name="vdate" class="java.util.Date"/>
