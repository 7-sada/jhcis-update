<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptvaccstudent" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="796" leftMargin="30" rightMargin="16" topMargin="20" bottomMargin="20" uuid="759198da-87b1-4fe9-90cc-405ce6c32005">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-01-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2010-12-30"]]></defaultValueExpression>
	</parameter>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT CONVERT(CONCAT(ifnull(titlename,ifnull(prename,'ไม่ระบุ') ),fname,' ',lname) using utf8)  as name,v.dateepi,DATE_FORMAT(birth,'%Y-%m-%d') as bb
,CONVERT(CONCAT(  DATE_FORMAT(v.dateepi,"%Y")-DATE_FORMAT(birth,"%Y") - (DATE_FORMAT(v.dateepi,"00-%m-%d")< DATE_FORMAT(birth,"00-%m-%d")), " ป ",
	CASE SIGN(DATE_FORMAT(v.dateepi,"%m")-DATE_FORMAT(birth,"%m"))
 	 WHEN 0 THEN (11 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.dateepi,"%m") -  (DATE_FORMAT(birth,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN -1 THEN (12 - DATE_FORMAT(birth,"%m") + DATE_FORMAT(v.dateepi,"%m") -  (DATE_FORMAT(v.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d")))
 	 WHEN 1 THEN(DATE_FORMAT(v.dateepi,"%m") - DATE_FORMAT(birth,"%m") -  (DATE_FORMAT(v.dateepi,"00-00-%d") < DATE_FORMAT(birth,"00-00-%d"))) END,  " ด ",
	CASE SIGN(DATE_FORMAT(v.dateepi,"%d") - DATE_FORMAT(birth,"%d"))
 	 WHEN 0 THEN(DATE_FORMAT(v.dateepi,"%d") - DATE_FORMAT(birth,"%d") )
	 WHEN -1 THEN (DATE_FORMAT(LAST_DAY(v.dateepi),"%d") + DATE_FORMAT(v.dateepi, "%d")  -  DATE_FORMAT(birth, "%d"))
 	 WHEN 1 THEN (DATE_FORMAT(v.dateepi,"%d") - DATE_FORMAT(birth,"%d") -  (DATE_FORMAT(v.dateepi,"%d") < DATE_FORMAT(birth,"%d")))  END ," ว "  ) USING utf8) AS age_ymd
,CONVERT(case when p.subdistcodemoi is null  then 'นอกเขต'
              when p.hnomoi is null then concat(' หมู่ที่ ',  p.`mumoi`)
              when p.mumoi is null then concat(p.`hnomoi`   )
              else concat(p.`hnomoi` ,' หมู่ที่ ',  p.`mumoi`  ) end   USING utf8)  AS address
,v.lotno
,h.hosname
,schoolname,classname,classroom

,(select DATE_FORMAT(v1.dateepi,'%Y-%m-%d') from visitepi v1 where v.pid = v1.pid and v.pcucodeperson=v1.pcucodeperson and v1.vaccinecode='BCGS1' group by v1.pid and v1.pcucodeperson) as bcg
,(select DATE_FORMAT(v2.dateepi,'%Y-%m-%d') from visitepi v2 where v.pid = v2.pid and v.pcucodeperson=v2.pcucodeperson and v2.vaccinecode='DTS1' group by v2.pid and v2.pcucodeperson) as dts1
,(select DATE_FORMAT(v3.dateepi,'%Y-%m-%d') from visitepi v3 where v.pid = v3.pid and v.pcucodeperson=v3.pcucodeperson and v3.vaccinecode='DTS2' group by v3.pid and v3.pcucodeperson) as dts2
,(select DATE_FORMAT(v5.dateepi,'%Y-%m-%d') from visitepi v5 where v.pid = v5.pid and v.pcucodeperson=v5.pcucodeperson and v5.vaccinecode='DTS3' group by v5.pid and v5.pcucodeperson) as dts3
,(select DATE_FORMAT(v6.dateepi,'%Y-%m-%d') from visitepi v6 where v.pid = v6.pid and v.pcucodeperson=v6.pcucodeperson and v6.vaccinecode='DTS4' group by v6.pid and v6.pcucodeperson) as dts4
,(select DATE_FORMAT(v7.dateepi,'%Y-%m-%d') from visitepi v7 where v.pid = v7.pid and v.pcucodeperson=v7.pcucodeperson and v7.vaccinecode='OPVs1' group by v7.pid and v7.pcucodeperson) as opvs1
,(select DATE_FORMAT(v8.dateepi,'%Y-%m-%d') from visitepi v8 where v.pid = v8.pid and v.pcucodeperson=v8.pcucodeperson and v8.vaccinecode='OPVs2' group by v8.pid and v8.pcucodeperson) as opvs2
,(select DATE_FORMAT(v9.dateepi,'%Y-%m-%d') from visitepi v9 where v.pid = v9.pid and v.pcucodeperson=v9.pcucodeperson and v9.vaccinecode='OPVs3' group by v9.pid and v9.pcucodeperson) as opvs3
,(select DATE_FORMAT(v4.dateepi,'%Y-%m-%d') from visitepi v4 where v.pid = v4.pid and v.pcucodeperson=v4.pcucodeperson and lcase(v4.vaccinecode) in('mmr2','mmrs') group by v4.pid and v4.pcucodeperson) as mmr

from  personstudent psd  left join person p on p.pid = psd.pid and p.pcucodeperson = psd.pcucodeperson
	left join ctitle on p.prename = ctitle.titlecode
        left join visitepi v on psd.pid = v.pid and psd.pcucodeperson = v.pcucodeperson
        left join house on p.hcode = house.hcode and p.pcucodeperson = house.pcucode
        left join village on house.villcode = village.villcode and v.pcucode = village.pcucode
	left join villageschool on psd.villcode = villageschool.villcode and psd.schoolno = villageschool.schoolno
	left join cschoolclass on psd.classeducate = cschoolclass.classcode
        left join csubdistrict tb on CONCAT(tb.provcode,tb.distcode,tb.subdistcode) = left(village.villcode,6)
        left join chospital h on v.pcucode = h.hoscode

where (p.birth IS NOT NULL AND p.birth NOT LIKE '0000%')
	and v.dateepi between $P{sdate} and $P{edate}
     $P!{pcucode}
group by v.pid,v.pcucodeperson
order by schoolname,classname,classroom]]>
	</queryString>
