	<property name="ireport.scriptlethandling" value="0" />
	<property name="ireport.encoding" value="UTF-8" />
	<import value="java.util.*" />
	<import value="net.sf.jasperreports.engine.*" />
	<import value="net.sf.jasperreports.engine.data.*" />

	<parameter name="p_startDate" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDate" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND visit.visitdate BETWEEN '2009-10-01' AND '2009-10-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_endDate" isForPrompting="false" class="java.util.Date">
		<defaultValueExpression ><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_reportOffice" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA["หน่วยงาน :: ........................"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDisease" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[" AND cdisease.diseasecode='E148' "]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlPcu" isForPrompting="false" class="java.lang.String">
		<defaultValueExpression ><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[SELECT person.pid AS hn,
     visit.visitno as visitno,
     visit.pcucode as pcucode,
     DATE_FORMAT(visit.visitdate,'%Y-%m-%d') AS visitdate,
     getageymd(person.birth,visit.visitdate)AS age,
     concat(ifnull(ctitle.`titlename`,''),person.fname," ",person.lname) AS personname,
     count(visitdiag.visitno ) AS visitcount
FROM
     visit visit INNER JOIN visitdiag visitdiag ON visit.pcucode = visitdiag.pcucode
     AND visit.visitno = visitdiag.visitno
     INNER JOIN person person ON visit.pcucodeperson = person.pcucodeperson
     AND person.pid = visit.pid
     INNER JOIN cdisease cdisease ON visitdiag.diagcode = cdisease.diseasecode
     LEFT OUTER JOIN `ctitle` ctitle ON person.`prename` = ctitle.`titlecode`
WHERE 1=1 $P!{p_sqlDate} $P!{p_sqlPcu} AND cdisease.diseasecode='$P!{p_sqlDisease}'
GROUP BY visitdiag.pcucode,visit.pid
ORDER BY visitdiag.pcucode,visit.pid,visit.visitdate desc]]></queryString>

	<field name="hn" class="java.lang.Integer"/>
	<field name="visitno" class="java.lang.Integer"/>
	<field name="pcucode" class="java.lang.String"/>
	<field name="visitdate" class="java.util.Date"/>
	<field name="age" class="java.lang.String"/>
	<field name="personname" class="java.lang.String"/>
	<field name="visitcount" class="java.lang.Long"/>

	<variable name="reportOffice" class="java.lang.String" resetType="Report" calculation="Nothing">
		<variableExpression><![CDATA[""]]></variableExpression>
	</variable>
	<variable name="v_totalvisit" class="java.lang.Long" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{visitcount}]]></variableExpression>
	</variable>
