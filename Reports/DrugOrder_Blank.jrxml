		<defaultValueExpression><![CDATA["14363"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["c:\\jhcis\\Reports"]]></defaultValueExpression>
	</parameter>
	<parameter name="jtTimeEnd_DrugOrder_Prn" class="java.lang.String" isForPrompting="false"/>
	<parameter name="jtTimeStart" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pid" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
person.pcucodeperson,person.pid,
     concat(ifnull(ct1.titlename,ifnull(person.`prename`,'...')),person.`fname`,'  ',person.`lname`)AS name,
     concat(chospital.`hosname`,' ต.',ifnull(csubdistricth.`subdistname`,'-'),' อ.',ifnull(cdistricth.`distname`,'-'),
                                ' จ.',ifnull(cprovinceh.`provname`,'-')) AS hostname,
     concat(ifnull(pc.`hno`,'-'),' ม.',ifnull(convert(pc.`mu` using utf8),'-'),
                                 ' ต.',ifnull(csd.`subdistname`,'-'),
                                 ' อ.',ifnull(cd.`distname`,'-'),' จ.',ifnull(cw.`provname`,'-')) AS addr,
     visit.`visitno` AS visit_visitno
,if(visit.`incup`='2','ใบสั่งยา (...นอก CUP)','ใบสั่งยา') AS incup
,visit.`pcucode` AS visit_pcucode
,person.`idcard` AS person_idcard
,visit.`username` AS visit_username
,visit.`pid` AS visit_pid
,curdate()as toDayDate
,visit.visitdate as vsDate
,visit.`timestart` AS visit_timestart
,visit.`timeend` AS visit_timeend
,ifnull(visit.`vitalcheck`,'..ไม่ระบุฯ') as vtc
,Concat(ifnull(ct2.titlename,ifnull(`user`.`prename`,'...')),`user`.`fname`,'  ',if(`user`.`lname` is null or trim(`user`.`lname`)='','..',`user`.`lname`)) fullname
,if(refer='00' or refer is null,'',concat('Case refer: ',referdesc)) as referc
,ifnull(ch2.hosname,'..') as hmm
,ifnull(ch3.hosname,'..') as hss
,IFNULL(sugarnumdigit,'...') sg
,concat('คำวินิจฉัยฯ:',IF(visit.`diagnote` is null OR TRIM(`diagnote`)='','-',TRIM(`diagnote`))) as diagnote
,person.birth
,DATE_FORMAT(person.birth,'%Y-%m-%d') as birththai
,IF(pa.pid IS NULL,NULL,'!!! มีการแพ้ยาฯ โปรดระมัดระวังเรื่องการจ่ายยาฯ') alg
FROM
     `person` person
left outer join ctitle ct1 on person.prename = ct1.titlecode
     inner JOIN `visit` visit ON person.`pid` = visit.`pid` and person.pcucodeperson = visit.pcucodeperson
     iNNER JOIN `chospital` chospital ON visit.`pcucode` = chospital.`hoscode`
     left outer JOIN `csubdistrict` csubdistricth ON csubdistricth.subdistcode = chospital.subdistcode and chospital.distcode = csubdistricth.distcode and chospital.provcode = csubdistricth.provcode
     left outer JOIN `cdistrict` cdistricth ON chospital.distcode = cdistricth.distcode and chospital.provcode = cdistricth.provcode
     left outer JOIN `cprovince` cprovinceh ON chospital.provcode = cprovinceh.provcode

     left outer join personaddresscontact pc on person.pcucodeperson = pc.pcucodeperson and person.pid = pc.pid
     left outer JOIN `csubdistrict` csd ON csd.subdistcode = pc.subdistcode and csd.distcode = pc.distcode and csd.provcode = pc.provcode
     left outer JOIN `cdistrict` cd ON cd.distcode = pc.distcode and cd.provcode = pc.provcode
     left outer JOIN `cprovince` cw ON cw.provcode = pc.provcode

     left outer JOIN `user` ON visit.username = `user`.`username` and `visit`.`pcucode` = `user`.`pcucode`
     left join cpatientrefer on visit.refer = cpatientrefer.refercode
     left join chospital ch2 on visit.hosmain = ch2.hoscode
     left join chospital ch3 on visit.hossub = ch3.hoscode
left join ctitle ct2 on `user`.prename = ct2.titlecode
LEFT JOIN visitlabsugarblood bld ON visit.pcucode=bld.pcucode AND visit.visitno=bld.visitno
LEFT JOIN (select pcucodeperson,pid from personalergic x WHERE x.pcucodeperson = $P{pcucode} AND x.pid = $P{pid}  LIMIT 1) AS pa
ON person.pcucodeperson=pa.pcucodeperson AND person.pid=pa.pid
WHERE visit.`visitno` = $P{visitno} and visit.pcucode = $P{pcucode}]]>
	</queryString>
