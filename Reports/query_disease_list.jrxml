	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="p_startDate" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDate" class="java.lang.String">
		<defaultValueExpression><![CDATA[" AND visit.visitdate BETWEEN '2009-10-01' AND '2009-10-31' "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_endDate" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="p_reportOffice" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["หน่วยงาน :: ........................"]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlDisease" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[" AND cdisease.diseasecode='E148' "]]></defaultValueExpression>
	</parameter>
	<parameter name="p_sqlPcu" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT person.pid AS hn,
     concat(ifnull(ctitle.`titlename`,''),person.fname," ",person.lname) AS personname,
     count(visitdiag.visitno ) AS visitcount
FROM
     visit visit INNER JOIN visitdiag visitdiag ON visit.pcucode = visitdiag.pcucode
     AND visit.visitno = visitdiag.visitno
     INNER JOIN person person ON visit.pcucodeperson = person.pcucodeperson
     AND person.pid = visit.pid
     INNER JOIN cdisease cdisease ON visitdiag.diagcode = cdisease.diseasecode
     LEFT OUTER JOIN `ctitle` ctitle ON person.`prename` = ctitle.`titlecode`
WHERE 1=1 $P!{p_sqlDate} $P!{p_sqlDisease} $P!{p_sqlPcu}
GROUP BY visitdiag.pcucode,visit.pid
ORDER BY visitdiag.pcucode,visit.pid]]>
	</queryString>
	<field name="hn" class="java.lang.Integer"/>
	<field name="personname" class="java.lang.String"/>
	<field name="visitcount" class="java.lang.Long"/>
	<variable name="reportOffice" class="java.lang.String">
		<variableExpression><![CDATA[""]]></variableExpression>
	</variable>
	<variable name="v_totalvisit" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{visitcount}]]></variableExpression>
	</variable>
