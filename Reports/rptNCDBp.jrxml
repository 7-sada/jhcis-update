				</textField>
				<staticText>
					<reportElement
						x="48"
						y="0"
						width="319"
						height="25"
						key="staticText-32"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ ประชากรที่มีอายุ 35 ปีขึ้นไปในพืนที่รับผิดชอบ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="25"
						width="319"
						height="25"
						key="staticText-33"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ ผู้ป่วยความดันโลหิตสูงที่เคยได้รับการวินิจฉัยจากแพทย์ (ผู้ป่วยเก่า ณ 30 กย)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="50"
						width="319"
						height="25"
						key="staticText-34"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ ประชากรที่มีอายุ 35 ปึขึ้นไปที่ต้องได้รับการคัดกรอง (ข้อ 1 ลบข้อ 2)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="75"
						width="319"
						height="25"
						key="staticText-35"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ 4.1 ผู้ที่ได้รับการคัดกรอง]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="100"
						width="319"
						height="25"
						key="staticText-36"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[    4.1.1 จากข้อ 4.1 ผู้ที่ได้รับการคัดกรองพบมีภาวะความดันโลหิตสูง 
           (BP 120/80 - 139/89 mmHg%)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="125"
						width="319"
						height="25"
						key="staticText-37"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isBold="false" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[       4.1.2 จากข้อ 4.1 ผู้ที่ได้รับการคัดกรองพบมีภาวะความดันโลหิตสูง 
           (BP >= 140/90 mmHg%)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="150"
						width="319"
						height="25"
						key="staticText-38"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ 4.2 จากข้อ 4.1.2 ผู้ที่สงสัยเป็นความดันโลหิตสูง ได้รับการส่งต่อพบแพทย์เพื่อการวินิจฉัย]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="175"
						width="319"
						height="25"
						key="staticText-39"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[4.3 จากข้อ 4.2 ผู้ที่ส่งต่อ ได้รับการวินิจฉัยจากแพทย์ว่า เป็นความดันโลหิตสูง]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="200"
						width="319"
						height="25"
						key="staticText-40"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ผู้ป่วยที่ได้รับการวินิจฉัยและรักษาจากสถานบริการอื่น และยังไม่ได้ขึ้นทะเบียน]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="225"
						width="319"
						height="25"
						key="staticText-41"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[การตายด้วยภาวะแทรกซ้อนจากโรคความดันโลหิตสูง / จากโรคอื่น ๆ]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="48"
						y="250"
						width="319"
						height="25"
						key="staticText-42"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[ผู้ป่วยทั้งหมดที่ได้รับการขึ้นทะเบียน (ข้อ 2 บวกข้อ 4.3 บวกข้อ 5 ลบข้อ 6)]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="0"
						y="200"
						width="48"
						height="25"
						key="staticText-48"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[5]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="0"
						y="225"
						width="48"
						height="25"
						key="staticText-51"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[6]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="0"
						y="250"
						width="48"
						height="25"
						key="staticText-54"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="Thin" leftBorderColor="#000000" rightBorder="Thin" rightBorderColor="#000000" bottomBorder="Thin" bottomBorderColor="#000000"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" size="8" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[7]]></text>
				</staticText>
				<staticText>
					<reportElement
						x="0"
						y="343"
						width="535"
						height="65"
						key="staticText-60"/>
					<box topBorder="None" topBorderColor="#000000" leftBorder="None" leftBorderColor="#000000" rightBorder="None" rightBorderColor="#000000" bottomBorder="None" bottomBorderColor="#000000"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Tahoma" pdfFontName="tahoma.ttf" isPdfEmbedded ="true" pdfEncoding ="Identity-H"/>
					</textElement>
				<text><![CDATA[หมายเหตุ   การคิดร้อยละของผลงานการคัดกรอง

        = (จำนวนผู้ที่ได้รับการคัดกรองด้วยวาจา + จำนวนผู้ป่วยเก่า) X 100
                
                      ประชากรที่มีอายุ 35 ปีขึ้นไปในพื้นที่รับผิดชอบ]]></text>
				</staticText>
				<line direction="TopDown">
					<reportElement
						x="34"
						y="543"
						width="261"
