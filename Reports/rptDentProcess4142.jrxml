				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<text><![CDATA[รายงานระหว่างวันที่]]></text>
			</staticText>
			<textField pattern="d MMMMM yyyy">
				<reportElement x="155" y="0" width="100" height="30"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{curdate()}.valueOf( $P{sdate} )]]></textFieldExpression>
			</textField>
			<textField pattern="d MMMMM yyyy">
				<reportElement x="267" y="0" width="100" height="30"/>
