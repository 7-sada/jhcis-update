<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDentProcess4144" language="groovy" pageWidth="900" pageHeight="600" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="860" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pcucode" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\iReport-4.5.1\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="sdate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2011-10-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="edate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["2012-09-30"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select if(cright.rightgroup ='3','(UC ไม่มี ท)' ,'(UC มี ท )') as rightgroupname,date_format(visit.visitdate,'%Y-%m') ymt
,hosname
,curdate()
from visitdrugdental inner join visit on visitdrugdental.visitno = visit.visitno and visitdrugdental.pcucode = visit.pcucode
inner join cright on visit.rightcode = cright.rightcode
left join crightgroup  on cright.rightgroup = crightgroup.rightgroupcode
inner join chospital on chospital.hoscode = visitdrugdental.pcucode
where 1=1 #and dentcode in ('2387010','2377010','23871S6')
and cright.rightgroup in('3','4')
and visitdate between $P{sdate} and  $P{edate}
$P!{pcucode}
group by rightgroup,date_format(visit.visitdate,'%Y-%m')]]>
	</queryString>
	<field name="rightgroupname" class="java.lang.String"/>
	<field name="ymt" class="java.lang.String"/>
	<field name="hosname" class="java.lang.String"/>
	<field name="curdate()" class="java.sql.Date"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
