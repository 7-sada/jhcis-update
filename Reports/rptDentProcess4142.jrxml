				</textElement>
				<textFieldExpression><![CDATA[$F{curdate()}.valueOf( $P{edate} )]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<columnHeader>
		<band height="125" splitType="Stretch">
