	<parameter name="header_1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="header_2" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
     crightgroup.`rightgroupcode` AS crightgroup_rightgroupcode,
     crightgroup.`rightgroupname` AS crightgroup_rightgroupname,
     IF(v0110_5_gr1_5.`sPer0`=0,NULL,v0110_5_gr1_5.`sPer0`)AS v0110_5_gr1_5_sPer0,
     IF(v0110_5_gr1_5.`sPer1`=0,NULL,v0110_5_gr1_5.`sPer1`)AS v0110_5_gr1_5_sPer1,
     IF(v0110_5_gr2_3.`s0`=0,NULL,v0110_5_gr2_3.`s0`)AS v0110_5_gr2_3_s0,
     IF(v0110_5_gr2_3.`s1`=0,NULL,v0110_5_gr2_3.`s1`)AS v0110_5_gr2_3_s1,
     IF(v0110_5_new_refer_st4.`1`=0,NULL,v0110_5_new_refer_st4.`1`)AS v0110_5_new_refer_st4_1,
     IF(v0110_5_new_refer_st4.`2`=0,NULL,v0110_5_new_refer_st4.`2`)AS v0110_5_new_refer_st4_2,
     IF(v0110_5_new_refer_st4.`3`=0,NULL,v0110_5_new_refer_st4.`3`)AS v0110_5_new_refer_st4_3,
     IF(v0110_5_new_refer_st4.`N`=0,NULL,v0110_5_new_refer_st4.`N`)AS v0110_5_new_refer_st4_N
FROM
     `crightgroup` crightgroup LEFT OUTER JOIN `v0110_5_gr2_3` v0110_5_gr2_3 ON crightgroup.`rightgroupcode` = v0110_5_gr2_3.`rtAndNullX`
     LEFT OUTER JOIN `v0110_5_new_refer_st4` v0110_5_new_refer_st4 ON crightgroup.`rightgroupcode` = v0110_5_new_refer_st4.`rtPRefer`
     LEFT OUTER JOIN `v0110_5_gr1_5` v0110_5_gr1_5 ON crightgroup.`rightgroupcode` = v0110_5_gr1_5.`rightgroup`]]>
	</queryString>
